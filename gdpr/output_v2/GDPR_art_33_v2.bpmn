    <bpmn:textAnnotation id="Annotation_fc66cad9"><bpmn:text>Notify the competent supervisory authority&#10;Applies when: Data Breach Detected AND Became Aware of Breach&#10;Applies when: Data Breach Detected AND High Risk to Individuals AND Risk to Rights & Freedoms AND Natural Person Affected&#10;Perform without undue delay</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_095c0853"><bpmn:text>Perform without undue delay&#10;Applies when: Became Aware of Breach AND Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_8c114f88"><bpmn:text>Applies when: Data Breach Detected&#10;Further information may be provided later</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_891a9452"><bpmn:text>Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_d86ba551"><bpmn:text>Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_d4fa7d60"><bpmn:text>Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_48579775"><bpmn:text>Include measures already taken or proposed to address the breach&#10;Applies when: Data Breach Detected&#10;Applies when: Data Breach Detected AND Describe AND mitigate AND High Risk to Individuals</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_e0b6feb9"><bpmn:text>Further information may be provided later&#10;Notify the competent supervisory authority&#10;Perform without undue delay&#10;Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_8c2eff41"><bpmn:text>Outcome should be verifiable&#10;Notify the competent supervisory authority&#10;Relates to Article 33&#10;Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
