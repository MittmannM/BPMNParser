    <bpmn:textAnnotation id="Annotation_a9512ff0"><bpmn:text>Notify the competent supervisory authority&#10;Applies when: Data Breach Detected AND Became Aware of Breach&#10;Applies when: Data Breach Detected AND High Risk to Individuals AND Risk to Rights & Freedoms AND Natural Person Affected&#10;Perform without undue delay</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_c946aa1d"><bpmn:text>Perform without undue delay&#10;Applies when: Became Aware of Breach AND Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_5817aedc"><bpmn:text>Applies when: Data Breach Detected&#10;Further information may be provided later</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_f93e27ed"><bpmn:text>Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_5d97229b"><bpmn:text>Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_236210d8"><bpmn:text>Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_456ee0e5"><bpmn:text>Include measures already taken or proposed to address the breach&#10;Applies when: Data Breach Detected&#10;Applies when: Data Breach Detected AND Describe AND mitigate AND High Risk to Individuals</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_2f1fe2ce"><bpmn:text>Further information may be provided later&#10;Notify the competent supervisory authority&#10;Perform without undue delay&#10;Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_53f235b5"><bpmn:text>Outcome should be verifiable&#10;Notify the competent supervisory authority&#10;Relates to Article 33&#10;Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
