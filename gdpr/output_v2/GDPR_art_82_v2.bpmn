    <bpmn:textAnnotation id="Annotation_bd989804"><bpmn:text>Check exception in Art. 82 Abs. 2&#10;Check exception in Art. 82 Abs. 3&#10;Applies when: Damage Suffered AND GDPR Violation</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_54009214"><bpmn:text>No exception under Art. 82 Abs. 2&#10;No exception under Art. 82 Abs. 3&#10;Applies when: Damage Suffered AND GDPR Violation</bpmn:text></bpmn:textAnnotation>
