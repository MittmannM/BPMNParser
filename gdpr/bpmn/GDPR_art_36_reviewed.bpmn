<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art36_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art36_Reviewed">
    <bpmn:participant id="Participant_Controller_Art36"
                      name="Controller"
                      processRef="Process_Controller_Art36" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art36"
                      name="Supervisory Authority" />

    <bpmn:messageFlow id="MessageFlow_SendPriorConsultation_Art36"
                      sourceRef="SendTask_SendPriorConsultation_Art36"
                      targetRef="Participant_SupervisoryAuthority_Art36" />
    <bpmn:messageFlow id="MessageFlow_RequestAdditionalInfo_Art36"
                      sourceRef="Participant_SupervisoryAuthority_Art36"
                      targetRef="ReceiveTask_ReceiveAdditionalInfoRequest_Art36" />
    <bpmn:messageFlow id="MessageFlow_SendAdditionalInfo_Art36"
                      sourceRef="SendTask_SendAdditionalInfo_Art36"
                      targetRef="Participant_SupervisoryAuthority_Art36" />
    <bpmn:messageFlow id="MessageFlow_SendExtensionNotice_Art36"
                      sourceRef="Participant_SupervisoryAuthority_Art36"
                      targetRef="ReceiveTask_ReceiveExtensionNotice_Art36" />
    <bpmn:messageFlow id="MessageFlow_SendWrittenAdvice_Art36"
                      sourceRef="Participant_SupervisoryAuthority_Art36"
                      targetRef="ReceiveTask_ReceiveWrittenAdvice_Art36" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Controller_Art36"
                name="Prior consultation under Article 36"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 36 based on the real English legal text
      of Regulation (EU) 2016/679. The model captures the Article 36(1) trigger,
      the Article 36(3)(a)-(f) information package, the additional-information and
      extension mechanics in Article 36(2), and the written-advice outcome. The
      separate Member-State-law and legislative-consultation paths in Article 36(4)-(5)
      are not modeled as the diagram focuses on the controller's operational prior-
      consultation workflow after a DPIA.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_CompleteDPIA_Art36"
                     name="Complete DPIA">
      <bpmn:outgoing>Flow_StartCompleteDPIA_To_TaskAssessResidualHighRisk_Art36</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_AssessResidualHighRisk_Art36"
               name="Assess residual high risk">
      <bpmn:incoming>Flow_StartCompleteDPIA_To_TaskAssessResidualHighRisk_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessResidualHighRisk_To_GatewayResidualHighRisk_Art36</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ResidualHighRisk_Art36"
                           name="Would the processing remain high risk without mitigation?">
      <bpmn:incoming>Flow_TaskAssessResidualHighRisk_To_GatewayResidualHighRisk_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayResidualHighRisk_To_EndNoConsultationRequired_Art36</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayResidualHighRisk_To_GatewaySplitConsultationPackage_Art36</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:parallelGateway id="Gateway_SplitConsultationPackage_Art36">
      <bpmn:incoming>Flow_GatewayResidualHighRisk_To_GatewaySplitConsultationPackage_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitConsultationPackage_To_TaskRecordResponsibilities_Art36</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitConsultationPackage_To_TaskRecordPurposesMeans_Art36</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitConsultationPackage_To_TaskRecordSafeguards_Art36</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitConsultationPackage_To_TaskAttachDPIA_Art36</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_RecordResponsibilities_Art36"
               name="Record responsibilities">
      <bpmn:incoming>Flow_GatewaySplitConsultationPackage_To_TaskRecordResponsibilities_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRecordResponsibilities_To_GatewayJoinConsultationPackage_Art36</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_RecordPurposesMeans_Art36"
               name="Record purposes and means">
      <bpmn:incoming>Flow_GatewaySplitConsultationPackage_To_TaskRecordPurposesMeans_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRecordPurposesMeans_To_GatewayJoinConsultationPackage_Art36</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_RecordSafeguards_Art36"
               name="Record safeguards and measures">
      <bpmn:incoming>Flow_GatewaySplitConsultationPackage_To_TaskRecordSafeguards_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRecordSafeguards_To_GatewayJoinConsultationPackage_Art36</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AttachDPIA_Art36"
               name="Attach DPIA">
      <bpmn:incoming>Flow_GatewaySplitConsultationPackage_To_TaskAttachDPIA_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAttachDPIA_To_GatewayJoinConsultationPackage_Art36</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinConsultationPackage_Art36">
      <bpmn:incoming>Flow_TaskRecordResponsibilities_To_GatewayJoinConsultationPackage_Art36</bpmn:incoming>
      <bpmn:incoming>Flow_TaskRecordPurposesMeans_To_GatewayJoinConsultationPackage_Art36</bpmn:incoming>
      <bpmn:incoming>Flow_TaskRecordSafeguards_To_GatewayJoinConsultationPackage_Art36</bpmn:incoming>
      <bpmn:incoming>Flow_TaskAttachDPIA_To_GatewayJoinConsultationPackage_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinConsultationPackage_To_GatewayDPODesignated_Art36</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:exclusiveGateway id="Gateway_DPODesignated_Art36"
                           name="Is a DPO designated?">
      <bpmn:incoming>Flow_GatewayJoinConsultationPackage_To_GatewayDPODesignated_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayDPODesignated_To_TaskProvideDPOContact_Art36</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayDPODesignated_To_SendTaskSendPriorConsultation_Art36</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ProvideDPOContact_Art36"
               name="Provide DPO contact details">
      <bpmn:incoming>Flow_GatewayDPODesignated_To_TaskProvideDPOContact_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskProvideDPOContact_To_SendTaskSendPriorConsultation_Art36</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_SendPriorConsultation_Art36"
                   name="Send prior consultation request">
      <bpmn:incoming>Flow_GatewayDPODesignated_To_SendTaskSendPriorConsultation_Art36</bpmn:incoming>
      <bpmn:incoming>Flow_TaskProvideDPOContact_To_SendTaskSendPriorConsultation_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendPriorConsultation_To_GatewayAdditionalInfoRequested_Art36</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_AdditionalInfoRequested_Art36"
                           name="Did the authority request additional information?">
      <bpmn:incoming>Flow_SendTaskSendPriorConsultation_To_GatewayAdditionalInfoRequested_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAdditionalInfoRequested_To_ReceiveTaskReceiveAdditionalInfoRequest_Art36</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAdditionalInfoRequested_To_GatewayExtensionNoticeReceived_Art36</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAdditionalInfoRequest_Art36"
                      name="Receive additional-info request">
      <bpmn:incoming>Flow_GatewayAdditionalInfoRequested_To_ReceiveTaskReceiveAdditionalInfoRequest_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveAdditionalInfoRequest_To_TaskCollectAdditionalInfo_Art36</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_CollectAdditionalInfo_Art36"
               name="Collect requested details">
      <bpmn:incoming>Flow_ReceiveTaskReceiveAdditionalInfoRequest_To_TaskCollectAdditionalInfo_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskCollectAdditionalInfo_To_SendTaskSendAdditionalInfo_Art36</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_SendAdditionalInfo_Art36"
                   name="Send requested details">
      <bpmn:incoming>Flow_TaskCollectAdditionalInfo_To_SendTaskSendAdditionalInfo_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendAdditionalInfo_To_GatewayExtensionNoticeReceived_Art36</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_ExtensionNoticeReceived_Art36"
                           name="Did the authority send an extension notice?">
      <bpmn:incoming>Flow_GatewayAdditionalInfoRequested_To_GatewayExtensionNoticeReceived_Art36</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskSendAdditionalInfo_To_GatewayExtensionNoticeReceived_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayExtensionNoticeReceived_To_ReceiveTaskReceiveExtensionNotice_Art36</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayExtensionNoticeReceived_To_ReceiveTaskReceiveWrittenAdvice_Art36</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:receiveTask id="ReceiveTask_ReceiveExtensionNotice_Art36"
                      name="Receive extension notice">
      <bpmn:incoming>Flow_GatewayExtensionNoticeReceived_To_ReceiveTaskReceiveExtensionNotice_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveExtensionNotice_To_ReceiveTaskReceiveWrittenAdvice_Art36</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveWrittenAdvice_Art36"
                      name="Receive written advice">
      <bpmn:incoming>Flow_GatewayExtensionNoticeReceived_To_ReceiveTaskReceiveWrittenAdvice_Art36</bpmn:incoming>
      <bpmn:incoming>Flow_ReceiveTaskReceiveExtensionNotice_To_ReceiveTaskReceiveWrittenAdvice_Art36</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveWrittenAdvice_To_EndConsultationCompleted_Art36</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:endEvent id="EndEvent_NoConsultationRequired_Art36"
                   name="No prior consultation required">
      <bpmn:incoming>Flow_GatewayResidualHighRisk_To_EndNoConsultationRequired_Art36</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_ConsultationCompleted_Art36"
                   name="Prior consultation completed">
      <bpmn:incoming>Flow_ReceiveTaskReceiveWrittenAdvice_To_EndConsultationCompleted_Art36</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartCompleteDPIA_To_TaskAssessResidualHighRisk_Art36" sourceRef="StartEvent_CompleteDPIA_Art36" targetRef="Task_AssessResidualHighRisk_Art36" />
    <bpmn:sequenceFlow id="Flow_TaskAssessResidualHighRisk_To_GatewayResidualHighRisk_Art36" sourceRef="Task_AssessResidualHighRisk_Art36" targetRef="Gateway_ResidualHighRisk_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewayResidualHighRisk_To_EndNoConsultationRequired_Art36" name="No" sourceRef="Gateway_ResidualHighRisk_Art36" targetRef="EndEvent_NoConsultationRequired_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewayResidualHighRisk_To_GatewaySplitConsultationPackage_Art36" name="Yes" sourceRef="Gateway_ResidualHighRisk_Art36" targetRef="Gateway_SplitConsultationPackage_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitConsultationPackage_To_TaskRecordResponsibilities_Art36" sourceRef="Gateway_SplitConsultationPackage_Art36" targetRef="Task_RecordResponsibilities_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitConsultationPackage_To_TaskRecordPurposesMeans_Art36" sourceRef="Gateway_SplitConsultationPackage_Art36" targetRef="Task_RecordPurposesMeans_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitConsultationPackage_To_TaskRecordSafeguards_Art36" sourceRef="Gateway_SplitConsultationPackage_Art36" targetRef="Task_RecordSafeguards_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitConsultationPackage_To_TaskAttachDPIA_Art36" sourceRef="Gateway_SplitConsultationPackage_Art36" targetRef="Task_AttachDPIA_Art36" />
    <bpmn:sequenceFlow id="Flow_TaskRecordResponsibilities_To_GatewayJoinConsultationPackage_Art36" sourceRef="Task_RecordResponsibilities_Art36" targetRef="Gateway_JoinConsultationPackage_Art36" />
    <bpmn:sequenceFlow id="Flow_TaskRecordPurposesMeans_To_GatewayJoinConsultationPackage_Art36" sourceRef="Task_RecordPurposesMeans_Art36" targetRef="Gateway_JoinConsultationPackage_Art36" />
    <bpmn:sequenceFlow id="Flow_TaskRecordSafeguards_To_GatewayJoinConsultationPackage_Art36" sourceRef="Task_RecordSafeguards_Art36" targetRef="Gateway_JoinConsultationPackage_Art36" />
    <bpmn:sequenceFlow id="Flow_TaskAttachDPIA_To_GatewayJoinConsultationPackage_Art36" sourceRef="Task_AttachDPIA_Art36" targetRef="Gateway_JoinConsultationPackage_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinConsultationPackage_To_GatewayDPODesignated_Art36" sourceRef="Gateway_JoinConsultationPackage_Art36" targetRef="Gateway_DPODesignated_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewayDPODesignated_To_TaskProvideDPOContact_Art36" name="Yes" sourceRef="Gateway_DPODesignated_Art36" targetRef="Task_ProvideDPOContact_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewayDPODesignated_To_SendTaskSendPriorConsultation_Art36" name="No" sourceRef="Gateway_DPODesignated_Art36" targetRef="SendTask_SendPriorConsultation_Art36" />
    <bpmn:sequenceFlow id="Flow_TaskProvideDPOContact_To_SendTaskSendPriorConsultation_Art36" sourceRef="Task_ProvideDPOContact_Art36" targetRef="SendTask_SendPriorConsultation_Art36" />
    <bpmn:sequenceFlow id="Flow_SendTaskSendPriorConsultation_To_GatewayAdditionalInfoRequested_Art36" sourceRef="SendTask_SendPriorConsultation_Art36" targetRef="Gateway_AdditionalInfoRequested_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewayAdditionalInfoRequested_To_ReceiveTaskReceiveAdditionalInfoRequest_Art36" name="Yes" sourceRef="Gateway_AdditionalInfoRequested_Art36" targetRef="ReceiveTask_ReceiveAdditionalInfoRequest_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewayAdditionalInfoRequested_To_GatewayExtensionNoticeReceived_Art36" name="No" sourceRef="Gateway_AdditionalInfoRequested_Art36" targetRef="Gateway_ExtensionNoticeReceived_Art36" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveAdditionalInfoRequest_To_TaskCollectAdditionalInfo_Art36" sourceRef="ReceiveTask_ReceiveAdditionalInfoRequest_Art36" targetRef="Task_CollectAdditionalInfo_Art36" />
    <bpmn:sequenceFlow id="Flow_TaskCollectAdditionalInfo_To_SendTaskSendAdditionalInfo_Art36" sourceRef="Task_CollectAdditionalInfo_Art36" targetRef="SendTask_SendAdditionalInfo_Art36" />
    <bpmn:sequenceFlow id="Flow_SendTaskSendAdditionalInfo_To_GatewayExtensionNoticeReceived_Art36" sourceRef="SendTask_SendAdditionalInfo_Art36" targetRef="Gateway_ExtensionNoticeReceived_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewayExtensionNoticeReceived_To_ReceiveTaskReceiveExtensionNotice_Art36" name="Yes" sourceRef="Gateway_ExtensionNoticeReceived_Art36" targetRef="ReceiveTask_ReceiveExtensionNotice_Art36" />
    <bpmn:sequenceFlow id="Flow_GatewayExtensionNoticeReceived_To_ReceiveTaskReceiveWrittenAdvice_Art36" name="No" sourceRef="Gateway_ExtensionNoticeReceived_Art36" targetRef="ReceiveTask_ReceiveWrittenAdvice_Art36" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveExtensionNotice_To_ReceiveTaskReceiveWrittenAdvice_Art36" sourceRef="ReceiveTask_ReceiveExtensionNotice_Art36" targetRef="ReceiveTask_ReceiveWrittenAdvice_Art36" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveWrittenAdvice_To_EndConsultationCompleted_Art36" sourceRef="ReceiveTask_ReceiveWrittenAdvice_Art36" targetRef="EndEvent_ConsultationCompleted_Art36" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art36_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art36_Reviewed" bpmnElement="Collaboration_Art36_Reviewed">
      <bpmndi:BPMNShape id="Participant_Controller_Art36_di" bpmnElement="Participant_Controller_Art36" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="4200" height="620" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_SupervisoryAuthority_Art36_di" bpmnElement="Participant_SupervisoryAuthority_Art36" isHorizontal="true">
        <dc:Bounds x="60" y="700" width="4200" height="140" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_CompleteDPIA_Art36_di" bpmnElement="StartEvent_CompleteDPIA_Art36">
        <dc:Bounds x="140" y="292" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessResidualHighRisk_Art36_di" bpmnElement="Task_AssessResidualHighRisk_Art36">
        <dc:Bounds x="220" y="270" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ResidualHighRisk_Art36_di" bpmnElement="Gateway_ResidualHighRisk_Art36" isMarkerVisible="true">
        <dc:Bounds x="450" y="285" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SplitConsultationPackage_Art36_di" bpmnElement="Gateway_SplitConsultationPackage_Art36" isMarkerVisible="true">
        <dc:Bounds x="600" y="285" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordResponsibilities_Art36_di" bpmnElement="Task_RecordResponsibilities_Art36">
        <dc:Bounds x="760" y="80" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordPurposesMeans_Art36_di" bpmnElement="Task_RecordPurposesMeans_Art36">
        <dc:Bounds x="1000" y="80" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordSafeguards_Art36_di" bpmnElement="Task_RecordSafeguards_Art36">
        <dc:Bounds x="760" y="450" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AttachDPIA_Art36_di" bpmnElement="Task_AttachDPIA_Art36">
        <dc:Bounds x="1000" y="450" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_JoinConsultationPackage_Art36_di" bpmnElement="Gateway_JoinConsultationPackage_Art36" isMarkerVisible="true">
        <dc:Bounds x="1265" y="285" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DPODesignated_Art36_di" bpmnElement="Gateway_DPODesignated_Art36" isMarkerVisible="true">
        <dc:Bounds x="1400" y="285" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProvideDPOContact_Art36_di" bpmnElement="Task_ProvideDPOContact_Art36">
        <dc:Bounds x="1560" y="150" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_SendPriorConsultation_Art36_di" bpmnElement="SendTask_SendPriorConsultation_Art36">
        <dc:Bounds x="1560" y="270" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AdditionalInfoRequested_Art36_di" bpmnElement="Gateway_AdditionalInfoRequested_Art36" isMarkerVisible="true">
        <dc:Bounds x="1840" y="285" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveAdditionalInfoRequest_Art36_di" bpmnElement="ReceiveTask_ReceiveAdditionalInfoRequest_Art36">
        <dc:Bounds x="2000" y="150" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CollectAdditionalInfo_Art36_di" bpmnElement="Task_CollectAdditionalInfo_Art36">
        <dc:Bounds x="2230" y="150" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_SendAdditionalInfo_Art36_di" bpmnElement="SendTask_SendAdditionalInfo_Art36">
        <dc:Bounds x="2460" y="150" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ExtensionNoticeReceived_Art36_di" bpmnElement="Gateway_ExtensionNoticeReceived_Art36" isMarkerVisible="true">
        <dc:Bounds x="2710" y="285" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveExtensionNotice_Art36_di" bpmnElement="ReceiveTask_ReceiveExtensionNotice_Art36">
        <dc:Bounds x="2870" y="150" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveWrittenAdvice_Art36_di" bpmnElement="ReceiveTask_ReceiveWrittenAdvice_Art36">
        <dc:Bounds x="2870" y="380" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoConsultationRequired_Art36_di" bpmnElement="EndEvent_NoConsultationRequired_Art36">
        <dc:Bounds x="532" y="552" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ConsultationCompleted_Art36_di" bpmnElement="EndEvent_ConsultationCompleted_Art36">
        <dc:Bounds x="3162" y="402" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_StartCompleteDPIA_To_TaskAssessResidualHighRisk_Art36_di" bpmnElement="Flow_StartCompleteDPIA_To_TaskAssessResidualHighRisk_Art36">
        <di:waypoint x="176" y="310" />
        <di:waypoint x="220" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskAssessResidualHighRisk_To_GatewayResidualHighRisk_Art36_di" bpmnElement="Flow_TaskAssessResidualHighRisk_To_GatewayResidualHighRisk_Art36">
        <di:waypoint x="400" y="310" />
        <di:waypoint x="450" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayResidualHighRisk_To_EndNoConsultationRequired_Art36_di" bpmnElement="Flow_GatewayResidualHighRisk_To_EndNoConsultationRequired_Art36">
        <di:waypoint x="475" y="335" />
        <di:waypoint x="475" y="570" />
        <di:waypoint x="532" y="570" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayResidualHighRisk_To_GatewaySplitConsultationPackage_Art36_di" bpmnElement="Flow_GatewayResidualHighRisk_To_GatewaySplitConsultationPackage_Art36">
        <di:waypoint x="500" y="310" />
        <di:waypoint x="600" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitConsultationPackage_To_TaskRecordResponsibilities_Art36_di" bpmnElement="Flow_GatewaySplitConsultationPackage_To_TaskRecordResponsibilities_Art36">
        <di:waypoint x="625" y="285" />
        <di:waypoint x="625" y="120" />
        <di:waypoint x="760" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitConsultationPackage_To_TaskRecordPurposesMeans_Art36_di" bpmnElement="Flow_GatewaySplitConsultationPackage_To_TaskRecordPurposesMeans_Art36">
        <di:waypoint x="625" y="285" />
        <di:waypoint x="625" y="120" />
        <di:waypoint x="1000" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitConsultationPackage_To_TaskRecordSafeguards_Art36_di" bpmnElement="Flow_GatewaySplitConsultationPackage_To_TaskRecordSafeguards_Art36">
        <di:waypoint x="625" y="335" />
        <di:waypoint x="625" y="490" />
