<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art18_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_Art18_Reviewed">
    <bpmn:participant id="Participant_Controller_Art18" name="Controller" processRef="Process_Controller_Art18" />
    <bpmn:participant id="Participant_DataSubject_Art18" name="Data Subject" />

    <bpmn:messageFlow id="MessageFlow_SendRestrictionRequest_Art18" sourceRef="Participant_DataSubject_Art18" targetRef="ReceiveTask_ReceiveRestrictionRequest_Art18" />
    <bpmn:messageFlow id="MessageFlow_InformBeforeLift_Art18" sourceRef="SendTask_InformBeforeLift_Art18" targetRef="Participant_DataSubject_Art18" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Controller_Art18" name="Handling the data subject's right to restriction of processing" isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 18 based on DAPRECO LegalRuleML
      statements97-102. The local XML models four qualifying grounds for restriction,
      the limited processing permission while restriction is in place, and the duty to
      inform the data subject before restriction is lifted. Repeated Article 12(2) and
      Article 11(2) filters are represented as one shared request-exception gateway.
      The official GDPR text is used only to label and group the XML-grounded branches
      transparently.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_RestrictionRequested_Art18" name="Data subject seeks restriction of processing">
      <bpmn:outgoing>Flow_Start_To_ReceiveTaskReceiveRestrictionRequest_Art18</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveRestrictionRequest_Art18" name="Receive restriction request">
      <bpmn:incoming>Flow_Start_To_ReceiveTaskReceiveRestrictionRequest_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveRestrictionRequest_To_GatewayRequestExceptions_Art18</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_RequestExceptions_Art18" name="Do Article 12(2) or Article 11(2) exceptions prevent handling the restriction request?">
      <bpmn:incoming>Flow_ReceiveTaskReceiveRestrictionRequest_To_GatewayRequestExceptions_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRequestExceptions_To_EndRequestBlocked_Art18</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRequestExceptions_To_GatewayRestrictionGround_Art18</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_RestrictionGround_Art18" name="Which Article 18(1) ground for restriction applies?">
      <bpmn:incoming>Flow_GatewayRequestExceptions_To_GatewayRestrictionGround_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRestrictionGround_To_TaskGroundAccuracyContested_Art18</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRestrictionGround_To_TaskGroundUnlawfulInsteadOfErasure_Art18</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRestrictionGround_To_TaskGroundLegalClaims_Art18</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRestrictionGround_To_TaskGroundPendingObjectionVerification_Art18</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRestrictionGround_To_EndNoRestrictionGround_Art18</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_GroundAccuracyContested_Art18" name="Assess contested accuracy">
      <bpmn:incoming>Flow_GatewayRestrictionGround_To_TaskGroundAccuracyContested_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskGroundAccuracyContested_To_GatewayJoinGrounds_Art18</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_GroundUnlawfulInsteadOfErasure_Art18" name="Assess unlawful processing with restriction request">
      <bpmn:incoming>Flow_GatewayRestrictionGround_To_TaskGroundUnlawfulInsteadOfErasure_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskGroundUnlawfulInsteadOfErasure_To_GatewayJoinGrounds_Art18</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_GroundLegalClaims_Art18" name="Assess legal-claims need">
      <bpmn:incoming>Flow_GatewayRestrictionGround_To_TaskGroundLegalClaims_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskGroundLegalClaims_To_GatewayJoinGrounds_Art18</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_GroundPendingObjectionVerification_Art18" name="Assess pending Article 21 objection">
      <bpmn:incoming>Flow_GatewayRestrictionGround_To_TaskGroundPendingObjectionVerification_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskGroundPendingObjectionVerification_To_GatewayJoinGrounds_Art18</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_JoinGrounds_Art18">
      <bpmn:incoming>Flow_TaskGroundAccuracyContested_To_GatewayJoinGrounds_Art18</bpmn:incoming>
      <bpmn:incoming>Flow_TaskGroundUnlawfulInsteadOfErasure_To_GatewayJoinGrounds_Art18</bpmn:incoming>
      <bpmn:incoming>Flow_TaskGroundLegalClaims_To_GatewayJoinGrounds_Art18</bpmn:incoming>
      <bpmn:incoming>Flow_TaskGroundPendingObjectionVerification_To_GatewayJoinGrounds_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinGrounds_To_TaskRestrictProcessing_Art18</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_RestrictProcessing_Art18" name="Restrict processing">
      <bpmn:incoming>Flow_GatewayJoinGrounds_To_TaskRestrictProcessing_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRestrictProcessing_To_GatewayFurtherProcessingNeeded_Art18</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_FurtherProcessingNeeded_Art18" name="Is any processing beyond storage needed while the restriction remains in place?">
      <bpmn:incoming>Flow_TaskRestrictProcessing_To_GatewayFurtherProcessingNeeded_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayFurtherProcessingNeeded_To_GatewayAllowedProcessingBasis_Art18</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFurtherProcessingNeeded_To_GatewayLiftRestriction_Art18</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_AllowedProcessingBasis_Art18" name="Which Article 18(2) basis permits the restricted processing?">
      <bpmn:incoming>Flow_GatewayFurtherProcessingNeeded_To_GatewayAllowedProcessingBasis_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAllowedProcessingBasis_To_TaskProcessByConsent_Art18</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAllowedProcessingBasis_To_TaskProcessForLegalClaims_Art18</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAllowedProcessingBasis_To_TaskProcessToProtectRights_Art18</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAllowedProcessingBasis_To_TaskProcessForPublicInterest_Art18</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAllowedProcessingBasis_To_EndNoPermittedProcessing_Art18</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ProcessByConsent_Art18" name="Process restricted data with consent">
      <bpmn:incoming>Flow_GatewayAllowedProcessingBasis_To_TaskProcessByConsent_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskProcessByConsent_To_GatewayLiftRestriction_Art18</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ProcessForLegalClaims_Art18" name="Process restricted data for legal claims">
      <bpmn:incoming>Flow_GatewayAllowedProcessingBasis_To_TaskProcessForLegalClaims_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskProcessForLegalClaims_To_GatewayLiftRestriction_Art18</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ProcessToProtectRights_Art18" name="Process restricted data to protect others' rights">
      <bpmn:incoming>Flow_GatewayAllowedProcessingBasis_To_TaskProcessToProtectRights_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskProcessToProtectRights_To_GatewayLiftRestriction_Art18</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ProcessForPublicInterest_Art18" name="Process restricted data for important public interest">
      <bpmn:incoming>Flow_GatewayAllowedProcessingBasis_To_TaskProcessForPublicInterest_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskProcessForPublicInterest_To_GatewayLiftRestriction_Art18</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_LiftRestriction_Art18" name="Will the restriction of processing be lifted?">
      <bpmn:incoming>Flow_GatewayFurtherProcessingNeeded_To_GatewayLiftRestriction_Art18</bpmn:incoming>
      <bpmn:incoming>Flow_TaskProcessByConsent_To_GatewayLiftRestriction_Art18</bpmn:incoming>
      <bpmn:incoming>Flow_TaskProcessForLegalClaims_To_GatewayLiftRestriction_Art18</bpmn:incoming>
      <bpmn:incoming>Flow_TaskProcessToProtectRights_To_GatewayLiftRestriction_Art18</bpmn:incoming>
      <bpmn:incoming>Flow_TaskProcessForPublicInterest_To_GatewayLiftRestriction_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayLiftRestriction_To_SendTaskInformBeforeLift_Art18</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayLiftRestriction_To_EndRestrictionRemains_Art18</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_InformBeforeLift_Art18" name="Inform before lifting restriction">
      <bpmn:incoming>Flow_GatewayLiftRestriction_To_SendTaskInformBeforeLift_Art18</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskInformBeforeLift_To_EndRestrictionLifted_Art18</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_RequestBlocked_Art18" name="The restriction request is not handled because Article 12(2) or Article 11(2) blocks the request">
      <bpmn:incoming>Flow_GatewayRequestExceptions_To_EndRequestBlocked_Art18</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_NoRestrictionGround_Art18" name="No Article 18(1) restriction ground is established">
      <bpmn:incoming>Flow_GatewayRestrictionGround_To_EndNoRestrictionGround_Art18</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_NoPermittedProcessing_Art18" name="No further processing beyond storage is permitted while the restriction remains in place">
      <bpmn:incoming>Flow_GatewayAllowedProcessingBasis_To_EndNoPermittedProcessing_Art18</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_RestrictionRemains_Art18" name="The restriction of processing remains in place">
      <bpmn:incoming>Flow_GatewayLiftRestriction_To_EndRestrictionRemains_Art18</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_RestrictionLifted_Art18" name="The data subject has been informed before the restriction is lifted">
      <bpmn:incoming>Flow_SendTaskInformBeforeLift_To_EndRestrictionLifted_Art18</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_ReceiveTaskReceiveRestrictionRequest_Art18" sourceRef="StartEvent_RestrictionRequested_Art18" targetRef="ReceiveTask_ReceiveRestrictionRequest_Art18" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveRestrictionRequest_To_GatewayRequestExceptions_Art18" sourceRef="ReceiveTask_ReceiveRestrictionRequest_Art18" targetRef="Gateway_RequestExceptions_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayRequestExceptions_To_EndRequestBlocked_Art18" name="Yes" sourceRef="Gateway_RequestExceptions_Art18" targetRef="EndEvent_RequestBlocked_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayRequestExceptions_To_GatewayRestrictionGround_Art18" name="No" sourceRef="Gateway_RequestExceptions_Art18" targetRef="Gateway_RestrictionGround_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayRestrictionGround_To_TaskGroundAccuracyContested_Art18" name="Accuracy is contested pending verification" sourceRef="Gateway_RestrictionGround_Art18" targetRef="Task_GroundAccuracyContested_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayRestrictionGround_To_TaskGroundUnlawfulInsteadOfErasure_Art18" name="Processing is unlawful and restriction is requested instead of erasure" sourceRef="Gateway_RestrictionGround_Art18" targetRef="Task_GroundUnlawfulInsteadOfErasure_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayRestrictionGround_To_TaskGroundLegalClaims_Art18" name="Controller no longer needs the data but the data subject needs them for legal claims" sourceRef="Gateway_RestrictionGround_Art18" targetRef="Task_GroundLegalClaims_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayRestrictionGround_To_TaskGroundPendingObjectionVerification_Art18" name="Article 21(1) objection is pending verification of overriding grounds" sourceRef="Gateway_RestrictionGround_Art18" targetRef="Task_GroundPendingObjectionVerification_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayRestrictionGround_To_EndNoRestrictionGround_Art18" name="No ground" sourceRef="Gateway_RestrictionGround_Art18" targetRef="EndEvent_NoRestrictionGround_Art18" />
    <bpmn:sequenceFlow id="Flow_TaskGroundAccuracyContested_To_GatewayJoinGrounds_Art18" sourceRef="Task_GroundAccuracyContested_Art18" targetRef="Gateway_JoinGrounds_Art18" />
    <bpmn:sequenceFlow id="Flow_TaskGroundUnlawfulInsteadOfErasure_To_GatewayJoinGrounds_Art18" sourceRef="Task_GroundUnlawfulInsteadOfErasure_Art18" targetRef="Gateway_JoinGrounds_Art18" />
    <bpmn:sequenceFlow id="Flow_TaskGroundLegalClaims_To_GatewayJoinGrounds_Art18" sourceRef="Task_GroundLegalClaims_Art18" targetRef="Gateway_JoinGrounds_Art18" />
    <bpmn:sequenceFlow id="Flow_TaskGroundPendingObjectionVerification_To_GatewayJoinGrounds_Art18" sourceRef="Task_GroundPendingObjectionVerification_Art18" targetRef="Gateway_JoinGrounds_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinGrounds_To_TaskRestrictProcessing_Art18" sourceRef="Gateway_JoinGrounds_Art18" targetRef="Task_RestrictProcessing_Art18" />
    <bpmn:sequenceFlow id="Flow_TaskRestrictProcessing_To_GatewayFurtherProcessingNeeded_Art18" sourceRef="Task_RestrictProcessing_Art18" targetRef="Gateway_FurtherProcessingNeeded_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayFurtherProcessingNeeded_To_GatewayAllowedProcessingBasis_Art18" name="Yes" sourceRef="Gateway_FurtherProcessingNeeded_Art18" targetRef="Gateway_AllowedProcessingBasis_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayFurtherProcessingNeeded_To_GatewayLiftRestriction_Art18" name="No" sourceRef="Gateway_FurtherProcessingNeeded_Art18" targetRef="Gateway_LiftRestriction_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayAllowedProcessingBasis_To_TaskProcessByConsent_Art18" name="The data subject consented to the restricted processing" sourceRef="Gateway_AllowedProcessingBasis_Art18" targetRef="Task_ProcessByConsent_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayAllowedProcessingBasis_To_TaskProcessForLegalClaims_Art18" name="Processing is needed for legal claims" sourceRef="Gateway_AllowedProcessingBasis_Art18" targetRef="Task_ProcessForLegalClaims_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayAllowedProcessingBasis_To_TaskProcessToProtectRights_Art18" name="Processing is needed to protect the rights of another person" sourceRef="Gateway_AllowedProcessingBasis_Art18" targetRef="Task_ProcessToProtectRights_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayAllowedProcessingBasis_To_TaskProcessForPublicInterest_Art18" name="Processing is needed for important public interest" sourceRef="Gateway_AllowedProcessingBasis_Art18" targetRef="Task_ProcessForPublicInterest_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayAllowedProcessingBasis_To_EndNoPermittedProcessing_Art18" name="No permitted basis" sourceRef="Gateway_AllowedProcessingBasis_Art18" targetRef="EndEvent_NoPermittedProcessing_Art18" />
    <bpmn:sequenceFlow id="Flow_TaskProcessByConsent_To_GatewayLiftRestriction_Art18" sourceRef="Task_ProcessByConsent_Art18" targetRef="Gateway_LiftRestriction_Art18" />
    <bpmn:sequenceFlow id="Flow_TaskProcessForLegalClaims_To_GatewayLiftRestriction_Art18" sourceRef="Task_ProcessForLegalClaims_Art18" targetRef="Gateway_LiftRestriction_Art18" />
    <bpmn:sequenceFlow id="Flow_TaskProcessToProtectRights_To_GatewayLiftRestriction_Art18" sourceRef="Task_ProcessToProtectRights_Art18" targetRef="Gateway_LiftRestriction_Art18" />
    <bpmn:sequenceFlow id="Flow_TaskProcessForPublicInterest_To_GatewayLiftRestriction_Art18" sourceRef="Task_ProcessForPublicInterest_Art18" targetRef="Gateway_LiftRestriction_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayLiftRestriction_To_SendTaskInformBeforeLift_Art18" name="Yes" sourceRef="Gateway_LiftRestriction_Art18" targetRef="SendTask_InformBeforeLift_Art18" />
    <bpmn:sequenceFlow id="Flow_GatewayLiftRestriction_To_EndRestrictionRemains_Art18" name="No" sourceRef="Gateway_LiftRestriction_Art18" targetRef="EndEvent_RestrictionRemains_Art18" />
    <bpmn:sequenceFlow id="Flow_SendTaskInformBeforeLift_To_EndRestrictionLifted_Art18" sourceRef="SendTask_InformBeforeLift_Art18" targetRef="EndEvent_RestrictionLifted_Art18" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art18_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art18_Reviewed" bpmnElement="Collaboration_Art18_Reviewed">
      <bpmndi:BPMNShape id="Participant_Controller_Art18_di" bpmnElement="Participant_Controller_Art18" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="5000" height="980" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art18_di" bpmnElement="Participant_DataSubject_Art18" isHorizontal="true">
        <dc:Bounds x="60" y="1060" width="5000" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_RestrictionRequested_Art18_di" bpmnElement="StartEvent_RestrictionRequested_Art18">
        <dc:Bounds x="120" y="452" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveRestrictionRequest_Art18_di" bpmnElement="ReceiveTask_ReceiveRestrictionRequest_Art18">
        <dc:Bounds x="240" y="430" width="300" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RequestExceptions_Art18_di" bpmnElement="Gateway_RequestExceptions_Art18" isMarkerVisible="true">
        <dc:Bounds x="640" y="445" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RestrictionGround_Art18_di" bpmnElement="Gateway_RestrictionGround_Art18" isMarkerVisible="true">
        <dc:Bounds x="860" y="445" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GroundAccuracyContested_Art18_di" bpmnElement="Task_GroundAccuracyContested_Art18">
        <dc:Bounds x="1120" y="80" width="620" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GroundUnlawfulInsteadOfErasure_Art18_di" bpmnElement="Task_GroundUnlawfulInsteadOfErasure_Art18">
        <dc:Bounds x="1120" y="180" width="690" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GroundLegalClaims_Art18_di" bpmnElement="Task_GroundLegalClaims_Art18">
        <dc:Bounds x="1120" y="280" width="650" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GroundPendingObjectionVerification_Art18_di" bpmnElement="Task_GroundPendingObjectionVerification_Art18">
        <dc:Bounds x="1120" y="380" width="700" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_JoinGrounds_Art18_di" bpmnElement="Gateway_JoinGrounds_Art18" isMarkerVisible="true">
        <dc:Bounds x="1940" y="445" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RestrictProcessing_Art18_di" bpmnElement="Task_RestrictProcessing_Art18">
        <dc:Bounds x="2140" y="430" width="360" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_FurtherProcessingNeeded_Art18_di" bpmnElement="Gateway_FurtherProcessingNeeded_Art18" isMarkerVisible="true">
        <dc:Bounds x="2640" y="445" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AllowedProcessingBasis_Art18_di" bpmnElement="Gateway_AllowedProcessingBasis_Art18" isMarkerVisible="true">
        <dc:Bounds x="2860" y="445" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProcessByConsent_Art18_di" bpmnElement="Task_ProcessByConsent_Art18">
        <dc:Bounds x="3110" y="80" width="460" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProcessForLegalClaims_Art18_di" bpmnElement="Task_ProcessForLegalClaims_Art18">
        <dc:Bounds x="3110" y="180" width="540" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProcessToProtectRights_Art18_di" bpmnElement="Task_ProcessToProtectRights_Art18">
        <dc:Bounds x="3110" y="280" width="560" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProcessForPublicInterest_Art18_di" bpmnElement="Task_ProcessForPublicInterest_Art18">
        <dc:Bounds x="3110" y="380" width="660" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_LiftRestriction_Art18_di" bpmnElement="Gateway_LiftRestriction_Art18" isMarkerVisible="true">
        <dc:Bounds x="3920" y="445" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_InformBeforeLift_Art18_di" bpmnElement="SendTask_InformBeforeLift_Art18">
        <dc:Bounds x="4140" y="430" width="520" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_RequestBlocked_Art18_di" bpmnElement="EndEvent_RequestBlocked_Art18">
        <dc:Bounds x="717" y="717" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoRestrictionGround_Art18_di" bpmnElement="EndEvent_NoRestrictionGround_Art18">
        <dc:Bounds x="1037" y="717" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoPermittedProcessing_Art18_di" bpmnElement="EndEvent_NoPermittedProcessing_Art18">
        <dc:Bounds x="3122" y="717" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RestrictionRemains_Art18_di" bpmnElement="EndEvent_RestrictionRemains_Art18">
        <dc:Bounds x="4002" y="717" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RestrictionLifted_Art18_di" bpmnElement="EndEvent_RestrictionLifted_Art18">
        <dc:Bounds x="4732" y="452" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_ReceiveTaskReceiveRestrictionRequest_Art18_di" bpmnElement="Flow_Start_To_ReceiveTaskReceiveRestrictionRequest_Art18">
        <di:waypoint x="156" y="470" />
        <di:waypoint x="240" y="470" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReceiveTaskReceiveRestrictionRequest_To_GatewayRequestExceptions_Art18_di" bpmnElement="Flow_ReceiveTaskReceiveRestrictionRequest_To_GatewayRequestExceptions_Art18">
        <di:waypoint x="540" y="470" />
