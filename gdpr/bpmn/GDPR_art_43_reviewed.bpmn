<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art43_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art43_Reviewed">
    <bpmn:participant id="Participant_CertificationBody_Art43"
                      name="Certification Body"
                      processRef="Process_CertificationBody_Art43" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art43"
                      name="Supervisory Authority"
                      processRef="Process_SupervisoryAuthority_Art43" />
    <bpmn:participant id="Participant_NationalAccreditationBody_Art43"
                      name="National Accreditation Body" />
    <bpmn:participant id="Participant_Board_Art43"
                      name="Board" />
    <bpmn:participant id="Participant_Commission_Art43"
                      name="Commission" />

    <bpmn:messageFlow id="MessageFlow_RequestSAAccreditation_Art43"
                      sourceRef="SendTask_RequestSAAccreditation_Art43"
                      targetRef="ReceiveTask_ReceiveSAAccreditationRequest_Art43" />
    <bpmn:messageFlow id="MessageFlow_RequestNABAccreditation_Art43"
                      sourceRef="SendTask_RequestNABAccreditation_Art43"
                      targetRef="Participant_NationalAccreditationBody_Art43" />
    <bpmn:messageFlow id="MessageFlow_InformAuthorityBeforeIssuing_Art43"
                      sourceRef="SendTask_InformAuthorityBeforeIssuing_Art43"
                      targetRef="ReceiveTask_ReceiveIssuanceInformation_Art43" />
    <bpmn:messageFlow id="MessageFlow_SendGrantReasons_Art43"
                      sourceRef="SendTask_SendGrantReasons_Art43"
                      targetRef="ReceiveTask_ReceiveGrantReasons_Art43" />
    <bpmn:messageFlow id="MessageFlow_SendWithdrawalReasons_Art43"
                      sourceRef="SendTask_SendWithdrawalReasons_Art43"
                      targetRef="ReceiveTask_ReceiveWithdrawalReasons_Art43" />
    <bpmn:messageFlow id="MessageFlow_SubmitRequirementsToBoard_Art43"
                      sourceRef="SendTask_SubmitRequirementsToBoard_Art43"
                      targetRef="Participant_Board_Art43" />
    <bpmn:messageFlow id="MessageFlow_SendPublicRequirementsToBoard_Art43"
                      sourceRef="SendTask_SendPublicRequirementsToBoard_Art43"
                      targetRef="Participant_Board_Art43" />
    <bpmn:messageFlow id="MessageFlow_RequestCommissionSpecifications_Art43"
                      sourceRef="SendTask_RequestCommissionSpecifications_Art43"
                      targetRef="Participant_Commission_Art43" />
    <bpmn:messageFlow id="MessageFlow_RequestCommissionStandards_Art43"
                      sourceRef="SendTask_RequestCommissionStandards_Art43"
                      targetRef="Participant_Commission_Art43" />
    <bpmn:messageFlow id="MessageFlow_RevokeByAuthority_Art43"
                      sourceRef="SendTask_RevokeAccreditation_Art43"
                      targetRef="Participant_CertificationBody_Art43" />
  </bpmn:collaboration>

  <bpmn:process id="Process_CertificationBody_Art43"
                name="Operating as a certification body under Article 43"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 43 based on the real English legal text
      from gdpr_articles/article_43.txt. This model captures the accreditation routes,
      the Article 43(2) eligibility requirements, issuing and renewing certification
      after informing the supervisory authority, the duty to provide reasons for
      granting or withdrawing certification, the proper-assessment responsibility, and
      the five-year accreditation lifecycle with renewal.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_SeekAccreditation_Art43"
                     name="Seek accreditation">
      <bpmn:outgoing>Flow_StartSeekAccreditation_To_GatewayAccreditationRoute_Art43</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_AccreditationRoute_Art43"
                           name="Will the supervisory authority accredit the body?">
      <bpmn:incoming>Flow_StartSeekAccreditation_To_GatewayAccreditationRoute_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAccreditationRoute_To_SendSAAccreditationRequest_Art43</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAccreditationRoute_To_SendNABAccreditationRequest_Art43</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_RequestSAAccreditation_Art43"
                   name="Request SA accreditation">
      <bpmn:incoming>Flow_GatewayAccreditationRoute_To_SendSAAccreditationRequest_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_SendSAAccreditationRequest_To_TaskDemonstrateRequirements_Art43</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_RequestNABAccreditation_Art43"
                   name="Request NAB accreditation">
      <bpmn:incoming>Flow_GatewayAccreditationRoute_To_SendNABAccreditationRequest_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_SendNABAccreditationRequest_To_TaskDemonstrateRequirements_Art43</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:parallelGateway id="Gateway_SplitRequirements_Art43">
      <bpmn:incoming>Flow_SendSAAccreditationRequest_To_TaskDemonstrateRequirements_Art43</bpmn:incoming>
      <bpmn:incoming>Flow_SendNABAccreditationRequest_To_TaskDemonstrateRequirements_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitRequirements_To_TaskDemonstrateIndependence_Art43</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitRequirements_To_TaskUndertakeApprovedCriteria_Art43</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitRequirements_To_TaskSetReviewWithdrawalProcedures_Art43</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitRequirements_To_TaskSetComplaintProcedures_Art43</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitRequirements_To_TaskShowNoConflicts_Art43</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_DemonstrateIndependence_Art43"
               name="Demonstrate independence and expertise">
      <bpmn:incoming>Flow_GatewaySplitRequirements_To_TaskDemonstrateIndependence_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDemonstrateIndependence_To_GatewayJoinRequirements_Art43</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_UndertakeApprovedCriteria_Art43"
               name="Undertake approved criteria">
      <bpmn:incoming>Flow_GatewaySplitRequirements_To_TaskUndertakeApprovedCriteria_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskUndertakeApprovedCriteria_To_GatewayJoinRequirements_Art43</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetReviewWithdrawalProcedures_Art43"
               name="Set review and withdrawal procedures">
      <bpmn:incoming>Flow_GatewaySplitRequirements_To_TaskSetReviewWithdrawalProcedures_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetReviewWithdrawalProcedures_To_GatewayJoinRequirements_Art43</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetComplaintProcedures_Art43"
               name="Set complaint procedures">
      <bpmn:incoming>Flow_GatewaySplitRequirements_To_TaskSetComplaintProcedures_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetComplaintProcedures_To_GatewayJoinRequirements_Art43</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ShowNoConflicts_Art43"
               name="Show no conflicts">
      <bpmn:incoming>Flow_GatewaySplitRequirements_To_TaskShowNoConflicts_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskShowNoConflicts_To_GatewayJoinRequirements_Art43</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinRequirements_Art43">
      <bpmn:incoming>Flow_TaskDemonstrateIndependence_To_GatewayJoinRequirements_Art43</bpmn:incoming>
      <bpmn:incoming>Flow_TaskUndertakeApprovedCriteria_To_GatewayJoinRequirements_Art43</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetReviewWithdrawalProcedures_To_GatewayJoinRequirements_Art43</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetComplaintProcedures_To_GatewayJoinRequirements_Art43</bpmn:incoming>
      <bpmn:incoming>Flow_TaskShowNoConflicts_To_GatewayJoinRequirements_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinRequirements_To_TaskRunProperAssessment_Art43</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_RunProperAssessment_Art43"
               name="Run proper assessment">
      <bpmn:incoming>Flow_GatewayJoinRequirements_To_TaskRunProperAssessment_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRunProperAssessment_To_SendInformAuthority_Art43</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_InformAuthorityBeforeIssuing_Art43"
                   name="Inform authority before issuing">
      <bpmn:incoming>Flow_TaskRunProperAssessment_To_SendInformAuthority_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_SendInformAuthority_To_GatewayCertificationOutcome_Art43</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_CertificationOutcome_Art43"
                           name="Will certification be granted or renewed?">
      <bpmn:incoming>Flow_SendInformAuthority_To_GatewayCertificationOutcome_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayCertificationOutcome_To_SendGrantReasons_Art43</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCertificationOutcome_To_SendWithdrawalReasons_Art43</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_SendGrantReasons_Art43"
                   name="Send grant or renewal reasons">
      <bpmn:incoming>Flow_GatewayCertificationOutcome_To_SendGrantReasons_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_SendGrantReasons_To_TaskManageAccreditationTerm_Art43</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ManageAccreditationTerm_Art43"
               name="Manage five-year accreditation">
      <bpmn:incoming>Flow_SendGrantReasons_To_TaskManageAccreditationTerm_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskManageAccreditationTerm_To_GatewayRenewAccreditation_Art43</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_RenewAccreditation_Art43"
                           name="Will accreditation be renewed on the same conditions?">
      <bpmn:incoming>Flow_TaskManageAccreditationTerm_To_GatewayRenewAccreditation_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRenewAccreditation_To_EndAccreditationEnded_Art43</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRenewAccreditation_To_TaskRunProperAssessment_Art43</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_AccreditationEnded_Art43"
                   name="Accreditation term ended">
      <bpmn:incoming>Flow_GatewayRenewAccreditation_To_EndAccreditationEnded_Art43</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_SendWithdrawalReasons_Art43"
                   name="Send withdrawal reasons">
      <bpmn:incoming>Flow_GatewayCertificationOutcome_To_SendWithdrawalReasons_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_SendWithdrawalReasons_To_EndCertificationWithdrawn_Art43</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_CertificationWithdrawn_Art43"
                   name="Certification withdrawn">
      <bpmn:incoming>Flow_SendWithdrawalReasons_To_EndCertificationWithdrawn_Art43</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartSeekAccreditation_To_GatewayAccreditationRoute_Art43" sourceRef="StartEvent_SeekAccreditation_Art43" targetRef="Gateway_AccreditationRoute_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewayAccreditationRoute_To_SendSAAccreditationRequest_Art43" name="Yes" sourceRef="Gateway_AccreditationRoute_Art43" targetRef="SendTask_RequestSAAccreditation_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewayAccreditationRoute_To_SendNABAccreditationRequest_Art43" name="No" sourceRef="Gateway_AccreditationRoute_Art43" targetRef="SendTask_RequestNABAccreditation_Art43" />
    <bpmn:sequenceFlow id="Flow_SendSAAccreditationRequest_To_TaskDemonstrateRequirements_Art43" sourceRef="SendTask_RequestSAAccreditation_Art43" targetRef="Gateway_SplitRequirements_Art43" />
    <bpmn:sequenceFlow id="Flow_SendNABAccreditationRequest_To_TaskDemonstrateRequirements_Art43" sourceRef="SendTask_RequestNABAccreditation_Art43" targetRef="Gateway_SplitRequirements_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitRequirements_To_TaskDemonstrateIndependence_Art43" sourceRef="Gateway_SplitRequirements_Art43" targetRef="Task_DemonstrateIndependence_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitRequirements_To_TaskUndertakeApprovedCriteria_Art43" sourceRef="Gateway_SplitRequirements_Art43" targetRef="Task_UndertakeApprovedCriteria_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitRequirements_To_TaskSetReviewWithdrawalProcedures_Art43" sourceRef="Gateway_SplitRequirements_Art43" targetRef="Task_SetReviewWithdrawalProcedures_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitRequirements_To_TaskSetComplaintProcedures_Art43" sourceRef="Gateway_SplitRequirements_Art43" targetRef="Task_SetComplaintProcedures_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitRequirements_To_TaskShowNoConflicts_Art43" sourceRef="Gateway_SplitRequirements_Art43" targetRef="Task_ShowNoConflicts_Art43" />
    <bpmn:sequenceFlow id="Flow_TaskDemonstrateIndependence_To_GatewayJoinRequirements_Art43" sourceRef="Task_DemonstrateIndependence_Art43" targetRef="Gateway_JoinRequirements_Art43" />
    <bpmn:sequenceFlow id="Flow_TaskUndertakeApprovedCriteria_To_GatewayJoinRequirements_Art43" sourceRef="Task_UndertakeApprovedCriteria_Art43" targetRef="Gateway_JoinRequirements_Art43" />
    <bpmn:sequenceFlow id="Flow_TaskSetReviewWithdrawalProcedures_To_GatewayJoinRequirements_Art43" sourceRef="Task_SetReviewWithdrawalProcedures_Art43" targetRef="Gateway_JoinRequirements_Art43" />
    <bpmn:sequenceFlow id="Flow_TaskSetComplaintProcedures_To_GatewayJoinRequirements_Art43" sourceRef="Task_SetComplaintProcedures_Art43" targetRef="Gateway_JoinRequirements_Art43" />
    <bpmn:sequenceFlow id="Flow_TaskShowNoConflicts_To_GatewayJoinRequirements_Art43" sourceRef="Task_ShowNoConflicts_Art43" targetRef="Gateway_JoinRequirements_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinRequirements_To_TaskRunProperAssessment_Art43" sourceRef="Gateway_JoinRequirements_Art43" targetRef="Task_RunProperAssessment_Art43" />
    <bpmn:sequenceFlow id="Flow_TaskRunProperAssessment_To_SendInformAuthority_Art43" sourceRef="Task_RunProperAssessment_Art43" targetRef="SendTask_InformAuthorityBeforeIssuing_Art43" />
    <bpmn:sequenceFlow id="Flow_SendInformAuthority_To_GatewayCertificationOutcome_Art43" sourceRef="SendTask_InformAuthorityBeforeIssuing_Art43" targetRef="Gateway_CertificationOutcome_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewayCertificationOutcome_To_SendGrantReasons_Art43" name="Yes" sourceRef="Gateway_CertificationOutcome_Art43" targetRef="SendTask_SendGrantReasons_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewayCertificationOutcome_To_SendWithdrawalReasons_Art43" name="No" sourceRef="Gateway_CertificationOutcome_Art43" targetRef="SendTask_SendWithdrawalReasons_Art43" />
    <bpmn:sequenceFlow id="Flow_SendGrantReasons_To_TaskManageAccreditationTerm_Art43" sourceRef="SendTask_SendGrantReasons_Art43" targetRef="Task_ManageAccreditationTerm_Art43" />
    <bpmn:sequenceFlow id="Flow_TaskManageAccreditationTerm_To_GatewayRenewAccreditation_Art43" sourceRef="Task_ManageAccreditationTerm_Art43" targetRef="Gateway_RenewAccreditation_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewayRenewAccreditation_To_EndAccreditationEnded_Art43" name="No" sourceRef="Gateway_RenewAccreditation_Art43" targetRef="EndEvent_AccreditationEnded_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewayRenewAccreditation_To_TaskRunProperAssessment_Art43" name="Yes" sourceRef="Gateway_RenewAccreditation_Art43" targetRef="Task_RunProperAssessment_Art43" />
    <bpmn:sequenceFlow id="Flow_SendWithdrawalReasons_To_EndCertificationWithdrawn_Art43" sourceRef="SendTask_SendWithdrawalReasons_Art43" targetRef="EndEvent_CertificationWithdrawn_Art43" />
  </bpmn:process>

  <bpmn:process id="Process_SupervisoryAuthority_Art43"
                name="Setting, publishing, and enforcing Article 43 requirements"
                isExecutable="false">
    <bpmn:documentation>
      This process captures the Article 43(3), (6), and (7) supervisory-authority
      duties: approving accreditation requirements, complementing the national-
      accreditation route, publishing requirements and Article 42(5) criteria,
      transmitting them to the Board, receiving reasons for grant or withdrawal, and
      revoking accreditation where conditions are not or are no longer met or where the
      certification body's actions infringe the GDPR. It also captures the Article 43(8)
      and (9) Commission follow-up requests.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_SetRequirements_Art43"
                     name="Set Article 43 framework">
      <bpmn:outgoing>Flow_StartSetRequirements_To_GatewayApprovalSource_Art43</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_ApprovalSource_Art43"
                           name="Will the Board approve the accreditation criteria?">
      <bpmn:incoming>Flow_StartSetRequirements_To_GatewayApprovalSource_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayApprovalSource_To_TaskApproveRequirements_Art43</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayApprovalSource_To_SendSubmitRequirementsToBoard_Art43</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ApproveRequirements_Art43"
               name="Approve accreditation requirements">
      <bpmn:incoming>Flow_GatewayApprovalSource_To_TaskApproveRequirements_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskApproveRequirements_To_TaskComplementNABRequirements_Art43</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_SubmitRequirementsToBoard_Art43"
                   name="Submit requirements to Board">
      <bpmn:incoming>Flow_GatewayApprovalSource_To_SendSubmitRequirementsToBoard_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_SendSubmitRequirementsToBoard_To_TaskComplementNABRequirements_Art43</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ComplementNABRequirements_Art43"
               name="Complement NAB requirements">
      <bpmn:incoming>Flow_TaskApproveRequirements_To_TaskComplementNABRequirements_Art43</bpmn:incoming>
      <bpmn:incoming>Flow_SendSubmitRequirementsToBoard_To_TaskComplementNABRequirements_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskComplementNABRequirements_To_TaskPublishRequirements_Art43</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PublishRequirements_Art43"
               name="Publish requirements and criteria">
      <bpmn:incoming>Flow_TaskComplementNABRequirements_To_TaskPublishRequirements_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPublishRequirements_To_SendPublicRequirementsToBoard_Art43</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_SendPublicRequirementsToBoard_Art43"
                   name="Send public requirements to Board">
      <bpmn:incoming>Flow_TaskPublishRequirements_To_SendPublicRequirementsToBoard_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_SendPublicRequirementsToBoard_To_SendRequestCommissionSpecifications_Art43</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_RequestCommissionSpecifications_Art43"
                   name="Request Commission specifications">
      <bpmn:incoming>Flow_SendPublicRequirementsToBoard_To_SendRequestCommissionSpecifications_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRequestCommissionSpecifications_To_SendRequestCommissionStandards_Art43</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_RequestCommissionStandards_Art43"
                   name="Request Commission standards">
      <bpmn:incoming>Flow_SendRequestCommissionSpecifications_To_SendRequestCommissionStandards_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRequestCommissionStandards_To_ReceiveSAAccreditationRequest_Art43</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveSAAccreditationRequest_Art43"
                      name="Receive SA accreditation request">
      <bpmn:incoming>Flow_SendRequestCommissionStandards_To_ReceiveSAAccreditationRequest_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveSAAccreditationRequest_To_ReceiveIssuanceInformation_Art43</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveIssuanceInformation_Art43"
                      name="Receive issuance information">
      <bpmn:incoming>Flow_ReceiveSAAccreditationRequest_To_ReceiveIssuanceInformation_Art43</bpmn:incoming>
      <bpmn:incoming>Flow_SendInformAuthorityBeforeIssuing_To_ReceiveIssuanceInformation_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveIssuanceInformation_To_ReceiveGrantReasons_Art43</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveGrantReasons_Art43"
                      name="Receive grant or renewal reasons">
      <bpmn:incoming>Flow_ReceiveIssuanceInformation_To_ReceiveGrantReasons_Art43</bpmn:incoming>
      <bpmn:incoming>Flow_SendGrantReasonsToAuthority_To_ReceiveGrantReasons_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveGrantReasons_To_ReceiveWithdrawalReasons_Art43</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveWithdrawalReasons_Art43"
                      name="Receive withdrawal reasons">
      <bpmn:incoming>Flow_ReceiveGrantReasons_To_ReceiveWithdrawalReasons_Art43</bpmn:incoming>
      <bpmn:incoming>Flow_SendWithdrawalReasonsToAuthority_To_ReceiveWithdrawalReasons_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveWithdrawalReasons_To_GatewayRevokeAccreditation_Art43</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_RevokeAccreditation_Art43"
                           name="Should accreditation be revoked?">
      <bpmn:incoming>Flow_ReceiveWithdrawalReasons_To_GatewayRevokeAccreditation_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRevokeAccreditation_To_EndAccreditationMaintained_Art43</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRevokeAccreditation_To_SendRevokeAccreditation_Art43</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_AccreditationMaintained_Art43"
                   name="Accreditation maintained">
      <bpmn:incoming>Flow_GatewayRevokeAccreditation_To_EndAccreditationMaintained_Art43</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_RevokeAccreditation_Art43"
                   name="Revoke accreditation">
      <bpmn:incoming>Flow_GatewayRevokeAccreditation_To_SendRevokeAccreditation_Art43</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRevokeAccreditation_To_EndAccreditationRevoked_Art43</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_AccreditationRevoked_Art43"
                   name="Accreditation revoked">
      <bpmn:incoming>Flow_SendRevokeAccreditation_To_EndAccreditationRevoked_Art43</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartSetRequirements_To_GatewayApprovalSource_Art43" sourceRef="StartEvent_SetRequirements_Art43" targetRef="Gateway_ApprovalSource_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewayApprovalSource_To_TaskApproveRequirements_Art43" name="No" sourceRef="Gateway_ApprovalSource_Art43" targetRef="Task_ApproveRequirements_Art43" />
    <bpmn:sequenceFlow id="Flow_GatewayApprovalSource_To_SendSubmitRequirementsToBoard_Art43" name="Yes" sourceRef="Gateway_ApprovalSource_Art43" targetRef="SendTask_SubmitRequirementsToBoard_Art43" />
    <bpmn:sequenceFlow id="Flow_TaskApproveRequirements_To_TaskComplementNABRequirements_Art43" sourceRef="Task_ApproveRequirements_Art43" targetRef="Task_ComplementNABRequirements_Art43" />
    <bpmn:sequenceFlow id="Flow_SendSubmitRequirementsToBoard_To_TaskComplementNABRequirements_Art43" sourceRef="SendTask_SubmitRequirementsToBoard_Art43" targetRef="Task_ComplementNABRequirements_Art43" />
