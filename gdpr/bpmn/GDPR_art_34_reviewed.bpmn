<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Art34_Gold"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art34_Gold">
    <bpmn:participant id="Participant_Controller_Art34"
                      name="Controller"
                      processRef="Process_Controller_Art34" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art34"
                      name="Supervisory Authority"
                      processRef="Process_SupervisoryAuthority_Art34" />
    <bpmn:participant id="Participant_DataSubject_Art34"
                      name="Data Subject" />
    <bpmn:participant id="Participant_Public_Art34"
                      name="Public" />

    <bpmn:messageFlow id="MessageFlow_RequireCommunication_Art34"
                      sourceRef="SendTask_RequireCommunication_Art34"
                      targetRef="MessageStartEvent_SARequirement_Art34" />
    <bpmn:messageFlow id="MessageFlow_CommunicateToDataSubject_Art34"
                      sourceRef="SendTask_CommunicateDataSubject_Art34"
                      targetRef="Participant_DataSubject_Art34" />
    <bpmn:messageFlow id="MessageFlow_PublicCommunication_Art34"
                      sourceRef="SendTask_PublicCommunication_Art34"
                      targetRef="Participant_Public_Art34" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Controller_Art34"
                name="Apply Article 34 breach-communication duties"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 34 based only on the real English legal text.
      The model covers Article 34(1) high-risk communication, the Article 34(2) clear-and-plain-
      language content bundle including the nature of the breach and the Article 33(3)(b)-(d)
      information, the Article 34(3)(a)-(c) exception paths, the substitute public-communication
      route, and the Article 34(4) supervisory-authority requirement path.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_AssessArticle34_Art34"
                     name="Assess Article 34 duties">
      <bpmn:outgoing>Flow_Start_To_AssessHighRisk_Art34</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:messageStartEvent id="MessageStartEvent_SARequirement_Art34"
                            name="Receive communication requirement">
      <bpmn:outgoing>Flow_MessageStart_To_PrepareNotice_Art34</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_SARequirement_Art34" />
    </bpmn:messageStartEvent>

    <bpmn:task id="Task_AssessHighRisk_Art34"
               name="Assess likely high risk">
      <bpmn:incoming>Flow_Start_To_AssessHighRisk_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessHighRisk_To_GatewayHighRisk_Art34</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_HighRiskLikely_Art34"
                           name="Is the breach likely to result in high risk?">
      <bpmn:incoming>Flow_AssessHighRisk_To_GatewayHighRisk_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayHighRisk_To_EndNoCommunication_Art34</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayHighRisk_To_AssessProtection_Art34</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessProtectionMeasures_Art34"
               name="Assess protection measures">
      <bpmn:incoming>Flow_GatewayHighRisk_To_AssessProtection_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessProtection_To_GatewayProtection_Art34</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ProtectionEffective_Art34"
                           name="Do the applied measures render the data unintelligible?">
      <bpmn:incoming>Flow_AssessProtection_To_GatewayProtection_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayProtection_To_EndNoCommunication_Art34</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayProtection_To_AssessSubsequent_Art34</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessSubsequentMeasures_Art34"
               name="Assess subsequent measures">
      <bpmn:incoming>Flow_GatewayProtection_To_AssessSubsequent_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessSubsequent_To_GatewaySubsequent_Art34</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_SubsequentMeasuresEffective_Art34"
                           name="Do subsequent measures remove the likely high risk?">
      <bpmn:incoming>Flow_AssessSubsequent_To_GatewaySubsequent_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySubsequent_To_EndNoCommunication_Art34</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySubsequent_To_AssessEffort_Art34</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessCommunicationEffort_Art34"
               name="Assess communication effort">
      <bpmn:incoming>Flow_GatewaySubsequent_To_AssessEffort_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessEffort_To_GatewayEffort_Art34</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_DisproportionateEffort_Art34"
                           name="Would individual communication require disproportionate effort?">
      <bpmn:incoming>Flow_AssessEffort_To_GatewayEffort_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayEffort_To_PublicCommunication_Art34</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayEffort_To_PrepareNotice_Art34</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_PublicCommunication_Art34"
                   name="Issue public communication or similar measure">
      <bpmn:documentation>
        Article 34(3)(c): when direct individual communication would involve disproportionate
        effort, the controller instead uses public communication or a similar equally effective
        measure.
      </bpmn:documentation>
      <bpmn:incoming>Flow_GatewayEffort_To_PublicCommunication_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_PublicCommunication_To_EndPublicCommunication_Art34</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_PrepareNotice_Art34"
               name="Prepare clear and plain-language notice">
      <bpmn:incoming>Flow_GatewayEffort_To_PrepareNotice_Art34</bpmn:incoming>
      <bpmn:incoming>Flow_MessageStart_To_PrepareNotice_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_PrepareNotice_To_GatewayCompileSplit_Art34</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_CompileSplit_Art34">
      <bpmn:incoming>Flow_PrepareNotice_To_GatewayCompileSplit_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayCompileSplit_To_DescribeNature_Art34</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCompileSplit_To_ProvideContact_Art34</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCompileSplit_To_DescribeConsequences_Art34</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCompileSplit_To_DescribeMeasures_Art34</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_DescribeNature_Art34"
               name="Describe breach nature">
      <bpmn:incoming>Flow_GatewayCompileSplit_To_DescribeNature_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_DescribeNature_To_GatewayCompileJoin_Art34</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ProvideContact_Art34"
               name="Provide DPO or contact point details">
      <bpmn:incoming>Flow_GatewayCompileSplit_To_ProvideContact_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_ProvideContact_To_GatewayCompileJoin_Art34</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DescribeConsequences_Art34"
               name="Describe likely consequences">
      <bpmn:incoming>Flow_GatewayCompileSplit_To_DescribeConsequences_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_DescribeConsequences_To_GatewayCompileJoin_Art34</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DescribeMeasures_Art34"
               name="Describe measures taken or proposed">
      <bpmn:incoming>Flow_GatewayCompileSplit_To_DescribeMeasures_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_DescribeMeasures_To_GatewayCompileJoin_Art34</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_CompileJoin_Art34">
      <bpmn:incoming>Flow_DescribeNature_To_GatewayCompileJoin_Art34</bpmn:incoming>
      <bpmn:incoming>Flow_ProvideContact_To_GatewayCompileJoin_Art34</bpmn:incoming>
      <bpmn:incoming>Flow_DescribeConsequences_To_GatewayCompileJoin_Art34</bpmn:incoming>
      <bpmn:incoming>Flow_DescribeMeasures_To_GatewayCompileJoin_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayCompileJoin_To_Communicate_Art34</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:sendTask id="SendTask_CommunicateDataSubject_Art34"
                   name="Communicate breach without undue delay">
      <bpmn:documentation>
        Articles 34(1) and 34(2): direct communication to the data subject must be without undue
        delay and in clear and plain language.
      </bpmn:documentation>
      <bpmn:incoming>Flow_GatewayCompileJoin_To_Communicate_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_Communicate_To_EndDirectCommunication_Art34</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_NoCommunicationRequired_Art34"
                   name="No direct communication required">
      <bpmn:incoming>Flow_GatewayHighRisk_To_EndNoCommunication_Art34</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayProtection_To_EndNoCommunication_Art34</bpmn:incoming>
      <bpmn:incoming>Flow_GatewaySubsequent_To_EndNoCommunication_Art34</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_PublicCommunicationCompleted_Art34"
                   name="Public communication completed">
      <bpmn:incoming>Flow_PublicCommunication_To_EndPublicCommunication_Art34</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_DirectCommunicationCompleted_Art34"
                   name="Direct communication completed">
      <bpmn:incoming>Flow_Communicate_To_EndDirectCommunication_Art34</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_AssessHighRisk_Art34"
                       sourceRef="StartEvent_AssessArticle34_Art34"
                       targetRef="Task_AssessHighRisk_Art34" />
    <bpmn:sequenceFlow id="Flow_AssessHighRisk_To_GatewayHighRisk_Art34"
                       sourceRef="Task_AssessHighRisk_Art34"
                       targetRef="Gateway_HighRiskLikely_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayHighRisk_To_EndNoCommunication_Art34"
                       name="No"
                       sourceRef="Gateway_HighRiskLikely_Art34"
                       targetRef="EndEvent_NoCommunicationRequired_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayHighRisk_To_AssessProtection_Art34"
                       name="Yes"
                       sourceRef="Gateway_HighRiskLikely_Art34"
                       targetRef="Task_AssessProtectionMeasures_Art34" />
    <bpmn:sequenceFlow id="Flow_AssessProtection_To_GatewayProtection_Art34"
                       sourceRef="Task_AssessProtectionMeasures_Art34"
                       targetRef="Gateway_ProtectionEffective_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayProtection_To_EndNoCommunication_Art34"
                       name="Yes"
                       sourceRef="Gateway_ProtectionEffective_Art34"
                       targetRef="EndEvent_NoCommunicationRequired_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayProtection_To_AssessSubsequent_Art34"
                       name="No"
                       sourceRef="Gateway_ProtectionEffective_Art34"
                       targetRef="Task_AssessSubsequentMeasures_Art34" />
    <bpmn:sequenceFlow id="Flow_AssessSubsequent_To_GatewaySubsequent_Art34"
                       sourceRef="Task_AssessSubsequentMeasures_Art34"
                       targetRef="Gateway_SubsequentMeasuresEffective_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewaySubsequent_To_EndNoCommunication_Art34"
                       name="Yes"
                       sourceRef="Gateway_SubsequentMeasuresEffective_Art34"
                       targetRef="EndEvent_NoCommunicationRequired_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewaySubsequent_To_AssessEffort_Art34"
                       name="No"
                       sourceRef="Gateway_SubsequentMeasuresEffective_Art34"
                       targetRef="Task_AssessCommunicationEffort_Art34" />
    <bpmn:sequenceFlow id="Flow_AssessEffort_To_GatewayEffort_Art34"
                       sourceRef="Task_AssessCommunicationEffort_Art34"
                       targetRef="Gateway_DisproportionateEffort_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayEffort_To_PublicCommunication_Art34"
                       name="Yes"
                       sourceRef="Gateway_DisproportionateEffort_Art34"
                       targetRef="SendTask_PublicCommunication_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayEffort_To_PrepareNotice_Art34"
                       name="No"
                       sourceRef="Gateway_DisproportionateEffort_Art34"
                       targetRef="Task_PrepareNotice_Art34" />
    <bpmn:sequenceFlow id="Flow_MessageStart_To_PrepareNotice_Art34"
                       sourceRef="MessageStartEvent_SARequirement_Art34"
                       targetRef="Task_PrepareNotice_Art34" />
    <bpmn:sequenceFlow id="Flow_PublicCommunication_To_EndPublicCommunication_Art34"
                       sourceRef="SendTask_PublicCommunication_Art34"
                       targetRef="EndEvent_PublicCommunicationCompleted_Art34" />
    <bpmn:sequenceFlow id="Flow_PrepareNotice_To_GatewayCompileSplit_Art34"
                       sourceRef="Task_PrepareNotice_Art34"
                       targetRef="Gateway_CompileSplit_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayCompileSplit_To_DescribeNature_Art34"
                       sourceRef="Gateway_CompileSplit_Art34"
                       targetRef="Task_DescribeNature_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayCompileSplit_To_ProvideContact_Art34"
                       sourceRef="Gateway_CompileSplit_Art34"
                       targetRef="Task_ProvideContact_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayCompileSplit_To_DescribeConsequences_Art34"
                       sourceRef="Gateway_CompileSplit_Art34"
                       targetRef="Task_DescribeConsequences_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayCompileSplit_To_DescribeMeasures_Art34"
                       sourceRef="Gateway_CompileSplit_Art34"
                       targetRef="Task_DescribeMeasures_Art34" />
    <bpmn:sequenceFlow id="Flow_DescribeNature_To_GatewayCompileJoin_Art34"
                       sourceRef="Task_DescribeNature_Art34"
                       targetRef="Gateway_CompileJoin_Art34" />
    <bpmn:sequenceFlow id="Flow_ProvideContact_To_GatewayCompileJoin_Art34"
                       sourceRef="Task_ProvideContact_Art34"
                       targetRef="Gateway_CompileJoin_Art34" />
    <bpmn:sequenceFlow id="Flow_DescribeConsequences_To_GatewayCompileJoin_Art34"
                       sourceRef="Task_DescribeConsequences_Art34"
                       targetRef="Gateway_CompileJoin_Art34" />
    <bpmn:sequenceFlow id="Flow_DescribeMeasures_To_GatewayCompileJoin_Art34"
                       sourceRef="Task_DescribeMeasures_Art34"
                       targetRef="Gateway_CompileJoin_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayCompileJoin_To_Communicate_Art34"
                       sourceRef="Gateway_CompileJoin_Art34"
                       targetRef="SendTask_CommunicateDataSubject_Art34" />
    <bpmn:sequenceFlow id="Flow_Communicate_To_EndDirectCommunication_Art34"
                       sourceRef="SendTask_CommunicateDataSubject_Art34"
                       targetRef="EndEvent_DirectCommunicationCompleted_Art34" />
  </bpmn:process>

  <bpmn:process id="Process_SupervisoryAuthority_Art34"
                name="Apply Article 34(4) supervisory-authority decision path"
                isExecutable="false">
    <bpmn:startEvent id="StartEvent_ReviewArticle34_Art34"
                     name="Review Article 34 case">
      <bpmn:outgoing>Flow_SAStart_To_AssessHighRisk_Art34</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_AssessHighRisk_SA_Art34"
               name="Assess likely high risk">
      <bpmn:incoming>Flow_SAStart_To_AssessHighRisk_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_SAAssessHighRisk_To_GatewayCommunicated_Art34</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ControllerCommunicated_Art34"
                           name="Has the controller already communicated?">
      <bpmn:incoming>Flow_SAAssessHighRisk_To_GatewayCommunicated_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayCommunicated_To_EndNoSAAction_Art34</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCommunicated_To_AssessExceptions_Art34</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessArticle34Exceptions_SA_Art34"
               name="Assess Article 34(3) conditions">
      <bpmn:incoming>Flow_GatewayCommunicated_To_AssessExceptions_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessExceptions_To_GatewayExceptions_Art34</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ExceptionsApply_SA_Art34"
                           name="Do Article 34(3) conditions apply?">
      <bpmn:incoming>Flow_AssessExceptions_To_GatewayExceptions_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayExceptions_To_EndExceptionsMet_Art34</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayExceptions_To_RequireCommunication_Art34</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_RequireCommunication_Art34"
                   name="Require controller communication">
      <bpmn:incoming>Flow_GatewayExceptions_To_RequireCommunication_Art34</bpmn:incoming>
      <bpmn:outgoing>Flow_RequireCommunication_To_EndRequirementSent_Art34</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_NoSAAction_Art34"
                   name="No supervisory authority action required">
      <bpmn:incoming>Flow_GatewayCommunicated_To_EndNoSAAction_Art34</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_ExceptionsMet_Art34"
                   name="Article 34(3) conditions met">
      <bpmn:incoming>Flow_GatewayExceptions_To_EndExceptionsMet_Art34</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_RequirementSent_Art34"
                   name="Communication requirement sent">
      <bpmn:incoming>Flow_RequireCommunication_To_EndRequirementSent_Art34</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_SAStart_To_AssessHighRisk_Art34"
                       sourceRef="StartEvent_ReviewArticle34_Art34"
                       targetRef="Task_AssessHighRisk_SA_Art34" />
    <bpmn:sequenceFlow id="Flow_SAAssessHighRisk_To_GatewayCommunicated_Art34"
                       sourceRef="Task_AssessHighRisk_SA_Art34"
                       targetRef="Gateway_ControllerCommunicated_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayCommunicated_To_EndNoSAAction_Art34"
                       name="Yes"
                       sourceRef="Gateway_ControllerCommunicated_Art34"
                       targetRef="EndEvent_NoSAAction_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayCommunicated_To_AssessExceptions_Art34"
                       name="No"
                       sourceRef="Gateway_ControllerCommunicated_Art34"
                       targetRef="Task_AssessArticle34Exceptions_SA_Art34" />
    <bpmn:sequenceFlow id="Flow_AssessExceptions_To_GatewayExceptions_Art34"
                       sourceRef="Task_AssessArticle34Exceptions_SA_Art34"
                       targetRef="Gateway_ExceptionsApply_SA_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayExceptions_To_EndExceptionsMet_Art34"
                       name="Yes"
                       sourceRef="Gateway_ExceptionsApply_SA_Art34"
                       targetRef="EndEvent_ExceptionsMet_Art34" />
    <bpmn:sequenceFlow id="Flow_GatewayExceptions_To_RequireCommunication_Art34"
                       name="No"
                       sourceRef="Gateway_ExceptionsApply_SA_Art34"
                       targetRef="SendTask_RequireCommunication_Art34" />
    <bpmn:sequenceFlow id="Flow_RequireCommunication_To_EndRequirementSent_Art34"
                       sourceRef="SendTask_RequireCommunication_Art34"
                       targetRef="EndEvent_RequirementSent_Art34" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art34_Gold">
    <bpmndi:BPMNPlane id="BPMNPlane_Art34_Gold"
                      bpmnElement="Collaboration_Art34_Gold">
      <bpmndi:BPMNShape id="Participant_Controller_Art34_di"
                        bpmnElement="Participant_Controller_Art34"
                        isHorizontal="true">
        <dc:Bounds x="60" y="40" width="2360" height="420" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_SupervisoryAuthority_Art34_di"
                        bpmnElement="Participant_SupervisoryAuthority_Art34"
                        isHorizontal="true">
        <dc:Bounds x="60" y="500" width="2360" height="250" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art34_di"
                        bpmnElement="Participant_DataSubject_Art34"
                        isHorizontal="true">
        <dc:Bounds x="60" y="790" width="2360" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Public_Art34_di"
                        bpmnElement="Participant_Public_Art34"
                        isHorizontal="true">
        <dc:Bounds x="60" y="950" width="2360" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_AssessArticle34_Art34_di"
                        bpmnElement="StartEvent_AssessArticle34_Art34">
        <dc:Bounds x="120" y="197" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessHighRisk_Art34_di"
                        bpmnElement="Task_AssessHighRisk_Art34">
        <dc:Bounds x="210" y="175" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_HighRiskLikely_Art34_di"
                        bpmnElement="Gateway_HighRiskLikely_Art34"
                        isMarkerVisible="true">
        <dc:Bounds x="370" y="190" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoCommunicationRequired_Art34_di"
                        bpmnElement="EndEvent_NoCommunicationRequired_Art34">
        <dc:Bounds x="560" y="97" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessProtectionMeasures_Art34_di"
                        bpmnElement="Task_AssessProtectionMeasures_Art34">
        <dc:Bounds x="500" y="175" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ProtectionEffective_Art34_di"
                        bpmnElement="Gateway_ProtectionEffective_Art34"
                        isMarkerVisible="true">
        <dc:Bounds x="680" y="190" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessSubsequentMeasures_Art34_di"
                        bpmnElement="Task_AssessSubsequentMeasures_Art34">
        <dc:Bounds x="800" y="175" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SubsequentMeasuresEffective_Art34_di"
                        bpmnElement="Gateway_SubsequentMeasuresEffective_Art34"
                        isMarkerVisible="true">
        <dc:Bounds x="980" y="190" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessCommunicationEffort_Art34_di"
                        bpmnElement="Task_AssessCommunicationEffort_Art34">
        <dc:Bounds x="1110" y="175" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DisproportionateEffort_Art34_di"
