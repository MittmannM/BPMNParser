<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Art41_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art41_Reviewed">
    <bpmn:participant id="Participant_MonitoringBody_Art41"
                      name="Monitoring Body"
                      processRef="Process_MonitoringBody_Art41" />
    <bpmn:participant id="Participant_ControllerProcessor_Art41"
                      name="Adhering Controller or Processor" />
    <bpmn:participant id="Participant_DataSubject_Art41"
                      name="Data Subject" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art41"
                      name="Supervisory Authority" />

    <bpmn:messageFlow id="MessageFlow_SubmitAccreditationRequest_Art41"
                      sourceRef="SendTask_SubmitAccreditationRequest_Art41"
                      targetRef="Participant_SupervisoryAuthority_Art41" />
    <bpmn:messageFlow id="MessageFlow_AccreditationDecision_Art41"
                      sourceRef="Participant_SupervisoryAuthority_Art41"
                      targetRef="ReceiveTask_ReceiveAccreditationDecision_Art41" />
    <bpmn:messageFlow id="MessageFlow_Complaint_Art41"
                      sourceRef="Participant_DataSubject_Art41"
                      targetRef="Task_MonitorAndHandleComplaints_Art41" />
    <bpmn:messageFlow id="MessageFlow_SuspendOrExclude_Art41"
                      sourceRef="SendTask_SuspendOrExclude_Art41"
                      targetRef="Participant_ControllerProcessor_Art41" />
    <bpmn:messageFlow id="MessageFlow_InformAuthority_Art41"
                      sourceRef="SendTask_InformAuthority_Art41"
                      targetRef="Participant_SupervisoryAuthority_Art41" />
  </bpmn:collaboration>

  <bpmn:process id="Process_MonitoringBody_Art41"
                name="Accrediting and operating a monitoring body"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 41 based on DAPRECO LegalRuleML statements231-234.
      The model captures the public-body exception, the expertise and conflict-of-interest checks,
      the implementation of monitoring and complaint procedures, the accreditation request, the
      actual monitoring activity, and the enforcement and notification path for non-compliance.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_MonitoringConsidered_Art41"
                     name="Monitoring under an approved code is considered">
      <bpmn:outgoing>Flow_Start_To_GatewayPublicAuthority_Art41</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_PublicAuthority_Art41"
                           name="Is the monitored controller or processor a public authority or body?">
      <bpmn:incoming>Flow_Start_To_GatewayPublicAuthority_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayPublicAuthority_To_EndNotApplicable_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayPublicAuthority_To_DemonstrateExpertise_Art41</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NotApplicable_Art41"
                   name="Article 41 monitoring-body regime does not apply">
      <bpmn:incoming>Flow_GatewayPublicAuthority_To_EndNotApplicable_Art41</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_DemonstrateExpertise_Art41"
               name="Demonstrate expertise in the code subject matter">
      <bpmn:incoming>Flow_GatewayPublicAuthority_To_DemonstrateExpertise_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_DemonstrateExpertise_To_DemonstrateNoConflict_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DemonstrateNoConflict_Art41"
               name="Demonstrate the absence of conflicts of interest">
      <bpmn:incoming>Flow_DemonstrateExpertise_To_DemonstrateNoConflict_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_DemonstrateNoConflict_To_SetupSplit_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_SetupSplit_Art41">
      <bpmn:incoming>Flow_DemonstrateNoConflict_To_SetupSplit_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_SetupSplit_To_ControllerMonitoring_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_SetupSplit_To_ProcessorMonitoring_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_SetupSplit_To_ComplaintHandling_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_SetupSplit_To_PublishProcedures_Art41</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_SetupControllerMonitoring_Art41"
               name="Set up procedures to monitor controllers' compliance with the code">
      <bpmn:incoming>Flow_SetupSplit_To_ControllerMonitoring_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_ControllerMonitoring_To_SetupJoin_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetupProcessorMonitoring_Art41"
               name="Set up procedures to monitor processors' compliance with the code">
      <bpmn:incoming>Flow_SetupSplit_To_ProcessorMonitoring_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_ProcessorMonitoring_To_SetupJoin_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetupComplaintHandling_Art41"
               name="Set up procedures to receive and handle complaints">
      <bpmn:incoming>Flow_SetupSplit_To_ComplaintHandling_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_ComplaintHandling_To_SetupJoin_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PublishProcedures_Art41"
               name="Publish the monitoring and complaint-handling procedures">
      <bpmn:incoming>Flow_SetupSplit_To_PublishProcedures_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_PublishProcedures_To_SetupJoin_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_SetupJoin_Art41">
      <bpmn:incoming>Flow_ControllerMonitoring_To_SetupJoin_Art41</bpmn:incoming>
      <bpmn:incoming>Flow_ProcessorMonitoring_To_SetupJoin_Art41</bpmn:incoming>
      <bpmn:incoming>Flow_ComplaintHandling_To_SetupJoin_Art41</bpmn:incoming>
      <bpmn:incoming>Flow_PublishProcedures_To_SetupJoin_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_SetupJoin_To_SubmitAccreditation_Art41</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:sendTask id="SendTask_SubmitAccreditationRequest_Art41"
                   name="Submit the accreditation request to the supervisory authority">
      <bpmn:incoming>Flow_SetupJoin_To_SubmitAccreditation_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_SubmitAccreditation_To_ReceiveDecision_Art41</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAccreditationDecision_Art41"
                      name="Receive the accreditation decision">
      <bpmn:incoming>Flow_SubmitAccreditation_To_ReceiveDecision_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveDecision_To_GatewayAccredited_Art41</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_Accredited_Art41"
                           name="Was the body accredited?">
      <bpmn:incoming>Flow_ReceiveDecision_To_GatewayAccredited_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAccredited_To_EndNotAccredited_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAccredited_To_MonitorAndHandleComplaints_Art41</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NotAccredited_Art41"
                   name="Body not accredited to monitor the code">
      <bpmn:incoming>Flow_GatewayAccredited_To_EndNotAccredited_Art41</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_MonitorAndHandleComplaints_Art41"
               name="Monitor compliance with the code and handle complaints">
      <bpmn:incoming>Flow_GatewayAccredited_To_MonitorAndHandleComplaints_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_MonitorAndHandleComplaints_To_GatewayNonCompliance_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_NonCompliance_Art41"
                           name="Was non-compliance with the code identified?">
      <bpmn:incoming>Flow_MonitorAndHandleComplaints_To_GatewayNonCompliance_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayNonCompliance_To_EndCompliant_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayNonCompliance_To_TakeAction_Art41</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Compliant_Art41"
                   name="Monitoring continues without enforcement action">
      <bpmn:incoming>Flow_GatewayNonCompliance_To_EndCompliant_Art41</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_TakeAction_Art41"
               name="Take action to address the non-compliance">
      <bpmn:incoming>Flow_GatewayNonCompliance_To_TakeAction_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TakeAction_To_GatewaySuspension_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_SuspensionRequired_Art41"
                           name="Is suspension or exclusion from the code required?">
      <bpmn:incoming>Flow_TakeAction_To_GatewaySuspension_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySuspension_To_SuspendOrExclude_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySuspension_To_InformAuthority_Art41</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_SuspendOrExclude_Art41"
                   name="Suspend or exclude the controller or processor from the code">
      <bpmn:incoming>Flow_GatewaySuspension_To_SuspendOrExclude_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_SuspendOrExclude_To_InformAuthority_Art41</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_InformAuthority_Art41"
                   name="Communicate the non-compliance and the measures taken to the supervisory authority">
      <bpmn:incoming>Flow_GatewaySuspension_To_InformAuthority_Art41</bpmn:incoming>
      <bpmn:incoming>Flow_SuspendOrExclude_To_InformAuthority_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_InformAuthority_To_EndInformed_Art41</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_AuthorityInformed_Art41"
                   name="Non-compliance and measures communicated">
      <bpmn:incoming>Flow_InformAuthority_To_EndInformed_Art41</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_GatewayPublicAuthority_Art41"
                       sourceRef="StartEvent_MonitoringConsidered_Art41"
                       targetRef="Gateway_PublicAuthority_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicAuthority_To_EndNotApplicable_Art41"
                       name="Yes"
                       sourceRef="Gateway_PublicAuthority_Art41"
                       targetRef="EndEvent_NotApplicable_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicAuthority_To_DemonstrateExpertise_Art41"
                       name="No"
                       sourceRef="Gateway_PublicAuthority_Art41"
                       targetRef="Task_DemonstrateExpertise_Art41" />
    <bpmn:sequenceFlow id="Flow_DemonstrateExpertise_To_DemonstrateNoConflict_Art41"
                       sourceRef="Task_DemonstrateExpertise_Art41"
                       targetRef="Task_DemonstrateNoConflict_Art41" />
    <bpmn:sequenceFlow id="Flow_DemonstrateNoConflict_To_SetupSplit_Art41"
                       sourceRef="Task_DemonstrateNoConflict_Art41"
                       targetRef="Gateway_SetupSplit_Art41" />
    <bpmn:sequenceFlow id="Flow_SetupSplit_To_ControllerMonitoring_Art41"
                       sourceRef="Gateway_SetupSplit_Art41"
                       targetRef="Task_SetupControllerMonitoring_Art41" />
    <bpmn:sequenceFlow id="Flow_SetupSplit_To_ProcessorMonitoring_Art41"
                       sourceRef="Gateway_SetupSplit_Art41"
                       targetRef="Task_SetupProcessorMonitoring_Art41" />
    <bpmn:sequenceFlow id="Flow_SetupSplit_To_ComplaintHandling_Art41"
                       sourceRef="Gateway_SetupSplit_Art41"
                       targetRef="Task_SetupComplaintHandling_Art41" />
    <bpmn:sequenceFlow id="Flow_SetupSplit_To_PublishProcedures_Art41"
                       sourceRef="Gateway_SetupSplit_Art41"
                       targetRef="Task_PublishProcedures_Art41" />
    <bpmn:sequenceFlow id="Flow_ControllerMonitoring_To_SetupJoin_Art41"
                       sourceRef="Task_SetupControllerMonitoring_Art41"
                       targetRef="Gateway_SetupJoin_Art41" />
    <bpmn:sequenceFlow id="Flow_ProcessorMonitoring_To_SetupJoin_Art41"
                       sourceRef="Task_SetupProcessorMonitoring_Art41"
                       targetRef="Gateway_SetupJoin_Art41" />
    <bpmn:sequenceFlow id="Flow_ComplaintHandling_To_SetupJoin_Art41"
                       sourceRef="Task_SetupComplaintHandling_Art41"
                       targetRef="Gateway_SetupJoin_Art41" />
    <bpmn:sequenceFlow id="Flow_PublishProcedures_To_SetupJoin_Art41"
                       sourceRef="Task_PublishProcedures_Art41"
                       targetRef="Gateway_SetupJoin_Art41" />
    <bpmn:sequenceFlow id="Flow_SetupJoin_To_SubmitAccreditation_Art41"
                       sourceRef="Gateway_SetupJoin_Art41"
                       targetRef="SendTask_SubmitAccreditationRequest_Art41" />
    <bpmn:sequenceFlow id="Flow_SubmitAccreditation_To_ReceiveDecision_Art41"
                       sourceRef="SendTask_SubmitAccreditationRequest_Art41"
                       targetRef="ReceiveTask_ReceiveAccreditationDecision_Art41" />
    <bpmn:sequenceFlow id="Flow_ReceiveDecision_To_GatewayAccredited_Art41"
                       sourceRef="ReceiveTask_ReceiveAccreditationDecision_Art41"
                       targetRef="Gateway_Accredited_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayAccredited_To_EndNotAccredited_Art41"
                       name="No"
                       sourceRef="Gateway_Accredited_Art41"
                       targetRef="EndEvent_NotAccredited_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayAccredited_To_MonitorAndHandleComplaints_Art41"
                       name="Yes"
                       sourceRef="Gateway_Accredited_Art41"
                       targetRef="Task_MonitorAndHandleComplaints_Art41" />
    <bpmn:sequenceFlow id="Flow_MonitorAndHandleComplaints_To_GatewayNonCompliance_Art41"
                       sourceRef="Task_MonitorAndHandleComplaints_Art41"
                       targetRef="Gateway_NonCompliance_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayNonCompliance_To_EndCompliant_Art41"
                       name="No"
                       sourceRef="Gateway_NonCompliance_Art41"
                       targetRef="EndEvent_Compliant_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayNonCompliance_To_TakeAction_Art41"
                       name="Yes"
                       sourceRef="Gateway_NonCompliance_Art41"
                       targetRef="Task_TakeAction_Art41" />
    <bpmn:sequenceFlow id="Flow_TakeAction_To_GatewaySuspension_Art41"
                       sourceRef="Task_TakeAction_Art41"
                       targetRef="Gateway_SuspensionRequired_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewaySuspension_To_SuspendOrExclude_Art41"
                       name="Yes"
                       sourceRef="Gateway_SuspensionRequired_Art41"
                       targetRef="SendTask_SuspendOrExclude_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewaySuspension_To_InformAuthority_Art41"
                       name="No"
                       sourceRef="Gateway_SuspensionRequired_Art41"
                       targetRef="SendTask_InformAuthority_Art41" />
    <bpmn:sequenceFlow id="Flow_SuspendOrExclude_To_InformAuthority_Art41"
                       sourceRef="SendTask_SuspendOrExclude_Art41"
                       targetRef="SendTask_InformAuthority_Art41" />
    <bpmn:sequenceFlow id="Flow_InformAuthority_To_EndInformed_Art41"
                       sourceRef="SendTask_InformAuthority_Art41"
                       targetRef="EndEvent_AuthorityInformed_Art41" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art41_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art41_Reviewed"
                      bpmnElement="Collaboration_Art41_Reviewed">
      <bpmndi:BPMNShape id="Participant_MonitoringBody_Art41_di"
                        bpmnElement="Participant_MonitoringBody_Art41"
                        isHorizontal="true">
        <dc:Bounds x="60" y="40" width="4800" height="560" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_ControllerProcessor_Art41_di"
                        bpmnElement="Participant_ControllerProcessor_Art41"
                        isHorizontal="true">
        <dc:Bounds x="60" y="660" width="4800" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art41_di"
                        bpmnElement="Participant_DataSubject_Art41"
                        isHorizontal="true">
        <dc:Bounds x="60" y="820" width="4800" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_SupervisoryAuthority_Art41_di"
                        bpmnElement="Participant_SupervisoryAuthority_Art41"
                        isHorizontal="true">
        <dc:Bounds x="60" y="980" width="4800" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_MonitoringConsidered_Art41_di"
                        bpmnElement="StartEvent_MonitoringConsidered_Art41">
        <dc:Bounds x="140" y="302" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PublicAuthority_Art41_di"
                        bpmnElement="Gateway_PublicAuthority_Art41"
                        isMarkerVisible="true">
        <dc:Bounds x="330" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NotApplicable_Art41_di"
                        bpmnElement="EndEvent_NotApplicable_Art41">
        <dc:Bounds x="470" y="142" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DemonstrateExpertise_Art41_di"
                        bpmnElement="Task_DemonstrateExpertise_Art41">
        <dc:Bounds x="430" y="280" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DemonstrateNoConflict_Art41_di"
                        bpmnElement="Task_DemonstrateNoConflict_Art41">
        <dc:Bounds x="700" y="280" width="230" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SetupSplit_Art41_di"
                        bpmnElement="Gateway_SetupSplit_Art41"
                        isMarkerVisible="true">
        <dc:Bounds x="990" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetupControllerMonitoring_Art41_di"
                        bpmnElement="Task_SetupControllerMonitoring_Art41">
        <dc:Bounds x="1120" y="90" width="260" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetupProcessorMonitoring_Art41_di"
                        bpmnElement="Task_SetupProcessorMonitoring_Art41">
        <dc:Bounds x="1420" y="90" width="260" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetupComplaintHandling_Art41_di"
                        bpmnElement="Task_SetupComplaintHandling_Art41">
        <dc:Bounds x="1120" y="390" width="260" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PublishProcedures_Art41_di"
                        bpmnElement="Task_PublishProcedures_Art41">
        <dc:Bounds x="1420" y="390" width="260" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SetupJoin_Art41_di"
                        bpmnElement="Gateway_SetupJoin_Art41"
                        isMarkerVisible="true">
        <dc:Bounds x="1760" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_SubmitAccreditationRequest_Art41_di"
                        bpmnElement="SendTask_SubmitAccreditationRequest_Art41">
        <dc:Bounds x="1890" y="280" width="240" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveAccreditationDecision_Art41_di"
                        bpmnElement="ReceiveTask_ReceiveAccreditationDecision_Art41">
        <dc:Bounds x="2190" y="280" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Accredited_Art41_di"
                        bpmnElement="Gateway_Accredited_Art41"
                        isMarkerVisible="true">
        <dc:Bounds x="2480" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NotAccredited_Art41_di"
                        bpmnElement="EndEvent_NotAccredited_Art41">
        <dc:Bounds x="2620" y="142" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_MonitorAndHandleComplaints_Art41_di"
                        bpmnElement="Task_MonitorAndHandleComplaints_Art41">
        <dc:Bounds x="2620" y="280" width="260" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_NonCompliance_Art41_di"
                        bpmnElement="Gateway_NonCompliance_Art41"
                        isMarkerVisible="true">
        <dc:Bounds x="2940" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Compliant_Art41_di"
                        bpmnElement="EndEvent_Compliant_Art41">
        <dc:Bounds x="3090" y="142" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_TakeAction_Art41_di"
                        bpmnElement="Task_TakeAction_Art41">
        <dc:Bounds x="3090" y="280" width="230" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SuspensionRequired_Art41_di"
                        bpmnElement="Gateway_SuspensionRequired_Art41"
                        isMarkerVisible="true">
        <dc:Bounds x="3380" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_SuspendOrExclude_Art41_di"
                        bpmnElement="SendTask_SuspendOrExclude_Art41">
        <dc:Bounds x="3530" y="120" width="240" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_InformAuthority_Art41_di"
                        bpmnElement="SendTask_InformAuthority_Art41">
        <dc:Bounds x="3530" y="280" width="260" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_AuthorityInformed_Art41_di"
                        bpmnElement="EndEvent_AuthorityInformed_Art41">
        <dc:Bounds x="3850" y="302" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_GatewayPublicAuthority_Art41_di" bpmnElement="Flow_Start_To_GatewayPublicAuthority_Art41">
        <di:waypoint x="176" y="320" />
        <di:waypoint x="330" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPublicAuthority_To_EndNotApplicable_Art41_di" bpmnElement="Flow_GatewayPublicAuthority_To_EndNotApplicable_Art41">
        <di:waypoint x="355" y="295" />
        <di:waypoint x="355" y="160" />
        <di:waypoint x="470" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPublicAuthority_To_DemonstrateExpertise_Art41_di" bpmnElement="Flow_GatewayPublicAuthority_To_DemonstrateExpertise_Art41">
        <di:waypoint x="380" y="320" />
        <di:waypoint x="430" y="320" />
      </bpmndi:BPMNEdge>
