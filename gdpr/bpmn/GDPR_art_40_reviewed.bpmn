<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Art40_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art40_Reviewed">
    <bpmn:participant id="Participant_Association_Art40"
                      name="Association or Other Body"
                      processRef="Process_Association_Art40" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art40"
                      name="Supervisory Authority"
                      processRef="Process_SupervisoryAuthority_Art40" />

    <bpmn:messageFlow id="MessageFlow_SubmitDraft_Art40"
                      sourceRef="SendTask_SubmitDraft_Art40"
                      targetRef="ReceiveTask_ReceiveDraft_Art40" />
    <bpmn:messageFlow id="MessageFlow_RejectionDecision_Art40"
                      sourceRef="SendTask_IssueRejection_Art40"
                      targetRef="ReceiveTask_ReceiveAuthorityDecision_Art40" />
    <bpmn:messageFlow id="MessageFlow_ApprovalDecision_Art40"
                      sourceRef="SendTask_NotifyApproval_Art40"
                      targetRef="ReceiveTask_ReceiveAuthorityDecision_Art40" />
    <bpmn:messageFlow id="MessageFlow_CrossBorderDecision_Art40"
                      sourceRef="SendTask_NotifyCrossBorderPath_Art40"
                      targetRef="ReceiveTask_ReceiveAuthorityDecision_Art40" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Association_Art40"
                name="Preparing and submitting a code of conduct"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 40 based on DAPRECO LegalRuleML statements217-230.
      The model captures the preparation or amendment of a code of conduct, the legally relevant
      content areas listed in the article, the inclusion of monitoring measures, submission to the
      competent supervisory authority, and the approval or revision path.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_NeedCode_Art40"
                     name="Need to improve GDPR application through a code of conduct">
      <bpmn:outgoing>Flow_Start_To_Draft_Art40</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_DraftCode_Art40"
               name="Draft, amend, or extend the code of conduct">
      <bpmn:incoming>Flow_Start_To_Draft_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_ReviseDraft_To_Draft_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_Draft_To_ContentSplit_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_ContentSplit_Art40">
      <bpmn:incoming>Flow_Draft_To_ContentSplit_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ContentSplit_To_FairTransparent_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_ContentSplit_To_LegitimateInterests_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_ContentSplit_To_CollectData_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_ContentSplit_To_Pseudonymisation_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_ContentSplit_To_PublicInformation_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_ContentSplit_To_ExerciseRights_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_ContentSplit_To_ChildrenConsent_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_ContentSplit_To_ControllerMeasures_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_ContentSplit_To_BreachProcedures_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_ContentSplit_To_Transfers_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_ContentSplit_To_DisputeResolution_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_ContentSplit_To_MonitoringMeasures_Art40</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_FairTransparent_Art40"
               name="Define fair and transparent processing practices">
      <bpmn:incoming>Flow_ContentSplit_To_FairTransparent_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_FairTransparent_To_ContentJoin_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_LegitimateInterests_Art40"
               name="Define the handling of legitimate interests in specific contexts">
      <bpmn:incoming>Flow_ContentSplit_To_LegitimateInterests_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_LegitimateInterests_To_ContentJoin_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_CollectData_Art40"
               name="Define rules for collecting personal data">
      <bpmn:incoming>Flow_ContentSplit_To_CollectData_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_CollectData_To_ContentJoin_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Pseudonymisation_Art40"
               name="Define pseudonymisation safeguards">
      <bpmn:incoming>Flow_ContentSplit_To_Pseudonymisation_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_Pseudonymisation_To_ContentJoin_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PublicInformation_Art40"
               name="Define information duties towards the public and data subjects">
      <bpmn:incoming>Flow_ContentSplit_To_PublicInformation_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_PublicInformation_To_ContentJoin_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ExerciseRights_Art40"
               name="Define how data subject rights are exercised">
      <bpmn:incoming>Flow_ContentSplit_To_ExerciseRights_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ExerciseRights_To_ContentJoin_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ChildrenConsent_Art40"
               name="Define child-protection information and consent mechanisms">
      <bpmn:incoming>Flow_ContentSplit_To_ChildrenConsent_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ChildrenConsent_To_ContentJoin_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ControllerMeasures_Art40"
               name="Define controller, privacy-by-design, and security measures">
      <bpmn:incoming>Flow_ContentSplit_To_ControllerMeasures_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ControllerMeasures_To_ContentJoin_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_BreachProcedures_Art40"
               name="Define personal data breach notification and communication procedures">
      <bpmn:incoming>Flow_ContentSplit_To_BreachProcedures_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_BreachProcedures_To_ContentJoin_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Transfers_Art40"
               name="Define safeguards for transfers to third countries or international organisations">
      <bpmn:incoming>Flow_ContentSplit_To_Transfers_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_Transfers_To_ContentJoin_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DisputeResolution_Art40"
               name="Define out-of-court and dispute-resolution procedures">
      <bpmn:incoming>Flow_ContentSplit_To_DisputeResolution_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_DisputeResolution_To_ContentJoin_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_MonitoringMeasures_Art40"
               name="Include measures that enable an accredited body to monitor compliance with the code">
      <bpmn:incoming>Flow_ContentSplit_To_MonitoringMeasures_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_MonitoringMeasures_To_ContentJoin_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_ContentJoin_Art40">
      <bpmn:incoming>Flow_FairTransparent_To_ContentJoin_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_LegitimateInterests_To_ContentJoin_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_CollectData_To_ContentJoin_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_Pseudonymisation_To_ContentJoin_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_PublicInformation_To_ContentJoin_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_ExerciseRights_To_ContentJoin_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_ChildrenConsent_To_ContentJoin_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_ControllerMeasures_To_ContentJoin_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_BreachProcedures_To_ContentJoin_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_Transfers_To_ContentJoin_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_DisputeResolution_To_ContentJoin_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_MonitoringMeasures_To_ContentJoin_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ContentJoin_To_GatewayRepresent_Art40</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:exclusiveGateway id="Gateway_RepresentCategories_Art40"
                           name="Does the body represent categories of controllers or processors?">
      <bpmn:incoming>Flow_ContentJoin_To_GatewayRepresent_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRepresent_To_EndCannotSubmit_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRepresent_To_SubmitDraft_Art40</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_CannotSubmit_Art40"
                   name="Draft cannot be submitted under Article 40(3)">
      <bpmn:incoming>Flow_GatewayRepresent_To_EndCannotSubmit_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_SubmitDraft_Art40"
                   name="Submit the draft, amendment, or extension to the competent supervisory authority">
      <bpmn:incoming>Flow_GatewayRepresent_To_SubmitDraft_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_SubmitDraft_To_ReceiveDecision_Art40</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAuthorityDecision_Art40"
                      name="Receive the supervisory authority decision">
      <bpmn:incoming>Flow_SubmitDraft_To_ReceiveDecision_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveDecision_To_GatewayApproved_Art40</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_Approved_Art40"
                           name="Was the draft approved?">
      <bpmn:incoming>Flow_ReceiveDecision_To_GatewayApproved_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayApproved_To_ReviseDraft_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayApproved_To_EndApproved_Art40</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ReviseDraft_Art40"
               name="Revise the draft code based on the authority feedback">
      <bpmn:incoming>Flow_GatewayApproved_To_ReviseDraft_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviseDraft_To_Draft_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_ApprovedCodeAvailable_Art40"
                   name="Approved code is available">
      <bpmn:incoming>Flow_GatewayApproved_To_EndApproved_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_Draft_Art40"
                       sourceRef="StartEvent_NeedCode_Art40"
                       targetRef="Task_DraftCode_Art40" />
    <bpmn:sequenceFlow id="Flow_Draft_To_ContentSplit_Art40"
                       sourceRef="Task_DraftCode_Art40"
                       targetRef="Gateway_ContentSplit_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentSplit_To_FairTransparent_Art40"
                       sourceRef="Gateway_ContentSplit_Art40"
                       targetRef="Task_FairTransparent_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentSplit_To_LegitimateInterests_Art40"
                       sourceRef="Gateway_ContentSplit_Art40"
                       targetRef="Task_LegitimateInterests_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentSplit_To_CollectData_Art40"
                       sourceRef="Gateway_ContentSplit_Art40"
                       targetRef="Task_CollectData_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentSplit_To_Pseudonymisation_Art40"
                       sourceRef="Gateway_ContentSplit_Art40"
                       targetRef="Task_Pseudonymisation_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentSplit_To_PublicInformation_Art40"
                       sourceRef="Gateway_ContentSplit_Art40"
                       targetRef="Task_PublicInformation_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentSplit_To_ExerciseRights_Art40"
                       sourceRef="Gateway_ContentSplit_Art40"
                       targetRef="Task_ExerciseRights_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentSplit_To_ChildrenConsent_Art40"
                       sourceRef="Gateway_ContentSplit_Art40"
                       targetRef="Task_ChildrenConsent_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentSplit_To_ControllerMeasures_Art40"
                       sourceRef="Gateway_ContentSplit_Art40"
                       targetRef="Task_ControllerMeasures_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentSplit_To_BreachProcedures_Art40"
                       sourceRef="Gateway_ContentSplit_Art40"
                       targetRef="Task_BreachProcedures_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentSplit_To_Transfers_Art40"
                       sourceRef="Gateway_ContentSplit_Art40"
                       targetRef="Task_Transfers_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentSplit_To_DisputeResolution_Art40"
                       sourceRef="Gateway_ContentSplit_Art40"
                       targetRef="Task_DisputeResolution_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentSplit_To_MonitoringMeasures_Art40"
                       sourceRef="Gateway_ContentSplit_Art40"
                       targetRef="Task_MonitoringMeasures_Art40" />
    <bpmn:sequenceFlow id="Flow_FairTransparent_To_ContentJoin_Art40"
                       sourceRef="Task_FairTransparent_Art40"
                       targetRef="Gateway_ContentJoin_Art40" />
    <bpmn:sequenceFlow id="Flow_LegitimateInterests_To_ContentJoin_Art40"
                       sourceRef="Task_LegitimateInterests_Art40"
                       targetRef="Gateway_ContentJoin_Art40" />
    <bpmn:sequenceFlow id="Flow_CollectData_To_ContentJoin_Art40"
                       sourceRef="Task_CollectData_Art40"
                       targetRef="Gateway_ContentJoin_Art40" />
    <bpmn:sequenceFlow id="Flow_Pseudonymisation_To_ContentJoin_Art40"
                       sourceRef="Task_Pseudonymisation_Art40"
                       targetRef="Gateway_ContentJoin_Art40" />
    <bpmn:sequenceFlow id="Flow_PublicInformation_To_ContentJoin_Art40"
                       sourceRef="Task_PublicInformation_Art40"
                       targetRef="Gateway_ContentJoin_Art40" />
    <bpmn:sequenceFlow id="Flow_ExerciseRights_To_ContentJoin_Art40"
                       sourceRef="Task_ExerciseRights_Art40"
                       targetRef="Gateway_ContentJoin_Art40" />
    <bpmn:sequenceFlow id="Flow_ChildrenConsent_To_ContentJoin_Art40"
                       sourceRef="Task_ChildrenConsent_Art40"
                       targetRef="Gateway_ContentJoin_Art40" />
    <bpmn:sequenceFlow id="Flow_ControllerMeasures_To_ContentJoin_Art40"
                       sourceRef="Task_ControllerMeasures_Art40"
                       targetRef="Gateway_ContentJoin_Art40" />
    <bpmn:sequenceFlow id="Flow_BreachProcedures_To_ContentJoin_Art40"
                       sourceRef="Task_BreachProcedures_Art40"
                       targetRef="Gateway_ContentJoin_Art40" />
    <bpmn:sequenceFlow id="Flow_Transfers_To_ContentJoin_Art40"
                       sourceRef="Task_Transfers_Art40"
                       targetRef="Gateway_ContentJoin_Art40" />
    <bpmn:sequenceFlow id="Flow_DisputeResolution_To_ContentJoin_Art40"
                       sourceRef="Task_DisputeResolution_Art40"
                       targetRef="Gateway_ContentJoin_Art40" />
    <bpmn:sequenceFlow id="Flow_MonitoringMeasures_To_ContentJoin_Art40"
                       sourceRef="Task_MonitoringMeasures_Art40"
                       targetRef="Gateway_ContentJoin_Art40" />
    <bpmn:sequenceFlow id="Flow_ContentJoin_To_GatewayRepresent_Art40"
                       sourceRef="Gateway_ContentJoin_Art40"
                       targetRef="Gateway_RepresentCategories_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayRepresent_To_EndCannotSubmit_Art40"
                       name="No"
                       sourceRef="Gateway_RepresentCategories_Art40"
                       targetRef="EndEvent_CannotSubmit_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayRepresent_To_SubmitDraft_Art40"
                       name="Yes"
                       sourceRef="Gateway_RepresentCategories_Art40"
                       targetRef="SendTask_SubmitDraft_Art40" />
    <bpmn:sequenceFlow id="Flow_SubmitDraft_To_ReceiveDecision_Art40"
                       sourceRef="SendTask_SubmitDraft_Art40"
                       targetRef="ReceiveTask_ReceiveAuthorityDecision_Art40" />
    <bpmn:sequenceFlow id="Flow_ReceiveDecision_To_GatewayApproved_Art40"
                       sourceRef="ReceiveTask_ReceiveAuthorityDecision_Art40"
                       targetRef="Gateway_Approved_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayApproved_To_ReviseDraft_Art40"
                       name="No"
                       sourceRef="Gateway_Approved_Art40"
                       targetRef="Task_ReviseDraft_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayApproved_To_EndApproved_Art40"
                       name="Yes"
                       sourceRef="Gateway_Approved_Art40"
                       targetRef="EndEvent_ApprovedCodeAvailable_Art40" />
    <bpmn:sequenceFlow id="Flow_ReviseDraft_To_Draft_Art40"
                       sourceRef="Task_ReviseDraft_Art40"
                       targetRef="Task_DraftCode_Art40" />
  </bpmn:process>

  <bpmn:process id="Process_SupervisoryAuthority_Art40"
                name="Reviewing and publishing the code of conduct"
                isExecutable="false">
    <bpmn:documentation>
      The supervisory-authority process reflects the review of the submitted draft, the decision on
      compliance and safeguards, the approval path, and the register-and-publish step where the
      approved code does not relate to processing activities in several Member States.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_ReviewTriggered_Art40"
                     name="Authority review is triggered">
      <bpmn:outgoing>Flow_AuthorityStart_To_ReceiveDraft_Art40</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveDraft_Art40"
                      name="Receive the draft, amendment, or extension">
      <bpmn:incoming>Flow_AuthorityStart_To_ReceiveDraft_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveDraft_To_Assess_Art40</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_AssessDraftCompliance_Art40"
               name="Assess whether the draft complies with GDPR and provides sufficient safeguards">
      <bpmn:incoming>Flow_ReceiveDraft_To_Assess_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_Assess_To_GatewayCompliance_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Compliance_Art40"
                           name="Does the draft comply and provide sufficient safeguards?">
      <bpmn:incoming>Flow_Assess_To_GatewayCompliance_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayCompliance_To_IssueRejection_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCompliance_To_ApproveDraft_Art40</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_IssueRejection_Art40"
                   name="Issue a negative opinion or request revisions">
      <bpmn:incoming>Flow_GatewayCompliance_To_IssueRejection_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_IssueRejection_To_EndNotApproved_Art40</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_NotApproved_Art40"
                   name="Draft not approved">
      <bpmn:incoming>Flow_IssueRejection_To_EndNotApproved_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_ApproveDraft_Art40"
               name="Approve the draft, amendment, or extension">
      <bpmn:incoming>Flow_GatewayCompliance_To_ApproveDraft_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ApproveDraft_To_GatewaySeveralStates_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_SeveralMemberStates_Art40"
                           name="Does the approved code relate to several Member States?">
      <bpmn:incoming>Flow_ApproveDraft_To_GatewaySeveralStates_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySeveralStates_To_NotifyCrossBorder_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySeveralStates_To_RegisterPublish_Art40</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_RegisterAndPublishCode_Art40"
               name="Register and publish the approved code">
      <bpmn:incoming>Flow_GatewaySeveralStates_To_RegisterPublish_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_RegisterPublish_To_NotifyApproval_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_NotifyApproval_Art40"
                   name="Notify the body that the draft was approved">
      <bpmn:incoming>Flow_RegisterPublish_To_NotifyApproval_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyApproval_To_EndApprovalCompleted_Art40</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_ApprovalCompleted_Art40"
                   name="Approval, registration, and publication completed">
      <bpmn:incoming>Flow_NotifyApproval_To_EndApprovalCompleted_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_NotifyCrossBorderPath_Art40"
                   name="Notify the body that the approved draft requires the multi-state path">
      <bpmn:incoming>Flow_GatewaySeveralStates_To_NotifyCrossBorder_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyCrossBorder_To_EndCrossBorder_Art40</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_CrossBorderPath_Art40"
                   name="Cross-border follow-up continues outside this article slice">
      <bpmn:incoming>Flow_NotifyCrossBorder_To_EndCrossBorder_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_AuthorityStart_To_ReceiveDraft_Art40"
                       sourceRef="StartEvent_ReviewTriggered_Art40"
                       targetRef="ReceiveTask_ReceiveDraft_Art40" />
    <bpmn:sequenceFlow id="Flow_ReceiveDraft_To_Assess_Art40"
                       sourceRef="ReceiveTask_ReceiveDraft_Art40"
                       targetRef="Task_AssessDraftCompliance_Art40" />
    <bpmn:sequenceFlow id="Flow_Assess_To_GatewayCompliance_Art40"
                       sourceRef="Task_AssessDraftCompliance_Art40"
                       targetRef="Gateway_Compliance_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayCompliance_To_IssueRejection_Art40"
                       name="No"
                       sourceRef="Gateway_Compliance_Art40"
                       targetRef="SendTask_IssueRejection_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayCompliance_To_ApproveDraft_Art40"
                       name="Yes"
                       sourceRef="Gateway_Compliance_Art40"
                       targetRef="Task_ApproveDraft_Art40" />
    <bpmn:sequenceFlow id="Flow_IssueRejection_To_EndNotApproved_Art40"
                       sourceRef="SendTask_IssueRejection_Art40"
                       targetRef="EndEvent_NotApproved_Art40" />
    <bpmn:sequenceFlow id="Flow_ApproveDraft_To_GatewaySeveralStates_Art40"
                       sourceRef="Task_ApproveDraft_Art40"
                       targetRef="Gateway_SeveralMemberStates_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySeveralStates_To_NotifyCrossBorder_Art40"
                       name="Yes"
                       sourceRef="Gateway_SeveralMemberStates_Art40"
                       targetRef="SendTask_NotifyCrossBorderPath_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySeveralStates_To_RegisterPublish_Art40"
                       name="No"
                       sourceRef="Gateway_SeveralMemberStates_Art40"
                       targetRef="Task_RegisterAndPublishCode_Art40" />
    <bpmn:sequenceFlow id="Flow_RegisterPublish_To_NotifyApproval_Art40"
                       sourceRef="Task_RegisterAndPublishCode_Art40"
                       targetRef="SendTask_NotifyApproval_Art40" />
    <bpmn:sequenceFlow id="Flow_NotifyApproval_To_EndApprovalCompleted_Art40"
