    <bpmn:task id="Task_f627414b" name="Erase Personal Data
(Art. 17 Abs. 2)"><bpmn:incoming>Flow_6b7ca87a</bpmn:incoming><bpmn:dataOutputAssociation id="Assoc_5f0e1f10"><bpmn:targetRef>DataRef_99df8be5</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:task>
