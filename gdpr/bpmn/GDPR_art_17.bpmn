    <bpmn:task id="Task_c65f51cd" name="Erase Personal Data
(Art. 17 Abs. 1 lit. a)"><bpmn:incoming>Flow_638900b1</bpmn:incoming></bpmn:task>
    <bpmn:textAnnotation id="Annotation_ddb392e2"><bpmn:text>No exception under Art. 17 Abs. 3&#10;No exception under Art. 18 Abs. 1, point 3&#10;No exception under Art. 12 Abs. 2&#10;No exception under Art. 11 Abs. 2&#10;Perform without undue delay</bpmn:text></bpmn:textAnnotation>
    <bpmn:association id="Assoc_Annot_79e0e379" sourceRef="Task_c65f51cd" targetRef="Annotation_ddb392e2" />
    <bpmn:sequenceFlow id="Flow_09b8ab9f" sourceRef="Task_c65f51cd" targetRef="Task_2703229c" />
    <bpmn:task id="Task_2703229c" name="Erase Personal Data
(Art. 17 Abs. 1 lit. b)"><bpmn:incoming>Flow_09b8ab9f</bpmn:incoming></bpmn:task>
    <bpmn:textAnnotation id="Annotation_d5a01fbc"><bpmn:text>No exception under Art. 17 Abs. 3&#10;No exception under Art. 12 Abs. 2&#10;No exception under Art. 11 Abs. 2&#10;Perform without undue delay&#10;Applies when: Consent Withdrawn</bpmn:text></bpmn:textAnnotation>
    <bpmn:association id="Assoc_Annot_6412eef4" sourceRef="Task_2703229c" targetRef="Annotation_d5a01fbc" />
    <bpmn:sequenceFlow id="Flow_8f484f00" sourceRef="Task_2703229c" targetRef="Task_4c5949f1" />
    <bpmn:task id="Task_4c5949f1" name="Erase Personal Data
(Art. 17 Abs. 1 lit. c)"><bpmn:incoming>Flow_8f484f00</bpmn:incoming></bpmn:task>
    <bpmn:textAnnotation id="Annotation_bc32e212"><bpmn:text>No exception under Art. 21 Abs. 1&#10;No exception under Art. 17 Abs. 3&#10;No exception under Art. 12 Abs. 2&#10;No exception under Art. 11 Abs. 2&#10;Perform without undue delay&#10;Applies when: Permitted AND Consent Withdrawn AND Legitimate Interest AND High Risk to Individuals</bpmn:text></bpmn:textAnnotation>
    <bpmn:association id="Assoc_Annot_bf031cb6" sourceRef="Task_4c5949f1" targetRef="Annotation_bc32e212" />
    <bpmn:sequenceFlow id="Flow_f98e3b8e" sourceRef="Task_4c5949f1" targetRef="Task_e0d0823a" />
    <bpmn:task id="Task_e0d0823a" name="Erase Personal Data
(Art. 17 Abs. 1 lit. d)"><bpmn:incoming>Flow_f98e3b8e</bpmn:incoming></bpmn:task>
    <bpmn:textAnnotation id="Annotation_b24055c7"><bpmn:text>No exception under Art. 17 Abs. 3&#10;No exception under Art. 18 Abs. 1, point 2&#10;No exception under Art. 12 Abs. 2&#10;No exception under Art. 11 Abs. 2&#10;Perform without undue delay&#10;Applies when: Processing Was Lawful</bpmn:text></bpmn:textAnnotation>
    <bpmn:association id="Assoc_Annot_eabe8b6e" sourceRef="Task_e0d0823a" targetRef="Annotation_b24055c7" />
    <bpmn:sequenceFlow id="Flow_f704caaf" sourceRef="Task_e0d0823a" targetRef="Task_59f15be9" />
    <bpmn:task id="Task_59f15be9" name="Erase Personal Data
(Art. 17 Abs. 1 lit. e)"><bpmn:incoming>Flow_f704caaf</bpmn:incoming></bpmn:task>
    <bpmn:textAnnotation id="Annotation_6d3eaf91"><bpmn:text>No exception under Art. 17 Abs. 3&#10;No exception under Art. 12 Abs. 2&#10;No exception under Art. 11 Abs. 2&#10;Perform without undue delay&#10;Applies when: Obliged</bpmn:text></bpmn:textAnnotation>
    <bpmn:association id="Assoc_Annot_87f0899c" sourceRef="Task_59f15be9" targetRef="Annotation_6d3eaf91" />
    <bpmn:sequenceFlow id="Flow_4154cb0f" sourceRef="Task_59f15be9" targetRef="Task_5c0ca704" />
    <bpmn:task id="Task_5c0ca704" name="Erase Personal Data
(Art. 17 Abs. 1 lit. f)"><bpmn:incoming>Flow_4154cb0f</bpmn:incoming></bpmn:task>
    <bpmn:textAnnotation id="Annotation_b1a3eca0"><bpmn:text>No exception under Art. 17 Abs. 3&#10;No exception under Art. 12 Abs. 2&#10;No exception under Art. 11 Abs. 2&#10;Perform without undue delay&#10;Applies when: Original Consent Given AND Data Subject Gave Consent AND Age at or below minimum consent age</bpmn:text></bpmn:textAnnotation>
    <bpmn:association id="Assoc_Annot_d2212b10" sourceRef="Task_5c0ca704" targetRef="Annotation_b1a3eca0" />
    <bpmn:sequenceFlow id="Flow_31376997" sourceRef="Task_5c0ca704" targetRef="Task_62470a72" />
    <bpmn:sendTask id="Task_62470a72" name="Notify to Controller
(Art. 17 Abs. 2)"><bpmn:incoming>Flow_31376997</bpmn:incoming></bpmn:sendTask>
    <bpmn:textAnnotation id="Annotation_c389affe"><bpmn:text>No exception under Art. 17 Abs. 3&#10;No exception under Art. 12 Abs. 2&#10;No exception under Art. 11 Abs. 2&#10;Use reasonable effort&#10;Applies when: Information Made Public AND Obliged</bpmn:text></bpmn:textAnnotation>
    <bpmn:association id="Assoc_Annot_0f992551" sourceRef="Task_62470a72" targetRef="Annotation_c389affe" />
