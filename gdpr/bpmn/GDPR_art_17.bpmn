    <bpmn:task id="Task_13d6e4be" name="Erase Personal Data
(Art. 17 Abs. 1)"><bpmn:incoming>Flow_98885fa6</bpmn:incoming></bpmn:task>
    <bpmn:textAnnotation id="Annotation_4102c57c"><bpmn:text>Check exception in Art. 17 Abs. 3 lit. a&#10;Check exception in Art. 17 Abs. 3 lit. b&#10;Check exception in Art. 17 Abs. 3 lit. c&#10;Check exception in Art. 17 Abs. 3 lit. d&#10;Check exception in Art. 17 Abs. 3 lit. e&#10;No exception under Art. 17 Abs. 3&#10;No exception under Art. 12 Abs. 2&#10;No exception under Art. 11 Abs. 2&#10;Perform without undue delay</bpmn:text></bpmn:textAnnotation>
    <bpmn:association id="Assoc_Annot_64de63ae" sourceRef="Task_13d6e4be" targetRef="Annotation_4102c57c" />
