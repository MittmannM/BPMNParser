<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art86_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art86_Reviewed">
    <bpmn:participant id="Participant_Authority_Art86"
                      name="Public authority or body"
                      processRef="Process_Authority_Art86" />
    <bpmn:participant id="Participant_Requester_Art86"
                      name="Requester or member of the public" />

    <bpmn:messageFlow id="MessageFlow_RequestAccess_Art86"
                      sourceRef="Participant_Requester_Art86"
                      targetRef="ReceiveTask_ReceiveAccessRequest_Art86" />
    <bpmn:messageFlow id="MessageFlow_DiscloseDocumentData_Art86"
                      sourceRef="SendTask_DisclosePersonalData_Art86"
                      targetRef="Participant_Requester_Art86" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Authority_Art86"
                name="Disclosing personal data in official documents under Article 86"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 86 based on DAPRECO LegalRuleML
      statements274. The XML encodes a permission to provide personal data that are
      part of a held document. The BPMN models the operational path that best matches
      the article text: receive an access request, identify the official document,
      confirm that the holder acts in the public interest, reconcile public access
      with data protection under applicable Union or Member State law, and disclose
      the personal data only where that law allows it. The local XML uses a compressed
      representation of the governing legal basis, so the reconciliation step is made
      explicit here for clarity.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_AssessAccess_Art86"
                     name="Need to assess access to an official document">
      <bpmn:outgoing>Flow_Start_To_ReceiveAccessRequest_Art86</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAccessRequest_Art86"
                      name="Receive a request for access to an official document">
      <bpmn:incoming>Flow_Start_To_ReceiveAccessRequest_Art86</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveAccessRequest_To_IdentifyDocument_Art86</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_IdentifyDocumentAndPersonalData_Art86"
               name="Identify the held official document and the personal data contained in it">
      <bpmn:incoming>Flow_ReceiveAccessRequest_To_IdentifyDocument_Art86</bpmn:incoming>
      <bpmn:outgoing>Flow_IdentifyDocument_To_GatewayPublicInterestHolder_Art86</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_PublicInterestHolder_Art86"
                           name="Is the document held by an authority or body for a task carried out in the public interest?">
      <bpmn:incoming>Flow_IdentifyDocument_To_GatewayPublicInterestHolder_Art86</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayPublicInterestHolder_To_TaskAssessLaw_Art86</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayPublicInterestHolder_To_EndNoArt86Route_Art86</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessApplicableAccessLaw_Art86"
               name="Assess the applicable Union or Member State access law">
      <bpmn:incoming>Flow_GatewayPublicInterestHolder_To_TaskAssessLaw_Art86</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessLaw_To_TaskReconcileAccessAndProtection_Art86</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ReconcileAccessAndProtection_Art86"
               name="Reconcile public access to official documents with the right to data protection">
      <bpmn:incoming>Flow_TaskAssessLaw_To_TaskReconcileAccessAndProtection_Art86</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskReconcileAccessAndProtection_To_GatewayLawAllowsDisclosure_Art86</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_LawAllowsDisclosure_Art86"
                           name="Does the applicable law allow disclosure of the personal data in the document?">
      <bpmn:incoming>Flow_TaskReconcileAccessAndProtection_To_GatewayLawAllowsDisclosure_Art86</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayLawAllowsDisclosure_To_SendTaskDisclose_Art86</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayLawAllowsDisclosure_To_EndNoDisclosure_Art86</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_DisclosePersonalData_Art86"
                   name="Disclose the personal data from the official document">
      <bpmn:incoming>Flow_GatewayLawAllowsDisclosure_To_SendTaskDisclose_Art86</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskDisclose_To_EndDisclosureCompleted_Art86</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_DisclosureCompleted_Art86"
                   name="Article 86 disclosure completed">
      <bpmn:incoming>Flow_SendTaskDisclose_To_EndDisclosureCompleted_Art86</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_NoDisclosure_Art86"
                   name="Disclosure is not permitted under the applicable law">
      <bpmn:incoming>Flow_GatewayLawAllowsDisclosure_To_EndNoDisclosure_Art86</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_NoArt86Route_Art86"
                   name="No Article 86 disclosure route is available">
      <bpmn:incoming>Flow_GatewayPublicInterestHolder_To_EndNoArt86Route_Art86</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_ReceiveAccessRequest_Art86" sourceRef="StartEvent_AssessAccess_Art86" targetRef="ReceiveTask_ReceiveAccessRequest_Art86" />
    <bpmn:sequenceFlow id="Flow_ReceiveAccessRequest_To_IdentifyDocument_Art86" sourceRef="ReceiveTask_ReceiveAccessRequest_Art86" targetRef="Task_IdentifyDocumentAndPersonalData_Art86" />
    <bpmn:sequenceFlow id="Flow_IdentifyDocument_To_GatewayPublicInterestHolder_Art86" sourceRef="Task_IdentifyDocumentAndPersonalData_Art86" targetRef="Gateway_PublicInterestHolder_Art86" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicInterestHolder_To_TaskAssessLaw_Art86" name="Yes" sourceRef="Gateway_PublicInterestHolder_Art86" targetRef="Task_AssessApplicableAccessLaw_Art86" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicInterestHolder_To_EndNoArt86Route_Art86" name="No" sourceRef="Gateway_PublicInterestHolder_Art86" targetRef="EndEvent_NoArt86Route_Art86" />
    <bpmn:sequenceFlow id="Flow_TaskAssessLaw_To_TaskReconcileAccessAndProtection_Art86" sourceRef="Task_AssessApplicableAccessLaw_Art86" targetRef="Task_ReconcileAccessAndProtection_Art86" />
    <bpmn:sequenceFlow id="Flow_TaskReconcileAccessAndProtection_To_GatewayLawAllowsDisclosure_Art86" sourceRef="Task_ReconcileAccessAndProtection_Art86" targetRef="Gateway_LawAllowsDisclosure_Art86" />
    <bpmn:sequenceFlow id="Flow_GatewayLawAllowsDisclosure_To_SendTaskDisclose_Art86" name="Yes" sourceRef="Gateway_LawAllowsDisclosure_Art86" targetRef="SendTask_DisclosePersonalData_Art86" />
    <bpmn:sequenceFlow id="Flow_GatewayLawAllowsDisclosure_To_EndNoDisclosure_Art86" name="No" sourceRef="Gateway_LawAllowsDisclosure_Art86" targetRef="EndEvent_NoDisclosure_Art86" />
    <bpmn:sequenceFlow id="Flow_SendTaskDisclose_To_EndDisclosureCompleted_Art86" sourceRef="SendTask_DisclosePersonalData_Art86" targetRef="EndEvent_DisclosureCompleted_Art86" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art86_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art86_Reviewed"
                      bpmnElement="Collaboration_Art86_Reviewed">
      <bpmndi:BPMNShape id="Participant_Authority_Art86_di" bpmnElement="Participant_Authority_Art86" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="3300" height="560" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Requester_Art86_di" bpmnElement="Participant_Requester_Art86" isHorizontal="true">
        <dc:Bounds x="60" y="660" width="3300" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_AssessAccess_Art86_di" bpmnElement="StartEvent_AssessAccess_Art86">
        <dc:Bounds x="120" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveAccessRequest_Art86_di" bpmnElement="ReceiveTask_ReceiveAccessRequest_Art86">
        <dc:Bounds x="230" y="260" width="320" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IdentifyDocumentAndPersonalData_Art86_di" bpmnElement="Task_IdentifyDocumentAndPersonalData_Art86">
        <dc:Bounds x="650" y="260" width="430" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PublicInterestHolder_Art86_di" bpmnElement="Gateway_PublicInterestHolder_Art86" isMarkerVisible="true">
        <dc:Bounds x="1180" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessApplicableAccessLaw_Art86_di" bpmnElement="Task_AssessApplicableAccessLaw_Art86">
        <dc:Bounds x="1380" y="120" width="360" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReconcileAccessAndProtection_Art86_di" bpmnElement="Task_ReconcileAccessAndProtection_Art86">
        <dc:Bounds x="1860" y="120" width="470" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_LawAllowsDisclosure_Art86_di" bpmnElement="Gateway_LawAllowsDisclosure_Art86" isMarkerVisible="true">
        <dc:Bounds x="2450" y="135" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_DisclosePersonalData_Art86_di" bpmnElement="SendTask_DisclosePersonalData_Art86">
        <dc:Bounds x="2660" y="120" width="320" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_DisclosureCompleted_Art86_di" bpmnElement="EndEvent_DisclosureCompleted_Art86">
        <dc:Bounds x="3080" y="142" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoDisclosure_Art86_di" bpmnElement="EndEvent_NoDisclosure_Art86">
        <dc:Bounds x="2667" y="322" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoArt86Route_Art86_di" bpmnElement="EndEvent_NoArt86Route_Art86">
        <dc:Bounds x="1387" y="432" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_ReceiveAccessRequest_Art86_di" bpmnElement="Flow_Start_To_ReceiveAccessRequest_Art86">
        <di:waypoint x="156" y="300" />
        <di:waypoint x="230" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReceiveAccessRequest_To_IdentifyDocument_Art86_di" bpmnElement="Flow_ReceiveAccessRequest_To_IdentifyDocument_Art86">
        <di:waypoint x="550" y="300" />
        <di:waypoint x="650" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_IdentifyDocument_To_GatewayPublicInterestHolder_Art86_di" bpmnElement="Flow_IdentifyDocument_To_GatewayPublicInterestHolder_Art86">
        <di:waypoint x="1080" y="300" />
        <di:waypoint x="1180" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPublicInterestHolder_To_TaskAssessLaw_Art86_di" bpmnElement="Flow_GatewayPublicInterestHolder_To_TaskAssessLaw_Art86">
        <di:waypoint x="1205" y="275" />
        <di:waypoint x="1205" y="160" />
        <di:waypoint x="1380" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPublicInterestHolder_To_EndNoArt86Route_Art86_di" bpmnElement="Flow_GatewayPublicInterestHolder_To_EndNoArt86Route_Art86">
        <di:waypoint x="1205" y="325" />
        <di:waypoint x="1205" y="450" />
        <di:waypoint x="1387" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskAssessLaw_To_TaskReconcileAccessAndProtection_Art86_di" bpmnElement="Flow_TaskAssessLaw_To_TaskReconcileAccessAndProtection_Art86">
        <di:waypoint x="1740" y="160" />
        <di:waypoint x="1860" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskReconcileAccessAndProtection_To_GatewayLawAllowsDisclosure_Art86_di" bpmnElement="Flow_TaskReconcileAccessAndProtection_To_GatewayLawAllowsDisclosure_Art86">
        <di:waypoint x="2330" y="160" />
        <di:waypoint x="2450" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayLawAllowsDisclosure_To_SendTaskDisclose_Art86_di" bpmnElement="Flow_GatewayLawAllowsDisclosure_To_SendTaskDisclose_Art86">
        <di:waypoint x="2500" y="160" />
        <di:waypoint x="2660" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayLawAllowsDisclosure_To_EndNoDisclosure_Art86_di" bpmnElement="Flow_GatewayLawAllowsDisclosure_To_EndNoDisclosure_Art86">
        <di:waypoint x="2475" y="185" />
        <di:waypoint x="2475" y="340" />
        <di:waypoint x="2667" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SendTaskDisclose_To_EndDisclosureCompleted_Art86_di" bpmnElement="Flow_SendTaskDisclose_To_EndDisclosureCompleted_Art86">
        <di:waypoint x="2980" y="160" />
        <di:waypoint x="3080" y="160" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MessageFlow_RequestAccess_Art86_di" bpmnElement="MessageFlow_RequestAccess_Art86">
        <di:waypoint x="390" y="660" />
        <di:waypoint x="390" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_DiscloseDocumentData_Art86_di" bpmnElement="MessageFlow_DiscloseDocumentData_Art86">
        <di:waypoint x="2820" y="200" />
        <di:waypoint x="2820" y="660" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
