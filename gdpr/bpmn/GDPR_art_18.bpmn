    <bpmn:textAnnotation id="Annotation_d8920d4a"><bpmn:text>No exception under Art. 12 Abs. 2&#10;No exception under Art. 11 Abs. 2&#10;Applies when: LegalClaim</bpmn:text></bpmn:textAnnotation>
