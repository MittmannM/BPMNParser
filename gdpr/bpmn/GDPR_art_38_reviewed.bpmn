<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Defs_Art38_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_Art38_Reviewed">
    <bpmn:participant id="Participant_ControllerProcessor_Art38"
                      name="Controller or Processor"
                      processRef="Process_ControllerProcessor_Art38" />
    <bpmn:participant id="Participant_DPO_Art38"
                      name="Data Protection Officer"
                      processRef="Process_DPO_Art38" />
    <bpmn:participant id="Participant_DataSubject_Art38"
                      name="Data Subject" />

    <bpmn:messageFlow id="MessageFlow_InvolveDPO_Art38"
                      sourceRef="SendTask_InvolveDPO_Art38"
                      targetRef="ReceiveTask_ReceiveIssue_Art38" />
    <bpmn:messageFlow id="MessageFlow_DataSubjectContact_Art38"
                      sourceRef="Participant_DataSubject_Art38"
                      targetRef="ReceiveTask_ReceiveDataSubjectMatter_Art38" />
  </bpmn:collaboration>

  <bpmn:process id="Process_ControllerProcessor_Art38"
                name="Apply Article 38 DPO safeguards"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 38 based on the real English legal
      text in gdpr_articles. The model covers timely and proper DPO involvement in
      all issues relating to personal-data protection, support through resources,
      access, and maintenance of expert knowledge, the no-instruction and no-
      dismissal-or-penalty safeguards, direct reporting to the highest management
      level, data-subject contact enablement, and conflict-of-interest checks for
      any other tasks or duties.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_MaintainDPO_Art38"
                     name="Maintain DPO safeguards">
      <bpmn:outgoing>Flow_Start_To_IdentifyIssue_Art38</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_IdentifyIssue_Art38"
               name="Identify personal-data-protection issue">
      <bpmn:incoming>Flow_Start_To_IdentifyIssue_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskIdentifyIssue_To_SendTaskInvolveDPO_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_InvolveDPO_Art38"
                   name="Involve DPO properly and timely">
      <bpmn:incoming>Flow_TaskIdentifyIssue_To_SendTaskInvolveDPO_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskInvolveDPO_To_TaskProvideResources_Art38</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ProvideResources_Art38"
               name="Provide necessary resources">
      <bpmn:incoming>Flow_SendTaskInvolveDPO_To_TaskProvideResources_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskProvideResources_To_TaskGrantAccess_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_GrantAccess_Art38"
               name="Grant access to data and processing">
      <bpmn:incoming>Flow_TaskProvideResources_To_TaskGrantAccess_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskGrantAccess_To_TaskSupportExpertKnowledge_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SupportExpertKnowledge_Art38"
               name="Support expert knowledge">
      <bpmn:incoming>Flow_TaskGrantAccess_To_TaskSupportExpertKnowledge_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSupportExpertKnowledge_To_GatewayInstruction_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Instruction_Art38"
                           name="Is an instruction on DPO task performance being considered?">
      <bpmn:incoming>Flow_TaskSupportExpertKnowledge_To_GatewayInstruction_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayInstruction_To_TaskWithdrawInstruction_Art38</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayInstruction_To_GatewaySanction_Art38</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_WithdrawInstruction_Art38"
               name="Withdraw instruction">
      <bpmn:incoming>Flow_GatewayInstruction_To_TaskWithdrawInstruction_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskWithdrawInstruction_To_GatewaySanction_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Sanction_Art38"
                           name="Is dismissal or a penalty being considered for DPO tasks?">
      <bpmn:incoming>Flow_GatewayInstruction_To_GatewaySanction_Art38</bpmn:incoming>
      <bpmn:incoming>Flow_TaskWithdrawInstruction_To_GatewaySanction_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySanction_To_TaskStopSanction_Art38</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySanction_To_TaskEnsureReporting_Art38</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_StopSanction_Art38"
               name="Stop dismissal or penalty">
      <bpmn:incoming>Flow_GatewaySanction_To_TaskStopSanction_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskStopSanction_To_TaskEnsureReporting_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EnsureReporting_Art38"
               name="Ensure direct reporting to top management">
      <bpmn:incoming>Flow_GatewaySanction_To_TaskEnsureReporting_Art38</bpmn:incoming>
      <bpmn:incoming>Flow_TaskStopSanction_To_TaskEnsureReporting_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskEnsureReporting_To_TaskEnableContact_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EnableContact_Art38"
               name="Enable data-subject contact">
      <bpmn:incoming>Flow_TaskEnsureReporting_To_TaskEnableContact_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskEnableContact_To_GatewayOtherDuties_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_OtherDuties_Art38"
                           name="Does the DPO perform other tasks or duties?">
      <bpmn:incoming>Flow_TaskEnableContact_To_GatewayOtherDuties_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayOtherDuties_To_TaskAssessConflict_Art38</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayOtherDuties_To_EndCompleted_Art38</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessConflict_Art38"
               name="Assess conflict of interests">
      <bpmn:incoming>Flow_GatewayOtherDuties_To_TaskAssessConflict_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessConflict_To_GatewayConflict_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Conflict_Art38"
                           name="Do the other tasks create a conflict of interests?">
      <bpmn:incoming>Flow_TaskAssessConflict_To_GatewayConflict_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayConflict_To_TaskRemoveConflict_Art38</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayConflict_To_EndCompleted_Art38</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_RemoveConflict_Art38"
               name="Remove or reassign conflicting tasks">
      <bpmn:incoming>Flow_GatewayConflict_To_TaskRemoveConflict_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRemoveConflict_To_EndCompleted_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_Completed_Art38"
                   name="Article 38 safeguards maintained">
      <bpmn:incoming>Flow_GatewayOtherDuties_To_EndCompleted_Art38</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayConflict_To_EndCompleted_Art38</bpmn:incoming>
      <bpmn:incoming>Flow_TaskRemoveConflict_To_EndCompleted_Art38</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_IdentifyIssue_Art38" sourceRef="StartEvent_MaintainDPO_Art38" targetRef="Task_IdentifyIssue_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskIdentifyIssue_To_SendTaskInvolveDPO_Art38" sourceRef="Task_IdentifyIssue_Art38" targetRef="SendTask_InvolveDPO_Art38" />
    <bpmn:sequenceFlow id="Flow_SendTaskInvolveDPO_To_TaskProvideResources_Art38" sourceRef="SendTask_InvolveDPO_Art38" targetRef="Task_ProvideResources_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskProvideResources_To_TaskGrantAccess_Art38" sourceRef="Task_ProvideResources_Art38" targetRef="Task_GrantAccess_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskGrantAccess_To_TaskSupportExpertKnowledge_Art38" sourceRef="Task_GrantAccess_Art38" targetRef="Task_SupportExpertKnowledge_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskSupportExpertKnowledge_To_GatewayInstruction_Art38" sourceRef="Task_SupportExpertKnowledge_Art38" targetRef="Gateway_Instruction_Art38" />
    <bpmn:sequenceFlow id="Flow_GatewayInstruction_To_TaskWithdrawInstruction_Art38" name="Yes" sourceRef="Gateway_Instruction_Art38" targetRef="Task_WithdrawInstruction_Art38" />
    <bpmn:sequenceFlow id="Flow_GatewayInstruction_To_GatewaySanction_Art38" name="No" sourceRef="Gateway_Instruction_Art38" targetRef="Gateway_Sanction_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskWithdrawInstruction_To_GatewaySanction_Art38" sourceRef="Task_WithdrawInstruction_Art38" targetRef="Gateway_Sanction_Art38" />
    <bpmn:sequenceFlow id="Flow_GatewaySanction_To_TaskStopSanction_Art38" name="Yes" sourceRef="Gateway_Sanction_Art38" targetRef="Task_StopSanction_Art38" />
    <bpmn:sequenceFlow id="Flow_GatewaySanction_To_TaskEnsureReporting_Art38" name="No" sourceRef="Gateway_Sanction_Art38" targetRef="Task_EnsureReporting_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskStopSanction_To_TaskEnsureReporting_Art38" sourceRef="Task_StopSanction_Art38" targetRef="Task_EnsureReporting_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskEnsureReporting_To_TaskEnableContact_Art38" sourceRef="Task_EnsureReporting_Art38" targetRef="Task_EnableContact_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskEnableContact_To_GatewayOtherDuties_Art38" sourceRef="Task_EnableContact_Art38" targetRef="Gateway_OtherDuties_Art38" />
    <bpmn:sequenceFlow id="Flow_GatewayOtherDuties_To_TaskAssessConflict_Art38" name="Yes" sourceRef="Gateway_OtherDuties_Art38" targetRef="Task_AssessConflict_Art38" />
    <bpmn:sequenceFlow id="Flow_GatewayOtherDuties_To_EndCompleted_Art38" name="No" sourceRef="Gateway_OtherDuties_Art38" targetRef="EndEvent_Completed_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskAssessConflict_To_GatewayConflict_Art38" sourceRef="Task_AssessConflict_Art38" targetRef="Gateway_Conflict_Art38" />
    <bpmn:sequenceFlow id="Flow_GatewayConflict_To_TaskRemoveConflict_Art38" name="Yes" sourceRef="Gateway_Conflict_Art38" targetRef="Task_RemoveConflict_Art38" />
    <bpmn:sequenceFlow id="Flow_GatewayConflict_To_EndCompleted_Art38" name="No" sourceRef="Gateway_Conflict_Art38" targetRef="EndEvent_Completed_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskRemoveConflict_To_EndCompleted_Art38" sourceRef="Task_RemoveConflict_Art38" targetRef="EndEvent_Completed_Art38" />
  </bpmn:process>

  <bpmn:process id="Process_DPO_Art38"
                name="Handle DPO issue and contact paths"
                isExecutable="false">
    <bpmn:documentation>
      This process captures the DPO-side handling of involvement requests and data-
      subject contacts together with the secrecy or confidentiality duty in Article
      38(5).
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_IssuePath_Art38"
                     name="Issue path available">
      <bpmn:outgoing>Flow_StartIssuePath_To_ReceiveIssue_Art38</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveIssue_Art38"
                      name="Receive DPO issue">
      <bpmn:incoming>Flow_StartIssuePath_To_ReceiveIssue_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveIssue_To_TaskHandleIssue_Art38</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_HandleIssue_Art38"
               name="Handle DPO issue">
      <bpmn:incoming>Flow_ReceiveIssue_To_TaskHandleIssue_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskHandleIssue_To_TaskObserveConfidentialityIssue_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ObserveConfidentialityIssue_Art38"
               name="Observe secrecy or confidentiality">
      <bpmn:incoming>Flow_TaskHandleIssue_To_TaskObserveConfidentialityIssue_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskObserveConfidentialityIssue_To_EndIssuePath_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_IssuePath_Art38"
                   name="Issue handled">
      <bpmn:incoming>Flow_TaskObserveConfidentialityIssue_To_EndIssuePath_Art38</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="StartEvent_DataSubjectPath_Art38"
                     name="Data-subject path available">
      <bpmn:outgoing>Flow_StartDataSubjectPath_To_ReceiveDataSubjectMatter_Art38</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveDataSubjectMatter_Art38"
                      name="Receive data-subject matter">
      <bpmn:incoming>Flow_StartDataSubjectPath_To_ReceiveDataSubjectMatter_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveDataSubjectMatter_To_TaskHandleRightsMatter_Art38</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_HandleRightsMatter_Art38"
               name="Handle processing or rights matter">
      <bpmn:incoming>Flow_ReceiveDataSubjectMatter_To_TaskHandleRightsMatter_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskHandleRightsMatter_To_TaskObserveConfidentialityRights_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ObserveConfidentialityRights_Art38"
               name="Observe secrecy or confidentiality">
      <bpmn:incoming>Flow_TaskHandleRightsMatter_To_TaskObserveConfidentialityRights_Art38</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskObserveConfidentialityRights_To_EndDataSubjectPath_Art38</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_DataSubjectPath_Art38"
                   name="Data-subject matter handled">
      <bpmn:incoming>Flow_TaskObserveConfidentialityRights_To_EndDataSubjectPath_Art38</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartIssuePath_To_ReceiveIssue_Art38" sourceRef="StartEvent_IssuePath_Art38" targetRef="ReceiveTask_ReceiveIssue_Art38" />
    <bpmn:sequenceFlow id="Flow_ReceiveIssue_To_TaskHandleIssue_Art38" sourceRef="ReceiveTask_ReceiveIssue_Art38" targetRef="Task_HandleIssue_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskHandleIssue_To_TaskObserveConfidentialityIssue_Art38" sourceRef="Task_HandleIssue_Art38" targetRef="Task_ObserveConfidentialityIssue_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskObserveConfidentialityIssue_To_EndIssuePath_Art38" sourceRef="Task_ObserveConfidentialityIssue_Art38" targetRef="EndEvent_IssuePath_Art38" />
    <bpmn:sequenceFlow id="Flow_StartDataSubjectPath_To_ReceiveDataSubjectMatter_Art38" sourceRef="StartEvent_DataSubjectPath_Art38" targetRef="ReceiveTask_ReceiveDataSubjectMatter_Art38" />
    <bpmn:sequenceFlow id="Flow_ReceiveDataSubjectMatter_To_TaskHandleRightsMatter_Art38" sourceRef="ReceiveTask_ReceiveDataSubjectMatter_Art38" targetRef="Task_HandleRightsMatter_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskHandleRightsMatter_To_TaskObserveConfidentialityRights_Art38" sourceRef="Task_HandleRightsMatter_Art38" targetRef="Task_ObserveConfidentialityRights_Art38" />
    <bpmn:sequenceFlow id="Flow_TaskObserveConfidentialityRights_To_EndDataSubjectPath_Art38" sourceRef="Task_ObserveConfidentialityRights_Art38" targetRef="EndEvent_DataSubjectPath_Art38" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art38_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art38_Reviewed" bpmnElement="Collaboration_Art38_Reviewed">
      <bpmndi:BPMNShape id="Participant_ControllerProcessor_Art38_di" bpmnElement="Participant_ControllerProcessor_Art38" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="4320" height="420" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DPO_Art38_di" bpmnElement="Participant_DPO_Art38" isHorizontal="true">
        <dc:Bounds x="60" y="500" width="4320" height="320" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art38_di" bpmnElement="Participant_DataSubject_Art38" isHorizontal="true">
        <dc:Bounds x="60" y="860" width="4320" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_MaintainDPO_Art38_di" bpmnElement="StartEvent_MaintainDPO_Art38">
        <dc:Bounds x="120" y="222" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IdentifyIssue_Art38_di" bpmnElement="Task_IdentifyIssue_Art38">
        <dc:Bounds x="210" y="200" width="240" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_InvolveDPO_Art38_di" bpmnElement="SendTask_InvolveDPO_Art38">
        <dc:Bounds x="530" y="200" width="240" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProvideResources_Art38_di" bpmnElement="Task_ProvideResources_Art38">
        <dc:Bounds x="860" y="200" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GrantAccess_Art38_di" bpmnElement="Task_GrantAccess_Art38">
        <dc:Bounds x="1160" y="200" width="230" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SupportExpertKnowledge_Art38_di" bpmnElement="Task_SupportExpertKnowledge_Art38">
        <dc:Bounds x="1480" y="200" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Instruction_Art38_di" bpmnElement="Gateway_Instruction_Art38" isMarkerVisible="true">
        <dc:Bounds x="1780" y="215" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_WithdrawInstruction_Art38_di" bpmnElement="Task_WithdrawInstruction_Art38">
        <dc:Bounds x="1920" y="80" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Sanction_Art38_di" bpmnElement="Gateway_Sanction_Art38" isMarkerVisible="true">
        <dc:Bounds x="2200" y="215" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_StopSanction_Art38_di" bpmnElement="Task_StopSanction_Art38">
        <dc:Bounds x="2360" y="80" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EnsureReporting_Art38_di" bpmnElement="Task_EnsureReporting_Art38">
        <dc:Bounds x="2360" y="200" width="280" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EnableContact_Art38_di" bpmnElement="Task_EnableContact_Art38">
        <dc:Bounds x="2750" y="200" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_OtherDuties_Art38_di" bpmnElement="Gateway_OtherDuties_Art38" isMarkerVisible="true">
        <dc:Bounds x="3050" y="215" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessConflict_Art38_di" bpmnElement="Task_AssessConflict_Art38">
        <dc:Bounds x="3190" y="200" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Conflict_Art38_di" bpmnElement="Gateway_Conflict_Art38" isMarkerVisible="true">
        <dc:Bounds x="3470" y="215" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RemoveConflict_Art38_di" bpmnElement="Task_RemoveConflict_Art38">
        <dc:Bounds x="3630" y="80" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Completed_Art38_di" bpmnElement="EndEvent_Completed_Art38">
        <dc:Bounds x="3942" y="222" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_IssuePath_Art38_di" bpmnElement="StartEvent_IssuePath_Art38">
        <dc:Bounds x="120" y="582" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveIssue_Art38_di" bpmnElement="ReceiveTask_ReceiveIssue_Art38">
        <dc:Bounds x="210" y="560" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HandleIssue_Art38_di" bpmnElement="Task_HandleIssue_Art38">
        <dc:Bounds x="470" y="560" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ObserveConfidentialityIssue_Art38_di" bpmnElement="Task_ObserveConfidentialityIssue_Art38">
        <dc:Bounds x="730" y="560" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_IssuePath_Art38_di" bpmnElement="EndEvent_IssuePath_Art38">
        <dc:Bounds x="1012" y="582" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_DataSubjectPath_Art38_di" bpmnElement="StartEvent_DataSubjectPath_Art38">
        <dc:Bounds x="120" y="702" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveDataSubjectMatter_Art38_di" bpmnElement="ReceiveTask_ReceiveDataSubjectMatter_Art38">
        <dc:Bounds x="210" y="680" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HandleRightsMatter_Art38_di" bpmnElement="Task_HandleRightsMatter_Art38">
        <dc:Bounds x="470" y="680" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ObserveConfidentialityRights_Art38_di" bpmnElement="Task_ObserveConfidentialityRights_Art38">
        <dc:Bounds x="760" y="680" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_DataSubjectPath_Art38_di" bpmnElement="EndEvent_DataSubjectPath_Art38">
        <dc:Bounds x="1042" y="702" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_IdentifyIssue_Art38_di" bpmnElement="Flow_Start_To_IdentifyIssue_Art38">
        <di:waypoint x="156" y="240" />
        <di:waypoint x="210" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskIdentifyIssue_To_SendTaskInvolveDPO_Art38_di" bpmnElement="Flow_TaskIdentifyIssue_To_SendTaskInvolveDPO_Art38">
        <di:waypoint x="450" y="240" />
