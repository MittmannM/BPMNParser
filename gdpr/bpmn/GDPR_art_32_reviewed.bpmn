<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art32_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_ControllerOrProcessor_Art32"
                name="Securing processing under Article 32"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 32 based on the real English legal text
      of Regulation (EU) 2016/679. The model captures the Article 32(1) context
      factors, the Article 32(2) risk assessment, the parallel implementation of the
      four example security-measure groups in Article 32(1)(a)-(d), the optional
      Article 40 or Article 42 evidence path in Article 32(3), and the Article 32(4)
      duty to ensure instruction-bound processing except where Union or Member State
      law requires otherwise.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_CarryOutProcessing_Art32"
                     name="Carry out processing">
      <bpmn:outgoing>Flow_StartCarryOutProcessing_To_TaskAssessSecurityContext_Art32</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_AssessSecurityContext_Art32"
               name="Assess state, costs, and processing context">
      <bpmn:incoming>Flow_StartCarryOutProcessing_To_TaskAssessSecurityContext_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessSecurityContext_To_TaskAssessProcessingRisks_Art32</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AssessProcessingRisks_Art32"
               name="Assess security risks">
      <bpmn:incoming>Flow_TaskAssessSecurityContext_To_TaskAssessProcessingRisks_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessProcessingRisks_To_TaskDefineSecurityLevel_Art32</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DefineSecurityLevel_Art32"
               name="Define risk-appropriate security level">
      <bpmn:incoming>Flow_TaskAssessProcessingRisks_To_TaskDefineSecurityLevel_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDefineSecurityLevel_To_GatewaySplitSecurityMeasures_Art32</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_SplitSecurityMeasures_Art32">
      <bpmn:incoming>Flow_TaskDefineSecurityLevel_To_GatewaySplitSecurityMeasures_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitSecurityMeasures_To_TaskImplementPseudonymisationEncryption_Art32</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitSecurityMeasures_To_TaskEnsureCIAResilience_Art32</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitSecurityMeasures_To_TaskSetRestorationCapability_Art32</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitSecurityMeasures_To_TaskSetTestingProcess_Art32</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_ImplementPseudonymisationEncryption_Art32"
               name="Implement pseudonymisation and encryption">
      <bpmn:incoming>Flow_GatewaySplitSecurityMeasures_To_TaskImplementPseudonymisationEncryption_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskImplementPseudonymisationEncryption_To_GatewayJoinSecurityMeasures_Art32</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EnsureCIAResilience_Art32"
               name="Ensure confidentiality, integrity, availability, and resilience">
      <bpmn:incoming>Flow_GatewaySplitSecurityMeasures_To_TaskEnsureCIAResilience_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskEnsureCIAResilience_To_GatewayJoinSecurityMeasures_Art32</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetRestorationCapability_Art32"
               name="Set restoration capability">
      <bpmn:incoming>Flow_GatewaySplitSecurityMeasures_To_TaskSetRestorationCapability_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetRestorationCapability_To_GatewayJoinSecurityMeasures_Art32</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetTestingProcess_Art32"
               name="Set testing and evaluation process">
      <bpmn:incoming>Flow_GatewaySplitSecurityMeasures_To_TaskSetTestingProcess_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetTestingProcess_To_GatewayJoinSecurityMeasures_Art32</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinSecurityMeasures_Art32">
      <bpmn:incoming>Flow_TaskImplementPseudonymisationEncryption_To_GatewayJoinSecurityMeasures_Art32</bpmn:incoming>
      <bpmn:incoming>Flow_TaskEnsureCIAResilience_To_GatewayJoinSecurityMeasures_Art32</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetRestorationCapability_To_GatewayJoinSecurityMeasures_Art32</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetTestingProcess_To_GatewayJoinSecurityMeasures_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinSecurityMeasures_To_GatewayUseCodeOrCertification_Art32</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:exclusiveGateway id="Gateway_UseCodeOrCertification_Art32"
                           name="Use Article 40 or Article 42 evidence?">
      <bpmn:incoming>Flow_GatewayJoinSecurityMeasures_To_GatewayUseCodeOrCertification_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayUseCodeOrCertification_To_TaskUseCodeOrCertification_Art32</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayUseCodeOrCertification_To_TaskSetInstructionOnlyRules_Art32</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_UseCodeOrCertification_Art32"
               name="Use Article 40 or 42 evidence">
      <bpmn:incoming>Flow_GatewayUseCodeOrCertification_To_TaskUseCodeOrCertification_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskUseCodeOrCertification_To_TaskSetInstructionOnlyRules_Art32</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetInstructionOnlyRules_Art32"
               name="Set instruction-only processing rules">
      <bpmn:incoming>Flow_GatewayUseCodeOrCertification_To_TaskSetInstructionOnlyRules_Art32</bpmn:incoming>
      <bpmn:incoming>Flow_TaskUseCodeOrCertification_To_TaskSetInstructionOnlyRules_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetInstructionOnlyRules_To_GatewayLawRequiresProcessing_Art32</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_LawRequiresProcessing_Art32"
                           name="Is processing required by Union or Member State law?">
      <bpmn:incoming>Flow_TaskSetInstructionOnlyRules_To_GatewayLawRequiresProcessing_Art32</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayLawRequiresProcessing_To_EndLawExceptionPreserved_Art32</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayLawRequiresProcessing_To_EndSecurityMeasuresImplemented_Art32</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_LawExceptionPreserved_Art32"
                   name="Law-based processing exception preserved">
      <bpmn:incoming>Flow_GatewayLawRequiresProcessing_To_EndLawExceptionPreserved_Art32</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_SecurityMeasuresImplemented_Art32"
                   name="Security measures implemented">
      <bpmn:incoming>Flow_GatewayLawRequiresProcessing_To_EndSecurityMeasuresImplemented_Art32</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartCarryOutProcessing_To_TaskAssessSecurityContext_Art32" sourceRef="StartEvent_CarryOutProcessing_Art32" targetRef="Task_AssessSecurityContext_Art32" />
    <bpmn:sequenceFlow id="Flow_TaskAssessSecurityContext_To_TaskAssessProcessingRisks_Art32" sourceRef="Task_AssessSecurityContext_Art32" targetRef="Task_AssessProcessingRisks_Art32" />
    <bpmn:sequenceFlow id="Flow_TaskAssessProcessingRisks_To_TaskDefineSecurityLevel_Art32" sourceRef="Task_AssessProcessingRisks_Art32" targetRef="Task_DefineSecurityLevel_Art32" />
    <bpmn:sequenceFlow id="Flow_TaskDefineSecurityLevel_To_GatewaySplitSecurityMeasures_Art32" sourceRef="Task_DefineSecurityLevel_Art32" targetRef="Gateway_SplitSecurityMeasures_Art32" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitSecurityMeasures_To_TaskImplementPseudonymisationEncryption_Art32" sourceRef="Gateway_SplitSecurityMeasures_Art32" targetRef="Task_ImplementPseudonymisationEncryption_Art32" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitSecurityMeasures_To_TaskEnsureCIAResilience_Art32" sourceRef="Gateway_SplitSecurityMeasures_Art32" targetRef="Task_EnsureCIAResilience_Art32" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitSecurityMeasures_To_TaskSetRestorationCapability_Art32" sourceRef="Gateway_SplitSecurityMeasures_Art32" targetRef="Task_SetRestorationCapability_Art32" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitSecurityMeasures_To_TaskSetTestingProcess_Art32" sourceRef="Gateway_SplitSecurityMeasures_Art32" targetRef="Task_SetTestingProcess_Art32" />
    <bpmn:sequenceFlow id="Flow_TaskImplementPseudonymisationEncryption_To_GatewayJoinSecurityMeasures_Art32" sourceRef="Task_ImplementPseudonymisationEncryption_Art32" targetRef="Gateway_JoinSecurityMeasures_Art32" />
    <bpmn:sequenceFlow id="Flow_TaskEnsureCIAResilience_To_GatewayJoinSecurityMeasures_Art32" sourceRef="Task_EnsureCIAResilience_Art32" targetRef="Gateway_JoinSecurityMeasures_Art32" />
    <bpmn:sequenceFlow id="Flow_TaskSetRestorationCapability_To_GatewayJoinSecurityMeasures_Art32" sourceRef="Task_SetRestorationCapability_Art32" targetRef="Gateway_JoinSecurityMeasures_Art32" />
    <bpmn:sequenceFlow id="Flow_TaskSetTestingProcess_To_GatewayJoinSecurityMeasures_Art32" sourceRef="Task_SetTestingProcess_Art32" targetRef="Gateway_JoinSecurityMeasures_Art32" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinSecurityMeasures_To_GatewayUseCodeOrCertification_Art32" sourceRef="Gateway_JoinSecurityMeasures_Art32" targetRef="Gateway_UseCodeOrCertification_Art32" />
    <bpmn:sequenceFlow id="Flow_GatewayUseCodeOrCertification_To_TaskUseCodeOrCertification_Art32" name="Yes" sourceRef="Gateway_UseCodeOrCertification_Art32" targetRef="Task_UseCodeOrCertification_Art32" />
    <bpmn:sequenceFlow id="Flow_GatewayUseCodeOrCertification_To_TaskSetInstructionOnlyRules_Art32" name="No" sourceRef="Gateway_UseCodeOrCertification_Art32" targetRef="Task_SetInstructionOnlyRules_Art32" />
    <bpmn:sequenceFlow id="Flow_TaskUseCodeOrCertification_To_TaskSetInstructionOnlyRules_Art32" sourceRef="Task_UseCodeOrCertification_Art32" targetRef="Task_SetInstructionOnlyRules_Art32" />
    <bpmn:sequenceFlow id="Flow_TaskSetInstructionOnlyRules_To_GatewayLawRequiresProcessing_Art32" sourceRef="Task_SetInstructionOnlyRules_Art32" targetRef="Gateway_LawRequiresProcessing_Art32" />
    <bpmn:sequenceFlow id="Flow_GatewayLawRequiresProcessing_To_EndLawExceptionPreserved_Art32" name="Yes" sourceRef="Gateway_LawRequiresProcessing_Art32" targetRef="EndEvent_LawExceptionPreserved_Art32" />
    <bpmn:sequenceFlow id="Flow_GatewayLawRequiresProcessing_To_EndSecurityMeasuresImplemented_Art32" name="No" sourceRef="Gateway_LawRequiresProcessing_Art32" targetRef="EndEvent_SecurityMeasuresImplemented_Art32" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art32_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art32_Reviewed" bpmnElement="Process_ControllerOrProcessor_Art32">
      <bpmndi:BPMNShape id="StartEvent_CarryOutProcessing_Art32_di" bpmnElement="StartEvent_CarryOutProcessing_Art32">
        <dc:Bounds x="80" y="302" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessSecurityContext_Art32_di" bpmnElement="Task_AssessSecurityContext_Art32">
        <dc:Bounds x="180" y="280" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessProcessingRisks_Art32_di" bpmnElement="Task_AssessProcessingRisks_Art32">
        <dc:Bounds x="470" y="280" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DefineSecurityLevel_Art32_di" bpmnElement="Task_DefineSecurityLevel_Art32">
        <dc:Bounds x="730" y="280" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SplitSecurityMeasures_Art32_di" bpmnElement="Gateway_SplitSecurityMeasures_Art32" isMarkerVisible="true">
        <dc:Bounds x="1035" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_ImplementPseudonymisationEncryption_Art32_di" bpmnElement="Task_ImplementPseudonymisationEncryption_Art32">
        <dc:Bounds x="1180" y="70" width="240" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EnsureCIAResilience_Art32_di" bpmnElement="Task_EnsureCIAResilience_Art32">
        <dc:Bounds x="1480" y="70" width="320" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetRestorationCapability_Art32_di" bpmnElement="Task_SetRestorationCapability_Art32">
        <dc:Bounds x="1180" y="500" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetTestingProcess_Art32_di" bpmnElement="Task_SetTestingProcess_Art32">
        <dc:Bounds x="1460" y="500" width="260" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_JoinSecurityMeasures_Art32_di" bpmnElement="Gateway_JoinSecurityMeasures_Art32" isMarkerVisible="true">
        <dc:Bounds x="1875" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_UseCodeOrCertification_Art32_di" bpmnElement="Gateway_UseCodeOrCertification_Art32" isMarkerVisible="true">
        <dc:Bounds x="2040" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_UseCodeOrCertification_Art32_di" bpmnElement="Task_UseCodeOrCertification_Art32">
        <dc:Bounds x="2200" y="280" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetInstructionOnlyRules_Art32_di" bpmnElement="Task_SetInstructionOnlyRules_Art32">
        <dc:Bounds x="2520" y="280" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_LawRequiresProcessing_Art32_di" bpmnElement="Gateway_LawRequiresProcessing_Art32" isMarkerVisible="true">
        <dc:Bounds x="2865" y="295" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_LawExceptionPreserved_Art32_di" bpmnElement="EndEvent_LawExceptionPreserved_Art32">
        <dc:Bounds x="3042" y="152" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_SecurityMeasuresImplemented_Art32_di" bpmnElement="EndEvent_SecurityMeasuresImplemented_Art32">
        <dc:Bounds x="3042" y="402" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_StartCarryOutProcessing_To_TaskAssessSecurityContext_Art32_di" bpmnElement="Flow_StartCarryOutProcessing_To_TaskAssessSecurityContext_Art32">
        <di:waypoint x="116" y="320" />
        <di:waypoint x="180" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskAssessSecurityContext_To_TaskAssessProcessingRisks_Art32_di" bpmnElement="Flow_TaskAssessSecurityContext_To_TaskAssessProcessingRisks_Art32">
        <di:waypoint x="390" y="320" />
        <di:waypoint x="470" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskAssessProcessingRisks_To_TaskDefineSecurityLevel_Art32_di" bpmnElement="Flow_TaskAssessProcessingRisks_To_TaskDefineSecurityLevel_Art32">
        <di:waypoint x="650" y="320" />
        <di:waypoint x="730" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskDefineSecurityLevel_To_GatewaySplitSecurityMeasures_Art32_di" bpmnElement="Flow_TaskDefineSecurityLevel_To_GatewaySplitSecurityMeasures_Art32">
        <di:waypoint x="950" y="320" />
        <di:waypoint x="1035" y="320" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GatewaySplitSecurityMeasures_To_TaskImplementPseudonymisationEncryption_Art32_di" bpmnElement="Flow_GatewaySplitSecurityMeasures_To_TaskImplementPseudonymisationEncryption_Art32">
        <di:waypoint x="1060" y="295" />
        <di:waypoint x="1060" y="110" />
        <di:waypoint x="1180" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitSecurityMeasures_To_TaskEnsureCIAResilience_Art32_di" bpmnElement="Flow_GatewaySplitSecurityMeasures_To_TaskEnsureCIAResilience_Art32">
        <di:waypoint x="1060" y="295" />
        <di:waypoint x="1060" y="110" />
        <di:waypoint x="1480" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitSecurityMeasures_To_TaskSetRestorationCapability_Art32_di" bpmnElement="Flow_GatewaySplitSecurityMeasures_To_TaskSetRestorationCapability_Art32">
        <di:waypoint x="1060" y="345" />
        <di:waypoint x="1060" y="540" />
        <di:waypoint x="1180" y="540" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitSecurityMeasures_To_TaskSetTestingProcess_Art32_di" bpmnElement="Flow_GatewaySplitSecurityMeasures_To_TaskSetTestingProcess_Art32">
        <di:waypoint x="1060" y="345" />
        <di:waypoint x="1060" y="540" />
        <di:waypoint x="1460" y="540" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_TaskImplementPseudonymisationEncryption_To_GatewayJoinSecurityMeasures_Art32_di" bpmnElement="Flow_TaskImplementPseudonymisationEncryption_To_GatewayJoinSecurityMeasures_Art32">
        <di:waypoint x="1420" y="110" />
        <di:waypoint x="1900" y="110" />
        <di:waypoint x="1900" y="295" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskEnsureCIAResilience_To_GatewayJoinSecurityMeasures_Art32_di" bpmnElement="Flow_TaskEnsureCIAResilience_To_GatewayJoinSecurityMeasures_Art32">
        <di:waypoint x="1800" y="110" />
        <di:waypoint x="1900" y="110" />
        <di:waypoint x="1900" y="295" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskSetRestorationCapability_To_GatewayJoinSecurityMeasures_Art32_di" bpmnElement="Flow_TaskSetRestorationCapability_To_GatewayJoinSecurityMeasures_Art32">
        <di:waypoint x="1400" y="540" />
        <di:waypoint x="1900" y="540" />
        <di:waypoint x="1900" y="345" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskSetTestingProcess_To_GatewayJoinSecurityMeasures_Art32_di" bpmnElement="Flow_TaskSetTestingProcess_To_GatewayJoinSecurityMeasures_Art32">
        <di:waypoint x="1720" y="540" />
        <di:waypoint x="1900" y="540" />
        <di:waypoint x="1900" y="345" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GatewayJoinSecurityMeasures_To_GatewayUseCodeOrCertification_Art32_di" bpmnElement="Flow_GatewayJoinSecurityMeasures_To_GatewayUseCodeOrCertification_Art32">
        <di:waypoint x="1925" y="320" />
        <di:waypoint x="2040" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayUseCodeOrCertification_To_TaskUseCodeOrCertification_Art32_di" bpmnElement="Flow_GatewayUseCodeOrCertification_To_TaskUseCodeOrCertification_Art32">
        <di:waypoint x="2090" y="320" />
        <di:waypoint x="2200" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayUseCodeOrCertification_To_TaskSetInstructionOnlyRules_Art32_di" bpmnElement="Flow_GatewayUseCodeOrCertification_To_TaskSetInstructionOnlyRules_Art32">
        <di:waypoint x="2065" y="345" />
        <di:waypoint x="2065" y="420" />
        <di:waypoint x="2630" y="420" />
        <di:waypoint x="2630" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskUseCodeOrCertification_To_TaskSetInstructionOnlyRules_Art32_di" bpmnElement="Flow_TaskUseCodeOrCertification_To_TaskSetInstructionOnlyRules_Art32">
        <di:waypoint x="2400" y="320" />
        <di:waypoint x="2520" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskSetInstructionOnlyRules_To_GatewayLawRequiresProcessing_Art32_di" bpmnElement="Flow_TaskSetInstructionOnlyRules_To_GatewayLawRequiresProcessing_Art32">
        <di:waypoint x="2740" y="320" />
        <di:waypoint x="2865" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayLawRequiresProcessing_To_EndLawExceptionPreserved_Art32_di" bpmnElement="Flow_GatewayLawRequiresProcessing_To_EndLawExceptionPreserved_Art32">
        <di:waypoint x="2890" y="295" />
        <di:waypoint x="2890" y="170" />
        <di:waypoint x="3042" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayLawRequiresProcessing_To_EndSecurityMeasuresImplemented_Art32_di" bpmnElement="Flow_GatewayLawRequiresProcessing_To_EndSecurityMeasuresImplemented_Art32">
        <di:waypoint x="2890" y="345" />
        <di:waypoint x="2890" y="420" />
        <di:waypoint x="3042" y="420" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
