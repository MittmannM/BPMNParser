<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Defs_Art35"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collab_Art35">
    <bpmn:participant id="P_Controller" name="Controller" processRef="Process_Art35" />
    <bpmn:participant id="P_DPO" name="Data Protection Officer" />
    <bpmn:participant id="P_DataSubjects" name="Data Subjects" />
    <bpmn:messageFlow id="MF_DPO" sourceRef="T_SeekDPOAdvice" targetRef="P_DPO" />
    <bpmn:messageFlow id="MF_DataSubjects" sourceRef="T_RequestViews" targetRef="P_DataSubjects" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Art35" name="Controller data protection impact assessment handling" isExecutable="false">
    <bpmn:documentation>Manual BPMN conversion for GDPR Article 35 based on DAPRECO LegalRuleML statements180-188.</bpmn:documentation>
    <bpmn:startEvent id="Start_Review" name="Controller reviews a processing operation">
      <bpmn:outgoing>F_Start_AssessException</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="T_AssessException" name="Assess whether the Article 35(10) exception applies">
      <bpmn:incoming>F_Start_AssessException</bpmn:incoming>
      <bpmn:outgoing>F_AssessException_GW_Exception</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Exception" name="Article 35(10) exception applies?">
      <bpmn:incoming>F_AssessException_GW_Exception</bpmn:incoming>
      <bpmn:outgoing>F_GW_Exception_End_NoDPIA</bpmn:outgoing>
      <bpmn:outgoing>F_GW_Exception_T_HighRisk</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_AssessHighRisk" name="Assess whether processing is likely to result in high risk">
      <bpmn:incoming>F_GW_Exception_T_HighRisk</bpmn:incoming>
      <bpmn:outgoing>F_T_HighRisk_GW_HighRisk</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_HighRisk" name="High risk to rights and freedoms likely?">
      <bpmn:incoming>F_T_HighRisk_GW_HighRisk</bpmn:incoming>
      <bpmn:outgoing>F_GW_HighRisk_T_Initiate</bpmn:outgoing>
      <bpmn:outgoing>F_GW_HighRisk_T_AutoDecision</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_AutoDecision" name="Assess whether automated decision-making has legal or similar significant effects">
      <bpmn:incoming>F_GW_HighRisk_T_AutoDecision</bpmn:incoming>
      <bpmn:outgoing>F_T_AutoDecision_GW_AutoDecision</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_AutoDecision" name="Automated decision trigger applies?">
      <bpmn:incoming>F_T_AutoDecision_GW_AutoDecision</bpmn:incoming>
      <bpmn:outgoing>F_GW_AutoDecision_T_Initiate</bpmn:outgoing>
      <bpmn:outgoing>F_GW_AutoDecision_T_SensitiveData</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_SensitiveData" name="Assess whether large-scale special-category or criminal-data processing occurs">
      <bpmn:incoming>F_GW_AutoDecision_T_SensitiveData</bpmn:incoming>
      <bpmn:outgoing>F_T_SensitiveData_GW_SensitiveData</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_SensitiveData" name="Large-scale sensitive-data trigger applies?">
      <bpmn:incoming>F_T_SensitiveData_GW_SensitiveData</bpmn:incoming>
      <bpmn:outgoing>F_GW_SensitiveData_T_Initiate</bpmn:outgoing>
      <bpmn:outgoing>F_GW_SensitiveData_T_Monitoring</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_Monitoring" name="Assess whether large-scale monitoring of a public area occurs">
      <bpmn:incoming>F_GW_SensitiveData_T_Monitoring</bpmn:incoming>
      <bpmn:outgoing>F_T_Monitoring_GW_Monitoring</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Monitoring" name="Public-area monitoring trigger applies?">
      <bpmn:incoming>F_T_Monitoring_GW_Monitoring</bpmn:incoming>
      <bpmn:outgoing>F_GW_Monitoring_T_Initiate</bpmn:outgoing>
      <bpmn:outgoing>F_GW_Monitoring_End_NoDPIA</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_Initiate" name="Initiate the data protection impact assessment">
      <bpmn:incoming>F_GW_HighRisk_T_Initiate</bpmn:incoming>
      <bpmn:incoming>F_GW_AutoDecision_T_Initiate</bpmn:incoming>
      <bpmn:incoming>F_GW_SensitiveData_T_Initiate</bpmn:incoming>
      <bpmn:incoming>F_GW_Monitoring_T_Initiate</bpmn:incoming>
      <bpmn:outgoing>F_T_Initiate_GW_DPO</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_DPO" name="Data protection officer designated?">
      <bpmn:incoming>F_T_Initiate_GW_DPO</bpmn:incoming>
      <bpmn:outgoing>F_GW_DPO_T_SeekDPOAdvice</bpmn:outgoing>
      <bpmn:outgoing>F_GW_DPO_GW_DPO_Merge</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="T_SeekDPOAdvice" name="Seek advice from the data protection officer">
      <bpmn:incoming>F_GW_DPO_T_SeekDPOAdvice</bpmn:incoming>
      <bpmn:outgoing>F_T_SeekDPOAdvice_GW_DPO_Merge</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="GW_DPO_Merge" name="DPO advice path merged">
      <bpmn:incoming>F_GW_DPO_GW_DPO_Merge</bpmn:incoming>
      <bpmn:incoming>F_T_SeekDPOAdvice_GW_DPO_Merge</bpmn:incoming>
      <bpmn:outgoing>F_GW_DPO_Merge_GW_Compile_Split</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="GW_Compile_Split">
      <bpmn:incoming>F_GW_DPO_Merge_GW_Compile_Split</bpmn:incoming>
      <bpmn:outgoing>F_GW_Compile_Split_T_OperationsPurposes</bpmn:outgoing>
      <bpmn:outgoing>F_GW_Compile_Split_T_LegitimateInterests</bpmn:outgoing>
      <bpmn:outgoing>F_GW_Compile_Split_T_NecessityProportionality</bpmn:outgoing>
      <bpmn:outgoing>F_GW_Compile_Split_T_Risks</bpmn:outgoing>
      <bpmn:outgoing>F_GW_Compile_Split_T_Measures</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="T_OperationsPurposes" name="Describe processing operations and purposes">
      <bpmn:incoming>F_GW_Compile_Split_T_OperationsPurposes</bpmn:incoming>
      <bpmn:outgoing>F_T_OperationsPurposes_GW_Compile_Join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_LegitimateInterests" name="Describe legitimate interests where applicable">
      <bpmn:incoming>F_GW_Compile_Split_T_LegitimateInterests</bpmn:incoming>
      <bpmn:outgoing>F_T_LegitimateInterests_GW_Compile_Join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_NecessityProportionality" name="Assess necessity and proportionality">
      <bpmn:incoming>F_GW_Compile_Split_T_NecessityProportionality</bpmn:incoming>
      <bpmn:outgoing>F_T_NecessityProportionality_GW_Compile_Join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Risks" name="Assess risks to rights and freedoms">
      <bpmn:incoming>F_GW_Compile_Split_T_Risks</bpmn:incoming>
      <bpmn:outgoing>F_T_Risks_GW_Compile_Join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Measures" name="Describe measures, safeguards, security, and compliance mechanisms">
      <bpmn:incoming>F_GW_Compile_Split_T_Measures</bpmn:incoming>
      <bpmn:outgoing>F_T_Measures_GW_Compile_Join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="GW_Compile_Join">
      <bpmn:incoming>F_T_OperationsPurposes_GW_Compile_Join</bpmn:incoming>
      <bpmn:incoming>F_T_LegitimateInterests_GW_Compile_Join</bpmn:incoming>
      <bpmn:incoming>F_T_NecessityProportionality_GW_Compile_Join</bpmn:incoming>
      <bpmn:incoming>F_T_Risks_GW_Compile_Join</bpmn:incoming>
      <bpmn:incoming>F_T_Measures_GW_Compile_Join</bpmn:incoming>
      <bpmn:outgoing>F_GW_Compile_Join_GW_Views</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:exclusiveGateway id="GW_Views" name="Seek data subject views without prejudicing protected interests?">
      <bpmn:incoming>F_GW_Compile_Join_GW_Views</bpmn:incoming>
      <bpmn:outgoing>F_GW_Views_T_RequestViews</bpmn:outgoing>
      <bpmn:outgoing>F_GW_Views_GW_Views_Merge</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="T_RequestViews" name="Request data subject views for the assessment">
      <bpmn:incoming>F_GW_Views_T_RequestViews</bpmn:incoming>
      <bpmn:outgoing>F_T_RequestViews_GW_Views_Merge</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="GW_Views_Merge" name="Data subject views path merged">
      <bpmn:incoming>F_GW_Views_GW_Views_Merge</bpmn:incoming>
      <bpmn:incoming>F_T_RequestViews_GW_Views_Merge</bpmn:incoming>
      <bpmn:outgoing>F_GW_Views_Merge_T_Finalize</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_Finalize" name="Finalize the data protection impact assessment">
      <bpmn:incoming>F_GW_Views_Merge_T_Finalize</bpmn:incoming>
      <bpmn:outgoing>F_T_Finalize_GW_Review</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Review" name="Review necessary later because conditions changed?">
      <bpmn:incoming>F_T_Finalize_GW_Review</bpmn:incoming>
      <bpmn:outgoing>F_GW_Review_T_ReviewAssessment</bpmn:outgoing>
      <bpmn:outgoing>F_GW_Review_End_Completed</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_ReviewAssessment" name="Review whether processing still complies with the impact assessment">
      <bpmn:incoming>F_GW_Review_T_ReviewAssessment</bpmn:incoming>
      <bpmn:outgoing>F_T_ReviewAssessment_End_Completed</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_NoDPIA" name="No DPIA required under Article 35">
      <bpmn:incoming>F_GW_Exception_End_NoDPIA</bpmn:incoming>
      <bpmn:incoming>F_GW_Monitoring_End_NoDPIA</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Completed" name="DPIA handling completed">
      <bpmn:incoming>F_GW_Review_End_Completed</bpmn:incoming>
      <bpmn:incoming>F_T_ReviewAssessment_End_Completed</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_Start_AssessException" sourceRef="Start_Review" targetRef="T_AssessException" />
    <bpmn:sequenceFlow id="F_AssessException_GW_Exception" sourceRef="T_AssessException" targetRef="GW_Exception" />
    <bpmn:sequenceFlow id="F_GW_Exception_End_NoDPIA" name="Yes" sourceRef="GW_Exception" targetRef="End_NoDPIA" />
    <bpmn:sequenceFlow id="F_GW_Exception_T_HighRisk" name="No" sourceRef="GW_Exception" targetRef="T_AssessHighRisk" />
    <bpmn:sequenceFlow id="F_T_HighRisk_GW_HighRisk" sourceRef="T_AssessHighRisk" targetRef="GW_HighRisk" />
    <bpmn:sequenceFlow id="F_GW_HighRisk_T_Initiate" name="Yes" sourceRef="GW_HighRisk" targetRef="T_Initiate" />
    <bpmn:sequenceFlow id="F_GW_HighRisk_T_AutoDecision" name="No" sourceRef="GW_HighRisk" targetRef="T_AutoDecision" />
    <bpmn:sequenceFlow id="F_T_AutoDecision_GW_AutoDecision" sourceRef="T_AutoDecision" targetRef="GW_AutoDecision" />
    <bpmn:sequenceFlow id="F_GW_AutoDecision_T_Initiate" name="Yes" sourceRef="GW_AutoDecision" targetRef="T_Initiate" />
    <bpmn:sequenceFlow id="F_GW_AutoDecision_T_SensitiveData" name="No" sourceRef="GW_AutoDecision" targetRef="T_SensitiveData" />
    <bpmn:sequenceFlow id="F_T_SensitiveData_GW_SensitiveData" sourceRef="T_SensitiveData" targetRef="GW_SensitiveData" />
    <bpmn:sequenceFlow id="F_GW_SensitiveData_T_Initiate" name="Yes" sourceRef="GW_SensitiveData" targetRef="T_Initiate" />
    <bpmn:sequenceFlow id="F_GW_SensitiveData_T_Monitoring" name="No" sourceRef="GW_SensitiveData" targetRef="T_Monitoring" />
    <bpmn:sequenceFlow id="F_T_Monitoring_GW_Monitoring" sourceRef="T_Monitoring" targetRef="GW_Monitoring" />
    <bpmn:sequenceFlow id="F_GW_Monitoring_T_Initiate" name="Yes" sourceRef="GW_Monitoring" targetRef="T_Initiate" />
    <bpmn:sequenceFlow id="F_GW_Monitoring_End_NoDPIA" name="No" sourceRef="GW_Monitoring" targetRef="End_NoDPIA" />
    <bpmn:sequenceFlow id="F_T_Initiate_GW_DPO" sourceRef="T_Initiate" targetRef="GW_DPO" />
    <bpmn:sequenceFlow id="F_GW_DPO_T_SeekDPOAdvice" name="Yes" sourceRef="GW_DPO" targetRef="T_SeekDPOAdvice" />
    <bpmn:sequenceFlow id="F_GW_DPO_GW_DPO_Merge" name="No" sourceRef="GW_DPO" targetRef="GW_DPO_Merge" />
    <bpmn:sequenceFlow id="F_T_SeekDPOAdvice_GW_DPO_Merge" sourceRef="T_SeekDPOAdvice" targetRef="GW_DPO_Merge" />
    <bpmn:sequenceFlow id="F_GW_DPO_Merge_GW_Compile_Split" sourceRef="GW_DPO_Merge" targetRef="GW_Compile_Split" />
    <bpmn:sequenceFlow id="F_GW_Compile_Split_T_OperationsPurposes" sourceRef="GW_Compile_Split" targetRef="T_OperationsPurposes" />
    <bpmn:sequenceFlow id="F_GW_Compile_Split_T_LegitimateInterests" sourceRef="GW_Compile_Split" targetRef="T_LegitimateInterests" />
    <bpmn:sequenceFlow id="F_GW_Compile_Split_T_NecessityProportionality" sourceRef="GW_Compile_Split" targetRef="T_NecessityProportionality" />
    <bpmn:sequenceFlow id="F_GW_Compile_Split_T_Risks" sourceRef="GW_Compile_Split" targetRef="T_Risks" />
    <bpmn:sequenceFlow id="F_GW_Compile_Split_T_Measures" sourceRef="GW_Compile_Split" targetRef="T_Measures" />
    <bpmn:sequenceFlow id="F_T_OperationsPurposes_GW_Compile_Join" sourceRef="T_OperationsPurposes" targetRef="GW_Compile_Join" />
    <bpmn:sequenceFlow id="F_T_LegitimateInterests_GW_Compile_Join" sourceRef="T_LegitimateInterests" targetRef="GW_Compile_Join" />
    <bpmn:sequenceFlow id="F_T_NecessityProportionality_GW_Compile_Join" sourceRef="T_NecessityProportionality" targetRef="GW_Compile_Join" />
    <bpmn:sequenceFlow id="F_T_Risks_GW_Compile_Join" sourceRef="T_Risks" targetRef="GW_Compile_Join" />
    <bpmn:sequenceFlow id="F_T_Measures_GW_Compile_Join" sourceRef="T_Measures" targetRef="GW_Compile_Join" />
    <bpmn:sequenceFlow id="F_GW_Compile_Join_GW_Views" sourceRef="GW_Compile_Join" targetRef="GW_Views" />
    <bpmn:sequenceFlow id="F_GW_Views_T_RequestViews" name="Yes" sourceRef="GW_Views" targetRef="T_RequestViews" />
    <bpmn:sequenceFlow id="F_GW_Views_GW_Views_Merge" name="No" sourceRef="GW_Views" targetRef="GW_Views_Merge" />
    <bpmn:sequenceFlow id="F_T_RequestViews_GW_Views_Merge" sourceRef="T_RequestViews" targetRef="GW_Views_Merge" />
    <bpmn:sequenceFlow id="F_GW_Views_Merge_T_Finalize" sourceRef="GW_Views_Merge" targetRef="T_Finalize" />
    <bpmn:sequenceFlow id="F_T_Finalize_GW_Review" sourceRef="T_Finalize" targetRef="GW_Review" />
    <bpmn:sequenceFlow id="F_GW_Review_T_ReviewAssessment" name="Yes" sourceRef="GW_Review" targetRef="T_ReviewAssessment" />
    <bpmn:sequenceFlow id="F_GW_Review_End_Completed" name="No" sourceRef="GW_Review" targetRef="End_Completed" />
    <bpmn:sequenceFlow id="F_T_ReviewAssessment_End_Completed" sourceRef="T_ReviewAssessment" targetRef="End_Completed" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Art35">
    <bpmndi:BPMNPlane id="BPMNPlane_Art35" bpmnElement="Collab_Art35">
      <bpmndi:BPMNShape id="P_Controller_di" bpmnElement="P_Controller" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="4480" height="560" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="P_DPO_di" bpmnElement="P_DPO" isHorizontal="true">
        <dc:Bounds x="60" y="640" width="4480" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="P_DataSubjects_di" bpmnElement="P_DataSubjects" isHorizontal="true">
        <dc:Bounds x="60" y="820" width="4480" height="140" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start_Review_di" bpmnElement="Start_Review">
        <dc:Bounds x="140" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_AssessException_di" bpmnElement="T_AssessException">
        <dc:Bounds x="220" y="170" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_Exception_di" bpmnElement="GW_Exception" isMarkerVisible="true">
        <dc:Bounds x="450" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_AssessHighRisk_di" bpmnElement="T_AssessHighRisk">
        <dc:Bounds x="560" y="170" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_HighRisk_di" bpmnElement="GW_HighRisk" isMarkerVisible="true">
        <dc:Bounds x="790" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_AutoDecision_di" bpmnElement="T_AutoDecision">
        <dc:Bounds x="900" y="170" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_AutoDecision_di" bpmnElement="GW_AutoDecision" isMarkerVisible="true">
        <dc:Bounds x="1160" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_SensitiveData_di" bpmnElement="T_SensitiveData">
        <dc:Bounds x="1270" y="170" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_SensitiveData_di" bpmnElement="GW_SensitiveData" isMarkerVisible="true">
        <dc:Bounds x="1540" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_Monitoring_di" bpmnElement="T_Monitoring">
        <dc:Bounds x="1650" y="170" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_Monitoring_di" bpmnElement="GW_Monitoring" isMarkerVisible="true">
        <dc:Bounds x="1910" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_Initiate_di" bpmnElement="T_Initiate">
        <dc:Bounds x="2070" y="170" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_DPO_di" bpmnElement="GW_DPO" isMarkerVisible="true">
        <dc:Bounds x="2300" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_SeekDPOAdvice_di" bpmnElement="T_SeekDPOAdvice">
        <dc:Bounds x="2410" y="70" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_DPO_Merge_di" bpmnElement="GW_DPO_Merge" isMarkerVisible="true">
        <dc:Bounds x="2670" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_Compile_Split_di" bpmnElement="GW_Compile_Split" isMarkerVisible="true">
        <dc:Bounds x="2790" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_OperationsPurposes_di" bpmnElement="T_OperationsPurposes">
        <dc:Bounds x="2900" y="20" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_LegitimateInterests_di" bpmnElement="T_LegitimateInterests">
        <dc:Bounds x="2900" y="110" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_NecessityProportionality_di" bpmnElement="T_NecessityProportionality">
        <dc:Bounds x="2900" y="200" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_Risks_di" bpmnElement="T_Risks">
        <dc:Bounds x="2900" y="290" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_Measures_di" bpmnElement="T_Measures">
        <dc:Bounds x="2900" y="380" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_Compile_Join_di" bpmnElement="GW_Compile_Join" isMarkerVisible="true">
        <dc:Bounds x="3170" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_Views_di" bpmnElement="GW_Views" isMarkerVisible="true">
        <dc:Bounds x="3300" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_RequestViews_di" bpmnElement="T_RequestViews">
        <dc:Bounds x="3410" y="70" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_Views_Merge_di" bpmnElement="GW_Views_Merge" isMarkerVisible="true">
        <dc:Bounds x="3680" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T_Finalize_di" bpmnElement="T_Finalize">
        <dc:Bounds x="3790" y="170" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_Review_di" bpmnElement="GW_Review" isMarkerVisible="true">
