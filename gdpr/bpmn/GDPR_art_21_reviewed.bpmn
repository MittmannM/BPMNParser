<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art21_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_Art21_Reviewed">
    <bpmn:participant id="Participant_Controller_Art21" name="Controller" processRef="Process_Controller_Art21" />
    <bpmn:participant id="Participant_DataSubject_Art21" name="Data Subject" />

    <bpmn:messageFlow id="MessageFlow_InformRightToObject_Art21" sourceRef="SendTask_InformRightToObject_Art21" targetRef="Participant_DataSubject_Art21" />
    <bpmn:messageFlow id="MessageFlow_ReceiveObjection_Art21" sourceRef="Participant_DataSubject_Art21" targetRef="ReceiveTask_ReceiveObjection_Art21" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Controller_Art21" name="Handling the right to object under Article 21" isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 21 based on the English legal text of
      Regulation (EU) 2016/679. The model separates the proactive duty to bring the
      Article 21(1) and 21(2) rights to object to the data subject's attention from the
      later objection-handling logic. The visible gateways preserve the article's own
      cross-references to Article 6(1)(e), Article 6(1)(f), and Article 89(1), as well
      as the special branches for direct marketing, information society services, and
      the public-interest limitation for research and statistics processing.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_FirstCommunication_Art21" name="The first communication with the data subject is prepared">
      <bpmn:outgoing>Flow_StartFirstCommunication_To_SendTaskInformRightToObject_Art21</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sendTask id="SendTask_InformRightToObject_Art21" name="Inform data subject of right to object">
      <bpmn:incoming>Flow_StartFirstCommunication_To_SendTaskInformRightToObject_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskInformRightToObject_To_GatewayInfoSocietyServices_Art21</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_InfoSocietyServices_Art21" name="Are information society services used?">
      <bpmn:incoming>Flow_SendTaskInformRightToObject_To_GatewayInfoSocietyServices_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayInfoSocietyServices_To_EndNoticeCompleted_Art21</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayInfoSocietyServices_To_TaskEnableAutomatedObjection_Art21</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_EnableAutomatedObjection_Art21" name="Enable automated objection">
      <bpmn:incoming>Flow_GatewayInfoSocietyServices_To_TaskEnableAutomatedObjection_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskEnableAutomatedObjection_To_EndNoticeCompleted_Art21</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_NoticeCompleted_Art21" name="Article 21 notice handling is completed">
      <bpmn:incoming>Flow_GatewayInfoSocietyServices_To_EndNoticeCompleted_Art21</bpmn:incoming>
      <bpmn:incoming>Flow_TaskEnableAutomatedObjection_To_EndNoticeCompleted_Art21</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="StartEvent_ObjectionExercise_Art21" name="The data subject seeks to exercise the right to object">
      <bpmn:outgoing>Flow_StartObjectionExercise_To_ReceiveTaskReceiveObjection_Art21</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveObjection_Art21" name="Receive objection">
      <bpmn:incoming>Flow_StartObjectionExercise_To_ReceiveTaskReceiveObjection_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveObjection_To_GatewayDirectMarketing_Art21</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_DirectMarketing_Art21" name="Is the objection directed at direct marketing, including profiling related to such direct marketing?">
      <bpmn:incoming>Flow_ReceiveTaskReceiveObjection_To_GatewayDirectMarketing_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayDirectMarketing_To_TaskStopDirectMarketing_Art21</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayDirectMarketing_To_TaskRecordParticularSituation_Art21</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_StopDirectMarketing_Art21" name="Stop direct marketing processing">
      <bpmn:incoming>Flow_GatewayDirectMarketing_To_TaskStopDirectMarketing_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskStopDirectMarketing_To_EndDirectMarketingStopped_Art21</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_DirectMarketingStopped_Art21" name="Direct marketing processing is stopped">
      <bpmn:incoming>Flow_TaskStopDirectMarketing_To_EndDirectMarketingStopped_Art21</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_RecordParticularSituation_Art21" name="Record particular-situation grounds">
      <bpmn:incoming>Flow_GatewayDirectMarketing_To_TaskRecordParticularSituation_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRecordParticularSituation_To_GatewayArticle6Basis_Art21</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Article6Basis_Art21" name="Is the processing based on Article 6(1)(e) or Article 6(1)(f), including profiling based on those provisions?">
      <bpmn:incoming>Flow_TaskRecordParticularSituation_To_GatewayArticle6Basis_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayArticle6Basis_To_TaskAssessOverridingGrounds_Art21</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayArticle6Basis_To_GatewayResearchStats_Art21</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessOverridingGrounds_Art21" name="Assess overriding grounds">
      <bpmn:incoming>Flow_GatewayArticle6Basis_To_TaskAssessOverridingGrounds_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessOverridingGrounds_To_GatewayOverridingGrounds_Art21</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_OverridingGrounds_Art21" name="Does the controller demonstrate overriding grounds or a need to establish, exercise, or defend legal claims?">
      <bpmn:incoming>Flow_TaskAssessOverridingGrounds_To_GatewayOverridingGrounds_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayOverridingGrounds_To_EndContinueProcessing_Art21</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayOverridingGrounds_To_TaskStopArticle6Processing_Art21</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_ContinueProcessing_Art21" name="Processing may continue because overriding grounds or legal claims were demonstrated">
      <bpmn:incoming>Flow_GatewayOverridingGrounds_To_EndContinueProcessing_Art21</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_StopArticle6Processing_Art21" name="Stop Article 6(1)(e)/(f) processing">
      <bpmn:incoming>Flow_GatewayOverridingGrounds_To_TaskStopArticle6Processing_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskStopArticle6Processing_To_EndArticle6ProcessingStopped_Art21</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_Article6ProcessingStopped_Art21" name="Article 21(1) processing is stopped">
      <bpmn:incoming>Flow_TaskStopArticle6Processing_To_EndArticle6ProcessingStopped_Art21</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_ResearchStats_Art21" name="Is the processing for scientific or historical research purposes or statistical purposes pursuant to Article 89(1)?">
      <bpmn:incoming>Flow_GatewayArticle6Basis_To_GatewayResearchStats_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayResearchStats_To_GatewayPublicInterestTask_Art21</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayResearchStats_To_EndNoApplicableContext_Art21</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_PublicInterestTask_Art21" name="Is the processing necessary for the performance of a task carried out for reasons of public interest?">
      <bpmn:incoming>Flow_GatewayResearchStats_To_GatewayPublicInterestTask_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayPublicInterestTask_To_EndResearchContinue_Art21</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayPublicInterestTask_To_TaskStopResearchProcessing_Art21</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_ResearchContinue_Art21" name="Research or statistics processing may continue because it is necessary for a public-interest task">
      <bpmn:incoming>Flow_GatewayPublicInterestTask_To_EndResearchContinue_Art21</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_StopResearchProcessing_Art21" name="Stop Article 89(1) processing">
      <bpmn:incoming>Flow_GatewayPublicInterestTask_To_TaskStopResearchProcessing_Art21</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskStopResearchProcessing_To_EndResearchStopped_Art21</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_ResearchStopped_Art21" name="Research or statistics processing is stopped">
      <bpmn:incoming>Flow_TaskStopResearchProcessing_To_EndResearchStopped_Art21</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_NoApplicableContext_Art21" name="No applicable Article 21 objection context was established">
      <bpmn:incoming>Flow_GatewayResearchStats_To_EndNoApplicableContext_Art21</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartFirstCommunication_To_SendTaskInformRightToObject_Art21" sourceRef="StartEvent_FirstCommunication_Art21" targetRef="SendTask_InformRightToObject_Art21" />
    <bpmn:sequenceFlow id="Flow_SendTaskInformRightToObject_To_GatewayInfoSocietyServices_Art21" sourceRef="SendTask_InformRightToObject_Art21" targetRef="Gateway_InfoSocietyServices_Art21" />
    <bpmn:sequenceFlow id="Flow_GatewayInfoSocietyServices_To_EndNoticeCompleted_Art21" name="No" sourceRef="Gateway_InfoSocietyServices_Art21" targetRef="EndEvent_NoticeCompleted_Art21" />
    <bpmn:sequenceFlow id="Flow_GatewayInfoSocietyServices_To_TaskEnableAutomatedObjection_Art21" name="Yes" sourceRef="Gateway_InfoSocietyServices_Art21" targetRef="Task_EnableAutomatedObjection_Art21" />
    <bpmn:sequenceFlow id="Flow_TaskEnableAutomatedObjection_To_EndNoticeCompleted_Art21" sourceRef="Task_EnableAutomatedObjection_Art21" targetRef="EndEvent_NoticeCompleted_Art21" />

    <bpmn:sequenceFlow id="Flow_StartObjectionExercise_To_ReceiveTaskReceiveObjection_Art21" sourceRef="StartEvent_ObjectionExercise_Art21" targetRef="ReceiveTask_ReceiveObjection_Art21" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveObjection_To_GatewayDirectMarketing_Art21" sourceRef="ReceiveTask_ReceiveObjection_Art21" targetRef="Gateway_DirectMarketing_Art21" />
    <bpmn:sequenceFlow id="Flow_GatewayDirectMarketing_To_TaskStopDirectMarketing_Art21" name="Yes" sourceRef="Gateway_DirectMarketing_Art21" targetRef="Task_StopDirectMarketing_Art21" />
    <bpmn:sequenceFlow id="Flow_GatewayDirectMarketing_To_TaskRecordParticularSituation_Art21" name="No" sourceRef="Gateway_DirectMarketing_Art21" targetRef="Task_RecordParticularSituation_Art21" />
    <bpmn:sequenceFlow id="Flow_TaskStopDirectMarketing_To_EndDirectMarketingStopped_Art21" sourceRef="Task_StopDirectMarketing_Art21" targetRef="EndEvent_DirectMarketingStopped_Art21" />
    <bpmn:sequenceFlow id="Flow_TaskRecordParticularSituation_To_GatewayArticle6Basis_Art21" sourceRef="Task_RecordParticularSituation_Art21" targetRef="Gateway_Article6Basis_Art21" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle6Basis_To_TaskAssessOverridingGrounds_Art21" name="Yes" sourceRef="Gateway_Article6Basis_Art21" targetRef="Task_AssessOverridingGrounds_Art21" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle6Basis_To_GatewayResearchStats_Art21" name="No" sourceRef="Gateway_Article6Basis_Art21" targetRef="Gateway_ResearchStats_Art21" />
    <bpmn:sequenceFlow id="Flow_TaskAssessOverridingGrounds_To_GatewayOverridingGrounds_Art21" sourceRef="Task_AssessOverridingGrounds_Art21" targetRef="Gateway_OverridingGrounds_Art21" />
    <bpmn:sequenceFlow id="Flow_GatewayOverridingGrounds_To_EndContinueProcessing_Art21" name="Yes" sourceRef="Gateway_OverridingGrounds_Art21" targetRef="EndEvent_ContinueProcessing_Art21" />
    <bpmn:sequenceFlow id="Flow_GatewayOverridingGrounds_To_TaskStopArticle6Processing_Art21" name="No" sourceRef="Gateway_OverridingGrounds_Art21" targetRef="Task_StopArticle6Processing_Art21" />
    <bpmn:sequenceFlow id="Flow_TaskStopArticle6Processing_To_EndArticle6ProcessingStopped_Art21" sourceRef="Task_StopArticle6Processing_Art21" targetRef="EndEvent_Article6ProcessingStopped_Art21" />
    <bpmn:sequenceFlow id="Flow_GatewayResearchStats_To_GatewayPublicInterestTask_Art21" name="Yes" sourceRef="Gateway_ResearchStats_Art21" targetRef="Gateway_PublicInterestTask_Art21" />
    <bpmn:sequenceFlow id="Flow_GatewayResearchStats_To_EndNoApplicableContext_Art21" name="No" sourceRef="Gateway_ResearchStats_Art21" targetRef="EndEvent_NoApplicableContext_Art21" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicInterestTask_To_EndResearchContinue_Art21" name="Yes" sourceRef="Gateway_PublicInterestTask_Art21" targetRef="EndEvent_ResearchContinue_Art21" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicInterestTask_To_TaskStopResearchProcessing_Art21" name="No" sourceRef="Gateway_PublicInterestTask_Art21" targetRef="Task_StopResearchProcessing_Art21" />
    <bpmn:sequenceFlow id="Flow_TaskStopResearchProcessing_To_EndResearchStopped_Art21" sourceRef="Task_StopResearchProcessing_Art21" targetRef="EndEvent_ResearchStopped_Art21" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art21_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art21_Reviewed" bpmnElement="Collaboration_Art21_Reviewed">
      <bpmndi:BPMNShape id="Participant_Controller_Art21_di" bpmnElement="Participant_Controller_Art21" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="6200" height="980" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art21_di" bpmnElement="Participant_DataSubject_Art21" isHorizontal="true">
        <dc:Bounds x="60" y="1060" width="6200" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_FirstCommunication_Art21_di" bpmnElement="StartEvent_FirstCommunication_Art21">
        <dc:Bounds x="120" y="172" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_InformRightToObject_Art21_di" bpmnElement="SendTask_InformRightToObject_Art21">
        <dc:Bounds x="240" y="150" width="520" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_InfoSocietyServices_Art21_di" bpmnElement="Gateway_InfoSocietyServices_Art21" isMarkerVisible="true">
        <dc:Bounds x="860" y="165" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EnableAutomatedObjection_Art21_di" bpmnElement="Task_EnableAutomatedObjection_Art21">
        <dc:Bounds x="1040" y="260" width="430" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoticeCompleted_Art21_di" bpmnElement="EndEvent_NoticeCompleted_Art21">
        <dc:Bounds x="1632" y="172" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_ObjectionExercise_Art21_di" bpmnElement="StartEvent_ObjectionExercise_Art21">
        <dc:Bounds x="120" y="632" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveObjection_Art21_di" bpmnElement="ReceiveTask_ReceiveObjection_Art21">
        <dc:Bounds x="240" y="610" width="330" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DirectMarketing_Art21_di" bpmnElement="Gateway_DirectMarketing_Art21" isMarkerVisible="true">
        <dc:Bounds x="680" y="625" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_StopDirectMarketing_Art21_di" bpmnElement="Task_StopDirectMarketing_Art21">
        <dc:Bounds x="860" y="480" width="440" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_DirectMarketingStopped_Art21_di" bpmnElement="EndEvent_DirectMarketingStopped_Art21">
        <dc:Bounds x="1462" y="502" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordParticularSituation_Art21_di" bpmnElement="Task_RecordParticularSituation_Art21">
        <dc:Bounds x="860" y="610" width="430" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Article6Basis_Art21_di" bpmnElement="Gateway_Article6Basis_Art21" isMarkerVisible="true">
        <dc:Bounds x="1400" y="625" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessOverridingGrounds_Art21_di" bpmnElement="Task_AssessOverridingGrounds_Art21">
        <dc:Bounds x="1600" y="480" width="480" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_OverridingGrounds_Art21_di" bpmnElement="Gateway_OverridingGrounds_Art21" isMarkerVisible="true">
        <dc:Bounds x="2190" y="495" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ContinueProcessing_Art21_di" bpmnElement="EndEvent_ContinueProcessing_Art21">
        <dc:Bounds x="2482" y="502" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_StopArticle6Processing_Art21_di" bpmnElement="Task_StopArticle6Processing_Art21">
        <dc:Bounds x="2440" y="610" width="450" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Article6ProcessingStopped_Art21_di" bpmnElement="EndEvent_Article6ProcessingStopped_Art21">
        <dc:Bounds x="2982" y="632" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ResearchStats_Art21_di" bpmnElement="Gateway_ResearchStats_Art21" isMarkerVisible="true">
        <dc:Bounds x="1600" y="755" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PublicInterestTask_Art21_di" bpmnElement="Gateway_PublicInterestTask_Art21" isMarkerVisible="true">
        <dc:Bounds x="2190" y="755" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ResearchContinue_Art21_di" bpmnElement="EndEvent_ResearchContinue_Art21">
        <dc:Bounds x="2482" y="762" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_StopResearchProcessing_Art21_di" bpmnElement="Task_StopResearchProcessing_Art21">
        <dc:Bounds x="2440" y="870" width="450" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ResearchStopped_Art21_di" bpmnElement="EndEvent_ResearchStopped_Art21">
        <dc:Bounds x="2982" y="892" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoApplicableContext_Art21_di" bpmnElement="EndEvent_NoApplicableContext_Art21">
        <dc:Bounds x="1892" y="917" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_StartFirstCommunication_To_SendTaskInformRightToObject_Art21_di" bpmnElement="Flow_StartFirstCommunication_To_SendTaskInformRightToObject_Art21">
        <di:waypoint x="156" y="190" />
        <di:waypoint x="240" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SendTaskInformRightToObject_To_GatewayInfoSocietyServices_Art21_di" bpmnElement="Flow_SendTaskInformRightToObject_To_GatewayInfoSocietyServices_Art21">
        <di:waypoint x="760" y="190" />
        <di:waypoint x="860" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayInfoSocietyServices_To_EndNoticeCompleted_Art21_di" bpmnElement="Flow_GatewayInfoSocietyServices_To_EndNoticeCompleted_Art21">
        <di:waypoint x="910" y="190" />
        <di:waypoint x="1632" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayInfoSocietyServices_To_TaskEnableAutomatedObjection_Art21_di" bpmnElement="Flow_GatewayInfoSocietyServices_To_TaskEnableAutomatedObjection_Art21">
        <di:waypoint x="885" y="215" />
        <di:waypoint x="885" y="300" />
        <di:waypoint x="1040" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskEnableAutomatedObjection_To_EndNoticeCompleted_Art21_di" bpmnElement="Flow_TaskEnableAutomatedObjection_To_EndNoticeCompleted_Art21">
        <di:waypoint x="1470" y="300" />
        <di:waypoint x="1560" y="300" />
        <di:waypoint x="1560" y="190" />
        <di:waypoint x="1632" y="190" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_StartObjectionExercise_To_ReceiveTaskReceiveObjection_Art21_di" bpmnElement="Flow_StartObjectionExercise_To_ReceiveTaskReceiveObjection_Art21">
        <di:waypoint x="156" y="650" />
        <di:waypoint x="240" y="650" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReceiveTaskReceiveObjection_To_GatewayDirectMarketing_Art21_di" bpmnElement="Flow_ReceiveTaskReceiveObjection_To_GatewayDirectMarketing_Art21">
        <di:waypoint x="570" y="650" />
        <di:waypoint x="680" y="650" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayDirectMarketing_To_TaskStopDirectMarketing_Art21_di" bpmnElement="Flow_GatewayDirectMarketing_To_TaskStopDirectMarketing_Art21">
        <di:waypoint x="705" y="625" />
        <di:waypoint x="705" y="520" />
        <di:waypoint x="860" y="520" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayDirectMarketing_To_TaskRecordParticularSituation_Art21_di" bpmnElement="Flow_GatewayDirectMarketing_To_TaskRecordParticularSituation_Art21">
        <di:waypoint x="730" y="650" />
        <di:waypoint x="860" y="650" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskStopDirectMarketing_To_EndDirectMarketingStopped_Art21_di" bpmnElement="Flow_TaskStopDirectMarketing_To_EndDirectMarketingStopped_Art21">
        <di:waypoint x="1300" y="520" />
        <di:waypoint x="1462" y="520" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskRecordParticularSituation_To_GatewayArticle6Basis_Art21_di" bpmnElement="Flow_TaskRecordParticularSituation_To_GatewayArticle6Basis_Art21">
        <di:waypoint x="1290" y="650" />
        <di:waypoint x="1400" y="650" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayArticle6Basis_To_TaskAssessOverridingGrounds_Art21_di" bpmnElement="Flow_GatewayArticle6Basis_To_TaskAssessOverridingGrounds_Art21">
        <di:waypoint x="1425" y="625" />
        <di:waypoint x="1425" y="520" />
