      <bpmndi:BPMNShape id="Gateway_JoinSupplementaryInfo_Art13_di" bpmnElement="Gateway_JoinSupplementaryInfo_Art13" isMarkerVisible="true"><dc:Bounds x="3470" y="375" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_SendInitialNotice_Art13_di" bpmnElement="SendTask_SendInitialNotice_Art13"><dc:Bounds x="3640" y="360" width="420" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_FurtherPurpose_Art13_di" bpmnElement="Gateway_FurtherPurpose_Art13" isMarkerVisible="true"><dc:Bounds x="4200" y="375" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_SendFurtherPurposeNotice_Art13_di" bpmnElement="SendTask_SendFurtherPurposeNotice_Art13"><dc:Bounds x="4380" y="210" width="460" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_InformationDutiesCompleted_Art13_di" bpmnElement="EndEvent_InformationDutiesCompleted_Art13"><dc:Bounds x="4872" y="382" width="36" height="36" /></bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_TaskPrepareIdentity_Art13_di" bpmnElement="Flow_Start_To_TaskPrepareIdentity_Art13"><di:waypoint x="156" y="400" /><di:waypoint x="240" y="400" /></bpmndi:BPMNEdge>
