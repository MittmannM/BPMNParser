      <bpmndi:BPMNShape id="Task_PrepareRecipients_Art13_di" bpmnElement="Task_PrepareRecipients_Art13"><dc:Bounds x="1820" y="360" width="390" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ThirdCountryTransfer_Art13_di" bpmnElement="Gateway_ThirdCountryTransfer_Art13" isMarkerVisible="true"><dc:Bounds x="2310" y="375" width="50" height="50" /></bpmndi:BPMNShape>
