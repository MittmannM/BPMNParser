      <bpmndi:BPMNShape id="Gateway_LegitimateInterests_Art13_di" bpmnElement="Gateway_LegitimateInterests_Art13" isMarkerVisible="true"><dc:Bounds x="1670" y="375" width="50" height="50" /></bpmndi:BPMNShape>
