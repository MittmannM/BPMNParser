      <bpmndi:BPMNEdge id="Flow_GatewayLegitimateInterests_To_TaskPrepareRecipients_Art13_di" bpmnElement="Flow_GatewayLegitimateInterests_To_TaskPrepareRecipients_Art13"><di:waypoint x="1720" y="400" /><di:waypoint x="1820" y="400" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskPrepareLegitimateInterests_To_TaskPrepareRecipients_Art13_di" bpmnElement="Flow_TaskPrepareLegitimateInterests_To_TaskPrepareRecipients_Art13"><di:waypoint x="2200" y="250" /><di:waypoint x="2250" y="250" /><di:waypoint x="2250" y="400" /><di:waypoint x="1820" y="400" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskPrepareRecipients_To_GatewayThirdCountryTransfer_Art13_di" bpmnElement="Flow_TaskPrepareRecipients_To_GatewayThirdCountryTransfer_Art13"><di:waypoint x="2210" y="400" /><di:waypoint x="2310" y="400" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayThirdCountryTransfer_To_TaskPrepareTransferInfo_Art13_di" bpmnElement="Flow_GatewayThirdCountryTransfer_To_TaskPrepareTransferInfo_Art13"><di:waypoint x="2335" y="425" /><di:waypoint x="2335" y="600" /><di:waypoint x="2470" y="600" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayThirdCountryTransfer_To_GatewaySplitSupplementaryInfo_Art13_di" bpmnElement="Flow_GatewayThirdCountryTransfer_To_GatewaySplitSupplementaryInfo_Art13"><di:waypoint x="2360" y="400" /><di:waypoint x="2470" y="400" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskPrepareTransferInfo_To_GatewaySplitSupplementaryInfo_Art13_di" bpmnElement="Flow_TaskPrepareTransferInfo_To_GatewaySplitSupplementaryInfo_Art13"><di:waypoint x="2700" y="560" /><di:waypoint x="2700" y="520" /><di:waypoint x="2495" y="520" /><di:waypoint x="2495" y="425" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitSupplementaryInfo_To_TaskPrepareRetentionInfo_Art13_di" bpmnElement="Flow_GatewaySplitSupplementaryInfo_To_TaskPrepareRetentionInfo_Art13"><di:waypoint x="2495" y="375" /><di:waypoint x="2495" y="80" /><di:waypoint x="2700" y="80" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitSupplementaryInfo_To_TaskPrepareRightsInfo_Art13_di" bpmnElement="Flow_GatewaySplitSupplementaryInfo_To_TaskPrepareRightsInfo_Art13"><di:waypoint x="2495" y="375" /><di:waypoint x="2495" y="210" /><di:waypoint x="2700" y="210" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitSupplementaryInfo_To_TaskPrepareProvisionInfo_Art13_di" bpmnElement="Flow_GatewaySplitSupplementaryInfo_To_TaskPrepareProvisionInfo_Art13"><di:waypoint x="2520" y="400" /><di:waypoint x="2700" y="340" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitSupplementaryInfo_To_TaskPrepareAutomatedDecisionInfo_Art13_di" bpmnElement="Flow_GatewaySplitSupplementaryInfo_To_TaskPrepareAutomatedDecisionInfo_Art13"><di:waypoint x="2495" y="425" /><di:waypoint x="2495" y="470" /><di:waypoint x="2700" y="470" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskPrepareRetentionInfo_To_GatewayJoinSupplementaryInfo_Art13_di" bpmnElement="Flow_TaskPrepareRetentionInfo_To_GatewayJoinSupplementaryInfo_Art13"><di:waypoint x="3080" y="80" /><di:waypoint x="3495" y="80" /><di:waypoint x="3495" y="375" /></bpmndi:BPMNEdge>
