<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art15_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_Art15_Reviewed">
    <bpmn:participant id="Participant_Controller_Art15" name="Controller" processRef="Process_Controller_Art15" />
    <bpmn:participant id="Participant_DataSubject_Art15" name="Data Subject" />

    <bpmn:messageFlow id="MessageFlow_ReceiveAccessRequest_Art15" sourceRef="Participant_DataSubject_Art15" targetRef="ReceiveTask_ReceiveAccessRequest_Art15" />
    <bpmn:messageFlow id="MessageFlow_SendNoProcessingConfirmation_Art15" sourceRef="SendTask_SendNoProcessingConfirmation_Art15" targetRef="Participant_DataSubject_Art15" />
    <bpmn:messageFlow id="MessageFlow_SendElectronicAccessResponse_Art15" sourceRef="SendTask_SendElectronicAccessResponse_Art15" targetRef="Participant_DataSubject_Art15" />
    <bpmn:messageFlow id="MessageFlow_SendRequestedFormatAccessResponse_Art15" sourceRef="SendTask_SendRequestedFormatAccessResponse_Art15" targetRef="Participant_DataSubject_Art15" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Controller_Art15" name="Handling the data subject's right of access" isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 15 based on DAPRECO LegalRuleML
      statements72-82. The local XML mainly serializes the positive access-response
      path once the controller is aware of the request and Articles 12(2) and 11(2)
      do not block the request. The BPMN therefore models the detailed Article 15(1)
      information bundle, the Article 15(2) safeguards information for transfers, the
      Article 15(3) copy path with first-copy and additional-copy handling plus the
      electronic-format rule, and the Article 15(4) limitation based on the rights and
      freedoms of others. A no-processing confirmation branch is included as a
      transparent supplement from the Article 15 text because the local XML focuses on
      the positive access case.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_AccessRequest_Art15" name="Data subject seeks access to personal data">
      <bpmn:outgoing>Flow_Start_To_ReceiveTaskReceiveAccessRequest_Art15</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAccessRequest_Art15" name="Receive the access request">
      <bpmn:incoming>Flow_Start_To_ReceiveTaskReceiveAccessRequest_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveAccessRequest_To_GatewayExceptions_Art15</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_Exceptions_Art15" name="Do Article 12(2) or Article 11(2) exceptions prevent handling the access request?">
      <bpmn:incoming>Flow_ReceiveTaskReceiveAccessRequest_To_GatewayExceptions_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayExceptions_To_EndExceptionBlocksAccess_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayExceptions_To_TaskAssessProcessing_Art15</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessProcessing_Art15" name="Assess whether personal data concerning the data subject are being processed">
      <bpmn:incoming>Flow_GatewayExceptions_To_TaskAssessProcessing_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessProcessing_To_GatewayProcessingOccurs_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ProcessingOccurs_Art15" name="Are personal data concerning the data subject being processed?">
      <bpmn:incoming>Flow_TaskAssessProcessing_To_GatewayProcessingOccurs_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayProcessingOccurs_To_GatewaySplitAccessInfo_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayProcessingOccurs_To_SendTaskSendNoProcessingConfirmation_Art15</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_SendNoProcessingConfirmation_Art15" name="Confirm that no personal data concerning the data subject are being processed">
      <bpmn:incoming>Flow_GatewayProcessingOccurs_To_SendTaskSendNoProcessingConfirmation_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendNoProcessingConfirmation_To_EndAccessHandled_Art15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:parallelGateway id="Gateway_SplitAccessInfo_Art15">
      <bpmn:incoming>Flow_GatewayProcessingOccurs_To_GatewaySplitAccessInfo_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitAccessInfo_To_TaskPreparePurposes_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAccessInfo_To_TaskPrepareCategories_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAccessInfo_To_TaskPrepareRecipients_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAccessInfo_To_TaskPrepareStorageInfo_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAccessInfo_To_TaskPrepareRightsInfo_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAccessInfo_To_TaskPrepareComplaintInfo_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAccessInfo_To_TaskPrepareSourceInfo_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAccessInfo_To_TaskPrepareAutomatedDecisionInfo_Art15</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_PreparePurposes_Art15" name="Prepare information about the purposes of the processing">
      <bpmn:incoming>Flow_GatewaySplitAccessInfo_To_TaskPreparePurposes_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPreparePurposes_To_GatewayJoinAccessInfo_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepareCategories_Art15" name="Prepare information about the categories of personal data concerned">
      <bpmn:incoming>Flow_GatewaySplitAccessInfo_To_TaskPrepareCategories_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareCategories_To_GatewayJoinAccessInfo_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepareRecipients_Art15" name="Prepare information about recipients or categories of recipients, including recipients in third countries or international organisations where relevant">
      <bpmn:incoming>Flow_GatewaySplitAccessInfo_To_TaskPrepareRecipients_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareRecipients_To_GatewayJoinAccessInfo_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepareStorageInfo_Art15" name="Prepare the envisaged storage period or, if not possible, the criteria used to determine it">
      <bpmn:incoming>Flow_GatewaySplitAccessInfo_To_TaskPrepareStorageInfo_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareStorageInfo_To_GatewayJoinAccessInfo_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepareRightsInfo_Art15" name="Prepare information about rectification, erasure, restriction, and objection rights">
      <bpmn:incoming>Flow_GatewaySplitAccessInfo_To_TaskPrepareRightsInfo_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareRightsInfo_To_GatewayJoinAccessInfo_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepareComplaintInfo_Art15" name="Prepare information about the right to lodge a complaint with a supervisory authority">
      <bpmn:incoming>Flow_GatewaySplitAccessInfo_To_TaskPrepareComplaintInfo_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareComplaintInfo_To_GatewayJoinAccessInfo_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepareSourceInfo_Art15" name="Prepare information about the source of the personal data if the data were not collected from the data subject">
      <bpmn:incoming>Flow_GatewaySplitAccessInfo_To_TaskPrepareSourceInfo_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareSourceInfo_To_GatewayJoinAccessInfo_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepareAutomatedDecisionInfo_Art15" name="Prepare information about automated decision-making, including profiling, the logic involved, and the significance and envisaged consequences">
      <bpmn:incoming>Flow_GatewaySplitAccessInfo_To_TaskPrepareAutomatedDecisionInfo_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareAutomatedDecisionInfo_To_GatewayJoinAccessInfo_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinAccessInfo_Art15">
      <bpmn:incoming>Flow_TaskPreparePurposes_To_GatewayJoinAccessInfo_Art15</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPrepareCategories_To_GatewayJoinAccessInfo_Art15</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPrepareRecipients_To_GatewayJoinAccessInfo_Art15</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPrepareStorageInfo_To_GatewayJoinAccessInfo_Art15</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPrepareRightsInfo_To_GatewayJoinAccessInfo_Art15</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPrepareComplaintInfo_To_GatewayJoinAccessInfo_Art15</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPrepareSourceInfo_To_GatewayJoinAccessInfo_Art15</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPrepareAutomatedDecisionInfo_To_GatewayJoinAccessInfo_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinAccessInfo_To_GatewayTransferSafeguards_Art15</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:exclusiveGateway id="Gateway_TransferSafeguards_Art15" name="Were personal data transferred to a third country or an international organisation?">
      <bpmn:incoming>Flow_GatewayJoinAccessInfo_To_GatewayTransferSafeguards_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayTransferSafeguards_To_TaskPrepareTransferSafeguards_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayTransferSafeguards_To_TaskPrepareCopy_Art15</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_PrepareTransferSafeguards_Art15" name="Prepare information about the appropriate safeguards for the transfer">
      <bpmn:incoming>Flow_GatewayTransferSafeguards_To_TaskPrepareTransferSafeguards_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareTransferSafeguards_To_TaskPrepareCopy_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepareCopy_Art15" name="Prepare a copy of the personal data undergoing processing">
      <bpmn:incoming>Flow_GatewayTransferSafeguards_To_TaskPrepareCopy_Art15</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPrepareTransferSafeguards_To_TaskPrepareCopy_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareCopy_To_GatewayProtectOthers_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ProtectOthers_Art15" name="Would providing the copy adversely affect the rights and freedoms of others?">
      <bpmn:incoming>Flow_TaskPrepareCopy_To_GatewayProtectOthers_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayProtectOthers_To_TaskLimitCopy_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayProtectOthers_To_GatewayAdditionalCopies_Art15</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_LimitCopy_Art15" name="Limit or protect the copy so that the rights and freedoms of others are not adversely affected">
      <bpmn:incoming>Flow_GatewayProtectOthers_To_TaskLimitCopy_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskLimitCopy_To_GatewayAdditionalCopies_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_AdditionalCopies_Art15" name="Did the data subject request additional copies?">
      <bpmn:incoming>Flow_GatewayProtectOthers_To_GatewayAdditionalCopies_Art15</bpmn:incoming>
      <bpmn:incoming>Flow_TaskLimitCopy_To_GatewayAdditionalCopies_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAdditionalCopies_To_TaskChargeReasonableFee_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAdditionalCopies_To_GatewayElectronicRequest_Art15</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ChargeReasonableFee_Art15" name="Charge a reasonable fee for additional copies based on administrative costs">
      <bpmn:incoming>Flow_GatewayAdditionalCopies_To_TaskChargeReasonableFee_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskChargeReasonableFee_To_GatewayElectronicRequest_Art15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ElectronicRequest_Art15" name="Was the request made by electronic means and has no other format been requested?">
      <bpmn:incoming>Flow_GatewayAdditionalCopies_To_GatewayElectronicRequest_Art15</bpmn:incoming>
      <bpmn:incoming>Flow_TaskChargeReasonableFee_To_GatewayElectronicRequest_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayElectronicRequest_To_SendTaskSendElectronicAccessResponse_Art15</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayElectronicRequest_To_SendTaskSendRequestedFormatAccessResponse_Art15</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_SendElectronicAccessResponse_Art15" name="Send the access response and the copy in a commonly used electronic form">
      <bpmn:incoming>Flow_GatewayElectronicRequest_To_SendTaskSendElectronicAccessResponse_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendElectronicAccessResponse_To_EndAccessHandled_Art15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_SendRequestedFormatAccessResponse_Art15" name="Send the access response and the copy in the requested non-electronic format">
      <bpmn:incoming>Flow_GatewayElectronicRequest_To_SendTaskSendRequestedFormatAccessResponse_Art15</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendRequestedFormatAccessResponse_To_EndAccessHandled_Art15</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_ExceptionBlocksAccess_Art15" name="The access request is not handled because Article 12(2) or Article 11(2) blocks the request">
      <bpmn:incoming>Flow_GatewayExceptions_To_EndExceptionBlocksAccess_Art15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_AccessHandled_Art15" name="Article 15 access handling is completed">
      <bpmn:incoming>Flow_SendTaskSendNoProcessingConfirmation_To_EndAccessHandled_Art15</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskSendElectronicAccessResponse_To_EndAccessHandled_Art15</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskSendRequestedFormatAccessResponse_To_EndAccessHandled_Art15</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_ReceiveTaskReceiveAccessRequest_Art15" sourceRef="StartEvent_AccessRequest_Art15" targetRef="ReceiveTask_ReceiveAccessRequest_Art15" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveAccessRequest_To_GatewayExceptions_Art15" sourceRef="ReceiveTask_ReceiveAccessRequest_Art15" targetRef="Gateway_Exceptions_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayExceptions_To_EndExceptionBlocksAccess_Art15" name="Yes" sourceRef="Gateway_Exceptions_Art15" targetRef="EndEvent_ExceptionBlocksAccess_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayExceptions_To_TaskAssessProcessing_Art15" name="No" sourceRef="Gateway_Exceptions_Art15" targetRef="Task_AssessProcessing_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskAssessProcessing_To_GatewayProcessingOccurs_Art15" sourceRef="Task_AssessProcessing_Art15" targetRef="Gateway_ProcessingOccurs_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayProcessingOccurs_To_GatewaySplitAccessInfo_Art15" name="Yes" sourceRef="Gateway_ProcessingOccurs_Art15" targetRef="Gateway_SplitAccessInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayProcessingOccurs_To_SendTaskSendNoProcessingConfirmation_Art15" name="No" sourceRef="Gateway_ProcessingOccurs_Art15" targetRef="SendTask_SendNoProcessingConfirmation_Art15" />
    <bpmn:sequenceFlow id="Flow_SendTaskSendNoProcessingConfirmation_To_EndAccessHandled_Art15" sourceRef="SendTask_SendNoProcessingConfirmation_Art15" targetRef="EndEvent_AccessHandled_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitAccessInfo_To_TaskPreparePurposes_Art15" sourceRef="Gateway_SplitAccessInfo_Art15" targetRef="Task_PreparePurposes_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitAccessInfo_To_TaskPrepareCategories_Art15" sourceRef="Gateway_SplitAccessInfo_Art15" targetRef="Task_PrepareCategories_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitAccessInfo_To_TaskPrepareRecipients_Art15" sourceRef="Gateway_SplitAccessInfo_Art15" targetRef="Task_PrepareRecipients_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitAccessInfo_To_TaskPrepareStorageInfo_Art15" sourceRef="Gateway_SplitAccessInfo_Art15" targetRef="Task_PrepareStorageInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitAccessInfo_To_TaskPrepareRightsInfo_Art15" sourceRef="Gateway_SplitAccessInfo_Art15" targetRef="Task_PrepareRightsInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitAccessInfo_To_TaskPrepareComplaintInfo_Art15" sourceRef="Gateway_SplitAccessInfo_Art15" targetRef="Task_PrepareComplaintInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitAccessInfo_To_TaskPrepareSourceInfo_Art15" sourceRef="Gateway_SplitAccessInfo_Art15" targetRef="Task_PrepareSourceInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitAccessInfo_To_TaskPrepareAutomatedDecisionInfo_Art15" sourceRef="Gateway_SplitAccessInfo_Art15" targetRef="Task_PrepareAutomatedDecisionInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskPreparePurposes_To_GatewayJoinAccessInfo_Art15" sourceRef="Task_PreparePurposes_Art15" targetRef="Gateway_JoinAccessInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskPrepareCategories_To_GatewayJoinAccessInfo_Art15" sourceRef="Task_PrepareCategories_Art15" targetRef="Gateway_JoinAccessInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskPrepareRecipients_To_GatewayJoinAccessInfo_Art15" sourceRef="Task_PrepareRecipients_Art15" targetRef="Gateway_JoinAccessInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskPrepareStorageInfo_To_GatewayJoinAccessInfo_Art15" sourceRef="Task_PrepareStorageInfo_Art15" targetRef="Gateway_JoinAccessInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskPrepareRightsInfo_To_GatewayJoinAccessInfo_Art15" sourceRef="Task_PrepareRightsInfo_Art15" targetRef="Gateway_JoinAccessInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskPrepareComplaintInfo_To_GatewayJoinAccessInfo_Art15" sourceRef="Task_PrepareComplaintInfo_Art15" targetRef="Gateway_JoinAccessInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskPrepareSourceInfo_To_GatewayJoinAccessInfo_Art15" sourceRef="Task_PrepareSourceInfo_Art15" targetRef="Gateway_JoinAccessInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskPrepareAutomatedDecisionInfo_To_GatewayJoinAccessInfo_Art15" sourceRef="Task_PrepareAutomatedDecisionInfo_Art15" targetRef="Gateway_JoinAccessInfo_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinAccessInfo_To_GatewayTransferSafeguards_Art15" sourceRef="Gateway_JoinAccessInfo_Art15" targetRef="Gateway_TransferSafeguards_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayTransferSafeguards_To_TaskPrepareTransferSafeguards_Art15" name="Yes" sourceRef="Gateway_TransferSafeguards_Art15" targetRef="Task_PrepareTransferSafeguards_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayTransferSafeguards_To_TaskPrepareCopy_Art15" name="No" sourceRef="Gateway_TransferSafeguards_Art15" targetRef="Task_PrepareCopy_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskPrepareTransferSafeguards_To_TaskPrepareCopy_Art15" sourceRef="Task_PrepareTransferSafeguards_Art15" targetRef="Task_PrepareCopy_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskPrepareCopy_To_GatewayProtectOthers_Art15" sourceRef="Task_PrepareCopy_Art15" targetRef="Gateway_ProtectOthers_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayProtectOthers_To_TaskLimitCopy_Art15" name="Yes" sourceRef="Gateway_ProtectOthers_Art15" targetRef="Task_LimitCopy_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayProtectOthers_To_GatewayAdditionalCopies_Art15" name="No" sourceRef="Gateway_ProtectOthers_Art15" targetRef="Gateway_AdditionalCopies_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskLimitCopy_To_GatewayAdditionalCopies_Art15" sourceRef="Task_LimitCopy_Art15" targetRef="Gateway_AdditionalCopies_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayAdditionalCopies_To_TaskChargeReasonableFee_Art15" name="Yes" sourceRef="Gateway_AdditionalCopies_Art15" targetRef="Task_ChargeReasonableFee_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayAdditionalCopies_To_GatewayElectronicRequest_Art15" name="No" sourceRef="Gateway_AdditionalCopies_Art15" targetRef="Gateway_ElectronicRequest_Art15" />
    <bpmn:sequenceFlow id="Flow_TaskChargeReasonableFee_To_GatewayElectronicRequest_Art15" sourceRef="Task_ChargeReasonableFee_Art15" targetRef="Gateway_ElectronicRequest_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayElectronicRequest_To_SendTaskSendElectronicAccessResponse_Art15" name="Yes" sourceRef="Gateway_ElectronicRequest_Art15" targetRef="SendTask_SendElectronicAccessResponse_Art15" />
    <bpmn:sequenceFlow id="Flow_GatewayElectronicRequest_To_SendTaskSendRequestedFormatAccessResponse_Art15" name="No" sourceRef="Gateway_ElectronicRequest_Art15" targetRef="SendTask_SendRequestedFormatAccessResponse_Art15" />
    <bpmn:sequenceFlow id="Flow_SendTaskSendElectronicAccessResponse_To_EndAccessHandled_Art15" sourceRef="SendTask_SendElectronicAccessResponse_Art15" targetRef="EndEvent_AccessHandled_Art15" />
    <bpmn:sequenceFlow id="Flow_SendTaskSendRequestedFormatAccessResponse_To_EndAccessHandled_Art15" sourceRef="SendTask_SendRequestedFormatAccessResponse_Art15" targetRef="EndEvent_AccessHandled_Art15" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art15_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art15_Reviewed" bpmnElement="Collaboration_Art15_Reviewed">
      <bpmndi:BPMNShape id="Participant_Controller_Art15_di" bpmnElement="Participant_Controller_Art15" isHorizontal="true"><dc:Bounds x="60" y="40" width="6400" height="860" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art15_di" bpmnElement="Participant_DataSubject_Art15" isHorizontal="true"><dc:Bounds x="60" y="940" width="6400" height="120" /></bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_AccessRequest_Art15_di" bpmnElement="StartEvent_AccessRequest_Art15"><dc:Bounds x="120" y="432" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveAccessRequest_Art15_di" bpmnElement="ReceiveTask_ReceiveAccessRequest_Art15"><dc:Bounds x="240" y="410" width="240" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Exceptions_Art15_di" bpmnElement="Gateway_Exceptions_Art15" isMarkerVisible="true"><dc:Bounds x="620" y="425" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessProcessing_Art15_di" bpmnElement="Task_AssessProcessing_Art15"><dc:Bounds x="820" y="410" width="350" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ProcessingOccurs_Art15_di" bpmnElement="Gateway_ProcessingOccurs_Art15" isMarkerVisible="true"><dc:Bounds x="1310" y="425" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_SendNoProcessingConfirmation_Art15_di" bpmnElement="SendTask_SendNoProcessingConfirmation_Art15"><dc:Bounds x="820" y="760" width="390" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SplitAccessInfo_Art15_di" bpmnElement="Gateway_SplitAccessInfo_Art15" isMarkerVisible="true"><dc:Bounds x="1480" y="425" width="50" height="50" /></bpmndi:BPMNShape>
