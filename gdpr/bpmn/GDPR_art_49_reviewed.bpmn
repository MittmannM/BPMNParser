<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art49_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art49_Reviewed">
    <bpmn:participant id="Participant_ControllerProcessor_Art49"
                      name="Controller or Processor"
                      processRef="Process_ControllerProcessor_Art49" />
    <bpmn:participant id="Participant_DataSubject_Art49"
                      name="Data Subject" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art49"
                      name="Supervisory Authority" />
    <bpmn:participant id="Participant_ThirdCountryRecipient_Art49"
                      name="Third-country recipient or requester" />
    <bpmn:messageFlow id="MessageFlow_InformRisks_Art49"
                      sourceRef="SendTask_InformDataSubjectAboutRisks_Art49"
                      targetRef="Participant_DataSubject_Art49" />
    <bpmn:messageFlow id="MessageFlow_ExplicitConsent_Art49"
                      sourceRef="Participant_DataSubject_Art49"
                      targetRef="ReceiveTask_ReceiveExplicitConsent_Art49" />
    <bpmn:messageFlow id="MessageFlow_InformFallbackTransfer_Art49"
                      sourceRef="SendTask_InformDataSubjectAboutFallbackTransfer_Art49"
                      targetRef="Participant_DataSubject_Art49" />
    <bpmn:messageFlow id="MessageFlow_InformSupervisoryAuthority_Art49"
                      sourceRef="SendTask_InformSupervisoryAuthority_Art49"
                      targetRef="Participant_SupervisoryAuthority_Art49" />
    <bpmn:messageFlow id="MessageFlow_TransferUnderDerogation_Art49"
                      sourceRef="SendTask_TransferUnderDerogation_Art49"
                      targetRef="Participant_ThirdCountryRecipient_Art49" />
  </bpmn:collaboration>

  <bpmn:process id="Process_ControllerProcessor_Art49"
                name="Assessing derogations for a transfer without Article 45 or 46 basis"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 49 based on DAPRECO LegalRuleML
      statements254-263 and cross-checked against the current Article 49 text and
      EDPB Guidelines 2/2018 on derogations of Article 49. The model represents the
      exceptional nature of Article 49: first verify that no Article 45 or 46 tool is
      available, then assess the specific derogation routes in Article 49(1), the
      additional public-register limitation in Article 49(2), the exclusion of points
      (a), (b), (c) and the fallback route for public authorities in Article 49(3), and
      the information plus documentation duties for the compelling-legitimate-interests
      route reflected in Article 49(1) second subparagraph and Article 49(6).
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_NeedExceptionalTransfer_Art49"
                     name="Need to assess a transfer to a third country or international organisation">
      <bpmn:outgoing>Flow_Start_To_GatewayPrimaryTool_Art49</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_PrimaryTransferTool_Art49"
                           name="Is an Article 45 adequacy decision or an Article 46 safeguard available?">
      <bpmn:incoming>Flow_Start_To_GatewayPrimaryTool_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayPrimaryTool_To_EndUsePrimaryTool_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayPrimaryTool_To_GatewayPublicAuthority_Art49</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_UsePrimaryTool_Art49"
                   name="Use the Article 45 or 46 transfer route instead of Article 49">
      <bpmn:incoming>Flow_GatewayPrimaryTool_To_EndUsePrimaryTool_Art49</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_PublicAuthorityPowers_Art49"
                           name="Is a public authority acting in the exercise of its public powers?">
      <bpmn:incoming>Flow_GatewayPrimaryTool_To_GatewayPublicAuthority_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayPublicAuthority_To_GatewayRestrictedDerogation_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayPublicAuthority_To_GatewayFullDerogation_Art49</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_FullDerogation_Art49"
                           name="Which Article 49 derogation applies?">
      <bpmn:incoming>Flow_GatewayPublicAuthority_To_GatewayFullDerogation_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayFullDerogation_To_InformRisks_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFullDerogation_To_VerifyDataSubjectContract_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFullDerogation_To_VerifyDataSubjectInterestContract_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFullDerogation_To_VerifyPublicInterest_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFullDerogation_To_VerifyLegalClaims_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFullDerogation_To_VerifyVitalInterests_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFullDerogation_To_AssessRegisterTransfer_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFullDerogation_To_AssessFallback_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFullDerogation_To_EndNoDerogation_Art49</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_RestrictedDerogation_Art49"
                           name="Which Article 49 derogation applies for the public authority?">
      <bpmn:incoming>Flow_GatewayPublicAuthority_To_GatewayRestrictedDerogation_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRestrictedDerogation_To_VerifyPublicInterest_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRestrictedDerogation_To_VerifyLegalClaims_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRestrictedDerogation_To_VerifyVitalInterests_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRestrictedDerogation_To_AssessRegisterTransfer_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRestrictedDerogation_To_EndNoDerogation_Art49</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NoDerogation_Art49"
                   name="No Article 49 derogation permits the transfer">
      <bpmn:incoming>Flow_GatewayFullDerogation_To_EndNoDerogation_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayRestrictedDerogation_To_EndNoDerogation_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayRegisterCompliant_To_EndNoDerogation_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayFallbackConditions_To_EndNoDerogation_Art49</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_InformDataSubjectAboutRisks_Art49"
                   name="Inform the data subject about the transfer risks due to the absence of adequacy and safeguards">
      <bpmn:incoming>Flow_GatewayFullDerogation_To_InformRisks_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_InformRisks_To_ReceiveExplicitConsent_Art49</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveExplicitConsent_Art49"
                      name="Receive the data subject's explicit consent to the proposed transfer">
      <bpmn:incoming>Flow_InformRisks_To_ReceiveExplicitConsent_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveExplicitConsent_To_GatewayTransferReady_Art49</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_VerifyDataSubjectContract_Art49"
               name="Verify that the transfer is necessary for the data subject's contract or requested pre-contractual measures">
      <bpmn:incoming>Flow_GatewayFullDerogation_To_VerifyDataSubjectContract_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_VerifyDataSubjectContract_To_GatewayTransferReady_Art49</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_VerifyDataSubjectInterestContract_Art49"
               name="Verify that the transfer is necessary for a contract concluded in the data subject's interest">
      <bpmn:incoming>Flow_GatewayFullDerogation_To_VerifyDataSubjectInterestContract_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_VerifyDataSubjectInterestContract_To_GatewayTransferReady_Art49</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_VerifyPublicInterest_Art49"
               name="Verify that the transfer is necessary for important reasons of public interest">
      <bpmn:incoming>Flow_GatewayFullDerogation_To_VerifyPublicInterest_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayRestrictedDerogation_To_VerifyPublicInterest_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_VerifyPublicInterest_To_GatewayTransferReady_Art49</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_VerifyLegalClaims_Art49"
               name="Verify that the transfer is necessary for the establishment, exercise, or defence of legal claims">
      <bpmn:incoming>Flow_GatewayFullDerogation_To_VerifyLegalClaims_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayRestrictedDerogation_To_VerifyLegalClaims_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_VerifyLegalClaims_To_GatewayTransferReady_Art49</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_VerifyVitalInterests_Art49"
               name="Verify that vital interests require the transfer and the data subject cannot give consent">
      <bpmn:incoming>Flow_GatewayFullDerogation_To_VerifyVitalInterests_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayRestrictedDerogation_To_VerifyVitalInterests_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_VerifyVitalInterests_To_GatewayTransferReady_Art49</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AssessRegisterTransfer_Art49"
               name="Assess whether the transfer from the register is lawfully consultable and limited to the permitted extract">
      <bpmn:incoming>Flow_GatewayFullDerogation_To_AssessRegisterTransfer_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayRestrictedDerogation_To_AssessRegisterTransfer_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessRegisterTransfer_To_GatewayRegisterCompliant_Art49</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_RegisterCompliant_Art49"
                           name="Is the register transfer limited and, where required, requested by an entitled recipient?">
      <bpmn:incoming>Flow_AssessRegisterTransfer_To_GatewayRegisterCompliant_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRegisterCompliant_To_EndNoDerogation_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRegisterCompliant_To_GatewayTransferReady_Art49</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessFallback_Art49"
               name="Assess compelling legitimate interests, limited data subjects, non-repetitive use, and suitable safeguards">
      <bpmn:incoming>Flow_GatewayFullDerogation_To_AssessFallback_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessFallback_To_GatewayFallbackConditions_Art49</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_FallbackConditions_Art49"
                           name="Are all fallback conditions for compelling legitimate interests met?">
      <bpmn:incoming>Flow_AssessFallback_To_GatewayFallbackConditions_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayFallbackConditions_To_EndNoDerogation_Art49</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFallbackConditions_To_InformSupervisoryAuthority_Art49</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_InformSupervisoryAuthority_Art49"
                   name="Inform the supervisory authority about the fallback transfer">
      <bpmn:incoming>Flow_GatewayFallbackConditions_To_InformSupervisoryAuthority_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_InformSupervisoryAuthority_To_InformDataSubjectAboutFallbackTransfer_Art49</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_InformDataSubjectAboutFallbackTransfer_Art49"
                   name="Inform the data subject about the fallback transfer and the compelling legitimate interests pursued">
      <bpmn:incoming>Flow_InformSupervisoryAuthority_To_InformDataSubjectAboutFallbackTransfer_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_InformDataSubjectAboutFallbackTransfer_To_DocumentFallbackAssessment_Art49</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_DocumentFallbackAssessment_Art49"
               name="Document the assessment and suitable safeguards in the Article 30 records">
      <bpmn:incoming>Flow_InformDataSubjectAboutFallbackTransfer_To_DocumentFallbackAssessment_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_DocumentFallbackAssessment_To_GatewayTransferReady_Art49</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_TransferReady_Art49">
      <bpmn:incoming>Flow_ReceiveExplicitConsent_To_GatewayTransferReady_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_VerifyDataSubjectContract_To_GatewayTransferReady_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_VerifyDataSubjectInterestContract_To_GatewayTransferReady_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_VerifyPublicInterest_To_GatewayTransferReady_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_VerifyLegalClaims_To_GatewayTransferReady_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_VerifyVitalInterests_To_GatewayTransferReady_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayRegisterCompliant_To_GatewayTransferReady_Art49</bpmn:incoming>
      <bpmn:incoming>Flow_DocumentFallbackAssessment_To_GatewayTransferReady_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayTransferReady_To_TransferUnderDerogation_Art49</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_TransferUnderDerogation_Art49"
                   name="Transfer the personal data under the applicable Article 49 derogation">
      <bpmn:incoming>Flow_GatewayTransferReady_To_TransferUnderDerogation_Art49</bpmn:incoming>
      <bpmn:outgoing>Flow_TransferUnderDerogation_To_EndTransferCompleted_Art49</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_TransferCompleted_Art49"
                   name="Transfer completed under an Article 49 derogation">
      <bpmn:incoming>Flow_TransferUnderDerogation_To_EndTransferCompleted_Art49</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_GatewayPrimaryTool_Art49" sourceRef="StartEvent_NeedExceptionalTransfer_Art49" targetRef="Gateway_PrimaryTransferTool_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayPrimaryTool_To_EndUsePrimaryTool_Art49" name="Yes" sourceRef="Gateway_PrimaryTransferTool_Art49" targetRef="EndEvent_UsePrimaryTool_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayPrimaryTool_To_GatewayPublicAuthority_Art49" name="No" sourceRef="Gateway_PrimaryTransferTool_Art49" targetRef="Gateway_PublicAuthorityPowers_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicAuthority_To_GatewayRestrictedDerogation_Art49" name="Yes" sourceRef="Gateway_PublicAuthorityPowers_Art49" targetRef="Gateway_RestrictedDerogation_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicAuthority_To_GatewayFullDerogation_Art49" name="No" sourceRef="Gateway_PublicAuthorityPowers_Art49" targetRef="Gateway_FullDerogation_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayFullDerogation_To_InformRisks_Art49" name="Explicit consent" sourceRef="Gateway_FullDerogation_Art49" targetRef="SendTask_InformDataSubjectAboutRisks_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayFullDerogation_To_VerifyDataSubjectContract_Art49" name="Data subject contract" sourceRef="Gateway_FullDerogation_Art49" targetRef="Task_VerifyDataSubjectContract_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayFullDerogation_To_VerifyDataSubjectInterestContract_Art49" name="Contract in data subject's interest" sourceRef="Gateway_FullDerogation_Art49" targetRef="Task_VerifyDataSubjectInterestContract_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayFullDerogation_To_VerifyPublicInterest_Art49" name="Important public interest" sourceRef="Gateway_FullDerogation_Art49" targetRef="Task_VerifyPublicInterest_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayFullDerogation_To_VerifyLegalClaims_Art49" name="Legal claims" sourceRef="Gateway_FullDerogation_Art49" targetRef="Task_VerifyLegalClaims_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayFullDerogation_To_VerifyVitalInterests_Art49" name="Vital interests" sourceRef="Gateway_FullDerogation_Art49" targetRef="Task_VerifyVitalInterests_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayFullDerogation_To_AssessRegisterTransfer_Art49" name="Public register" sourceRef="Gateway_FullDerogation_Art49" targetRef="Task_AssessRegisterTransfer_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayFullDerogation_To_AssessFallback_Art49" name="Compelling legitimate interests" sourceRef="Gateway_FullDerogation_Art49" targetRef="Task_AssessFallback_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayFullDerogation_To_EndNoDerogation_Art49" name="None" sourceRef="Gateway_FullDerogation_Art49" targetRef="EndEvent_NoDerogation_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayRestrictedDerogation_To_VerifyPublicInterest_Art49" name="Important public interest" sourceRef="Gateway_RestrictedDerogation_Art49" targetRef="Task_VerifyPublicInterest_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayRestrictedDerogation_To_VerifyLegalClaims_Art49" name="Legal claims" sourceRef="Gateway_RestrictedDerogation_Art49" targetRef="Task_VerifyLegalClaims_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayRestrictedDerogation_To_VerifyVitalInterests_Art49" name="Vital interests" sourceRef="Gateway_RestrictedDerogation_Art49" targetRef="Task_VerifyVitalInterests_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayRestrictedDerogation_To_AssessRegisterTransfer_Art49" name="Public register" sourceRef="Gateway_RestrictedDerogation_Art49" targetRef="Task_AssessRegisterTransfer_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayRestrictedDerogation_To_EndNoDerogation_Art49" name="None" sourceRef="Gateway_RestrictedDerogation_Art49" targetRef="EndEvent_NoDerogation_Art49" />
    <bpmn:sequenceFlow id="Flow_InformRisks_To_ReceiveExplicitConsent_Art49" sourceRef="SendTask_InformDataSubjectAboutRisks_Art49" targetRef="ReceiveTask_ReceiveExplicitConsent_Art49" />
    <bpmn:sequenceFlow id="Flow_ReceiveExplicitConsent_To_GatewayTransferReady_Art49" sourceRef="ReceiveTask_ReceiveExplicitConsent_Art49" targetRef="Gateway_TransferReady_Art49" />
    <bpmn:sequenceFlow id="Flow_VerifyDataSubjectContract_To_GatewayTransferReady_Art49" sourceRef="Task_VerifyDataSubjectContract_Art49" targetRef="Gateway_TransferReady_Art49" />
    <bpmn:sequenceFlow id="Flow_VerifyDataSubjectInterestContract_To_GatewayTransferReady_Art49" sourceRef="Task_VerifyDataSubjectInterestContract_Art49" targetRef="Gateway_TransferReady_Art49" />
    <bpmn:sequenceFlow id="Flow_VerifyPublicInterest_To_GatewayTransferReady_Art49" sourceRef="Task_VerifyPublicInterest_Art49" targetRef="Gateway_TransferReady_Art49" />
    <bpmn:sequenceFlow id="Flow_VerifyLegalClaims_To_GatewayTransferReady_Art49" sourceRef="Task_VerifyLegalClaims_Art49" targetRef="Gateway_TransferReady_Art49" />
    <bpmn:sequenceFlow id="Flow_VerifyVitalInterests_To_GatewayTransferReady_Art49" sourceRef="Task_VerifyVitalInterests_Art49" targetRef="Gateway_TransferReady_Art49" />
    <bpmn:sequenceFlow id="Flow_AssessRegisterTransfer_To_GatewayRegisterCompliant_Art49" sourceRef="Task_AssessRegisterTransfer_Art49" targetRef="Gateway_RegisterCompliant_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayRegisterCompliant_To_EndNoDerogation_Art49" name="No" sourceRef="Gateway_RegisterCompliant_Art49" targetRef="EndEvent_NoDerogation_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayRegisterCompliant_To_GatewayTransferReady_Art49" name="Yes" sourceRef="Gateway_RegisterCompliant_Art49" targetRef="Gateway_TransferReady_Art49" />
    <bpmn:sequenceFlow id="Flow_AssessFallback_To_GatewayFallbackConditions_Art49" sourceRef="Task_AssessFallback_Art49" targetRef="Gateway_FallbackConditions_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayFallbackConditions_To_EndNoDerogation_Art49" name="No" sourceRef="Gateway_FallbackConditions_Art49" targetRef="EndEvent_NoDerogation_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayFallbackConditions_To_InformSupervisoryAuthority_Art49" name="Yes" sourceRef="Gateway_FallbackConditions_Art49" targetRef="SendTask_InformSupervisoryAuthority_Art49" />
    <bpmn:sequenceFlow id="Flow_InformSupervisoryAuthority_To_InformDataSubjectAboutFallbackTransfer_Art49" sourceRef="SendTask_InformSupervisoryAuthority_Art49" targetRef="SendTask_InformDataSubjectAboutFallbackTransfer_Art49" />
    <bpmn:sequenceFlow id="Flow_InformDataSubjectAboutFallbackTransfer_To_DocumentFallbackAssessment_Art49" sourceRef="SendTask_InformDataSubjectAboutFallbackTransfer_Art49" targetRef="Task_DocumentFallbackAssessment_Art49" />
    <bpmn:sequenceFlow id="Flow_DocumentFallbackAssessment_To_GatewayTransferReady_Art49" sourceRef="Task_DocumentFallbackAssessment_Art49" targetRef="Gateway_TransferReady_Art49" />
    <bpmn:sequenceFlow id="Flow_GatewayTransferReady_To_TransferUnderDerogation_Art49" sourceRef="Gateway_TransferReady_Art49" targetRef="SendTask_TransferUnderDerogation_Art49" />
    <bpmn:sequenceFlow id="Flow_TransferUnderDerogation_To_EndTransferCompleted_Art49" sourceRef="SendTask_TransferUnderDerogation_Art49" targetRef="EndEvent_TransferCompleted_Art49" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Art49_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art49_Reviewed"
                      bpmnElement="Collaboration_Art49_Reviewed">
      <bpmndi:BPMNShape id="Participant_ControllerProcessor_Art49_di" bpmnElement="Participant_ControllerProcessor_Art49" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="6400" height="980" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art49_di" bpmnElement="Participant_DataSubject_Art49" isHorizontal="true">
        <dc:Bounds x="60" y="1060" width="6400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_SupervisoryAuthority_Art49_di" bpmnElement="Participant_SupervisoryAuthority_Art49" isHorizontal="true">
        <dc:Bounds x="60" y="1220" width="6400" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_ThirdCountryRecipient_Art49_di" bpmnElement="Participant_ThirdCountryRecipient_Art49" isHorizontal="true">
        <dc:Bounds x="60" y="1380" width="6400" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_NeedExceptionalTransfer_Art49_di" bpmnElement="StartEvent_NeedExceptionalTransfer_Art49">
        <dc:Bounds x="120" y="472" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PrimaryTransferTool_Art49_di" bpmnElement="Gateway_PrimaryTransferTool_Art49" isMarkerVisible="true">
        <dc:Bounds x="260" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_UsePrimaryTool_Art49_di" bpmnElement="EndEvent_UsePrimaryTool_Art49">
        <dc:Bounds x="440" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PublicAuthorityPowers_Art49_di" bpmnElement="Gateway_PublicAuthorityPowers_Art49" isMarkerVisible="true">
        <dc:Bounds x="460" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_FullDerogation_Art49_di" bpmnElement="Gateway_FullDerogation_Art49" isMarkerVisible="true">
        <dc:Bounds x="650" y="465" width="50" height="50" />
