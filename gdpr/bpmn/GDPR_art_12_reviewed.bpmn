<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art12_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art12_Reviewed">
    <bpmn:participant id="Participant_Controller_Art12"
                      name="Controller"
                      processRef="Process_Controller_Art12" />
    <bpmn:participant id="Participant_DataSubject_Art12"
                      name="Data Subject" />

    <bpmn:messageFlow id="MessageFlow_ProvideInformationOrally_Art12"
                      sourceRef="SendTask_ProvideInformationOrally_Art12"
                      targetRef="Participant_DataSubject_Art12" />
    <bpmn:messageFlow id="MessageFlow_SendElectronicInformation_Art12"
                      sourceRef="SendTask_SendElectronicInformation_Art12"
                      targetRef="Participant_DataSubject_Art12" />
    <bpmn:messageFlow id="MessageFlow_SendWrittenInformation_Art12"
                      sourceRef="SendTask_SendWrittenInformation_Art12"
                      targetRef="Participant_DataSubject_Art12" />
    <bpmn:messageFlow id="MessageFlow_ReceiveRequest_Art12"
                      sourceRef="Participant_DataSubject_Art12"
                      targetRef="ReceiveTask_ReceiveRequest_Art12" />
    <bpmn:messageFlow id="MessageFlow_RequestAdditionalIdentityInfo_Art12"
                      sourceRef="SendTask_RequestAdditionalIdentityInfo_Art12"
                      targetRef="Participant_DataSubject_Art12" />
    <bpmn:messageFlow id="MessageFlow_ReceiveAdditionalIdentityInfo_Art12"
                      sourceRef="Participant_DataSubject_Art12"
                      targetRef="ReceiveTask_ReceiveAdditionalIdentityInfo_Art12" />
    <bpmn:messageFlow id="MessageFlow_InformUnableToIdentify_Art12"
                      sourceRef="SendTask_InformUnableToIdentify_Art12"
                      targetRef="Participant_DataSubject_Art12" />
    <bpmn:messageFlow id="MessageFlow_SendExtensionNotice_Art12"
                      sourceRef="SendTask_SendExtensionNotice_Art12"
                      targetRef="Participant_DataSubject_Art12" />
    <bpmn:messageFlow id="MessageFlow_ProvideResponseOrally_Art12"
                      sourceRef="SendTask_ProvideResponseOrally_Art12"
                      targetRef="Participant_DataSubject_Art12" />
    <bpmn:messageFlow id="MessageFlow_SendElectronicResponse_Art12"
                      sourceRef="SendTask_SendElectronicResponse_Art12"
                      targetRef="Participant_DataSubject_Art12" />
    <bpmn:messageFlow id="MessageFlow_SendWrittenResponse_Art12"
                      sourceRef="SendTask_SendWrittenResponse_Art12"
                      targetRef="Participant_DataSubject_Art12" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Controller_Art12"
                name="Applying Article 12 transparency and request-handling rules"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 12 based on DAPRECO LegalRuleML
      statements32-38. The local XML models the Article 12(1) communication-quality
      duties, writing-or-electronic default, oral-delivery exception where requested
      and identity is proven, the Article 12(2) facilitation duty together with the
      Article 11(2) inability-to-identify exception, the Article 12(3) one-month
      response rule and the possible extension with reasons, the Article 12(4) no-
      action notice with reasons plus complaint and judicial-remedy information, the
      Article 12(5) free-of-charge default with fee-or-refusal exception for
      manifestly unfounded or excessive requests and the controller's burden to
      demonstrate that, the Article 12(6) ability to request additional identity
      information where reasonable doubts exist, and the Article 12(7) optional icons
      plus machine-readable requirement for electronic icon presentation. The BPMN
      therefore separates a general information path from a request-handling path and
      keeps the Article 12 paragraph logic explicit.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_ProvideInformation_Art12"
                     name="Need to provide GDPR information to the data subject">
      <bpmn:outgoing>Flow_StartProvideInformation_To_TaskPrepareGeneralInformation_Art12</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_PrepareGeneralInformation_Art12"
               name="Prepare concise, transparent, intelligible and easily accessible information in clear and plain language">
      <bpmn:incoming>Flow_StartProvideInformation_To_TaskPrepareGeneralInformation_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareGeneralInformation_To_GatewayOralInfo_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_OralInfo_Art12"
                           name="Was oral delivery requested and is the data subject's identity proven by other means?">
      <bpmn:incoming>Flow_TaskPrepareGeneralInformation_To_GatewayOralInfo_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayOralInfo_To_SendTaskProvideInformationOrally_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayOralInfo_To_GatewayElectronicInfo_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_ProvideInformationOrally_Art12"
                   name="Provide the information orally">
      <bpmn:incoming>Flow_GatewayOralInfo_To_SendTaskProvideInformationOrally_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskProvideInformationOrally_To_EndInformationProvided_Art12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_ElectronicInfo_Art12"
                           name="Should the information be provided electronically?">
      <bpmn:incoming>Flow_GatewayOralInfo_To_GatewayElectronicInfo_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayElectronicInfo_To_GatewayUseIconsElectronic_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayElectronicInfo_To_GatewayUseIconsWritten_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_UseIconsElectronic_Art12"
                           name="Use standardized icons with the electronic information?">
      <bpmn:incoming>Flow_GatewayElectronicInfo_To_GatewayUseIconsElectronic_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayUseIconsElectronic_To_TaskAttachIconsElectronic_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayUseIconsElectronic_To_SendTaskSendElectronicInformation_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AttachIconsElectronic_Art12"
               name="Attach standardized icons to the electronic information and ensure they are machine-readable">
      <bpmn:incoming>Flow_GatewayUseIconsElectronic_To_TaskAttachIconsElectronic_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAttachIconsElectronic_To_SendTaskSendElectronicInformation_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_SendElectronicInformation_Art12"
                   name="Send the information electronically">
      <bpmn:incoming>Flow_GatewayUseIconsElectronic_To_SendTaskSendElectronicInformation_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_TaskAttachIconsElectronic_To_SendTaskSendElectronicInformation_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendElectronicInformation_To_EndInformationProvided_Art12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_UseIconsWritten_Art12"
                           name="Use standardized icons with the written or other non-electronic information?">
      <bpmn:incoming>Flow_GatewayElectronicInfo_To_GatewayUseIconsWritten_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayUseIconsWritten_To_TaskAttachIconsWritten_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayUseIconsWritten_To_SendTaskSendWrittenInformation_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AttachIconsWritten_Art12"
               name="Attach standardized icons to the written or other non-electronic information">
      <bpmn:incoming>Flow_GatewayUseIconsWritten_To_TaskAttachIconsWritten_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAttachIconsWritten_To_SendTaskSendWrittenInformation_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_SendWrittenInformation_Art12"
                   name="Provide the information in writing or by other means">
      <bpmn:incoming>Flow_GatewayUseIconsWritten_To_SendTaskSendWrittenInformation_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_TaskAttachIconsWritten_To_SendTaskSendWrittenInformation_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendWrittenInformation_To_EndInformationProvided_Art12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:startEvent id="StartEvent_HandleRequest_Art12"
                     name="Receive a data subject request">
      <bpmn:outgoing>Flow_StartHandleRequest_To_ReceiveTaskReceiveRequest_Art12</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveRequest_Art12"
                      name="Receive the request from the data subject">
      <bpmn:incoming>Flow_StartHandleRequest_To_ReceiveTaskReceiveRequest_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveRequest_To_TaskFacilitateRights_Art12</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_FacilitateRights_Art12"
               name="Facilitate the exercise of the data subject's rights">
      <bpmn:incoming>Flow_ReceiveTaskReceiveRequest_To_TaskFacilitateRights_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskFacilitateRights_To_GatewayIdentityDoubts_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_IdentityDoubts_Art12"
                           name="Are there reasonable doubts concerning the identity of the requestor?">
      <bpmn:incoming>Flow_TaskFacilitateRights_To_GatewayIdentityDoubts_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayIdentityDoubts_To_SendTaskRequestAdditionalIdentityInfo_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayIdentityDoubts_To_GatewayRequestAssessmentJoin_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_RequestAdditionalIdentityInfo_Art12"
                   name="Request additional information necessary to confirm the data subject's identity">
      <bpmn:incoming>Flow_GatewayIdentityDoubts_To_SendTaskRequestAdditionalIdentityInfo_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskRequestAdditionalIdentityInfo_To_ReceiveTaskReceiveAdditionalIdentityInfo_Art12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAdditionalIdentityInfo_Art12"
                      name="Receive additional identifying information from the data subject">
      <bpmn:incoming>Flow_SendTaskRequestAdditionalIdentityInfo_To_ReceiveTaskReceiveAdditionalIdentityInfo_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveAdditionalIdentityInfo_To_GatewayIdentificationPossible_Art12</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_IdentificationPossible_Art12"
                           name="Is identification possible after the additional information is received?">
      <bpmn:incoming>Flow_ReceiveTaskReceiveAdditionalIdentityInfo_To_GatewayIdentificationPossible_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayIdentificationPossible_To_GatewayRequestAssessmentJoin_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayIdentificationPossible_To_TaskAssessInabilityToIdentify_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessInabilityToIdentify_Art12"
               name="Assess whether the controller can demonstrate inability to identify the data subject under Article 11(2)">
      <bpmn:incoming>Flow_GatewayIdentificationPossible_To_TaskAssessInabilityToIdentify_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessInabilityToIdentify_To_GatewayInabilityDemonstrated_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_InabilityDemonstrated_Art12"
                           name="Can the controller demonstrate inability to identify the data subject?">
      <bpmn:incoming>Flow_TaskAssessInabilityToIdentify_To_GatewayInabilityDemonstrated_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayInabilityDemonstrated_To_GatewayInformUnableIdentify_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayInabilityDemonstrated_To_GatewayRequestAssessmentJoin_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_InformUnableIdentify_Art12"
                           name="Is it possible to inform the data subject accordingly?">
      <bpmn:incoming>Flow_GatewayInabilityDemonstrated_To_GatewayInformUnableIdentify_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayInformUnableIdentify_To_SendTaskInformUnableToIdentify_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayInformUnableIdentify_To_EndUnableToIdentify_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_InformUnableToIdentify_Art12"
                   name="Inform the data subject that the controller is not in a position to identify him or her">
      <bpmn:incoming>Flow_GatewayInformUnableIdentify_To_SendTaskInformUnableToIdentify_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskInformUnableToIdentify_To_EndUnableToIdentify_Art12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_RequestAssessmentJoin_Art12">
      <bpmn:incoming>Flow_GatewayIdentityDoubts_To_GatewayRequestAssessmentJoin_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayIdentificationPossible_To_GatewayRequestAssessmentJoin_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayInabilityDemonstrated_To_GatewayRequestAssessmentJoin_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRequestAssessmentJoin_To_GatewayUnfoundedExcessive_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_UnfoundedExcessive_Art12"
                           name="Is the request manifestly unfounded or excessive?">
      <bpmn:incoming>Flow_GatewayRequestAssessmentJoin_To_GatewayUnfoundedExcessive_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayUnfoundedExcessive_To_TaskDemonstrateManifestlyUnfoundedExcessive_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayUnfoundedExcessive_To_TaskHandleFreeOfCharge_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_DemonstrateManifestlyUnfoundedExcessive_Art12"
               name="Demonstrate that the request is manifestly unfounded or excessive">
      <bpmn:incoming>Flow_GatewayUnfoundedExcessive_To_TaskDemonstrateManifestlyUnfoundedExcessive_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDemonstrateManifestlyUnfoundedExcessive_To_GatewayFeeOrRefuse_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_FeeOrRefuse_Art12"
                           name="Charge a reasonable fee or refuse to act on the request?">
      <bpmn:incoming>Flow_TaskDemonstrateManifestlyUnfoundedExcessive_To_GatewayFeeOrRefuse_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayFeeOrRefuse_To_TaskChargeReasonableFee_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFeeOrRefuse_To_TaskPrepareRefusalNotice_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ChargeReasonableFee_Art12"
               name="Charge a reasonable fee based on the administrative costs of handling the request">
      <bpmn:incoming>Flow_GatewayFeeOrRefuse_To_TaskChargeReasonableFee_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskChargeReasonableFee_To_GatewayHandlingChargeJoin_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_HandleFreeOfCharge_Art12"
               name="Handle the request free of charge">
      <bpmn:incoming>Flow_GatewayUnfoundedExcessive_To_TaskHandleFreeOfCharge_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskHandleFreeOfCharge_To_GatewayHandlingChargeJoin_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_HandlingChargeJoin_Art12">
      <bpmn:incoming>Flow_TaskChargeReasonableFee_To_GatewayHandlingChargeJoin_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_TaskHandleFreeOfCharge_To_GatewayHandlingChargeJoin_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayHandlingChargeJoin_To_GatewayTakeAction_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_TakeAction_Art12"
                           name="Will the controller take action on the request?">
      <bpmn:incoming>Flow_GatewayHandlingChargeJoin_To_GatewayTakeAction_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayTakeAction_To_GatewayExtensionNecessary_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayTakeAction_To_TaskPrepareNoActionNotice_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_ExtensionNecessary_Art12"
                           name="Is an extension beyond one month necessary because of the complexity or number of requests?">
      <bpmn:incoming>Flow_GatewayTakeAction_To_GatewayExtensionNecessary_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayExtensionNecessary_To_SendTaskSendExtensionNotice_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayExtensionNecessary_To_TaskTakeActionWithinOneMonth_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_SendExtensionNotice_Art12"
                   name="Inform the data subject within one month about the extension and the reasons for the delay">
      <bpmn:incoming>Flow_GatewayExtensionNecessary_To_SendTaskSendExtensionNotice_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendExtensionNotice_To_TaskTakeActionWithinThreeMonths_Art12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_TakeActionWithinThreeMonths_Art12"
               name="Take action on the request without undue delay and within three months of receipt">
      <bpmn:incoming>Flow_SendTaskSendExtensionNotice_To_TaskTakeActionWithinThreeMonths_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskTakeActionWithinThreeMonths_To_TaskPrepareRequestCommunication_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_TakeActionWithinOneMonth_Art12"
               name="Take action on the request without undue delay and within one month of receipt">
      <bpmn:incoming>Flow_GatewayExtensionNecessary_To_TaskTakeActionWithinOneMonth_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskTakeActionWithinOneMonth_To_TaskPrepareRequestCommunication_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepareNoActionNotice_Art12"
               name="Prepare a notice that no action will be taken, including reasons and information about the right to lodge a complaint and seek a judicial remedy">
      <bpmn:incoming>Flow_GatewayTakeAction_To_TaskPrepareNoActionNotice_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareNoActionNotice_To_TaskPrepareRequestCommunication_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepareRefusalNotice_Art12"
               name="Prepare a refusal notice including reasons and information about the right to lodge a complaint and seek a judicial remedy">
      <bpmn:incoming>Flow_GatewayFeeOrRefuse_To_TaskPrepareRefusalNotice_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareRefusalNotice_To_TaskPrepareRequestCommunication_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepareRequestCommunication_Art12"
               name="Prepare concise, transparent, intelligible and easily accessible request-related communication in clear and plain language">
      <bpmn:incoming>Flow_TaskTakeActionWithinThreeMonths_To_TaskPrepareRequestCommunication_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_TaskTakeActionWithinOneMonth_To_TaskPrepareRequestCommunication_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPrepareNoActionNotice_To_TaskPrepareRequestCommunication_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPrepareRefusalNotice_To_TaskPrepareRequestCommunication_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareRequestCommunication_To_GatewayElectronicResponse_Art12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ElectronicResponse_Art12"
                           name="Was the request made electronically and has no other format been requested?">
      <bpmn:incoming>Flow_TaskPrepareRequestCommunication_To_GatewayElectronicResponse_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayElectronicResponse_To_SendTaskSendElectronicResponse_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayElectronicResponse_To_GatewayOralResponse_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_SendElectronicResponse_Art12"
                   name="Send the response or notice electronically">
      <bpmn:incoming>Flow_GatewayElectronicResponse_To_SendTaskSendElectronicResponse_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendElectronicResponse_To_EndRequestHandled_Art12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_OralResponse_Art12"
                           name="Was oral communication requested and is the data subject's identity proven by other means?">
      <bpmn:incoming>Flow_GatewayElectronicResponse_To_GatewayOralResponse_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayOralResponse_To_SendTaskProvideResponseOrally_Art12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayOralResponse_To_SendTaskSendWrittenResponse_Art12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_ProvideResponseOrally_Art12"
                   name="Provide the response or notice orally">
      <bpmn:incoming>Flow_GatewayOralResponse_To_SendTaskProvideResponseOrally_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskProvideResponseOrally_To_EndRequestHandled_Art12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_SendWrittenResponse_Art12"
                   name="Send the response or notice in writing or by other means">
      <bpmn:incoming>Flow_GatewayOralResponse_To_SendTaskSendWrittenResponse_Art12</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendWrittenResponse_To_EndRequestHandled_Art12</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_InformationProvided_Art12"
                   name="Article 12 information has been provided">
      <bpmn:incoming>Flow_SendTaskProvideInformationOrally_To_EndInformationProvided_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskSendElectronicInformation_To_EndInformationProvided_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskSendWrittenInformation_To_EndInformationProvided_Art12</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_UnableToIdentify_Art12"
                   name="No action is taken because inability to identify was demonstrated under Article 11(2)">
      <bpmn:incoming>Flow_GatewayInformUnableIdentify_To_EndUnableToIdentify_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskInformUnableToIdentify_To_EndUnableToIdentify_Art12</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_RequestHandled_Art12"
                   name="The Article 12 request-handling path is completed">
      <bpmn:incoming>Flow_SendTaskSendElectronicResponse_To_EndRequestHandled_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskProvideResponseOrally_To_EndRequestHandled_Art12</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskSendWrittenResponse_To_EndRequestHandled_Art12</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartProvideInformation_To_TaskPrepareGeneralInformation_Art12" sourceRef="StartEvent_ProvideInformation_Art12" targetRef="Task_PrepareGeneralInformation_Art12" />
    <bpmn:sequenceFlow id="Flow_TaskPrepareGeneralInformation_To_GatewayOralInfo_Art12" sourceRef="Task_PrepareGeneralInformation_Art12" targetRef="Gateway_OralInfo_Art12" />
    <bpmn:sequenceFlow id="Flow_GatewayOralInfo_To_SendTaskProvideInformationOrally_Art12" name="Yes" sourceRef="Gateway_OralInfo_Art12" targetRef="SendTask_ProvideInformationOrally_Art12" />
    <bpmn:sequenceFlow id="Flow_GatewayOralInfo_To_GatewayElectronicInfo_Art12" name="No" sourceRef="Gateway_OralInfo_Art12" targetRef="Gateway_ElectronicInfo_Art12" />
