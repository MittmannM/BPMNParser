<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art89_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_Controller_Art89"
                name="Applying Article 89 safeguards"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 89 based on DAPRECO LegalRuleML
      statements275. The local XML covers paragraph 1 and emphasizes three elements:
      the processing must be for archiving in the public interest, research, or
      statistical purposes; appropriate safeguards for rights and freedoms must be put
      in place through technical and organisational measures, especially data
      minimisation; and the controller must use pseudonymisation or a non-identifying
      mode of processing where the purpose can be fulfilled in that manner. Paragraphs
      2 to 4 are not modeled because they are not present in the local XML file.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_AssessPurpose_Art89"
                     name="Need to configure processing for an Article 89 purpose">
      <bpmn:outgoing>Flow_Start_To_GatewayPurpose_Art89</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_Article89Purpose_Art89"
                           name="Is the processing for archiving in the public interest, research, or statistical purposes?">
      <bpmn:incoming>Flow_Start_To_GatewayPurpose_Art89</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayPurpose_To_TaskEstablishSafeguards_Art89</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayPurpose_To_EndNoArticle89Regime_Art89</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_EstablishSafeguards_Art89"
               name="Establish appropriate safeguards for the rights and freedoms of data subjects">
      <bpmn:incoming>Flow_GatewayPurpose_To_TaskEstablishSafeguards_Art89</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskEstablishSafeguards_To_TaskImplementMeasures_Art89</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ImplementMeasures_Art89"
               name="Implement technical and organisational measures for the processing">
      <bpmn:incoming>Flow_TaskEstablishSafeguards_To_TaskImplementMeasures_Art89</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskImplementMeasures_To_TaskEnsureMinimisation_Art89</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EnsureDataMinimisation_Art89"
               name="Ensure that the measures respect the principle of data minimisation">
      <bpmn:incoming>Flow_TaskImplementMeasures_To_TaskEnsureMinimisation_Art89</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskEnsureMinimisation_To_GatewayPseudonymisation_Art89</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Pseudonymisation_Art89"
                           name="Can the purpose be fulfilled with pseudonymisation?">
      <bpmn:incoming>Flow_TaskEnsureMinimisation_To_GatewayPseudonymisation_Art89</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayPseudonymisation_To_TaskUsePseudonymisation_Art89</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayPseudonymisation_To_GatewayNonIdentifyingMode_Art89</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_UsePseudonymisation_Art89"
               name="Use pseudonymisation as part of the safeguards">
      <bpmn:incoming>Flow_GatewayPseudonymisation_To_TaskUsePseudonymisation_Art89</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskUsePseudonymisation_To_GatewayNonIdentifyingMode_Art89</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_NonIdentifyingMode_Art89"
                           name="Can the purpose be fulfilled by processing that does not or no longer identifies data subjects?">
      <bpmn:incoming>Flow_GatewayPseudonymisation_To_GatewayNonIdentifyingMode_Art89</bpmn:incoming>
      <bpmn:incoming>Flow_TaskUsePseudonymisation_To_GatewayNonIdentifyingMode_Art89</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayNonIdentifyingMode_To_TaskProcessWithoutIdentification_Art89</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayNonIdentifyingMode_To_EndSafeguardsConfigured_Art89</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ProcessWithoutIdentification_Art89"
               name="Fulfil the purpose through processing that does not or no longer permits identification">
      <bpmn:incoming>Flow_GatewayNonIdentifyingMode_To_TaskProcessWithoutIdentification_Art89</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskProcessWithoutIdentification_To_EndSafeguardsConfigured_Art89</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_SafeguardsConfigured_Art89"
                   name="Article 89 safeguards configured">
      <bpmn:incoming>Flow_GatewayNonIdentifyingMode_To_EndSafeguardsConfigured_Art89</bpmn:incoming>
      <bpmn:incoming>Flow_TaskProcessWithoutIdentification_To_EndSafeguardsConfigured_Art89</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_NoArticle89Regime_Art89"
                   name="No Article 89 special safeguarding regime applies">
      <bpmn:incoming>Flow_GatewayPurpose_To_EndNoArticle89Regime_Art89</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_GatewayPurpose_Art89" sourceRef="StartEvent_AssessPurpose_Art89" targetRef="Gateway_Article89Purpose_Art89" />
    <bpmn:sequenceFlow id="Flow_GatewayPurpose_To_TaskEstablishSafeguards_Art89" name="Yes" sourceRef="Gateway_Article89Purpose_Art89" targetRef="Task_EstablishSafeguards_Art89" />
    <bpmn:sequenceFlow id="Flow_GatewayPurpose_To_EndNoArticle89Regime_Art89" name="No" sourceRef="Gateway_Article89Purpose_Art89" targetRef="EndEvent_NoArticle89Regime_Art89" />
    <bpmn:sequenceFlow id="Flow_TaskEstablishSafeguards_To_TaskImplementMeasures_Art89" sourceRef="Task_EstablishSafeguards_Art89" targetRef="Task_ImplementMeasures_Art89" />
    <bpmn:sequenceFlow id="Flow_TaskImplementMeasures_To_TaskEnsureMinimisation_Art89" sourceRef="Task_ImplementMeasures_Art89" targetRef="Task_EnsureDataMinimisation_Art89" />
    <bpmn:sequenceFlow id="Flow_TaskEnsureMinimisation_To_GatewayPseudonymisation_Art89" sourceRef="Task_EnsureDataMinimisation_Art89" targetRef="Gateway_Pseudonymisation_Art89" />
    <bpmn:sequenceFlow id="Flow_GatewayPseudonymisation_To_TaskUsePseudonymisation_Art89" name="Yes" sourceRef="Gateway_Pseudonymisation_Art89" targetRef="Task_UsePseudonymisation_Art89" />
    <bpmn:sequenceFlow id="Flow_GatewayPseudonymisation_To_GatewayNonIdentifyingMode_Art89" name="No" sourceRef="Gateway_Pseudonymisation_Art89" targetRef="Gateway_NonIdentifyingMode_Art89" />
    <bpmn:sequenceFlow id="Flow_TaskUsePseudonymisation_To_GatewayNonIdentifyingMode_Art89" sourceRef="Task_UsePseudonymisation_Art89" targetRef="Gateway_NonIdentifyingMode_Art89" />
    <bpmn:sequenceFlow id="Flow_GatewayNonIdentifyingMode_To_TaskProcessWithoutIdentification_Art89" name="Yes" sourceRef="Gateway_NonIdentifyingMode_Art89" targetRef="Task_ProcessWithoutIdentification_Art89" />
    <bpmn:sequenceFlow id="Flow_GatewayNonIdentifyingMode_To_EndSafeguardsConfigured_Art89" name="No" sourceRef="Gateway_NonIdentifyingMode_Art89" targetRef="EndEvent_SafeguardsConfigured_Art89" />
    <bpmn:sequenceFlow id="Flow_TaskProcessWithoutIdentification_To_EndSafeguardsConfigured_Art89" sourceRef="Task_ProcessWithoutIdentification_Art89" targetRef="EndEvent_SafeguardsConfigured_Art89" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art89_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art89_Reviewed"
                      bpmnElement="Process_Controller_Art89">
      <bpmndi:BPMNShape id="StartEvent_AssessPurpose_Art89_di" bpmnElement="StartEvent_AssessPurpose_Art89">
        <dc:Bounds x="120" y="262" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Article89Purpose_Art89_di" bpmnElement="Gateway_Article89Purpose_Art89" isMarkerVisible="true">
        <dc:Bounds x="250" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EstablishSafeguards_Art89_di" bpmnElement="Task_EstablishSafeguards_Art89">
        <dc:Bounds x="450" y="120" width="410" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ImplementMeasures_Art89_di" bpmnElement="Task_ImplementMeasures_Art89">
        <dc:Bounds x="980" y="120" width="390" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EnsureDataMinimisation_Art89_di" bpmnElement="Task_EnsureDataMinimisation_Art89">
        <dc:Bounds x="1490" y="120" width="410" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Pseudonymisation_Art89_di" bpmnElement="Gateway_Pseudonymisation_Art89" isMarkerVisible="true">
        <dc:Bounds x="2020" y="135" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_UsePseudonymisation_Art89_di" bpmnElement="Task_UsePseudonymisation_Art89">
        <dc:Bounds x="2230" y="120" width="310" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_NonIdentifyingMode_Art89_di" bpmnElement="Gateway_NonIdentifyingMode_Art89" isMarkerVisible="true">
        <dc:Bounds x="2690" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProcessWithoutIdentification_Art89_di" bpmnElement="Task_ProcessWithoutIdentification_Art89">
        <dc:Bounds x="2900" y="120" width="480" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_SafeguardsConfigured_Art89_di" bpmnElement="EndEvent_SafeguardsConfigured_Art89">
        <dc:Bounds x="3500" y="262" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoArticle89Regime_Art89_di" bpmnElement="EndEvent_NoArticle89Regime_Art89">
        <dc:Bounds x="457" y="422" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_GatewayPurpose_Art89_di" bpmnElement="Flow_Start_To_GatewayPurpose_Art89">
        <di:waypoint x="156" y="280" />
        <di:waypoint x="250" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPurpose_To_TaskEstablishSafeguards_Art89_di" bpmnElement="Flow_GatewayPurpose_To_TaskEstablishSafeguards_Art89">
        <di:waypoint x="275" y="255" />
        <di:waypoint x="275" y="160" />
        <di:waypoint x="450" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPurpose_To_EndNoArticle89Regime_Art89_di" bpmnElement="Flow_GatewayPurpose_To_EndNoArticle89Regime_Art89">
        <di:waypoint x="275" y="305" />
        <di:waypoint x="275" y="440" />
        <di:waypoint x="457" y="440" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskEstablishSafeguards_To_TaskImplementMeasures_Art89_di" bpmnElement="Flow_TaskEstablishSafeguards_To_TaskImplementMeasures_Art89">
        <di:waypoint x="860" y="160" />
        <di:waypoint x="980" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskImplementMeasures_To_TaskEnsureMinimisation_Art89_di" bpmnElement="Flow_TaskImplementMeasures_To_TaskEnsureMinimisation_Art89">
        <di:waypoint x="1370" y="160" />
        <di:waypoint x="1490" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskEnsureMinimisation_To_GatewayPseudonymisation_Art89_di" bpmnElement="Flow_TaskEnsureMinimisation_To_GatewayPseudonymisation_Art89">
        <di:waypoint x="1900" y="160" />
        <di:waypoint x="2020" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPseudonymisation_To_TaskUsePseudonymisation_Art89_di" bpmnElement="Flow_GatewayPseudonymisation_To_TaskUsePseudonymisation_Art89">
        <di:waypoint x="2070" y="160" />
        <di:waypoint x="2230" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPseudonymisation_To_GatewayNonIdentifyingMode_Art89_di" bpmnElement="Flow_GatewayPseudonymisation_To_GatewayNonIdentifyingMode_Art89">
        <di:waypoint x="2045" y="185" />
        <di:waypoint x="2045" y="280" />
        <di:waypoint x="2690" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskUsePseudonymisation_To_GatewayNonIdentifyingMode_Art89_di" bpmnElement="Flow_TaskUsePseudonymisation_To_GatewayNonIdentifyingMode_Art89">
        <di:waypoint x="2540" y="160" />
        <di:waypoint x="2715" y="160" />
        <di:waypoint x="2715" y="255" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayNonIdentifyingMode_To_TaskProcessWithoutIdentification_Art89_di" bpmnElement="Flow_GatewayNonIdentifyingMode_To_TaskProcessWithoutIdentification_Art89">
        <di:waypoint x="2715" y="255" />
        <di:waypoint x="2715" y="160" />
        <di:waypoint x="2900" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayNonIdentifyingMode_To_EndSafeguardsConfigured_Art89_di" bpmnElement="Flow_GatewayNonIdentifyingMode_To_EndSafeguardsConfigured_Art89">
        <di:waypoint x="2740" y="280" />
        <di:waypoint x="3500" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskProcessWithoutIdentification_To_EndSafeguardsConfigured_Art89_di" bpmnElement="Flow_TaskProcessWithoutIdentification_To_EndSafeguardsConfigured_Art89">
        <di:waypoint x="3380" y="160" />
        <di:waypoint x="3518" y="160" />
        <di:waypoint x="3518" y="262" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
