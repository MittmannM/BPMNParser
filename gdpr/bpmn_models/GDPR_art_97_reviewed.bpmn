        <di:waypoint x="270" y="820" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_SubmitReportToParliament_Art97_di"
                       bpmnElement="MessageFlow_SubmitReportToParliament_Art97">
        <di:waypoint x="1420" y="290" />
        <di:waypoint x="1420" y="500" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_SubmitReportToCouncil_Art97_di"
