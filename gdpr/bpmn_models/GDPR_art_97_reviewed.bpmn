<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art97_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art97_Reviewed">
    <bpmn:participant id="Participant_Commission_Art97"
                      name="Commission"
                      processRef="Process_Commission_Art97" />
    <bpmn:participant id="Participant_EuropeanParliament_Art97"
                      name="European Parliament" />
    <bpmn:participant id="Participant_Council_Art97"
                      name="Council" />
    <bpmn:participant id="Participant_MemberStatesAndSupervisoryAuthorities_Art97"
                      name="Member States and Supervisory Authorities" />
    <bpmn:participant id="Participant_Public_Art97"
                      name="Public" />

    <bpmn:messageFlow id="MessageFlow_RequestInformation_Art97"
                      sourceRef="Task_RequestInformation_Art97"
                      targetRef="Participant_MemberStatesAndSupervisoryAuthorities_Art97" />
    <bpmn:messageFlow id="MessageFlow_SubmitReportToParliament_Art97"
                      sourceRef="Task_SubmitReportToParliamentAndCouncil_Art97"
                      targetRef="Participant_EuropeanParliament_Art97" />
    <bpmn:messageFlow id="MessageFlow_SubmitReportToCouncil_Art97"
                      sourceRef="Task_SubmitReportToParliamentAndCouncil_Art97"
                      targetRef="Participant_Council_Art97" />
    <bpmn:messageFlow id="MessageFlow_MakeReportPublic_Art97"
                      sourceRef="Task_MakeReportPublic_Art97"
                      targetRef="Participant_Public_Art97" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Commission_Art97"
                name="Evaluate and review the Regulation"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 97 based on the real English legal text from
      gdpr_articles/article_97.txt. This collaboration captures the four-year review cycle from
      25 May 2020, the examination of Chapter V and Chapter VII, optional information requests,
      consideration of positions and findings, report submission and publication, and the
      optional submission of proposals to amend the Regulation.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_StartReviewCycle_Art97"
                     name="Start four-year review cycle">
      <bpmn:outgoing>Flow_StartReviewCycle_To_RequestInformation_Art97</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_RequestInformation_Art97"
               name="Request information if needed">
      <bpmn:incoming>Flow_StartReviewCycle_To_RequestInformation_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestInformation_To_SplitReviewWork_Art97</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_SplitReviewWork_Art97">
      <bpmn:incoming>Flow_RequestInformation_To_SplitReviewWork_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplit_To_ReviewChapterV_Art97</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplit_To_ReviewChapterVII_Art97</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_ReviewChapterV_Art97"
               name="Review Chapter V">
      <bpmn:incoming>Flow_GatewaySplit_To_ReviewChapterV_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewChapterV_To_GatewayJoinReviewWork_Art97</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ReviewChapterVII_Art97"
               name="Review Chapter VII">
      <bpmn:incoming>Flow_GatewaySplit_To_ReviewChapterVII_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewChapterVII_To_GatewayJoinReviewWork_Art97</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinReviewWork_Art97">
      <bpmn:incoming>Flow_ReviewChapterV_To_GatewayJoinReviewWork_Art97</bpmn:incoming>
      <bpmn:incoming>Flow_ReviewChapterVII_To_GatewayJoinReviewWork_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoin_To_TakeIntoAccountPositions_Art97</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_TakeIntoAccountPositionsAndFindings_Art97"
               name="Take into account positions and findings">
      <bpmn:incoming>Flow_GatewayJoin_To_TakeIntoAccountPositions_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_TakeIntoAccountPositions_To_SubmitReport_Art97</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_SubmitReportToParliamentAndCouncil_Art97"
                   name="Submit report to Parliament and Council">
      <bpmn:incoming>Flow_TakeIntoAccountPositions_To_SubmitReport_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_SubmitReport_To_SplitPublicationAndAmendment_Art97</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:parallelGateway id="Gateway_SplitPublicationAndAmendment_Art97">
      <bpmn:incoming>Flow_SubmitReport_To_SplitPublicationAndAmendment_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitPublication_To_MakeReportPublic_Art97</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitPublication_To_GatewayAmendmentNeed_Art97</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:sendTask id="Task_MakeReportPublic_Art97"
                   name="Make report public">
      <bpmn:incoming>Flow_GatewaySplitPublication_To_MakeReportPublic_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_MakeReportPublic_To_GatewayJoinPublicationAndAmendment_Art97</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_IsAmendmentProposalNecessary_Art97"
                           name="Is an amendment proposal necessary?">
      <bpmn:incoming>Flow_GatewaySplitPublication_To_GatewayAmendmentNeed_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAmendmentNeed_To_SubmitAmendmentProposals_Art97</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAmendmentNeed_To_GatewayMergeAmendmentNeed_Art97</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_SubmitAmendmentProposals_Art97"
               name="Submit amendment proposals">
      <bpmn:incoming>Flow_GatewayAmendmentNeed_To_SubmitAmendmentProposals_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_SubmitAmendmentProposals_To_GatewayMergeAmendmentNeed_Art97</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_MergeAmendmentNeed_Art97">
      <bpmn:incoming>Flow_GatewayAmendmentNeed_To_GatewayMergeAmendmentNeed_Art97</bpmn:incoming>
      <bpmn:incoming>Flow_SubmitAmendmentProposals_To_GatewayMergeAmendmentNeed_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMergeAmendmentNeed_To_GatewayJoinPublicationAndAmendment_Art97</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:parallelGateway id="Gateway_JoinPublicationAndAmendment_Art97">
      <bpmn:incoming>Flow_MakeReportPublic_To_GatewayJoinPublicationAndAmendment_Art97</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayMergeAmendmentNeed_To_GatewayJoinPublicationAndAmendment_Art97</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinPublicationAndAmendment_To_EndReviewCycleCompleted_Art97</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:endEvent id="EndEvent_ReviewCycleCompleted_Art97"
                   name="Review cycle completed">
      <bpmn:incoming>Flow_GatewayJoinPublicationAndAmendment_To_EndReviewCycleCompleted_Art97</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartReviewCycle_To_RequestInformation_Art97"
                       sourceRef="StartEvent_StartReviewCycle_Art97"
                       targetRef="Task_RequestInformation_Art97" />
    <bpmn:sequenceFlow id="Flow_RequestInformation_To_SplitReviewWork_Art97"
                       sourceRef="Task_RequestInformation_Art97"
                       targetRef="Gateway_SplitReviewWork_Art97" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_ReviewChapterV_Art97"
                       sourceRef="Gateway_SplitReviewWork_Art97"
                       targetRef="Task_ReviewChapterV_Art97" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_ReviewChapterVII_Art97"
                       sourceRef="Gateway_SplitReviewWork_Art97"
                       targetRef="Task_ReviewChapterVII_Art97" />
    <bpmn:sequenceFlow id="Flow_ReviewChapterV_To_GatewayJoinReviewWork_Art97"
                       sourceRef="Task_ReviewChapterV_Art97"
                       targetRef="Gateway_JoinReviewWork_Art97" />
    <bpmn:sequenceFlow id="Flow_ReviewChapterVII_To_GatewayJoinReviewWork_Art97"
                       sourceRef="Task_ReviewChapterVII_Art97"
                       targetRef="Gateway_JoinReviewWork_Art97" />
    <bpmn:sequenceFlow id="Flow_GatewayJoin_To_TakeIntoAccountPositions_Art97"
                       sourceRef="Gateway_JoinReviewWork_Art97"
                       targetRef="Task_TakeIntoAccountPositionsAndFindings_Art97" />
    <bpmn:sequenceFlow id="Flow_TakeIntoAccountPositions_To_SubmitReport_Art97"
                       sourceRef="Task_TakeIntoAccountPositionsAndFindings_Art97"
                       targetRef="Task_SubmitReportToParliamentAndCouncil_Art97" />
    <bpmn:sequenceFlow id="Flow_SubmitReport_To_SplitPublicationAndAmendment_Art97"
                       sourceRef="Task_SubmitReportToParliamentAndCouncil_Art97"
                       targetRef="Gateway_SplitPublicationAndAmendment_Art97" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitPublication_To_MakeReportPublic_Art97"
                       sourceRef="Gateway_SplitPublicationAndAmendment_Art97"
                       targetRef="Task_MakeReportPublic_Art97" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitPublication_To_GatewayAmendmentNeed_Art97"
                       sourceRef="Gateway_SplitPublicationAndAmendment_Art97"
                       targetRef="Gateway_IsAmendmentProposalNecessary_Art97" />
    <bpmn:sequenceFlow id="Flow_MakeReportPublic_To_GatewayJoinPublicationAndAmendment_Art97"
                       sourceRef="Task_MakeReportPublic_Art97"
                       targetRef="Gateway_JoinPublicationAndAmendment_Art97" />
    <bpmn:sequenceFlow id="Flow_GatewayAmendmentNeed_To_SubmitAmendmentProposals_Art97"
                       name="Yes"
                       sourceRef="Gateway_IsAmendmentProposalNecessary_Art97"
                       targetRef="Task_SubmitAmendmentProposals_Art97" />
    <bpmn:sequenceFlow id="Flow_GatewayAmendmentNeed_To_GatewayMergeAmendmentNeed_Art97"
                       name="No"
                       sourceRef="Gateway_IsAmendmentProposalNecessary_Art97"
                       targetRef="Gateway_MergeAmendmentNeed_Art97" />
    <bpmn:sequenceFlow id="Flow_SubmitAmendmentProposals_To_GatewayMergeAmendmentNeed_Art97"
                       sourceRef="Task_SubmitAmendmentProposals_Art97"
                       targetRef="Gateway_MergeAmendmentNeed_Art97" />
    <bpmn:sequenceFlow id="Flow_GatewayMergeAmendmentNeed_To_GatewayJoinPublicationAndAmendment_Art97"
                       sourceRef="Gateway_MergeAmendmentNeed_Art97"
                       targetRef="Gateway_JoinPublicationAndAmendment_Art97" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinPublicationAndAmendment_To_EndReviewCycleCompleted_Art97"
                       sourceRef="Gateway_JoinPublicationAndAmendment_Art97"
                       targetRef="EndEvent_ReviewCycleCompleted_Art97" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art97_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art97_Reviewed"
                      bpmnElement="Collaboration_Art97_Reviewed">
      <bpmndi:BPMNShape id="Participant_Commission_Art97_di"
