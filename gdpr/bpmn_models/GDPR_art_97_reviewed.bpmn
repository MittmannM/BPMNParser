        <di:waypoint x="430" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_ReviewChapterV_Art97_di"
                       bpmnElement="Flow_GatewaySplit_To_ReviewChapterV_Art97">
        <di:waypoint x="455" y="225" />
        <di:waypoint x="455" y="160" />
        <di:waypoint x="580" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_ReviewChapterVII_Art97_di"
                       bpmnElement="Flow_GatewaySplit_To_ReviewChapterVII_Art97">
        <di:waypoint x="455" y="275" />
        <di:waypoint x="455" y="340" />
        <di:waypoint x="580" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReviewChapterV_To_GatewayJoinReviewWork_Art97_di"
                       bpmnElement="Flow_ReviewChapterV_To_GatewayJoinReviewWork_Art97">
        <di:waypoint x="740" y="160" />
        <di:waypoint x="885" y="160" />
        <di:waypoint x="885" y="225" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReviewChapterVII_To_GatewayJoinReviewWork_Art97_di"
                       bpmnElement="Flow_ReviewChapterVII_To_GatewayJoinReviewWork_Art97">
        <di:waypoint x="750" y="340" />
        <di:waypoint x="885" y="340" />
        <di:waypoint x="885" y="275" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayJoin_To_TakeIntoAccountPositions_Art97_di"
                       bpmnElement="Flow_GatewayJoin_To_TakeIntoAccountPositions_Art97">
        <di:waypoint x="910" y="250" />
        <di:waypoint x="980" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TakeIntoAccountPositions_To_SubmitReport_Art97_di"
                       bpmnElement="Flow_TakeIntoAccountPositions_To_SubmitReport_Art97">
        <di:waypoint x="1220" y="250" />
        <di:waypoint x="1310" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SubmitReport_To_SplitPublicationAndAmendment_Art97_di"
