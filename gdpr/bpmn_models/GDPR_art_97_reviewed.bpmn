                        bpmnElement="Task_MakeReportPublic_Art97">
        <dc:Bounds x="1780" y="120" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IsAmendmentProposalNecessary_Art97_di"
                        bpmnElement="Gateway_IsAmendmentProposalNecessary_Art97"
                        isMarkerVisible="true">
        <dc:Bounds x="1780" y="315" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SubmitAmendmentProposals_Art97_di"
                        bpmnElement="Task_SubmitAmendmentProposals_Art97">
        <dc:Bounds x="1940" y="300" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MergeAmendmentNeed_Art97_di"
                        bpmnElement="Gateway_MergeAmendmentNeed_Art97"
                        isMarkerVisible="true">
        <dc:Bounds x="2240" y="315" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_JoinPublicationAndAmendment_Art97_di"
                        bpmnElement="Gateway_JoinPublicationAndAmendment_Art97"
                        isMarkerVisible="true">
        <dc:Bounds x="2400" y="225" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ReviewCycleCompleted_Art97_di"
                        bpmnElement="EndEvent_ReviewCycleCompleted_Art97">
        <dc:Bounds x="2542" y="232" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_StartReviewCycle_To_RequestInformation_Art97_di"
                       bpmnElement="Flow_StartReviewCycle_To_RequestInformation_Art97">
        <di:waypoint x="136" y="250" />
        <di:waypoint x="180" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RequestInformation_To_SplitReviewWork_Art97_di"
