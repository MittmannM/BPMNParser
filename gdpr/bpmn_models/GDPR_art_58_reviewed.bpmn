<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art58_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art58_Reviewed">
    <bpmn:participant id="Participant_SupervisoryAuthority_Art58"
                      name="Supervisory Authority"
                      processRef="Process_SupervisoryAuthority_Art58" />
    <bpmn:participant id="Participant_ControllerProcessorRepresentative_Art58"
                      name="Controller, Processor, or Representative" />
    <bpmn:participant id="Participant_DataSubject_Art58"
                      name="Data Subject" />
    <bpmn:participant id="Participant_CertificationBody_Art58"
                      name="Certification Body" />
    <bpmn:participant id="Participant_NationalInstitutionsAndPublic_Art58"
                      name="National Institutions and Public" />
    <bpmn:participant id="Participant_JudicialAuthorities_Art58"
                      name="Judicial Authorities" />

    <bpmn:messageFlow id="MessageFlow_OrderRequiredInformation_Art58"
                      sourceRef="Task_OrderRequiredInformation_Art58"
                      targetRef="Participant_ControllerProcessorRepresentative_Art58" />
    <bpmn:messageFlow id="MessageFlow_NotifyAllegedInfringement_Art58"
                      sourceRef="Task_NotifyAllegedInfringement_Art58"
                      targetRef="Participant_ControllerProcessorRepresentative_Art58" />
    <bpmn:messageFlow id="MessageFlow_IssueWarning_Art58"
                      sourceRef="Task_IssueWarning_Art58"
                      targetRef="Participant_ControllerProcessorRepresentative_Art58" />
    <bpmn:messageFlow id="MessageFlow_IssueReprimand_Art58"
                      sourceRef="Task_IssueReprimand_Art58"
                      targetRef="Participant_ControllerProcessorRepresentative_Art58" />
    <bpmn:messageFlow id="MessageFlow_OrderRightsCompliance_Art58"
                      sourceRef="Task_OrderRightsCompliance_Art58"
                      targetRef="Participant_ControllerProcessorRepresentative_Art58" />
    <bpmn:messageFlow id="MessageFlow_OrderProcessingCompliance_Art58"
                      sourceRef="Task_OrderProcessingCompliance_Art58"
                      targetRef="Participant_ControllerProcessorRepresentative_Art58" />
    <bpmn:messageFlow id="MessageFlow_OrderBreachCommunication_Art58"
                      sourceRef="Task_OrderBreachCommunication_Art58"
                      targetRef="Participant_ControllerProcessorRepresentative_Art58" />
    <bpmn:messageFlow id="MessageFlow_LimitOrBanProcessing_Art58"
                      sourceRef="Task_LimitOrBanProcessing_Art58"
                      targetRef="Participant_ControllerProcessorRepresentative_Art58" />
    <bpmn:messageFlow id="MessageFlow_OrderRectificationErasureRestriction_Art58"
                      sourceRef="Task_OrderRectificationErasureRestriction_Art58"
                      targetRef="Participant_ControllerProcessorRepresentative_Art58" />
    <bpmn:messageFlow id="MessageFlow_SuspendThirdCountryDataFlows_Art58"
                      sourceRef="Task_SuspendThirdCountryDataFlows_Art58"
                      targetRef="Participant_ControllerProcessorRepresentative_Art58" />
    <bpmn:messageFlow id="MessageFlow_AdviseUnderArticle36_Art58"
                      sourceRef="Task_AdviseUnderArticle36_Art58"
                      targetRef="Participant_ControllerProcessorRepresentative_Art58" />
    <bpmn:messageFlow id="MessageFlow_IssueOpinions_Art58"
                      sourceRef="Task_IssueOpinions_Art58"
                      targetRef="Participant_NationalInstitutionsAndPublic_Art58" />
    <bpmn:messageFlow id="MessageFlow_WithdrawOrBlockCertification_Art58"
                      sourceRef="Task_WithdrawOrBlockCertification_Art58"
                      targetRef="Participant_CertificationBody_Art58" />
    <bpmn:messageFlow id="MessageFlow_BringInfringementsToJudicialAuthorities_Art58"
                      sourceRef="Task_BringInfringementsToJudicialAuthorities_Art58"
                      targetRef="Participant_JudicialAuthorities_Art58" />
  </bpmn:collaboration>

  <bpmn:process id="Process_SupervisoryAuthority_Art58"
                name="Maintain Article 58 supervisory authority powers"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 58 based on the real English legal text from
      gdpr_articles/article_58.txt. The model organizes the full power set into coherent blocks:
      Article 58(4) safeguards, the Article 58(1)(a)-(f) investigative powers, the Article
      58(2)(a)-(j) corrective powers, the Article 58(3)(a)-(j) authorisation and advisory
      powers, Article 58(5) judicial-authority escalation power, and Article 58(6) optional
      additional powers with the Chapter VII non-impairment limit.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_MaintainArticle58Powers_Art58"
                     name="Maintain Article 58 powers">
      <bpmn:outgoing>Flow_Start_To_ApplySafeguards_Art58</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_ApplySafeguardsAndDueProcess_Art58"
               name="Apply safeguards, judicial remedy, and due process">
      <bpmn:incoming>Flow_Start_To_ApplySafeguards_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_ApplySafeguards_To_GatewaySplitPowerBlocks_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_SplitPowerBlocks_Art58">
      <bpmn:incoming>Flow_ApplySafeguards_To_GatewaySplitPowerBlocks_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitPowerBlocks_To_GatewaySplitInvestigative_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitPowerBlocks_To_GatewaySplitCorrective_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitPowerBlocks_To_GatewaySplitAdvisory_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitPowerBlocks_To_GatewayAdditionalPowersProvided_Art58</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="Gateway_SplitInvestigative_Art58">
      <bpmn:incoming>Flow_GatewaySplitPowerBlocks_To_GatewaySplitInvestigative_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitInvestigative_To_OrderRequiredInformation_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitInvestigative_To_ConductAudits_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitInvestigative_To_ReviewCertifications_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitInvestigative_To_NotifyAllegedInfringement_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitInvestigative_To_ObtainDataAccess_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitInvestigative_To_ObtainPremisesAccess_Art58</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:sendTask id="Task_OrderRequiredInformation_Art58"
                   name="Order required information">
      <bpmn:incoming>Flow_GatewaySplitInvestigative_To_OrderRequiredInformation_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_OrderRequiredInformation_To_GatewayJoinInvestigative_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ConductDataProtectionAudits_Art58"
               name="Conduct data protection audits">
      <bpmn:incoming>Flow_GatewaySplitInvestigative_To_ConductAudits_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_ConductAudits_To_GatewayJoinInvestigative_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ReviewArticle42Certifications_Art58"
               name="Review Article 42(7) certifications">
      <bpmn:incoming>Flow_GatewaySplitInvestigative_To_ReviewCertifications_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewCertifications_To_GatewayJoinInvestigative_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_NotifyAllegedInfringement_Art58"
                   name="Notify alleged infringement">
      <bpmn:incoming>Flow_GatewaySplitInvestigative_To_NotifyAllegedInfringement_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyAllegedInfringement_To_GatewayJoinInvestigative_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ObtainDataAndInformationAccess_Art58"
               name="Obtain data and information access">
      <bpmn:incoming>Flow_GatewaySplitInvestigative_To_ObtainDataAccess_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_ObtainDataAccess_To_GatewayJoinInvestigative_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ObtainPremisesAndEquipmentAccess_Art58"
               name="Obtain premises and equipment access">
      <bpmn:incoming>Flow_GatewaySplitInvestigative_To_ObtainPremisesAccess_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_ObtainPremisesAccess_To_GatewayJoinInvestigative_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinInvestigative_Art58">
      <bpmn:incoming>Flow_OrderRequiredInformation_To_GatewayJoinInvestigative_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_ConductAudits_To_GatewayJoinInvestigative_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_ReviewCertifications_To_GatewayJoinInvestigative_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_NotifyAllegedInfringement_To_GatewayJoinInvestigative_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_ObtainDataAccess_To_GatewayJoinInvestigative_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_ObtainPremisesAccess_To_GatewayJoinInvestigative_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinInvestigative_To_GatewayJoinPowerBlocks_Art58</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="Gateway_SplitCorrective_Art58">
      <bpmn:incoming>Flow_GatewaySplitPowerBlocks_To_GatewaySplitCorrective_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitCorrective_To_IssueWarning_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitCorrective_To_IssueReprimand_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitCorrective_To_OrderRightsCompliance_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitCorrective_To_OrderProcessingCompliance_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitCorrective_To_OrderBreachCommunication_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitCorrective_To_LimitOrBanProcessing_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitCorrective_To_OrderRectificationErasureRestriction_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitCorrective_To_WithdrawOrBlockCertification_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitCorrective_To_ImposeAdministrativeFine_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitCorrective_To_SuspendThirdCountryDataFlows_Art58</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:sendTask id="Task_IssueWarning_Art58"
                   name="Issue warning">
      <bpmn:incoming>Flow_GatewaySplitCorrective_To_IssueWarning_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_IssueWarning_To_GatewayJoinCorrective_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_IssueReprimand_Art58"
                   name="Issue reprimand">
      <bpmn:incoming>Flow_GatewaySplitCorrective_To_IssueReprimand_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_IssueReprimand_To_GatewayJoinCorrective_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_OrderRightsCompliance_Art58"
                   name="Order rights compliance">
      <bpmn:incoming>Flow_GatewaySplitCorrective_To_OrderRightsCompliance_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_OrderRightsCompliance_To_GatewayJoinCorrective_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_OrderProcessingCompliance_Art58"
                   name="Order processing compliance">
      <bpmn:incoming>Flow_GatewaySplitCorrective_To_OrderProcessingCompliance_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_OrderProcessingCompliance_To_GatewayJoinCorrective_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_OrderBreachCommunication_Art58"
                   name="Order breach communication to data subject">
      <bpmn:incoming>Flow_GatewaySplitCorrective_To_OrderBreachCommunication_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_OrderBreachCommunication_To_GatewayJoinCorrective_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_LimitOrBanProcessing_Art58"
                   name="Limit or ban processing">
      <bpmn:incoming>Flow_GatewaySplitCorrective_To_LimitOrBanProcessing_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_LimitOrBanProcessing_To_GatewayJoinCorrective_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_OrderRectificationErasureRestriction_Art58"
                   name="Order rectification, erasure, or restriction">
      <bpmn:incoming>Flow_GatewaySplitCorrective_To_OrderRectificationErasureRestriction_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_OrderRectificationErasureRestriction_To_GatewayJoinCorrective_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_WithdrawOrBlockCertification_Art58"
                   name="Withdraw or block certification">
      <bpmn:incoming>Flow_GatewaySplitCorrective_To_WithdrawOrBlockCertification_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_WithdrawOrBlockCertification_To_GatewayJoinCorrective_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ImposeAdministrativeFine_Art58"
               name="Impose administrative fine">
      <bpmn:incoming>Flow_GatewaySplitCorrective_To_ImposeAdministrativeFine_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_ImposeAdministrativeFine_To_GatewayJoinCorrective_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_SuspendThirdCountryDataFlows_Art58"
                   name="Suspend third-country data flows">
      <bpmn:incoming>Flow_GatewaySplitCorrective_To_SuspendThirdCountryDataFlows_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_SuspendThirdCountryDataFlows_To_GatewayJoinCorrective_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:parallelGateway id="Gateway_JoinCorrective_Art58">
      <bpmn:incoming>Flow_IssueWarning_To_GatewayJoinCorrective_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_IssueReprimand_To_GatewayJoinCorrective_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_OrderRightsCompliance_To_GatewayJoinCorrective_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_OrderProcessingCompliance_To_GatewayJoinCorrective_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_OrderBreachCommunication_To_GatewayJoinCorrective_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_LimitOrBanProcessing_To_GatewayJoinCorrective_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_OrderRectificationErasureRestriction_To_GatewayJoinCorrective_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_WithdrawOrBlockCertification_To_GatewayJoinCorrective_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_ImposeAdministrativeFine_To_GatewayJoinCorrective_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_SuspendThirdCountryDataFlows_To_GatewayJoinCorrective_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinCorrective_To_GatewayJoinPowerBlocks_Art58</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="Gateway_SplitAdvisory_Art58">
      <bpmn:incoming>Flow_GatewaySplitPowerBlocks_To_GatewaySplitAdvisory_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitAdvisory_To_AdviseUnderArticle36_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAdvisory_To_IssueOpinions_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAdvisory_To_AuthoriseArticle365Processing_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAdvisory_To_ApproveDraftCodes_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAdvisory_To_AccreditCertificationBodies_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAdvisory_To_IssueCertifications_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAdvisory_To_AdoptStandardClauses_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAdvisory_To_AuthoriseContractualClauses_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAdvisory_To_AuthoriseAdministrativeArrangements_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAdvisory_To_ApproveBCRs_Art58</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:sendTask id="Task_AdviseUnderArticle36_Art58"
                   name="Advise under Article 36">
      <bpmn:incoming>Flow_GatewaySplitAdvisory_To_AdviseUnderArticle36_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_AdviseUnderArticle36_To_GatewayJoinAdvisory_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_IssueOpinions_Art58"
                   name="Issue opinions">
      <bpmn:incoming>Flow_GatewaySplitAdvisory_To_IssueOpinions_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_IssueOpinions_To_GatewayJoinAdvisory_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_AuthoriseArticle365Processing_Art58"
               name="Authorise Article 36(5) processing">
      <bpmn:incoming>Flow_GatewaySplitAdvisory_To_AuthoriseArticle365Processing_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_AuthoriseArticle365Processing_To_GatewayJoinAdvisory_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ApproveDraftCodesOfConduct_Art58"
               name="Approve draft codes of conduct">
      <bpmn:incoming>Flow_GatewaySplitAdvisory_To_ApproveDraftCodes_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_ApproveDraftCodes_To_GatewayJoinAdvisory_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AccreditCertificationBodies_Art58"
               name="Accredit certification bodies">
      <bpmn:incoming>Flow_GatewaySplitAdvisory_To_AccreditCertificationBodies_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_AccreditCertificationBodies_To_GatewayJoinAdvisory_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_IssueCertificationsAndApproveCriteria_Art58"
               name="Issue certifications and approve criteria">
      <bpmn:incoming>Flow_GatewaySplitAdvisory_To_IssueCertifications_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_IssueCertifications_To_GatewayJoinAdvisory_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AdoptStandardDataProtectionClauses_Art58"
               name="Adopt standard data protection clauses">
      <bpmn:incoming>Flow_GatewaySplitAdvisory_To_AdoptStandardClauses_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptStandardClauses_To_GatewayJoinAdvisory_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AuthoriseContractualClauses_Art58"
               name="Authorise Article 46(3)(a) contractual clauses">
      <bpmn:incoming>Flow_GatewaySplitAdvisory_To_AuthoriseContractualClauses_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_AuthoriseContractualClauses_To_GatewayJoinAdvisory_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AuthoriseAdministrativeArrangements_Art58"
               name="Authorise Article 46(3)(b) administrative arrangements">
      <bpmn:incoming>Flow_GatewaySplitAdvisory_To_AuthoriseAdministrativeArrangements_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_AuthoriseAdministrativeArrangements_To_GatewayJoinAdvisory_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ApproveBindingCorporateRules_Art58"
               name="Approve binding corporate rules">
      <bpmn:incoming>Flow_GatewaySplitAdvisory_To_ApproveBCRs_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_ApproveBCRs_To_GatewayJoinAdvisory_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinAdvisory_Art58">
      <bpmn:incoming>Flow_AdviseUnderArticle36_To_GatewayJoinAdvisory_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_IssueOpinions_To_GatewayJoinAdvisory_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_AuthoriseArticle365Processing_To_GatewayJoinAdvisory_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_ApproveDraftCodes_To_GatewayJoinAdvisory_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_AccreditCertificationBodies_To_GatewayJoinAdvisory_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_IssueCertifications_To_GatewayJoinAdvisory_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_AdoptStandardClauses_To_GatewayJoinAdvisory_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_AuthoriseContractualClauses_To_GatewayJoinAdvisory_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_AuthoriseAdministrativeArrangements_To_GatewayJoinAdvisory_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_ApproveBCRs_To_GatewayJoinAdvisory_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinAdvisory_To_GatewayJoinPowerBlocks_Art58</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:exclusiveGateway id="Gateway_AdditionalPowersProvided_Art58"
                           name="Are additional powers provided by Member State law?">
      <bpmn:incoming>Flow_GatewaySplitPowerBlocks_To_GatewayAdditionalPowersProvided_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAdditionalPowersProvided_To_BringInfringements_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAdditionalPowersProvided_To_GatewayJoinPowerBlocks_Art58</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_BringInfringementsToJudicialAuthorities_Art58"
                   name="Bring infringements to judicial authorities">
      <bpmn:incoming>Flow_GatewayAdditionalPowersProvided_To_BringInfringements_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_BringInfringements_To_GatewayImpairChapterVII_Art58</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_ImpairChapterVII_Art58"
                           name="Would additional powers impair the effective operation of Chapter VII?">
      <bpmn:incoming>Flow_BringInfringements_To_GatewayImpairChapterVII_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayImpairChapterVII_To_GatewayJoinPowerBlocks_Art58</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayImpairChapterVII_To_ExerciseAdditionalPowers_Art58</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ExerciseAdditionalPowers_Art58"
               name="Exercise additional powers">
      <bpmn:incoming>Flow_GatewayImpairChapterVII_To_ExerciseAdditionalPowers_Art58</bpmn:incoming>
      <bpmn:outgoing>Flow_ExerciseAdditionalPowers_To_GatewayJoinPowerBlocks_Art58</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinPowerBlocks_Art58">
      <bpmn:incoming>Flow_GatewayJoinInvestigative_To_GatewayJoinPowerBlocks_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayJoinCorrective_To_GatewayJoinPowerBlocks_Art58</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayJoinAdvisory_To_GatewayJoinPowerBlocks_Art58</bpmn:incoming>
