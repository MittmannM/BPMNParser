<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art11_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art11_Reviewed">
    <bpmn:participant id="Participant_Controller_Art11"
                      name="Controller"
                      processRef="Process_Controller_Art11" />
    <bpmn:participant id="Participant_DataSubject_Art11"
                      name="Data Subject" />

    <bpmn:messageFlow id="MessageFlow_InformDataSubject_Art11"
                      sourceRef="SendTask_InformDataSubject_Art11"
                      targetRef="Participant_DataSubject_Art11" />
    <bpmn:messageFlow id="MessageFlow_RightsRequest_Art11"
                      sourceRef="Participant_DataSubject_Art11"
                      targetRef="ReceiveTask_ReceiveRightsRequest_Art11" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Controller_Art11"
                name="Apply Article 11"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 11 based on the real English legal text.
      The model covers the Article 11(1) rule that no additional identification
      information must be maintained, acquired, or processed solely for GDPR
      compliance when identification is not or no longer required for the purposes.
      It also covers the Article 11(2) demonstrable inability-to-identify branch, the
      if-possible information duty, and the rule that Articles 15 to 20 do not apply
      unless the data subject provides additional information enabling identification.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_AssessArticle11_Art11"
                     name="Need Article 11 assessment">
      <bpmn:outgoing>Flow_Start_To_TaskAssessIdentificationNeed_Art11</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_AssessIdentificationNeed_Art11"
               name="Check identification need">
      <bpmn:incoming>Flow_Start_To_TaskAssessIdentificationNeed_Art11</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessIdentificationNeed_To_GatewayPurposeRequiresIdentification_Art11</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_PurposeRequiresIdentification_Art11"
                           name="Do the processing purposes require identification of the data subject?">
      <bpmn:incoming>Flow_TaskAssessIdentificationNeed_To_GatewayPurposeRequiresIdentification_Art11</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayPurposeRequiresIdentification_To_EndArticle11NotApplicable_Art11</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayPurposeRequiresIdentification_To_TaskAvoidAdditionalIdentification_Art11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AvoidAdditionalIdentification_Art11"
               name="Avoid extra identification data">
      <bpmn:incoming>Flow_GatewayPurposeRequiresIdentification_To_TaskAvoidAdditionalIdentification_Art11</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAvoidAdditionalIdentification_To_GatewayCanDemonstrateInability_Art11</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_CanDemonstrateInability_Art11"
                           name="Can the controller demonstrate that it is not in a position to identify the data subject?">
      <bpmn:incoming>Flow_TaskAvoidAdditionalIdentification_To_GatewayCanDemonstrateInability_Art11</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayCanDemonstrateInability_To_GatewayInformPossible_Art11</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCanDemonstrateInability_To_EndNoArt11Par2Relief_Art11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_InformPossible_Art11"
                           name="Is it possible to inform the data subject accordingly?">
      <bpmn:incoming>Flow_GatewayCanDemonstrateInability_To_GatewayInformPossible_Art11</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayInformPossible_To_SendTaskInformDataSubject_Art11</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayInformPossible_To_GatewayRightsRequest_Art11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_InformDataSubject_Art11"
                   name="Inform inability to identify">
      <bpmn:incoming>Flow_GatewayInformPossible_To_SendTaskInformDataSubject_Art11</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskInformDataSubject_To_GatewayRightsRequest_Art11</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_RightsRequest_Art11"
                           name="Does the data subject seek to exercise rights under Articles 15 to 20?">
      <bpmn:incoming>Flow_GatewayInformPossible_To_GatewayRightsRequest_Art11</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskInformDataSubject_To_GatewayRightsRequest_Art11</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRightsRequest_To_ReceiveTaskReceiveRightsRequest_Art11</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRightsRequest_To_EndNoFurtherIdentificationNeeded_Art11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:receiveTask id="ReceiveTask_ReceiveRightsRequest_Art11"
                      name="Receive rights request and added information">
      <bpmn:incoming>Flow_GatewayRightsRequest_To_ReceiveTaskReceiveRightsRequest_Art11</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveRightsRequest_To_GatewayAdditionalInfo_Art11</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_AdditionalInfo_Art11"
                           name="Did the data subject provide additional information enabling identification?">
      <bpmn:incoming>Flow_ReceiveTaskReceiveRightsRequest_To_GatewayAdditionalInfo_Art11</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAdditionalInfo_To_EndRightsMayProceed_Art11</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAdditionalInfo_To_EndRightsDoNotApply_Art11</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Article11NotApplicable_Art11"
                   name="Article 11 not applicable">
      <bpmn:incoming>Flow_GatewayPurposeRequiresIdentification_To_EndArticle11NotApplicable_Art11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_NoArt11Par2Relief_Art11"
                   name="Article 11(2) relief not established">
      <bpmn:incoming>Flow_GatewayCanDemonstrateInability_To_EndNoArt11Par2Relief_Art11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_NoFurtherIdentificationNeeded_Art11"
                   name="No further identification needed">
      <bpmn:incoming>Flow_GatewayRightsRequest_To_EndNoFurtherIdentificationNeeded_Art11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_RightsMayProceed_Art11"
                   name="Rights request may proceed">
      <bpmn:incoming>Flow_GatewayAdditionalInfo_To_EndRightsMayProceed_Art11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_RightsDoNotApply_Art11"
                   name="Articles 15 to 20 do not apply">
      <bpmn:incoming>Flow_GatewayAdditionalInfo_To_EndRightsDoNotApply_Art11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_TaskAssessIdentificationNeed_Art11" sourceRef="StartEvent_AssessArticle11_Art11" targetRef="Task_AssessIdentificationNeed_Art11" />
    <bpmn:sequenceFlow id="Flow_TaskAssessIdentificationNeed_To_GatewayPurposeRequiresIdentification_Art11" sourceRef="Task_AssessIdentificationNeed_Art11" targetRef="Gateway_PurposeRequiresIdentification_Art11" />
    <bpmn:sequenceFlow id="Flow_GatewayPurposeRequiresIdentification_To_EndArticle11NotApplicable_Art11" name="Yes" sourceRef="Gateway_PurposeRequiresIdentification_Art11" targetRef="EndEvent_Article11NotApplicable_Art11" />
    <bpmn:sequenceFlow id="Flow_GatewayPurposeRequiresIdentification_To_TaskAvoidAdditionalIdentification_Art11" name="No" sourceRef="Gateway_PurposeRequiresIdentification_Art11" targetRef="Task_AvoidAdditionalIdentification_Art11" />
    <bpmn:sequenceFlow id="Flow_TaskAvoidAdditionalIdentification_To_GatewayCanDemonstrateInability_Art11" sourceRef="Task_AvoidAdditionalIdentification_Art11" targetRef="Gateway_CanDemonstrateInability_Art11" />
    <bpmn:sequenceFlow id="Flow_GatewayCanDemonstrateInability_To_GatewayInformPossible_Art11" name="Yes" sourceRef="Gateway_CanDemonstrateInability_Art11" targetRef="Gateway_InformPossible_Art11" />
    <bpmn:sequenceFlow id="Flow_GatewayCanDemonstrateInability_To_EndNoArt11Par2Relief_Art11" name="No" sourceRef="Gateway_CanDemonstrateInability_Art11" targetRef="EndEvent_NoArt11Par2Relief_Art11" />
    <bpmn:sequenceFlow id="Flow_GatewayInformPossible_To_SendTaskInformDataSubject_Art11" name="Yes" sourceRef="Gateway_InformPossible_Art11" targetRef="SendTask_InformDataSubject_Art11" />
    <bpmn:sequenceFlow id="Flow_GatewayInformPossible_To_GatewayRightsRequest_Art11" name="No" sourceRef="Gateway_InformPossible_Art11" targetRef="Gateway_RightsRequest_Art11" />
    <bpmn:sequenceFlow id="Flow_SendTaskInformDataSubject_To_GatewayRightsRequest_Art11" sourceRef="SendTask_InformDataSubject_Art11" targetRef="Gateway_RightsRequest_Art11" />
    <bpmn:sequenceFlow id="Flow_GatewayRightsRequest_To_ReceiveTaskReceiveRightsRequest_Art11" name="Yes" sourceRef="Gateway_RightsRequest_Art11" targetRef="ReceiveTask_ReceiveRightsRequest_Art11" />
    <bpmn:sequenceFlow id="Flow_GatewayRightsRequest_To_EndNoFurtherIdentificationNeeded_Art11" name="No" sourceRef="Gateway_RightsRequest_Art11" targetRef="EndEvent_NoFurtherIdentificationNeeded_Art11" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveRightsRequest_To_GatewayAdditionalInfo_Art11" sourceRef="ReceiveTask_ReceiveRightsRequest_Art11" targetRef="Gateway_AdditionalInfo_Art11" />
    <bpmn:sequenceFlow id="Flow_GatewayAdditionalInfo_To_EndRightsMayProceed_Art11" name="Yes" sourceRef="Gateway_AdditionalInfo_Art11" targetRef="EndEvent_RightsMayProceed_Art11" />
    <bpmn:sequenceFlow id="Flow_GatewayAdditionalInfo_To_EndRightsDoNotApply_Art11" name="No" sourceRef="Gateway_AdditionalInfo_Art11" targetRef="EndEvent_RightsDoNotApply_Art11" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art11_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art11_Reviewed" bpmnElement="Collaboration_Art11_Reviewed">
      <bpmndi:BPMNShape id="Participant_Controller_Art11_di" bpmnElement="Participant_Controller_Art11" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="4200" height="760" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art11_di" bpmnElement="Participant_DataSubject_Art11" isHorizontal="true">
        <dc:Bounds x="60" y="860" width="4200" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_AssessArticle11_Art11_di" bpmnElement="StartEvent_AssessArticle11_Art11">
        <dc:Bounds x="120" y="382" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessIdentificationNeed_Art11_di" bpmnElement="Task_AssessIdentificationNeed_Art11">
        <dc:Bounds x="240" y="360" width="430" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PurposeRequiresIdentification_Art11_di" bpmnElement="Gateway_PurposeRequiresIdentification_Art11" isMarkerVisible="true">
        <dc:Bounds x="810" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AvoidAdditionalIdentification_Art11_di" bpmnElement="Task_AvoidAdditionalIdentification_Art11">
        <dc:Bounds x="980" y="360" width="520" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_CanDemonstrateInability_Art11_di" bpmnElement="Gateway_CanDemonstrateInability_Art11" isMarkerVisible="true">
        <dc:Bounds x="1640" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_InformPossible_Art11_di" bpmnElement="Gateway_InformPossible_Art11" isMarkerVisible="true">
        <dc:Bounds x="1840" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_InformDataSubject_Art11_di" bpmnElement="SendTask_InformDataSubject_Art11">
        <dc:Bounds x="2060" y="210" width="470" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RightsRequest_Art11_di" bpmnElement="Gateway_RightsRequest_Art11" isMarkerVisible="true">
        <dc:Bounds x="2060" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveRightsRequest_Art11_di" bpmnElement="ReceiveTask_ReceiveRightsRequest_Art11">
        <dc:Bounds x="2270" y="360" width="520" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AdditionalInfo_Art11_di" bpmnElement="Gateway_AdditionalInfo_Art11" isMarkerVisible="true">
        <dc:Bounds x="2930" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_Article11NotApplicable_Art11_di" bpmnElement="EndEvent_Article11NotApplicable_Art11">
        <dc:Bounds x="822" y="522" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoArt11Par2Relief_Art11_di" bpmnElement="EndEvent_NoArt11Par2Relief_Art11">
        <dc:Bounds x="1652" y="612" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoFurtherIdentificationNeeded_Art11_di" bpmnElement="EndEvent_NoFurtherIdentificationNeeded_Art11">
        <dc:Bounds x="2072" y="612" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RightsMayProceed_Art11_di" bpmnElement="EndEvent_RightsMayProceed_Art11">
        <dc:Bounds x="3202" y="312" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RightsDoNotApply_Art11_di" bpmnElement="EndEvent_RightsDoNotApply_Art11">
        <dc:Bounds x="3202" y="492" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_TaskAssessIdentificationNeed_Art11_di" bpmnElement="Flow_Start_To_TaskAssessIdentificationNeed_Art11">
        <di:waypoint x="156" y="400" />
        <di:waypoint x="240" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskAssessIdentificationNeed_To_GatewayPurposeRequiresIdentification_Art11_di" bpmnElement="Flow_TaskAssessIdentificationNeed_To_GatewayPurposeRequiresIdentification_Art11">
        <di:waypoint x="670" y="400" />
        <di:waypoint x="810" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPurposeRequiresIdentification_To_EndArticle11NotApplicable_Art11_di" bpmnElement="Flow_GatewayPurposeRequiresIdentification_To_EndArticle11NotApplicable_Art11">
        <di:waypoint x="835" y="425" />
        <di:waypoint x="840" y="522" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPurposeRequiresIdentification_To_TaskAvoidAdditionalIdentification_Art11_di" bpmnElement="Flow_GatewayPurposeRequiresIdentification_To_TaskAvoidAdditionalIdentification_Art11">
        <di:waypoint x="860" y="400" />
        <di:waypoint x="980" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskAvoidAdditionalIdentification_To_GatewayCanDemonstrateInability_Art11_di" bpmnElement="Flow_TaskAvoidAdditionalIdentification_To_GatewayCanDemonstrateInability_Art11">
        <di:waypoint x="1500" y="400" />
        <di:waypoint x="1640" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayCanDemonstrateInability_To_GatewayInformPossible_Art11_di" bpmnElement="Flow_GatewayCanDemonstrateInability_To_GatewayInformPossible_Art11">
        <di:waypoint x="1690" y="400" />
        <di:waypoint x="1840" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayCanDemonstrateInability_To_EndNoArt11Par2Relief_Art11_di" bpmnElement="Flow_GatewayCanDemonstrateInability_To_EndNoArt11Par2Relief_Art11">
        <di:waypoint x="1665" y="425" />
        <di:waypoint x="1670" y="612" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayInformPossible_To_SendTaskInformDataSubject_Art11_di" bpmnElement="Flow_GatewayInformPossible_To_SendTaskInformDataSubject_Art11">
        <di:waypoint x="1865" y="375" />
        <di:waypoint x="1865" y="250" />
        <di:waypoint x="2060" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayInformPossible_To_GatewayRightsRequest_Art11_di" bpmnElement="Flow_GatewayInformPossible_To_GatewayRightsRequest_Art11">
        <di:waypoint x="1890" y="400" />
        <di:waypoint x="2060" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SendTaskInformDataSubject_To_GatewayRightsRequest_Art11_di" bpmnElement="Flow_SendTaskInformDataSubject_To_GatewayRightsRequest_Art11">
        <di:waypoint x="2295" y="290" />
        <di:waypoint x="2295" y="330" />
        <di:waypoint x="2085" y="330" />
        <di:waypoint x="2085" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayRightsRequest_To_ReceiveTaskReceiveRightsRequest_Art11_di" bpmnElement="Flow_GatewayRightsRequest_To_ReceiveTaskReceiveRightsRequest_Art11">
        <di:waypoint x="2110" y="400" />
        <di:waypoint x="2270" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayRightsRequest_To_EndNoFurtherIdentificationNeeded_Art11_di" bpmnElement="Flow_GatewayRightsRequest_To_EndNoFurtherIdentificationNeeded_Art11">
        <di:waypoint x="2085" y="425" />
        <di:waypoint x="2090" y="612" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReceiveTaskReceiveRightsRequest_To_GatewayAdditionalInfo_Art11_di" bpmnElement="Flow_ReceiveTaskReceiveRightsRequest_To_GatewayAdditionalInfo_Art11">
        <di:waypoint x="2790" y="400" />
        <di:waypoint x="2930" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAdditionalInfo_To_EndRightsMayProceed_Art11_di" bpmnElement="Flow_GatewayAdditionalInfo_To_EndRightsMayProceed_Art11">
        <di:waypoint x="2955" y="375" />
        <di:waypoint x="2955" y="330" />
        <di:waypoint x="3202" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAdditionalInfo_To_EndRightsDoNotApply_Art11_di" bpmnElement="Flow_GatewayAdditionalInfo_To_EndRightsDoNotApply_Art11">
        <di:waypoint x="2955" y="425" />
        <di:waypoint x="2955" y="510" />
        <di:waypoint x="3202" y="510" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MessageFlow_InformDataSubject_Art11_di" bpmnElement="MessageFlow_InformDataSubject_Art11">
        <di:waypoint x="2295" y="290" />
        <di:waypoint x="2295" y="860" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_RightsRequest_Art11_di" bpmnElement="MessageFlow_RightsRequest_Art11">
        <di:waypoint x="2530" y="400" />
        <di:waypoint x="2530" y="860" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
