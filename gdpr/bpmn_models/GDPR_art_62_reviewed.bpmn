<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art62_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art62_Reviewed">
    <bpmn:participant id="Participant_HostSupervisoryAuthority_Art62"
                      name="Host Supervisory Authority"
                      processRef="Process_HostSupervisoryAuthority_Art62" />
    <bpmn:participant id="Participant_ParticipatingSupervisoryAuthority_Art62"
                      name="Participating Supervisory Authority"
                      processRef="Process_ParticipatingSupervisoryAuthority_Art62" />
    <bpmn:participant id="Participant_HostMemberState_Art62"
                      name="Host Member State" />
    <bpmn:participant id="Participant_SecondingMemberState_Art62"
                      name="Seconding Member State" />
    <bpmn:participant id="Participant_Board_Art62"
                      name="Board" />

    <bpmn:messageFlow id="MessageFlow_SendParticipationInvite_Art62"
                      sourceRef="Task_SendParticipationInvite_Art62"
                      targetRef="StartEvent_ReceiveParticipationInvite_Art62" />
    <bpmn:messageFlow id="MessageFlow_RequestParticipation_Art62"
                      sourceRef="Task_RequestParticipation_Art62"
                      targetRef="StartEvent_ReceiveParticipationRequest_Art62" />
    <bpmn:messageFlow id="MessageFlow_SendParticipationResponse_Art62"
                      sourceRef="Task_SendParticipationResponse_Art62"
                      targetRef="Task_ReceiveParticipationResponse_Art62" />
    <bpmn:messageFlow id="MessageFlow_ConferOrAllowPowers_Art62"
                      sourceRef="Task_ConferOrAllowPowers_Art62"
                      targetRef="Task_OperateUnderHostGuidance_Art62" />
    <bpmn:messageFlow id="MessageFlow_NotifyHostMemberState_Art62"
                      sourceRef="Task_NotifyHostMemberStateOfDamage_Art62"
                      targetRef="Participant_HostMemberState_Art62" />
    <bpmn:messageFlow id="MessageFlow_RequestReimbursement_Art62"
                      sourceRef="Task_RequestReimbursementFromSecondingState_Art62"
                      targetRef="Participant_SecondingMemberState_Art62" />
    <bpmn:messageFlow id="MessageFlow_RequestUrgentBoardDecision_Art62"
                      sourceRef="Task_RequestUrgentBoardDecision_Art62"
                      targetRef="Participant_Board_Art62" />
  </bpmn:collaboration>

  <bpmn:process id="Process_HostSupervisoryAuthority_Art62"
                name="Conduct and manage joint operations"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 62 based on the real English legal text from
      gdpr_articles/article_62.txt. This process captures the host supervisory authority's
      joint-operation setup, invitation of affected authorities, no-delay response to
      participation requests, Article 62(3) host-law and guidance framework including the
      conferral or allowance of investigative powers where permitted, and the Article 62(4)-(6)
      liability and reimbursement consequences where damage is caused during operations.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_PlanJointOperation_Art62"
                     name="Plan joint operation">
      <bpmn:outgoing>Flow_StartPlanJointOperation_To_IdentifyAuthorities_Art62</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_IdentifyParticipatingAuthorities_Art62"
               name="Identify participating authorities">
      <bpmn:incoming>Flow_StartPlanJointOperation_To_IdentifyAuthorities_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_IdentifyAuthorities_To_SendInvite_Art62</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_SendParticipationInvite_Art62"
                   name="Invite authorities to participate">
      <bpmn:incoming>Flow_IdentifyAuthorities_To_SendInvite_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_SendInvite_To_GatewayHostPowers_Art62</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_WillHostConferPowers_Art62"
                           name="Will host confer or allow investigative powers?">
      <bpmn:incoming>Flow_SendInvite_To_GatewayHostPowers_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayHostPowers_To_ConferOrAllowPowers_Art62</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayHostPowers_To_ConductJointOperation_Art62</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_ConferOrAllowPowers_Art62"
                   name="Confer or allow investigative powers">
      <bpmn:incoming>Flow_GatewayHostPowers_To_ConferOrAllowPowers_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_ConferOrAllowPowers_To_ConductJointOperation_Art62</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ConductJointOperation_Art62"
               name="Conduct joint operation under host law">
      <bpmn:incoming>Flow_GatewayHostPowers_To_ConductJointOperation_Art62</bpmn:incoming>
      <bpmn:incoming>Flow_ConferOrAllowPowers_To_ConductJointOperation_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_ConductJointOperation_To_GatewayDamage_Art62</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_WasDamageCaused_Art62"
                           name="Was damage caused during operations?">
      <bpmn:incoming>Flow_ConductJointOperation_To_GatewayDamage_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayDamage_To_NotifyHostState_Art62</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayDamage_To_EndJointOperationCompleted_Art62</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_NotifyHostMemberStateOfDamage_Art62"
                   name="Notify host Member State of damage">
      <bpmn:incoming>Flow_GatewayDamage_To_NotifyHostState_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyHostState_To_CompensateDamage_Art62</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_CompensateDamageUnderHostLaw_Art62"
               name="Compensate damage under host law">
      <bpmn:incoming>Flow_NotifyHostState_To_CompensateDamage_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_CompensateDamage_To_RequestReimbursement_Art62</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_RequestReimbursementFromSecondingState_Art62"
                   name="Request full reimbursement">
      <bpmn:incoming>Flow_CompensateDamage_To_RequestReimbursement_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestReimbursement_To_RefrainFromOtherClaims_Art62</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_RefrainFromOtherReimbursementClaims_Art62"
               name="Refrain from other reimbursement claims">
      <bpmn:incoming>Flow_RequestReimbursement_To_RefrainFromOtherClaims_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_RefrainFromOtherClaims_To_EndDamageHandled_Art62</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_JointOperationCompleted_Art62"
                   name="Joint operation completed">
      <bpmn:incoming>Flow_GatewayDamage_To_EndJointOperationCompleted_Art62</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_DamageHandled_Art62"
                   name="Damage handled">
      <bpmn:incoming>Flow_RefrainFromOtherClaims_To_EndDamageHandled_Art62</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="StartEvent_ReceiveParticipationRequest_Art62"
                     name="Receive participation request">
      <bpmn:messageEventDefinition />
      <bpmn:outgoing>Flow_StartReceiveParticipationRequest_To_SendParticipationResponse_Art62</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sendTask id="Task_SendParticipationResponse_Art62"
                   name="Respond to participation request without delay">
      <bpmn:incoming>Flow_StartReceiveParticipationRequest_To_SendParticipationResponse_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_SendParticipationResponse_To_EndParticipationResponseSent_Art62</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_ParticipationResponseSent_Art62"
                   name="Participation response sent">
      <bpmn:incoming>Flow_SendParticipationResponse_To_EndParticipationResponseSent_Art62</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartPlanJointOperation_To_IdentifyAuthorities_Art62"
                       sourceRef="StartEvent_PlanJointOperation_Art62"
                       targetRef="Task_IdentifyParticipatingAuthorities_Art62" />
    <bpmn:sequenceFlow id="Flow_IdentifyAuthorities_To_SendInvite_Art62"
                       sourceRef="Task_IdentifyParticipatingAuthorities_Art62"
                       targetRef="Task_SendParticipationInvite_Art62" />
    <bpmn:sequenceFlow id="Flow_SendInvite_To_GatewayHostPowers_Art62"
                       sourceRef="Task_SendParticipationInvite_Art62"
                       targetRef="Gateway_WillHostConferPowers_Art62" />
    <bpmn:sequenceFlow id="Flow_GatewayHostPowers_To_ConferOrAllowPowers_Art62"
                       name="Yes"
                       sourceRef="Gateway_WillHostConferPowers_Art62"
                       targetRef="Task_ConferOrAllowPowers_Art62" />
    <bpmn:sequenceFlow id="Flow_GatewayHostPowers_To_ConductJointOperation_Art62"
                       name="No"
                       sourceRef="Gateway_WillHostConferPowers_Art62"
                       targetRef="Task_ConductJointOperation_Art62" />
    <bpmn:sequenceFlow id="Flow_ConferOrAllowPowers_To_ConductJointOperation_Art62"
                       sourceRef="Task_ConferOrAllowPowers_Art62"
                       targetRef="Task_ConductJointOperation_Art62" />
    <bpmn:sequenceFlow id="Flow_ConductJointOperation_To_GatewayDamage_Art62"
                       sourceRef="Task_ConductJointOperation_Art62"
                       targetRef="Gateway_WasDamageCaused_Art62" />
    <bpmn:sequenceFlow id="Flow_GatewayDamage_To_NotifyHostState_Art62"
                       name="Yes"
                       sourceRef="Gateway_WasDamageCaused_Art62"
                       targetRef="Task_NotifyHostMemberStateOfDamage_Art62" />
    <bpmn:sequenceFlow id="Flow_GatewayDamage_To_EndJointOperationCompleted_Art62"
                       name="No"
                       sourceRef="Gateway_WasDamageCaused_Art62"
                       targetRef="EndEvent_JointOperationCompleted_Art62" />
    <bpmn:sequenceFlow id="Flow_NotifyHostState_To_CompensateDamage_Art62"
                       sourceRef="Task_NotifyHostMemberStateOfDamage_Art62"
                       targetRef="Task_CompensateDamageUnderHostLaw_Art62" />
    <bpmn:sequenceFlow id="Flow_CompensateDamage_To_RequestReimbursement_Art62"
                       sourceRef="Task_CompensateDamageUnderHostLaw_Art62"
                       targetRef="Task_RequestReimbursementFromSecondingState_Art62" />
    <bpmn:sequenceFlow id="Flow_RequestReimbursement_To_RefrainFromOtherClaims_Art62"
                       sourceRef="Task_RequestReimbursementFromSecondingState_Art62"
                       targetRef="Task_RefrainFromOtherReimbursementClaims_Art62" />
    <bpmn:sequenceFlow id="Flow_RefrainFromOtherClaims_To_EndDamageHandled_Art62"
                       sourceRef="Task_RefrainFromOtherReimbursementClaims_Art62"
                       targetRef="EndEvent_DamageHandled_Art62" />
    <bpmn:sequenceFlow id="Flow_StartReceiveParticipationRequest_To_SendParticipationResponse_Art62"
                       sourceRef="StartEvent_ReceiveParticipationRequest_Art62"
                       targetRef="Task_SendParticipationResponse_Art62" />
    <bpmn:sequenceFlow id="Flow_SendParticipationResponse_To_EndParticipationResponseSent_Art62"
                       sourceRef="Task_SendParticipationResponse_Art62"
                       targetRef="EndEvent_ParticipationResponseSent_Art62" />
  </bpmn:process>

  <bpmn:process id="Process_ParticipatingSupervisoryAuthority_Art62"
                name="Join or request participation in joint operations"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 62 based on the real English legal text from
      gdpr_articles/article_62.txt. This process captures the participating supervisory
      authority's right to participate where Article 62(2) conditions are met, request-based
      participation, one-month silence escalation to Article 55 and Article 66(2), and the
      operation of seconded members or staff under host guidance and host Member State law.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_NeedToParticipate_Art62"
                     name="Need to participate">
      <bpmn:outgoing>Flow_StartNeedToParticipate_To_RequestParticipation_Art62</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sendTask id="Task_RequestParticipation_Art62"
                   name="Request participation">
      <bpmn:incoming>Flow_StartNeedToParticipate_To_RequestParticipation_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestParticipation_To_GatewayOneMonth_Art62</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="Gateway_WhatReceivedWithinOneMonth_Art62"
                            name="What is received within one month?">
      <bpmn:incoming>Flow_RequestParticipation_To_GatewayOneMonth_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayOneMonth_To_ReceiveParticipationResponse_Art62</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayOneMonth_To_OneMonthElapsed_Art62</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:receiveTask id="Task_ReceiveParticipationResponse_Art62"
                      name="Receive participation response">
      <bpmn:incoming>Flow_GatewayOneMonth_To_ReceiveParticipationResponse_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveParticipationResponse_To_AuthorizeSecondedStaff_Art62</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:intermediateCatchEvent id="IntermediateCatchEvent_OneMonthElapsed_Art62"
                                 name="One month elapsed">
      <bpmn:incoming>Flow_GatewayOneMonth_To_OneMonthElapsed_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_OneMonthElapsed_To_AdoptProvisionalMeasure_Art62</bpmn:outgoing>
      <bpmn:timerEventDefinition />
    </bpmn:intermediateCatchEvent>

    <bpmn:startEvent id="StartEvent_ReceiveParticipationInvite_Art62"
                     name="Receive participation invite">
      <bpmn:messageEventDefinition />
      <bpmn:outgoing>Flow_StartReceiveParticipationInvite_To_AuthorizeSecondedStaff_Art62</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_AuthorizeSecondedStaff_Art62"
               name="Authorize seconded members or staff">
      <bpmn:incoming>Flow_ReceiveParticipationResponse_To_AuthorizeSecondedStaff_Art62</bpmn:incoming>
      <bpmn:incoming>Flow_StartReceiveParticipationInvite_To_AuthorizeSecondedStaff_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_AuthorizeSecondedStaff_To_OperateUnderHostGuidance_Art62</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_OperateUnderHostGuidance_Art62"
               name="Operate under host guidance and host law">
      <bpmn:incoming>Flow_AuthorizeSecondedStaff_To_OperateUnderHostGuidance_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_OperateUnderHostGuidance_To_EndParticipationCompleted_Art62</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AdoptProvisionalMeasure_Art62"
               name="Adopt provisional measure under Article 55">
      <bpmn:incoming>Flow_OneMonthElapsed_To_AdoptProvisionalMeasure_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptProvisionalMeasure_To_RequestUrgentBoardDecision_Art62</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_RequestUrgentBoardDecision_Art62"
                   name="Request urgent Board decision under Article 66(2)">
      <bpmn:incoming>Flow_AdoptProvisionalMeasure_To_RequestUrgentBoardDecision_Art62</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestUrgentBoardDecision_To_EndUrgencyTriggered_Art62</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_ParticipationCompleted_Art62"
                   name="Participation completed">
      <bpmn:incoming>Flow_OperateUnderHostGuidance_To_EndParticipationCompleted_Art62</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_UrgencyRouteTriggered_Art62"
                   name="Urgency route triggered">
      <bpmn:incoming>Flow_RequestUrgentBoardDecision_To_EndUrgencyTriggered_Art62</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartNeedToParticipate_To_RequestParticipation_Art62"
                       sourceRef="StartEvent_NeedToParticipate_Art62"
                       targetRef="Task_RequestParticipation_Art62" />
    <bpmn:sequenceFlow id="Flow_RequestParticipation_To_GatewayOneMonth_Art62"
                       sourceRef="Task_RequestParticipation_Art62"
                       targetRef="Gateway_WhatReceivedWithinOneMonth_Art62" />
    <bpmn:sequenceFlow id="Flow_GatewayOneMonth_To_ReceiveParticipationResponse_Art62"
                       name="Response"
                       sourceRef="Gateway_WhatReceivedWithinOneMonth_Art62"
                       targetRef="Task_ReceiveParticipationResponse_Art62" />
    <bpmn:sequenceFlow id="Flow_GatewayOneMonth_To_OneMonthElapsed_Art62"
                       name="One month"
                       sourceRef="Gateway_WhatReceivedWithinOneMonth_Art62"
                       targetRef="IntermediateCatchEvent_OneMonthElapsed_Art62" />
    <bpmn:sequenceFlow id="Flow_ReceiveParticipationResponse_To_AuthorizeSecondedStaff_Art62"
                       sourceRef="Task_ReceiveParticipationResponse_Art62"
                       targetRef="Task_AuthorizeSecondedStaff_Art62" />
    <bpmn:sequenceFlow id="Flow_StartReceiveParticipationInvite_To_AuthorizeSecondedStaff_Art62"
                       sourceRef="StartEvent_ReceiveParticipationInvite_Art62"
                       targetRef="Task_AuthorizeSecondedStaff_Art62" />
    <bpmn:sequenceFlow id="Flow_AuthorizeSecondedStaff_To_OperateUnderHostGuidance_Art62"
                       sourceRef="Task_AuthorizeSecondedStaff_Art62"
                       targetRef="Task_OperateUnderHostGuidance_Art62" />
    <bpmn:sequenceFlow id="Flow_OperateUnderHostGuidance_To_EndParticipationCompleted_Art62"
                       sourceRef="Task_OperateUnderHostGuidance_Art62"
                       targetRef="EndEvent_ParticipationCompleted_Art62" />
    <bpmn:sequenceFlow id="Flow_OneMonthElapsed_To_AdoptProvisionalMeasure_Art62"
                       sourceRef="IntermediateCatchEvent_OneMonthElapsed_Art62"
                       targetRef="Task_AdoptProvisionalMeasure_Art62" />
    <bpmn:sequenceFlow id="Flow_AdoptProvisionalMeasure_To_RequestUrgentBoardDecision_Art62"
                       sourceRef="Task_AdoptProvisionalMeasure_Art62"
                       targetRef="Task_RequestUrgentBoardDecision_Art62" />
    <bpmn:sequenceFlow id="Flow_RequestUrgentBoardDecision_To_EndUrgencyTriggered_Art62"
                       sourceRef="Task_RequestUrgentBoardDecision_Art62"
                       targetRef="EndEvent_UrgencyRouteTriggered_Art62" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art62_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art62_Reviewed"
                      bpmnElement="Collaboration_Art62_Reviewed">
      <bpmndi:BPMNShape id="Participant_HostSupervisoryAuthority_Art62_di"
                        bpmnElement="Participant_HostSupervisoryAuthority_Art62"
                        isHorizontal="true">
        <dc:Bounds x="20" y="20" width="2550" height="430" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_ParticipatingSupervisoryAuthority_Art62_di"
                        bpmnElement="Participant_ParticipatingSupervisoryAuthority_Art62"
                        isHorizontal="true">
        <dc:Bounds x="20" y="470" width="2550" height="390" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_HostMemberState_Art62_di"
                        bpmnElement="Participant_HostMemberState_Art62"
                        isHorizontal="true">
        <dc:Bounds x="20" y="890" width="2550" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_SecondingMemberState_Art62_di"
                        bpmnElement="Participant_SecondingMemberState_Art62"
                        isHorizontal="true">
        <dc:Bounds x="20" y="1010" width="2550" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Board_Art62_di"
                        bpmnElement="Participant_Board_Art62"
                        isHorizontal="true">
        <dc:Bounds x="20" y="1130" width="2550" height="100" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_PlanJointOperation_Art62_di"
                        bpmnElement="StartEvent_PlanJointOperation_Art62">
        <dc:Bounds x="120" y="132" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IdentifyParticipatingAuthorities_Art62_di"
                        bpmnElement="Task_IdentifyParticipatingAuthorities_Art62">
        <dc:Bounds x="230" y="90" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendParticipationInvite_Art62_di"
                        bpmnElement="Task_SendParticipationInvite_Art62">
        <dc:Bounds x="470" y="90" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_WillHostConferPowers_Art62_di"
                        bpmnElement="Gateway_WillHostConferPowers_Art62"
                        isMarkerVisible="true">
        <dc:Bounds x="730" y="105" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ConferOrAllowPowers_Art62_di"
                        bpmnElement="Task_ConferOrAllowPowers_Art62">
        <dc:Bounds x="850" y="40" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ConductJointOperation_Art62_di"
                        bpmnElement="Task_ConductJointOperation_Art62">
        <dc:Bounds x="1080" y="90" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_WasDamageCaused_Art62_di"
                        bpmnElement="Gateway_WasDamageCaused_Art62"
                        isMarkerVisible="true">
        <dc:Bounds x="1310" y="105" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyHostMemberStateOfDamage_Art62_di"
                        bpmnElement="Task_NotifyHostMemberStateOfDamage_Art62">
        <dc:Bounds x="1440" y="40" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CompensateDamageUnderHostLaw_Art62_di"
                        bpmnElement="Task_CompensateDamageUnderHostLaw_Art62">
        <dc:Bounds x="1680" y="40" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RequestReimbursementFromSecondingState_Art62_di"
                        bpmnElement="Task_RequestReimbursementFromSecondingState_Art62">
        <dc:Bounds x="1910" y="40" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RefrainFromOtherReimbursementClaims_Art62_di"
                        bpmnElement="Task_RefrainFromOtherReimbursementClaims_Art62">
        <dc:Bounds x="2140" y="40" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_JointOperationCompleted_Art62_di"
                        bpmnElement="EndEvent_JointOperationCompleted_Art62">
        <dc:Bounds x="1460" y="197" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_DamageHandled_Art62_di"
                        bpmnElement="EndEvent_DamageHandled_Art62">
        <dc:Bounds x="2390" y="62" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_ReceiveParticipationRequest_Art62_di"
                        bpmnElement="StartEvent_ReceiveParticipationRequest_Art62">
        <dc:Bounds x="120" y="312" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendParticipationResponse_Art62_di"
                        bpmnElement="Task_SendParticipationResponse_Art62">
        <dc:Bounds x="230" y="280" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ParticipationResponseSent_Art62_di"
                        bpmnElement="EndEvent_ParticipationResponseSent_Art62">
        <dc:Bounds x="500" y="302" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_NeedToParticipate_Art62_di"
