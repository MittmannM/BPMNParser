                       bpmnElement="Flow_BringActIntoForce_To_EndActInForce_Art92">
        <di:waypoint x="2350" y="260" />
        <di:waypoint x="2432" y="260" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MessageFlow_NotifyParliament_Art92_di"
                       bpmnElement="MessageFlow_NotifyParliament_Art92">
        <di:waypoint x="1060" y="390" />
        <di:waypoint x="1060" y="500" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_NotifyCouncil_Art92_di"
                       bpmnElement="MessageFlow_NotifyCouncil_Art92">
        <di:waypoint x="1120" y="390" />
        <di:waypoint x="1120" y="660" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
