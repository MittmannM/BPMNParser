<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art92_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art92_Reviewed">
    <bpmn:participant id="Participant_Commission_Art92"
                      name="Commission"
                      processRef="Process_Commission_Art92" />
    <bpmn:participant id="Participant_EuropeanParliament_Art92"
                      name="European Parliament" />
    <bpmn:participant id="Participant_Council_Art92"
                      name="Council" />

    <bpmn:messageFlow id="MessageFlow_NotifyParliament_Art92"
                      sourceRef="Task_NotifyParliamentAndCouncil_Art92"
                      targetRef="Participant_EuropeanParliament_Art92" />
    <bpmn:messageFlow id="MessageFlow_NotifyCouncil_Art92"
                      sourceRef="Task_NotifyParliamentAndCouncil_Art92"
                      targetRef="Participant_Council_Art92" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Commission_Art92"
                name="Adopt delegated acts under Article 92"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 92 based on the real English legal text from
      gdpr_articles/article_92.txt. This collaboration captures the indefinite delegation of
      power for Articles 12(8) and 43(8) from 24 May 2016, the revocation possibility by the
      European Parliament or the Council and its effects, the simultaneous notification duty for
      delegated acts, the objection period with possible extension, and the conditions for entry
      into force.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_HandleDelegatedActPower_Art92"
                     name="Handle delegated-act power">
      <bpmn:outgoing>Flow_Start_To_ConferDelegation_Art92</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_ConferDelegationForIndeterminatePeriod_Art92"
               name="Confer delegation for indeterminate period">
      <bpmn:incoming>Flow_Start_To_ConferDelegation_Art92</bpmn:incoming>
      <bpmn:outgoing>Flow_ConferDelegation_To_GatewayRevocation_Art92</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_HasDelegationBeenRevoked_Art92"
                           name="Has Parliament or Council revoked the delegation?">
      <bpmn:incoming>Flow_ConferDelegation_To_GatewayRevocation_Art92</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRevocation_To_ApplyRevocationDecision_Art92</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRevocation_To_AdoptDelegatedAct_Art92</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ApplyRevocationDecision_Art92"
               name="Apply revocation decision">
      <bpmn:incoming>Flow_GatewayRevocation_To_ApplyRevocationDecision_Art92</bpmn:incoming>
      <bpmn:outgoing>Flow_ApplyRevocationDecision_To_PreserveExistingValidity_Art92</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PreserveValidityOfActsAlreadyInForce_Art92"
               name="Preserve validity of acts already in force">
      <bpmn:incoming>Flow_ApplyRevocationDecision_To_PreserveExistingValidity_Art92</bpmn:incoming>
      <bpmn:outgoing>Flow_PreserveExistingValidity_To_EndDelegationRevoked_Art92</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_DelegationRevoked_Art92"
                   name="Delegation revoked">
      <bpmn:incoming>Flow_PreserveExistingValidity_To_EndDelegationRevoked_Art92</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_AdoptDelegatedAct_Art92"
               name="Adopt delegated act">
      <bpmn:incoming>Flow_GatewayRevocation_To_AdoptDelegatedAct_Art92</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptDelegatedAct_To_NotifyParliamentAndCouncil_Art92</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_NotifyParliamentAndCouncil_Art92"
                   name="Notify Parliament and Council">
      <bpmn:incoming>Flow_AdoptDelegatedAct_To_NotifyParliamentAndCouncil_Art92</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyParliamentAndCouncil_To_GatewayExtension_Art92</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_HasAnExtensionBeenInitiated_Art92"
                           name="Has Parliament or Council initiated an extension?">
      <bpmn:incoming>Flow_NotifyParliamentAndCouncil_To_GatewayExtension_Art92</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayExtension_To_ExtendObjectionPeriod_Art92</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayExtension_To_GatewayEarlyNoObjection_Art92</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ExtendObjectionPeriodByThreeMonths_Art92"
               name="Extend objection period by three months">
      <bpmn:incoming>Flow_GatewayExtension_To_ExtendObjectionPeriod_Art92</bpmn:incoming>
      <bpmn:outgoing>Flow_ExtendObjectionPeriod_To_GatewayEarlyNoObjection_Art92</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_DidBothBodiesInformNoObjection_Art92"
                           name="Did Parliament and Council both inform the Commission that they will not object?">
      <bpmn:incoming>Flow_GatewayExtension_To_GatewayEarlyNoObjection_Art92</bpmn:incoming>
      <bpmn:incoming>Flow_ExtendObjectionPeriod_To_GatewayEarlyNoObjection_Art92</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayEarlyNoObjection_To_BringActIntoForce_Art92</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayEarlyNoObjection_To_GatewayObjection_Art92</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_HasAnyBodyObjectedWithinPeriod_Art92"
                           name="Has either Parliament or Council objected within the objection period?">
      <bpmn:incoming>Flow_GatewayEarlyNoObjection_To_GatewayObjection_Art92</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayObjection_To_EndActBlocked_Art92</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayObjection_To_BringActIntoForce_Art92</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_DelegatedActBlocked_Art92"
                   name="Delegated act blocked">
      <bpmn:incoming>Flow_GatewayObjection_To_EndActBlocked_Art92</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_BringDelegatedActIntoForce_Art92"
               name="Bring delegated act into force">
      <bpmn:incoming>Flow_GatewayEarlyNoObjection_To_BringActIntoForce_Art92</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayObjection_To_BringActIntoForce_Art92</bpmn:incoming>
      <bpmn:outgoing>Flow_BringActIntoForce_To_EndActInForce_Art92</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_DelegatedActInForce_Art92"
                   name="Delegated act in force">
      <bpmn:incoming>Flow_BringActIntoForce_To_EndActInForce_Art92</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_ConferDelegation_Art92"
                       sourceRef="StartEvent_HandleDelegatedActPower_Art92"
                       targetRef="Task_ConferDelegationForIndeterminatePeriod_Art92" />
    <bpmn:sequenceFlow id="Flow_ConferDelegation_To_GatewayRevocation_Art92"
                       sourceRef="Task_ConferDelegationForIndeterminatePeriod_Art92"
                       targetRef="Gateway_HasDelegationBeenRevoked_Art92" />
    <bpmn:sequenceFlow id="Flow_GatewayRevocation_To_ApplyRevocationDecision_Art92"
                       name="Yes"
                       sourceRef="Gateway_HasDelegationBeenRevoked_Art92"
                       targetRef="Task_ApplyRevocationDecision_Art92" />
    <bpmn:sequenceFlow id="Flow_GatewayRevocation_To_AdoptDelegatedAct_Art92"
                       name="No"
                       sourceRef="Gateway_HasDelegationBeenRevoked_Art92"
                       targetRef="Task_AdoptDelegatedAct_Art92" />
    <bpmn:sequenceFlow id="Flow_ApplyRevocationDecision_To_PreserveExistingValidity_Art92"
                       sourceRef="Task_ApplyRevocationDecision_Art92"
                       targetRef="Task_PreserveValidityOfActsAlreadyInForce_Art92" />
    <bpmn:sequenceFlow id="Flow_PreserveExistingValidity_To_EndDelegationRevoked_Art92"
                       sourceRef="Task_PreserveValidityOfActsAlreadyInForce_Art92"
                       targetRef="EndEvent_DelegationRevoked_Art92" />
    <bpmn:sequenceFlow id="Flow_AdoptDelegatedAct_To_NotifyParliamentAndCouncil_Art92"
                       sourceRef="Task_AdoptDelegatedAct_Art92"
                       targetRef="Task_NotifyParliamentAndCouncil_Art92" />
    <bpmn:sequenceFlow id="Flow_NotifyParliamentAndCouncil_To_GatewayExtension_Art92"
                       sourceRef="Task_NotifyParliamentAndCouncil_Art92"
                       targetRef="Gateway_HasAnExtensionBeenInitiated_Art92" />
    <bpmn:sequenceFlow id="Flow_GatewayExtension_To_ExtendObjectionPeriod_Art92"
                       name="Yes"
                       sourceRef="Gateway_HasAnExtensionBeenInitiated_Art92"
                       targetRef="Task_ExtendObjectionPeriodByThreeMonths_Art92" />
    <bpmn:sequenceFlow id="Flow_GatewayExtension_To_GatewayEarlyNoObjection_Art92"
                       name="No"
                       sourceRef="Gateway_HasAnExtensionBeenInitiated_Art92"
                       targetRef="Gateway_DidBothBodiesInformNoObjection_Art92" />
    <bpmn:sequenceFlow id="Flow_ExtendObjectionPeriod_To_GatewayEarlyNoObjection_Art92"
                       sourceRef="Task_ExtendObjectionPeriodByThreeMonths_Art92"
                       targetRef="Gateway_DidBothBodiesInformNoObjection_Art92" />
    <bpmn:sequenceFlow id="Flow_GatewayEarlyNoObjection_To_BringActIntoForce_Art92"
                       name="Yes"
                       sourceRef="Gateway_DidBothBodiesInformNoObjection_Art92"
                       targetRef="Task_BringDelegatedActIntoForce_Art92" />
    <bpmn:sequenceFlow id="Flow_GatewayEarlyNoObjection_To_GatewayObjection_Art92"
                       name="No"
                       sourceRef="Gateway_DidBothBodiesInformNoObjection_Art92"
                       targetRef="Gateway_HasAnyBodyObjectedWithinPeriod_Art92" />
    <bpmn:sequenceFlow id="Flow_GatewayObjection_To_EndActBlocked_Art92"
                       name="Yes"
                       sourceRef="Gateway_HasAnyBodyObjectedWithinPeriod_Art92"
                       targetRef="EndEvent_DelegatedActBlocked_Art92" />
    <bpmn:sequenceFlow id="Flow_GatewayObjection_To_BringActIntoForce_Art92"
                       name="No"
                       sourceRef="Gateway_HasAnyBodyObjectedWithinPeriod_Art92"
                       targetRef="Task_BringDelegatedActIntoForce_Art92" />
    <bpmn:sequenceFlow id="Flow_BringActIntoForce_To_EndActInForce_Art92"
                       sourceRef="Task_BringDelegatedActIntoForce_Art92"
                       targetRef="EndEvent_DelegatedActInForce_Art92" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art92_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art92_Reviewed"
                      bpmnElement="Collaboration_Art92_Reviewed">
      <bpmndi:BPMNShape id="Participant_Commission_Art92_di"
