      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PreserveValidityOfActsAlreadyInForce_Art92_di"
                        bpmnElement="Task_PreserveValidityOfActsAlreadyInForce_Art92">
        <dc:Bounds x="960" y="120" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_DelegationRevoked_Art92_di"
                        bpmnElement="EndEvent_DelegationRevoked_Art92">
