                        bpmnElement="Gateway_HasAnyBodyObjectedWithinPeriod_Art92"
                        isMarkerVisible="true">
        <dc:Bounds x="1930" y="325" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_DelegatedActBlocked_Art92_di"
                        bpmnElement="EndEvent_DelegatedActBlocked_Art92">
        <dc:Bounds x="2162" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_BringDelegatedActIntoForce_Art92_di"
                        bpmnElement="Task_BringDelegatedActIntoForce_Art92">
        <dc:Bounds x="2160" y="220" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_DelegatedActInForce_Art92_di"
                        bpmnElement="EndEvent_DelegatedActInForce_Art92">
        <dc:Bounds x="2432" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_ConferDelegation_Art92_di"
                       bpmnElement="Flow_Start_To_ConferDelegation_Art92">
        <di:waypoint x="156" y="270" />
        <di:waypoint x="210" y="270" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ConferDelegation_To_GatewayRevocation_Art92_di"
                       bpmnElement="Flow_ConferDelegation_To_GatewayRevocation_Art92">
        <di:waypoint x="430" y="270" />
        <di:waypoint x="520" y="270" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayRevocation_To_ApplyRevocationDecision_Art92_di"
                       bpmnElement="Flow_GatewayRevocation_To_ApplyRevocationDecision_Art92">
        <di:waypoint x="545" y="245" />
        <di:waypoint x="545" y="160" />
        <di:waypoint x="680" y="160" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="578" y="176" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayRevocation_To_AdoptDelegatedAct_Art92_di"
                       bpmnElement="Flow_GatewayRevocation_To_AdoptDelegatedAct_Art92">
        <di:waypoint x="570" y="270" />
        <di:waypoint x="680" y="350" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="604" y="292" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ApplyRevocationDecision_To_PreserveExistingValidity_Art92_di"
                       bpmnElement="Flow_ApplyRevocationDecision_To_PreserveExistingValidity_Art92">
        <di:waypoint x="860" y="160" />
        <di:waypoint x="960" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PreserveExistingValidity_To_EndDelegationRevoked_Art92_di"
                       bpmnElement="Flow_PreserveExistingValidity_To_EndDelegationRevoked_Art92">
        <di:waypoint x="1180" y="160" />
        <di:waypoint x="1262" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdoptDelegatedAct_To_NotifyParliamentAndCouncil_Art92_di"
                       bpmnElement="Flow_AdoptDelegatedAct_To_NotifyParliamentAndCouncil_Art92">
        <di:waypoint x="850" y="350" />
        <di:waypoint x="960" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotifyParliamentAndCouncil_To_GatewayExtension_Art92_di"
                       bpmnElement="Flow_NotifyParliamentAndCouncil_To_GatewayExtension_Art92">
        <di:waypoint x="1160" y="350" />
        <di:waypoint x="1260" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayExtension_To_ExtendObjectionPeriod_Art92_di"
                       bpmnElement="Flow_GatewayExtension_To_ExtendObjectionPeriod_Art92">
        <di:waypoint x="1285" y="325" />
        <di:waypoint x="1285" y="260" />
        <di:waypoint x="1410" y="260" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1316" y="276" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayExtension_To_GatewayEarlyNoObjection_Art92_di"
                       bpmnElement="Flow_GatewayExtension_To_GatewayEarlyNoObjection_Art92">
        <di:waypoint x="1310" y="350" />
        <di:waypoint x="1730" y="350" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1508" y="332" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ExtendObjectionPeriod_To_GatewayEarlyNoObjection_Art92_di"
                       bpmnElement="Flow_ExtendObjectionPeriod_To_GatewayEarlyNoObjection_Art92">
        <di:waypoint x="1630" y="260" />
        <di:waypoint x="1755" y="260" />
        <di:waypoint x="1755" y="325" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayEarlyNoObjection_To_BringActIntoForce_Art92_di"
                       bpmnElement="Flow_GatewayEarlyNoObjection_To_BringActIntoForce_Art92">
        <di:waypoint x="1780" y="325" />
        <di:waypoint x="1780" y="260" />
        <di:waypoint x="2160" y="260" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1948" y="242" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayEarlyNoObjection_To_GatewayObjection_Art92_di"
                       bpmnElement="Flow_GatewayEarlyNoObjection_To_GatewayObjection_Art92">
        <di:waypoint x="1780" y="350" />
        <di:waypoint x="1930" y="350" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1848" y="332" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayObjection_To_EndActBlocked_Art92_di"
