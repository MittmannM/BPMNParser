<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art75_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_Board_Art75"
                name="Set up and run the Board secretariat"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 75 based on the real English legal text from
      gdpr_articles/article_75.txt. This process captures the provision of the Board secretariat
      by the European Data Protection Supervisor, Chair-only instruction, separate reporting
      lines, the optional Memorandum of Understanding, the support function of the secretariat,
      and the full Article 75(6)(a)-(g) responsibility set.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_SetUpSecretariat_Art75"
                     name="Set up Board secretariat">
      <bpmn:outgoing>Flow_Start_To_ObtainSecretariat_Art75</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_ObtainSecretariatFromEDPS_Art75"
               name="Obtain secretariat from EDPS">
      <bpmn:incoming>Flow_Start_To_ObtainSecretariat_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_ObtainSecretariat_To_SetInstructions_Art75</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetChairOnlyInstructions_Art75"
               name="Set Chair-only instructions">
      <bpmn:incoming>Flow_ObtainSecretariat_To_SetInstructions_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_SetInstructions_To_SetReportingLines_Art75</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetSeparateReportingLines_Art75"
               name="Set separate reporting lines">
      <bpmn:incoming>Flow_SetInstructions_To_SetReportingLines_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_SetReportingLines_To_GatewayMoU_Art75</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_IsMoUAppropriate_Art75"
                           name="Is a memorandum of understanding appropriate?">
      <bpmn:incoming>Flow_SetReportingLines_To_GatewayMoU_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMoU_To_EstablishMoU_Art75</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayMoU_To_GatewayMergeMoU_Art75</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_EstablishMoU_Art75"
               name="Establish memorandum of understanding">
      <bpmn:incoming>Flow_GatewayMoU_To_EstablishMoU_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_EstablishMoU_To_PublishMoU_Art75</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_PublishMoU_Art75"
                   name="Publish memorandum of understanding">
      <bpmn:incoming>Flow_EstablishMoU_To_PublishMoU_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_PublishMoU_To_GatewayMergeMoU_Art75</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_MergeMoUPath_Art75">
      <bpmn:incoming>Flow_GatewayMoU_To_GatewayMergeMoU_Art75</bpmn:incoming>
      <bpmn:incoming>Flow_PublishMoU_To_GatewayMergeMoU_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMergeMoU_To_ProvideSupport_Art75</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ProvideBoardSupport_Art75"
               name="Provide Board support">
      <bpmn:incoming>Flow_GatewayMergeMoU_To_ProvideSupport_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_ProvideSupport_To_GatewaySplitResponsibilities_Art75</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_SplitResponsibilities_Art75">
      <bpmn:incoming>Flow_ProvideSupport_To_GatewaySplitResponsibilities_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplit_To_RunDayToDayBusiness_Art75</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplit_To_ManageBoardAndCommissionCommunications_Art75</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplit_To_ManageInstitutionalAndPublicCommunications_Art75</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplit_To_UseElectronicMeans_Art75</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplit_To_TranslateInformation_Art75</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplit_To_PrepareMeetings_Art75</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplit_To_PrepareBoardTexts_Art75</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_RunDayToDayBusiness_Art75"
               name="Run day-to-day business">
      <bpmn:incoming>Flow_GatewaySplit_To_RunDayToDayBusiness_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_RunDayToDayBusiness_To_GatewayJoinResponsibilities_Art75</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_ManageBoardAndCommissionCommunications_Art75"
                   name="Manage Board and Commission communications">
      <bpmn:incoming>Flow_GatewaySplit_To_ManageBoardAndCommissionCommunications_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_ManageBoardAndCommissionCommunications_To_GatewayJoinResponsibilities_Art75</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_ManageInstitutionalAndPublicCommunications_Art75"
                   name="Manage institutional and public communications">
      <bpmn:incoming>Flow_GatewaySplit_To_ManageInstitutionalAndPublicCommunications_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_ManageInstitutionalAndPublicCommunications_To_GatewayJoinResponsibilities_Art75</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_UseElectronicMeans_Art75"
               name="Use electronic communication means">
      <bpmn:incoming>Flow_GatewaySplit_To_UseElectronicMeans_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_UseElectronicMeans_To_GatewayJoinResponsibilities_Art75</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_TranslateRelevantInformation_Art75"
               name="Translate relevant information">
      <bpmn:incoming>Flow_GatewaySplit_To_TranslateInformation_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_TranslateRelevantInformation_To_GatewayJoinResponsibilities_Art75</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PrepareAndFollowUpMeetings_Art75"
               name="Prepare and follow up meetings">
      <bpmn:incoming>Flow_GatewaySplit_To_PrepareMeetings_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_PrepareAndFollowUpMeetings_To_GatewayJoinResponsibilities_Art75</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_PrepareAndPublishBoardTexts_Art75"
                   name="Prepare and publish Board texts">
      <bpmn:incoming>Flow_GatewaySplit_To_PrepareBoardTexts_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_PrepareAndPublishBoardTexts_To_GatewayJoinResponsibilities_Art75</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:parallelGateway id="Gateway_JoinResponsibilities_Art75">
      <bpmn:incoming>Flow_RunDayToDayBusiness_To_GatewayJoinResponsibilities_Art75</bpmn:incoming>
      <bpmn:incoming>Flow_ManageBoardAndCommissionCommunications_To_GatewayJoinResponsibilities_Art75</bpmn:incoming>
      <bpmn:incoming>Flow_ManageInstitutionalAndPublicCommunications_To_GatewayJoinResponsibilities_Art75</bpmn:incoming>
      <bpmn:incoming>Flow_UseElectronicMeans_To_GatewayJoinResponsibilities_Art75</bpmn:incoming>
      <bpmn:incoming>Flow_TranslateRelevantInformation_To_GatewayJoinResponsibilities_Art75</bpmn:incoming>
      <bpmn:incoming>Flow_PrepareAndFollowUpMeetings_To_GatewayJoinResponsibilities_Art75</bpmn:incoming>
      <bpmn:incoming>Flow_PrepareAndPublishBoardTexts_To_GatewayJoinResponsibilities_Art75</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinResponsibilities_To_EndSecretariat_Art75</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:endEvent id="EndEvent_SecretariatSupportsBoard_Art75"
                   name="Secretariat supports Board">
      <bpmn:incoming>Flow_GatewayJoinResponsibilities_To_EndSecretariat_Art75</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_ObtainSecretariat_Art75"
                       sourceRef="StartEvent_SetUpSecretariat_Art75"
                       targetRef="Task_ObtainSecretariatFromEDPS_Art75" />
    <bpmn:sequenceFlow id="Flow_ObtainSecretariat_To_SetInstructions_Art75"
                       sourceRef="Task_ObtainSecretariatFromEDPS_Art75"
                       targetRef="Task_SetChairOnlyInstructions_Art75" />
    <bpmn:sequenceFlow id="Flow_SetInstructions_To_SetReportingLines_Art75"
                       sourceRef="Task_SetChairOnlyInstructions_Art75"
                       targetRef="Task_SetSeparateReportingLines_Art75" />
    <bpmn:sequenceFlow id="Flow_SetReportingLines_To_GatewayMoU_Art75"
                       sourceRef="Task_SetSeparateReportingLines_Art75"
                       targetRef="Gateway_IsMoUAppropriate_Art75" />
    <bpmn:sequenceFlow id="Flow_GatewayMoU_To_EstablishMoU_Art75"
                       name="Yes"
                       sourceRef="Gateway_IsMoUAppropriate_Art75"
                       targetRef="Task_EstablishMoU_Art75" />
    <bpmn:sequenceFlow id="Flow_GatewayMoU_To_GatewayMergeMoU_Art75"
                       name="No"
                       sourceRef="Gateway_IsMoUAppropriate_Art75"
                       targetRef="Gateway_MergeMoUPath_Art75" />
    <bpmn:sequenceFlow id="Flow_EstablishMoU_To_PublishMoU_Art75"
                       sourceRef="Task_EstablishMoU_Art75"
                       targetRef="Task_PublishMoU_Art75" />
    <bpmn:sequenceFlow id="Flow_PublishMoU_To_GatewayMergeMoU_Art75"
                       sourceRef="Task_PublishMoU_Art75"
                       targetRef="Gateway_MergeMoUPath_Art75" />
    <bpmn:sequenceFlow id="Flow_GatewayMergeMoU_To_ProvideSupport_Art75"
                       sourceRef="Gateway_MergeMoUPath_Art75"
                       targetRef="Task_ProvideBoardSupport_Art75" />
    <bpmn:sequenceFlow id="Flow_ProvideSupport_To_GatewaySplitResponsibilities_Art75"
                       sourceRef="Task_ProvideBoardSupport_Art75"
                       targetRef="Gateway_SplitResponsibilities_Art75" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_RunDayToDayBusiness_Art75"
                       sourceRef="Gateway_SplitResponsibilities_Art75"
                       targetRef="Task_RunDayToDayBusiness_Art75" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_ManageBoardAndCommissionCommunications_Art75"
                       sourceRef="Gateway_SplitResponsibilities_Art75"
                       targetRef="Task_ManageBoardAndCommissionCommunications_Art75" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_ManageInstitutionalAndPublicCommunications_Art75"
                       sourceRef="Gateway_SplitResponsibilities_Art75"
                       targetRef="Task_ManageInstitutionalAndPublicCommunications_Art75" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_UseElectronicMeans_Art75"
                       sourceRef="Gateway_SplitResponsibilities_Art75"
                       targetRef="Task_UseElectronicMeans_Art75" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_TranslateInformation_Art75"
                       sourceRef="Gateway_SplitResponsibilities_Art75"
                       targetRef="Task_TranslateRelevantInformation_Art75" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_PrepareMeetings_Art75"
                       sourceRef="Gateway_SplitResponsibilities_Art75"
                       targetRef="Task_PrepareAndFollowUpMeetings_Art75" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_PrepareBoardTexts_Art75"
                       sourceRef="Gateway_SplitResponsibilities_Art75"
                       targetRef="Task_PrepareAndPublishBoardTexts_Art75" />
    <bpmn:sequenceFlow id="Flow_RunDayToDayBusiness_To_GatewayJoinResponsibilities_Art75"
                       sourceRef="Task_RunDayToDayBusiness_Art75"
                       targetRef="Gateway_JoinResponsibilities_Art75" />
    <bpmn:sequenceFlow id="Flow_ManageBoardAndCommissionCommunications_To_GatewayJoinResponsibilities_Art75"
                       sourceRef="Task_ManageBoardAndCommissionCommunications_Art75"
                       targetRef="Gateway_JoinResponsibilities_Art75" />
    <bpmn:sequenceFlow id="Flow_ManageInstitutionalAndPublicCommunications_To_GatewayJoinResponsibilities_Art75"
                       sourceRef="Task_ManageInstitutionalAndPublicCommunications_Art75"
                       targetRef="Gateway_JoinResponsibilities_Art75" />
    <bpmn:sequenceFlow id="Flow_UseElectronicMeans_To_GatewayJoinResponsibilities_Art75"
                       sourceRef="Task_UseElectronicMeans_Art75"
                       targetRef="Gateway_JoinResponsibilities_Art75" />
    <bpmn:sequenceFlow id="Flow_TranslateRelevantInformation_To_GatewayJoinResponsibilities_Art75"
                       sourceRef="Task_TranslateRelevantInformation_Art75"
                       targetRef="Gateway_JoinResponsibilities_Art75" />
    <bpmn:sequenceFlow id="Flow_PrepareAndFollowUpMeetings_To_GatewayJoinResponsibilities_Art75"
                       sourceRef="Task_PrepareAndFollowUpMeetings_Art75"
                       targetRef="Gateway_JoinResponsibilities_Art75" />
    <bpmn:sequenceFlow id="Flow_PrepareAndPublishBoardTexts_To_GatewayJoinResponsibilities_Art75"
                       sourceRef="Task_PrepareAndPublishBoardTexts_Art75"
                       targetRef="Gateway_JoinResponsibilities_Art75" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinResponsibilities_To_EndSecretariat_Art75"
                       sourceRef="Gateway_JoinResponsibilities_Art75"
                       targetRef="EndEvent_SecretariatSupportsBoard_Art75" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art75_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art75_Reviewed"
                      bpmnElement="Process_Board_Art75">
      <bpmndi:BPMNShape id="StartEvent_SetUpSecretariat_Art75_di"
                        bpmnElement="StartEvent_SetUpSecretariat_Art75">
        <dc:Bounds x="90" y="337" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ObtainSecretariatFromEDPS_Art75_di"
                        bpmnElement="Task_ObtainSecretariatFromEDPS_Art75">
        <dc:Bounds x="180" y="315" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetChairOnlyInstructions_Art75_di"
                        bpmnElement="Task_SetChairOnlyInstructions_Art75">
        <dc:Bounds x="430" y="315" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetSeparateReportingLines_Art75_di"
                        bpmnElement="Task_SetSeparateReportingLines_Art75">
        <dc:Bounds x="670" y="315" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IsMoUAppropriate_Art75_di"
                        bpmnElement="Gateway_IsMoUAppropriate_Art75"
                        isMarkerVisible="true">
        <dc:Bounds x="930" y="330" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EstablishMoU_Art75_di"
                        bpmnElement="Task_EstablishMoU_Art75">
        <dc:Bounds x="1070" y="230" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PublishMoU_Art75_di"
                        bpmnElement="Task_PublishMoU_Art75">
        <dc:Bounds x="1320" y="230" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MergeMoUPath_Art75_di"
                        bpmnElement="Gateway_MergeMoUPath_Art75"
                        isMarkerVisible="true">
        <dc:Bounds x="1600" y="330" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProvideBoardSupport_Art75_di"
                        bpmnElement="Task_ProvideBoardSupport_Art75">
        <dc:Bounds x="1720" y="315" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SplitResponsibilities_Art75_di"
                        bpmnElement="Gateway_SplitResponsibilities_Art75"
                        isMarkerVisible="true">
        <dc:Bounds x="1960" y="330" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RunDayToDayBusiness_Art75_di"
                        bpmnElement="Task_RunDayToDayBusiness_Art75">
        <dc:Bounds x="2100" y="20" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ManageBoardAndCommissionCommunications_Art75_di"
                        bpmnElement="Task_ManageBoardAndCommissionCommunications_Art75">
        <dc:Bounds x="2100" y="110" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ManageInstitutionalAndPublicCommunications_Art75_di"
                        bpmnElement="Task_ManageInstitutionalAndPublicCommunications_Art75">
        <dc:Bounds x="2100" y="200" width="230" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_UseElectronicMeans_Art75_di"
                        bpmnElement="Task_UseElectronicMeans_Art75">
        <dc:Bounds x="2100" y="290" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_TranslateRelevantInformation_Art75_di"
                        bpmnElement="Task_TranslateRelevantInformation_Art75">
        <dc:Bounds x="2100" y="380" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PrepareAndFollowUpMeetings_Art75_di"
                        bpmnElement="Task_PrepareAndFollowUpMeetings_Art75">
        <dc:Bounds x="2100" y="470" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PrepareAndPublishBoardTexts_Art75_di"
                        bpmnElement="Task_PrepareAndPublishBoardTexts_Art75">
        <dc:Bounds x="2100" y="560" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_JoinResponsibilities_Art75_di"
                        bpmnElement="Gateway_JoinResponsibilities_Art75"
                        isMarkerVisible="true">
        <dc:Bounds x="2430" y="330" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_SecretariatSupportsBoard_Art75_di"
                        bpmnElement="EndEvent_SecretariatSupportsBoard_Art75">
        <dc:Bounds x="2580" y="337" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_ObtainSecretariat_Art75_di"
                       bpmnElement="Flow_Start_To_ObtainSecretariat_Art75">
        <di:waypoint x="126" y="355" />
        <di:waypoint x="180" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ObtainSecretariat_To_SetInstructions_Art75_di"
                       bpmnElement="Flow_ObtainSecretariat_To_SetInstructions_Art75">
        <di:waypoint x="360" y="355" />
        <di:waypoint x="430" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SetInstructions_To_SetReportingLines_Art75_di"
                       bpmnElement="Flow_SetInstructions_To_SetReportingLines_Art75">
        <di:waypoint x="600" y="355" />
        <di:waypoint x="670" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SetReportingLines_To_GatewayMoU_Art75_di"
                       bpmnElement="Flow_SetReportingLines_To_GatewayMoU_Art75">
        <di:waypoint x="850" y="355" />
        <di:waypoint x="930" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayMoU_To_EstablishMoU_Art75_di"
                       bpmnElement="Flow_GatewayMoU_To_EstablishMoU_Art75">
        <di:waypoint x="955" y="330" />
        <di:waypoint x="955" y="270" />
        <di:waypoint x="1070" y="270" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="978" y="286" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayMoU_To_GatewayMergeMoU_Art75_di"
                       bpmnElement="Flow_GatewayMoU_To_GatewayMergeMoU_Art75">
        <di:waypoint x="980" y="355" />
        <di:waypoint x="1600" y="355" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1270" y="337" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EstablishMoU_To_PublishMoU_Art75_di"
                       bpmnElement="Flow_EstablishMoU_To_PublishMoU_Art75">
        <di:waypoint x="1260" y="270" />
        <di:waypoint x="1320" y="270" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PublishMoU_To_GatewayMergeMoU_Art75_di"
                       bpmnElement="Flow_PublishMoU_To_GatewayMergeMoU_Art75">
        <di:waypoint x="1510" y="270" />
        <di:waypoint x="1625" y="270" />
        <di:waypoint x="1625" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayMergeMoU_To_ProvideSupport_Art75_di"
                       bpmnElement="Flow_GatewayMergeMoU_To_ProvideSupport_Art75">
        <di:waypoint x="1650" y="355" />
        <di:waypoint x="1720" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ProvideSupport_To_GatewaySplitResponsibilities_Art75_di"
                       bpmnElement="Flow_ProvideSupport_To_GatewaySplitResponsibilities_Art75">
        <di:waypoint x="1890" y="355" />
        <di:waypoint x="1960" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_RunDayToDayBusiness_Art75_di"
                       bpmnElement="Flow_GatewaySplit_To_RunDayToDayBusiness_Art75">
        <di:waypoint x="1985" y="330" />
        <di:waypoint x="1985" y="60" />
        <di:waypoint x="2100" y="60" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_ManageBoardAndCommissionCommunications_Art75_di"
                       bpmnElement="Flow_GatewaySplit_To_ManageBoardAndCommissionCommunications_Art75">
        <di:waypoint x="1985" y="330" />
        <di:waypoint x="1985" y="150" />
        <di:waypoint x="2100" y="150" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_ManageInstitutionalAndPublicCommunications_Art75_di"
                       bpmnElement="Flow_GatewaySplit_To_ManageInstitutionalAndPublicCommunications_Art75">
        <di:waypoint x="1985" y="330" />
        <di:waypoint x="1985" y="240" />
        <di:waypoint x="2100" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_UseElectronicMeans_Art75_di"
                       bpmnElement="Flow_GatewaySplit_To_UseElectronicMeans_Art75">
        <di:waypoint x="2010" y="355" />
        <di:waypoint x="2100" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_TranslateInformation_Art75_di"
                       bpmnElement="Flow_GatewaySplit_To_TranslateInformation_Art75">
        <di:waypoint x="1985" y="380" />
        <di:waypoint x="1985" y="420" />
