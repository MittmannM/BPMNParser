<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art26_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art26_Reviewed">
    <bpmn:participant id="Participant_JointControllerA_Art26"
                      name="Joint Controller A"
                      processRef="Process_JointControllerA_Art26" />
    <bpmn:participant id="Participant_JointControllerB_Art26"
                      name="Joint Controller B" />
    <bpmn:participant id="Participant_DataSubject_Art26"
                      name="Data Subject" />

    <bpmn:messageFlow id="MessageFlow_CoordinateArrangement_Art26"
                      sourceRef="SendTask_CoordinateArrangement_Art26"
                      targetRef="Participant_JointControllerB_Art26" />
    <bpmn:messageFlow id="MessageFlow_ReceiveArrangementInput_Art26"
                      sourceRef="Participant_JointControllerB_Art26"
                      targetRef="ReceiveTask_ReceiveArrangementInput_Art26" />
    <bpmn:messageFlow id="MessageFlow_MakeEssenceAvailable_Art26"
                      sourceRef="SendTask_MakeEssenceAvailable_Art26"
                      targetRef="Participant_DataSubject_Art26" />
    <bpmn:messageFlow id="MessageFlow_DataSubjectRequestToA_Art26"
                      sourceRef="Participant_DataSubject_Art26"
                      targetRef="ReceiveTask_ReceiveRightsRequestA_Art26" />
    <bpmn:messageFlow id="MessageFlow_DataSubjectRequestToB_Art26"
                      sourceRef="Participant_DataSubject_Art26"
                      targetRef="Participant_JointControllerB_Art26" />
  </bpmn:collaboration>

  <bpmn:process id="Process_JointControllerA_Art26"
                name="Establishing a joint-controller framework under Article 26"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 26 based on the real English legal text
      of Regulation (EU) 2016/679. The model captures the trigger for joint
      controllership, the split between an arrangement and responsibilities determined
      by Union or Member State law, the allocation of responsibilities for data
      subject rights and the information duties under Articles 13 and 14, the
      optional designation of a contact point, the duty to make the essence of the
      arrangement available to the data subject, and the rule that rights may be
      exercised against each controller irrespective of the arrangement.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_PlanJointProcessing_Art26"
                     name="Plan joint processing">
      <bpmn:outgoing>Flow_StartPlanJointProcessing_To_GatewayJointDetermination_Art26</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_JointDetermination_Art26"
                           name="Are the purposes and means jointly determined?">
      <bpmn:incoming>Flow_StartPlanJointProcessing_To_GatewayJointDetermination_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJointDetermination_To_GatewayLegalAllocation_Art26</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayJointDetermination_To_EndArticle26NotTriggered_Art26</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Article26NotTriggered_Art26"
                   name="Article 26 is not triggered">
      <bpmn:incoming>Flow_GatewayJointDetermination_To_EndArticle26NotTriggered_Art26</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_LegalAllocation_Art26"
                           name="Are responsibilities determined by Union or Member State law?">
      <bpmn:incoming>Flow_GatewayJointDetermination_To_GatewayLegalAllocation_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayLegalAllocation_To_TaskApplyLegalAllocation_Art26</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayLegalAllocation_To_SendTaskCoordinateArrangement_Art26</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ApplyLegalAllocation_Art26"
               name="Apply legal allocation">
      <bpmn:incoming>Flow_GatewayLegalAllocation_To_TaskApplyLegalAllocation_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskApplyLegalAllocation_To_GatewayRightsAgainstA_Art26</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_CoordinateArrangement_Art26"
                   name="Coordinate arrangement">
      <bpmn:incoming>Flow_GatewayLegalAllocation_To_SendTaskCoordinateArrangement_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskCoordinateArrangement_To_ReceiveTaskReceiveArrangementInput_Art26</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveArrangementInput_Art26"
                      name="Receive arrangement input">
      <bpmn:incoming>Flow_SendTaskCoordinateArrangement_To_ReceiveTaskReceiveArrangementInput_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveArrangementInput_To_TaskDefineResponsibilities_Art26</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_DefineResponsibilities_Art26"
               name="Define responsibilities">
      <bpmn:incoming>Flow_ReceiveTaskReceiveArrangementInput_To_TaskDefineResponsibilities_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDefineResponsibilities_To_TaskReflectRoles_Art26</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ReflectRoles_Art26"
               name="Reflect roles and relationships">
      <bpmn:incoming>Flow_TaskDefineResponsibilities_To_TaskReflectRoles_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskReflectRoles_To_TaskAllocateRightsNoticeDuties_Art26</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AllocateRightsNoticeDuties_Art26"
               name="Allocate rights and notice duties">
      <bpmn:incoming>Flow_TaskReflectRoles_To_TaskAllocateRightsNoticeDuties_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAllocateRightsNoticeDuties_To_GatewayDesignateContactPoint_Art26</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_DesignateContactPoint_Art26"
                           name="Designate a contact point for data subjects?">
      <bpmn:incoming>Flow_TaskAllocateRightsNoticeDuties_To_GatewayDesignateContactPoint_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayDesignateContactPoint_To_TaskDesignateContactPoint_Art26</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayDesignateContactPoint_To_GatewayContactPointJoin_Art26</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_DesignateContactPoint_Art26"
               name="Designate contact point">
      <bpmn:incoming>Flow_GatewayDesignateContactPoint_To_TaskDesignateContactPoint_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDesignateContactPoint_To_GatewayContactPointJoin_Art26</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ContactPointJoin_Art26">
      <bpmn:incoming>Flow_GatewayDesignateContactPoint_To_GatewayContactPointJoin_Art26</bpmn:incoming>
      <bpmn:incoming>Flow_TaskDesignateContactPoint_To_GatewayContactPointJoin_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayContactPointJoin_To_SendTaskMakeEssenceAvailable_Art26</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_MakeEssenceAvailable_Art26"
                   name="Make arrangement essence available">
      <bpmn:incoming>Flow_GatewayContactPointJoin_To_SendTaskMakeEssenceAvailable_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskMakeEssenceAvailable_To_GatewayRightsAgainstA_Art26</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_RightsAgainstA_Art26"
                           name="Did the data subject exercise rights against Joint Controller A?">
      <bpmn:incoming>Flow_TaskApplyLegalAllocation_To_GatewayRightsAgainstA_Art26</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskMakeEssenceAvailable_To_GatewayRightsAgainstA_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRightsAgainstA_To_ReceiveTaskReceiveRightsRequestA_Art26</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRightsAgainstA_To_EndFrameworkEstablished_Art26</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:receiveTask id="ReceiveTask_ReceiveRightsRequestA_Art26"
                      name="Receive rights request">
      <bpmn:incoming>Flow_GatewayRightsAgainstA_To_ReceiveTaskReceiveRightsRequestA_Art26</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveRightsRequestA_To_EndFrameworkEstablished_Art26</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:endEvent id="EndEvent_FrameworkEstablished_Art26"
                   name="Article 26 joint-controller framework established">
      <bpmn:incoming>Flow_GatewayRightsAgainstA_To_EndFrameworkEstablished_Art26</bpmn:incoming>
      <bpmn:incoming>Flow_ReceiveTaskReceiveRightsRequestA_To_EndFrameworkEstablished_Art26</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartPlanJointProcessing_To_GatewayJointDetermination_Art26" sourceRef="StartEvent_PlanJointProcessing_Art26" targetRef="Gateway_JointDetermination_Art26" />
    <bpmn:sequenceFlow id="Flow_GatewayJointDetermination_To_GatewayLegalAllocation_Art26" name="Yes" sourceRef="Gateway_JointDetermination_Art26" targetRef="Gateway_LegalAllocation_Art26" />
    <bpmn:sequenceFlow id="Flow_GatewayJointDetermination_To_EndArticle26NotTriggered_Art26" name="No" sourceRef="Gateway_JointDetermination_Art26" targetRef="EndEvent_Article26NotTriggered_Art26" />
    <bpmn:sequenceFlow id="Flow_GatewayLegalAllocation_To_TaskApplyLegalAllocation_Art26" name="Yes" sourceRef="Gateway_LegalAllocation_Art26" targetRef="Task_ApplyLegalAllocation_Art26" />
    <bpmn:sequenceFlow id="Flow_GatewayLegalAllocation_To_SendTaskCoordinateArrangement_Art26" name="No" sourceRef="Gateway_LegalAllocation_Art26" targetRef="SendTask_CoordinateArrangement_Art26" />
    <bpmn:sequenceFlow id="Flow_SendTaskCoordinateArrangement_To_ReceiveTaskReceiveArrangementInput_Art26" sourceRef="SendTask_CoordinateArrangement_Art26" targetRef="ReceiveTask_ReceiveArrangementInput_Art26" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveArrangementInput_To_TaskDefineResponsibilities_Art26" sourceRef="ReceiveTask_ReceiveArrangementInput_Art26" targetRef="Task_DefineResponsibilities_Art26" />
    <bpmn:sequenceFlow id="Flow_TaskDefineResponsibilities_To_TaskReflectRoles_Art26" sourceRef="Task_DefineResponsibilities_Art26" targetRef="Task_ReflectRoles_Art26" />
    <bpmn:sequenceFlow id="Flow_TaskReflectRoles_To_TaskAllocateRightsNoticeDuties_Art26" sourceRef="Task_ReflectRoles_Art26" targetRef="Task_AllocateRightsNoticeDuties_Art26" />
    <bpmn:sequenceFlow id="Flow_TaskAllocateRightsNoticeDuties_To_GatewayDesignateContactPoint_Art26" sourceRef="Task_AllocateRightsNoticeDuties_Art26" targetRef="Gateway_DesignateContactPoint_Art26" />
    <bpmn:sequenceFlow id="Flow_GatewayDesignateContactPoint_To_TaskDesignateContactPoint_Art26" name="Yes" sourceRef="Gateway_DesignateContactPoint_Art26" targetRef="Task_DesignateContactPoint_Art26" />
    <bpmn:sequenceFlow id="Flow_GatewayDesignateContactPoint_To_GatewayContactPointJoin_Art26" name="No" sourceRef="Gateway_DesignateContactPoint_Art26" targetRef="Gateway_ContactPointJoin_Art26" />
    <bpmn:sequenceFlow id="Flow_TaskDesignateContactPoint_To_GatewayContactPointJoin_Art26" sourceRef="Task_DesignateContactPoint_Art26" targetRef="Gateway_ContactPointJoin_Art26" />
    <bpmn:sequenceFlow id="Flow_GatewayContactPointJoin_To_SendTaskMakeEssenceAvailable_Art26" sourceRef="Gateway_ContactPointJoin_Art26" targetRef="SendTask_MakeEssenceAvailable_Art26" />
    <bpmn:sequenceFlow id="Flow_SendTaskMakeEssenceAvailable_To_GatewayRightsAgainstA_Art26" sourceRef="SendTask_MakeEssenceAvailable_Art26" targetRef="Gateway_RightsAgainstA_Art26" />
    <bpmn:sequenceFlow id="Flow_TaskApplyLegalAllocation_To_GatewayRightsAgainstA_Art26" sourceRef="Task_ApplyLegalAllocation_Art26" targetRef="Gateway_RightsAgainstA_Art26" />
    <bpmn:sequenceFlow id="Flow_GatewayRightsAgainstA_To_ReceiveTaskReceiveRightsRequestA_Art26" name="Yes" sourceRef="Gateway_RightsAgainstA_Art26" targetRef="ReceiveTask_ReceiveRightsRequestA_Art26" />
    <bpmn:sequenceFlow id="Flow_GatewayRightsAgainstA_To_EndFrameworkEstablished_Art26" name="No" sourceRef="Gateway_RightsAgainstA_Art26" targetRef="EndEvent_FrameworkEstablished_Art26" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveRightsRequestA_To_EndFrameworkEstablished_Art26" sourceRef="ReceiveTask_ReceiveRightsRequestA_Art26" targetRef="EndEvent_FrameworkEstablished_Art26" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art26_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art26_Reviewed" bpmnElement="Collaboration_Art26_Reviewed">
      <bpmndi:BPMNShape id="Participant_JointControllerA_Art26_di"
                        bpmnElement="Participant_JointControllerA_Art26"
                        isHorizontal="true">
        <dc:Bounds x="60" y="40" width="4500" height="380" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_JointControllerB_Art26_di"
                        bpmnElement="Participant_JointControllerB_Art26"
                        isHorizontal="true">
        <dc:Bounds x="60" y="460" width="4500" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art26_di"
                        bpmnElement="Participant_DataSubject_Art26"
                        isHorizontal="true">
        <dc:Bounds x="60" y="620" width="4500" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_PlanJointProcessing_Art26_di" bpmnElement="StartEvent_PlanJointProcessing_Art26">
        <dc:Bounds x="120" y="232" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_JointDetermination_Art26_di" bpmnElement="Gateway_JointDetermination_Art26" isMarkerVisible="true">
        <dc:Bounds x="260" y="225" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Article26NotTriggered_Art26_di" bpmnElement="EndEvent_Article26NotTriggered_Art26">
        <dc:Bounds x="402" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_LegalAllocation_Art26_di" bpmnElement="Gateway_LegalAllocation_Art26" isMarkerVisible="true">
        <dc:Bounds x="460" y="225" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ApplyLegalAllocation_Art26_di" bpmnElement="Task_ApplyLegalAllocation_Art26">
        <dc:Bounds x="680" y="80" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_CoordinateArrangement_Art26_di" bpmnElement="SendTask_CoordinateArrangement_Art26">
        <dc:Bounds x="680" y="220" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveArrangementInput_Art26_di" bpmnElement="ReceiveTask_ReceiveArrangementInput_Art26">
        <dc:Bounds x="1010" y="220" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DefineResponsibilities_Art26_di" bpmnElement="Task_DefineResponsibilities_Art26">
        <dc:Bounds x="1340" y="220" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReflectRoles_Art26_di" bpmnElement="Task_ReflectRoles_Art26">
        <dc:Bounds x="1660" y="80" width="230" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AllocateRightsNoticeDuties_Art26_di" bpmnElement="Task_AllocateRightsNoticeDuties_Art26">
        <dc:Bounds x="1660" y="220" width="240" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DesignateContactPoint_Art26_di" bpmnElement="Gateway_DesignateContactPoint_Art26" isMarkerVisible="true">
        <dc:Bounds x="2020" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DesignateContactPoint_Art26_di" bpmnElement="Task_DesignateContactPoint_Art26">
        <dc:Bounds x="2200" y="80" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ContactPointJoin_Art26_di" bpmnElement="Gateway_ContactPointJoin_Art26" isMarkerVisible="true">
        <dc:Bounds x="2530" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_MakeEssenceAvailable_Art26_di" bpmnElement="SendTask_MakeEssenceAvailable_Art26">
        <dc:Bounds x="2700" y="220" width="230" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RightsAgainstA_Art26_di" bpmnElement="Gateway_RightsAgainstA_Art26" isMarkerVisible="true">
        <dc:Bounds x="3070" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveRightsRequestA_Art26_di" bpmnElement="ReceiveTask_ReceiveRightsRequestA_Art26">
        <dc:Bounds x="3250" y="220" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_FrameworkEstablished_Art26_di" bpmnElement="EndEvent_FrameworkEstablished_Art26">
        <dc:Bounds x="3582" y="232" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_StartPlanJointProcessing_To_GatewayJointDetermination_Art26_di" bpmnElement="Flow_StartPlanJointProcessing_To_GatewayJointDetermination_Art26">
        <di:waypoint x="156" y="250" />
        <di:waypoint x="260" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayJointDetermination_To_GatewayLegalAllocation_Art26_di" bpmnElement="Flow_GatewayJointDetermination_To_GatewayLegalAllocation_Art26">
        <di:waypoint x="310" y="250" />
        <di:waypoint x="460" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayJointDetermination_To_EndArticle26NotTriggered_Art26_di" bpmnElement="Flow_GatewayJointDetermination_To_EndArticle26NotTriggered_Art26">
        <di:waypoint x="285" y="275" />
        <di:waypoint x="285" y="360" />
        <di:waypoint x="402" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayLegalAllocation_To_TaskApplyLegalAllocation_Art26_di" bpmnElement="Flow_GatewayLegalAllocation_To_TaskApplyLegalAllocation_Art26">
        <di:waypoint x="485" y="225" />
        <di:waypoint x="485" y="120" />
        <di:waypoint x="680" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayLegalAllocation_To_SendTaskCoordinateArrangement_Art26_di" bpmnElement="Flow_GatewayLegalAllocation_To_SendTaskCoordinateArrangement_Art26">
        <di:waypoint x="510" y="250" />
        <di:waypoint x="680" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SendTaskCoordinateArrangement_To_ReceiveTaskReceiveArrangementInput_Art26_di" bpmnElement="Flow_SendTaskCoordinateArrangement_To_ReceiveTaskReceiveArrangementInput_Art26">
        <di:waypoint x="880" y="260" />
        <di:waypoint x="1010" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReceiveTaskReceiveArrangementInput_To_TaskDefineResponsibilities_Art26_di" bpmnElement="Flow_ReceiveTaskReceiveArrangementInput_To_TaskDefineResponsibilities_Art26">
        <di:waypoint x="1220" y="260" />
        <di:waypoint x="1340" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskDefineResponsibilities_To_TaskReflectRoles_Art26_di" bpmnElement="Flow_TaskDefineResponsibilities_To_TaskReflectRoles_Art26">
        <di:waypoint x="1540" y="260" />
        <di:waypoint x="1570" y="260" />
        <di:waypoint x="1570" y="120" />
        <di:waypoint x="1660" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskReflectRoles_To_TaskAllocateRightsNoticeDuties_Art26_di" bpmnElement="Flow_TaskReflectRoles_To_TaskAllocateRightsNoticeDuties_Art26">
        <di:waypoint x="1775" y="160" />
        <di:waypoint x="1775" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskAllocateRightsNoticeDuties_To_GatewayDesignateContactPoint_Art26_di" bpmnElement="Flow_TaskAllocateRightsNoticeDuties_To_GatewayDesignateContactPoint_Art26">
        <di:waypoint x="1900" y="260" />
        <di:waypoint x="2020" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayDesignateContactPoint_To_TaskDesignateContactPoint_Art26_di" bpmnElement="Flow_GatewayDesignateContactPoint_To_TaskDesignateContactPoint_Art26">
        <di:waypoint x="2045" y="235" />
        <di:waypoint x="2045" y="120" />
        <di:waypoint x="2200" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayDesignateContactPoint_To_GatewayContactPointJoin_Art26_di" bpmnElement="Flow_GatewayDesignateContactPoint_To_GatewayContactPointJoin_Art26">
        <di:waypoint x="2070" y="260" />
        <di:waypoint x="2530" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskDesignateContactPoint_To_GatewayContactPointJoin_Art26_di" bpmnElement="Flow_TaskDesignateContactPoint_To_GatewayContactPointJoin_Art26">
        <di:waypoint x="2390" y="120" />
        <di:waypoint x="2555" y="120" />
        <di:waypoint x="2555" y="235" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayContactPointJoin_To_SendTaskMakeEssenceAvailable_Art26_di" bpmnElement="Flow_GatewayContactPointJoin_To_SendTaskMakeEssenceAvailable_Art26">
        <di:waypoint x="2580" y="260" />
        <di:waypoint x="2700" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SendTaskMakeEssenceAvailable_To_GatewayRightsAgainstA_Art26_di" bpmnElement="Flow_SendTaskMakeEssenceAvailable_To_GatewayRightsAgainstA_Art26">
        <di:waypoint x="2930" y="260" />
        <di:waypoint x="3070" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskApplyLegalAllocation_To_GatewayRightsAgainstA_Art26_di" bpmnElement="Flow_TaskApplyLegalAllocation_To_GatewayRightsAgainstA_Art26">
        <di:waypoint x="880" y="120" />
        <di:waypoint x="3095" y="120" />
        <di:waypoint x="3095" y="235" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayRightsAgainstA_To_ReceiveTaskReceiveRightsRequestA_Art26_di" bpmnElement="Flow_GatewayRightsAgainstA_To_ReceiveTaskReceiveRightsRequestA_Art26">
        <di:waypoint x="3120" y="260" />
        <di:waypoint x="3250" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayRightsAgainstA_To_EndFrameworkEstablished_Art26_di" bpmnElement="Flow_GatewayRightsAgainstA_To_EndFrameworkEstablished_Art26">
        <di:waypoint x="3095" y="285" />
        <di:waypoint x="3095" y="360" />
        <di:waypoint x="3600" y="360" />
