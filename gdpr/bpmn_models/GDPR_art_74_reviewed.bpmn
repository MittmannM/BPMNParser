<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art74_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_Board_Art74"
                name="Perform Board chair tasks"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 74 based on the real English legal text from
      gdpr_articles/article_74.txt. This compact process captures the Chair's three listed tasks
      and the Board's duty to allocate tasks between the Chair and the deputy chairs in the rules
      of procedure.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_HandleChairTasks_Art74"
                     name="Handle chair tasks">
      <bpmn:outgoing>Flow_StartChairTasks_To_GatewaySplit_Art74</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:parallelGateway id="Gateway_SplitChairTasks_Art74">
      <bpmn:incoming>Flow_StartChairTasks_To_GatewaySplit_Art74</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplit_To_ConveneMeetings_Art74</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplit_To_NotifyArticle65Decisions_Art74</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplit_To_EnsureTimelyPerformance_Art74</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplit_To_AllocateTasks_Art74</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_ConveneMeetingsAndPrepareAgenda_Art74"
               name="Convene meetings and prepare agenda">
      <bpmn:incoming>Flow_GatewaySplit_To_ConveneMeetings_Art74</bpmn:incoming>
      <bpmn:outgoing>Flow_ConveneMeetings_To_GatewayJoin_Art74</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_NotifyArticle65Decisions_Art74"
                   name="Notify Article 65 decisions">
      <bpmn:incoming>Flow_GatewaySplit_To_NotifyArticle65Decisions_Art74</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyArticle65Decisions_To_GatewayJoin_Art74</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_EnsureTimelyBoardPerformance_Art74"
               name="Ensure timely Board performance">
      <bpmn:incoming>Flow_GatewaySplit_To_EnsureTimelyPerformance_Art74</bpmn:incoming>
      <bpmn:outgoing>Flow_EnsureTimelyPerformance_To_GatewayJoin_Art74</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AllocateTasksInRulesOfProcedure_Art74"
               name="Allocate tasks in rules of procedure">
      <bpmn:incoming>Flow_GatewaySplit_To_AllocateTasks_Art74</bpmn:incoming>
      <bpmn:outgoing>Flow_AllocateTasks_To_GatewayJoin_Art74</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinChairTasks_Art74">
      <bpmn:incoming>Flow_ConveneMeetings_To_GatewayJoin_Art74</bpmn:incoming>
      <bpmn:incoming>Flow_NotifyArticle65Decisions_To_GatewayJoin_Art74</bpmn:incoming>
      <bpmn:incoming>Flow_EnsureTimelyPerformance_To_GatewayJoin_Art74</bpmn:incoming>
      <bpmn:incoming>Flow_AllocateTasks_To_GatewayJoin_Art74</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoin_To_EndChairTasks_Art74</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:endEvent id="EndEvent_ChairTasksCompleted_Art74"
                   name="Chair tasks completed">
      <bpmn:incoming>Flow_GatewayJoin_To_EndChairTasks_Art74</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartChairTasks_To_GatewaySplit_Art74"
                       sourceRef="StartEvent_HandleChairTasks_Art74"
                       targetRef="Gateway_SplitChairTasks_Art74" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_ConveneMeetings_Art74"
                       sourceRef="Gateway_SplitChairTasks_Art74"
                       targetRef="Task_ConveneMeetingsAndPrepareAgenda_Art74" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_NotifyArticle65Decisions_Art74"
                       sourceRef="Gateway_SplitChairTasks_Art74"
                       targetRef="Task_NotifyArticle65Decisions_Art74" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_EnsureTimelyPerformance_Art74"
                       sourceRef="Gateway_SplitChairTasks_Art74"
                       targetRef="Task_EnsureTimelyBoardPerformance_Art74" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_AllocateTasks_Art74"
                       sourceRef="Gateway_SplitChairTasks_Art74"
                       targetRef="Task_AllocateTasksInRulesOfProcedure_Art74" />
    <bpmn:sequenceFlow id="Flow_ConveneMeetings_To_GatewayJoin_Art74"
                       sourceRef="Task_ConveneMeetingsAndPrepareAgenda_Art74"
                       targetRef="Gateway_JoinChairTasks_Art74" />
    <bpmn:sequenceFlow id="Flow_NotifyArticle65Decisions_To_GatewayJoin_Art74"
                       sourceRef="Task_NotifyArticle65Decisions_Art74"
                       targetRef="Gateway_JoinChairTasks_Art74" />
    <bpmn:sequenceFlow id="Flow_EnsureTimelyPerformance_To_GatewayJoin_Art74"
                       sourceRef="Task_EnsureTimelyBoardPerformance_Art74"
                       targetRef="Gateway_JoinChairTasks_Art74" />
    <bpmn:sequenceFlow id="Flow_AllocateTasks_To_GatewayJoin_Art74"
                       sourceRef="Task_AllocateTasksInRulesOfProcedure_Art74"
                       targetRef="Gateway_JoinChairTasks_Art74" />
    <bpmn:sequenceFlow id="Flow_GatewayJoin_To_EndChairTasks_Art74"
                       sourceRef="Gateway_JoinChairTasks_Art74"
                       targetRef="EndEvent_ChairTasksCompleted_Art74" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art74_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art74_Reviewed"
                      bpmnElement="Process_Board_Art74">
      <bpmndi:BPMNShape id="StartEvent_HandleChairTasks_Art74_di"
                        bpmnElement="StartEvent_HandleChairTasks_Art74">
        <dc:Bounds x="90" y="212" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SplitChairTasks_Art74_di"
                        bpmnElement="Gateway_SplitChairTasks_Art74"
                        isMarkerVisible="true">
        <dc:Bounds x="190" y="205" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ConveneMeetingsAndPrepareAgenda_Art74_di"
                        bpmnElement="Task_ConveneMeetingsAndPrepareAgenda_Art74">
        <dc:Bounds x="330" y="50" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyArticle65Decisions_Art74_di"
                        bpmnElement="Task_NotifyArticle65Decisions_Art74">
        <dc:Bounds x="330" y="160" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EnsureTimelyBoardPerformance_Art74_di"
                        bpmnElement="Task_EnsureTimelyBoardPerformance_Art74">
        <dc:Bounds x="330" y="270" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AllocateTasksInRulesOfProcedure_Art74_di"
                        bpmnElement="Task_AllocateTasksInRulesOfProcedure_Art74">
        <dc:Bounds x="330" y="380" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_JoinChairTasks_Art74_di"
                        bpmnElement="Gateway_JoinChairTasks_Art74"
                        isMarkerVisible="true">
        <dc:Bounds x="650" y="205" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ChairTasksCompleted_Art74_di"
                        bpmnElement="EndEvent_ChairTasksCompleted_Art74">
        <dc:Bounds x="820" y="212" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_StartChairTasks_To_GatewaySplit_Art74_di"
                       bpmnElement="Flow_StartChairTasks_To_GatewaySplit_Art74">
        <di:waypoint x="126" y="230" />
        <di:waypoint x="190" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_ConveneMeetings_Art74_di"
                       bpmnElement="Flow_GatewaySplit_To_ConveneMeetings_Art74">
        <di:waypoint x="215" y="205" />
        <di:waypoint x="215" y="90" />
        <di:waypoint x="330" y="90" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_NotifyArticle65Decisions_Art74_di"
                       bpmnElement="Flow_GatewaySplit_To_NotifyArticle65Decisions_Art74">
        <di:waypoint x="240" y="218" />
        <di:waypoint x="330" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_EnsureTimelyPerformance_Art74_di"
                       bpmnElement="Flow_GatewaySplit_To_EnsureTimelyPerformance_Art74">
        <di:waypoint x="240" y="242" />
        <di:waypoint x="330" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_AllocateTasks_Art74_di"
                       bpmnElement="Flow_GatewaySplit_To_AllocateTasks_Art74">
        <di:waypoint x="215" y="255" />
        <di:waypoint x="215" y="420" />
        <di:waypoint x="330" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ConveneMeetings_To_GatewayJoin_Art74_di"
                       bpmnElement="Flow_ConveneMeetings_To_GatewayJoin_Art74">
        <di:waypoint x="520" y="90" />
        <di:waypoint x="675" y="90" />
        <di:waypoint x="675" y="205" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotifyArticle65Decisions_To_GatewayJoin_Art74_di"
                       bpmnElement="Flow_NotifyArticle65Decisions_To_GatewayJoin_Art74">
        <di:waypoint x="510" y="200" />
        <di:waypoint x="650" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EnsureTimelyPerformance_To_GatewayJoin_Art74_di"
                       bpmnElement="Flow_EnsureTimelyPerformance_To_GatewayJoin_Art74">
        <di:waypoint x="520" y="310" />
        <di:waypoint x="675" y="310" />
        <di:waypoint x="675" y="255" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AllocateTasks_To_GatewayJoin_Art74_di"
                       bpmnElement="Flow_AllocateTasks_To_GatewayJoin_Art74">
        <di:waypoint x="520" y="420" />
        <di:waypoint x="675" y="420" />
        <di:waypoint x="675" y="255" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayJoin_To_EndChairTasks_Art74_di"
                       bpmnElement="Flow_GatewayJoin_To_EndChairTasks_Art74">
        <di:waypoint x="700" y="230" />
        <di:waypoint x="820" y="230" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
