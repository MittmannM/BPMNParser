<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art31_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art31_Reviewed">
    <bpmn:participant id="Participant_ControllerProcessorRepresentative_Art31"
                      name="Controller, Processor, or Representative"
                      processRef="Process_ControllerProcessorRepresentative_Art31" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art31"
                      name="Supervisory Authority" />

    <bpmn:messageFlow id="MessageFlow_RequestCooperation_Art31"
                      sourceRef="Participant_SupervisoryAuthority_Art31"
                      targetRef="StartEvent_RequestReceived_Art31" />
    <bpmn:messageFlow id="MessageFlow_ProvideCooperation_Art31"
                      sourceRef="SendTask_ProvideCooperation_Art31"
                      targetRef="Participant_SupervisoryAuthority_Art31" />
  </bpmn:collaboration>

  <bpmn:process id="Process_ControllerProcessorRepresentative_Art31"
                name="Cooperating with the supervisory authority under Article 31"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 31 based on the real English legal text
      of Regulation (EU) 2016/679. The model captures the request-triggered duty of
      the controller, the processor, and, where applicable, their representatives to
      cooperate with the supervisory authority in the performance of its tasks.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_RequestReceived_Art31"
                     name="Authority request received">
      <bpmn:outgoing>Flow_StartRequestReceived_To_TaskPrepareCooperation_Art31</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_PrepareCooperation_Art31"
               name="Prepare cooperation">
      <bpmn:incoming>Flow_StartRequestReceived_To_TaskPrepareCooperation_Art31</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareCooperation_To_SendTaskProvideCooperation_Art31</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_ProvideCooperation_Art31"
                   name="Provide cooperation">
      <bpmn:incoming>Flow_TaskPrepareCooperation_To_SendTaskProvideCooperation_Art31</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskProvideCooperation_To_EndCooperationProvided_Art31</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_CooperationProvided_Art31"
                   name="Cooperation provided">
      <bpmn:incoming>Flow_SendTaskProvideCooperation_To_EndCooperationProvided_Art31</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartRequestReceived_To_TaskPrepareCooperation_Art31" sourceRef="StartEvent_RequestReceived_Art31" targetRef="Task_PrepareCooperation_Art31" />
    <bpmn:sequenceFlow id="Flow_TaskPrepareCooperation_To_SendTaskProvideCooperation_Art31" sourceRef="Task_PrepareCooperation_Art31" targetRef="SendTask_ProvideCooperation_Art31" />
    <bpmn:sequenceFlow id="Flow_SendTaskProvideCooperation_To_EndCooperationProvided_Art31" sourceRef="SendTask_ProvideCooperation_Art31" targetRef="EndEvent_CooperationProvided_Art31" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art31_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art31_Reviewed" bpmnElement="Collaboration_Art31_Reviewed">
      <bpmndi:BPMNShape id="Participant_ControllerProcessorRepresentative_Art31_di"
                        bpmnElement="Participant_ControllerProcessorRepresentative_Art31"
                        isHorizontal="true">
        <dc:Bounds x="60" y="40" width="2100" height="300" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_SupervisoryAuthority_Art31_di"
                        bpmnElement="Participant_SupervisoryAuthority_Art31"
                        isHorizontal="true">
        <dc:Bounds x="60" y="390" width="2100" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_RequestReceived_Art31_di" bpmnElement="StartEvent_RequestReceived_Art31">
        <dc:Bounds x="180" y="172" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PrepareCooperation_Art31_di" bpmnElement="Task_PrepareCooperation_Art31">
        <dc:Bounds x="310" y="150" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_ProvideCooperation_Art31_di" bpmnElement="SendTask_ProvideCooperation_Art31">
        <dc:Bounds x="610" y="150" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_CooperationProvided_Art31_di" bpmnElement="EndEvent_CooperationProvided_Art31">
        <dc:Bounds x="912" y="172" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_StartRequestReceived_To_TaskPrepareCooperation_Art31_di" bpmnElement="Flow_StartRequestReceived_To_TaskPrepareCooperation_Art31">
        <di:waypoint x="216" y="190" />
        <di:waypoint x="310" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskPrepareCooperation_To_SendTaskProvideCooperation_Art31_di" bpmnElement="Flow_TaskPrepareCooperation_To_SendTaskProvideCooperation_Art31">
        <di:waypoint x="490" y="190" />
        <di:waypoint x="610" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SendTaskProvideCooperation_To_EndCooperationProvided_Art31_di" bpmnElement="Flow_SendTaskProvideCooperation_To_EndCooperationProvided_Art31">
        <di:waypoint x="790" y="190" />
        <di:waypoint x="912" y="190" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MessageFlow_RequestCooperation_Art31_di" bpmnElement="MessageFlow_RequestCooperation_Art31">
        <di:waypoint x="198" y="390" />
        <di:waypoint x="198" y="208" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_ProvideCooperation_Art31_di" bpmnElement="MessageFlow_ProvideCooperation_Art31">
        <di:waypoint x="700" y="230" />
        <di:waypoint x="700" y="390" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
