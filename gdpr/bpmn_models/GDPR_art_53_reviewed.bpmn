                        bpmnElement="EndEvent_CompulsoryRetirement_Art53">
        <dc:Bounds x="2600" y="302" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DismissalGrounds_Art53_di"
                        bpmnElement="Gateway_DismissalGrounds_Art53"
                        isMarkerVisible="true">
        <dc:Bounds x="2600" y="480" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DismissMember_Art53_di"
                        bpmnElement="Task_DismissMember_Art53">
        <dc:Bounds x="2780" y="370" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Dismissal_Art53_di"
                        bpmnElement="EndEvent_Dismissal_Art53">
        <dc:Bounds x="3090" y="392" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_DefineProcedure_Art53_di"
                       bpmnElement="Flow_Start_To_DefineProcedure_Art53">
        <di:waypoint x="156" y="400" />
        <di:waypoint x="230" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_DefineProcedure_To_GatewayAppointingBody_Art53_di"
                       bpmnElement="Flow_DefineProcedure_To_GatewayAppointingBody_Art53">
        <di:waypoint x="490" y="400" />
        <di:waypoint x="590" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAppointingBody_To_ParliamentRoute_Art53_di"
                       bpmnElement="Flow_GatewayAppointingBody_To_ParliamentRoute_Art53">
        <di:waypoint x="615" y="375" />
        <di:waypoint x="615" y="80" />
        <di:waypoint x="800" y="80" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAppointingBody_To_GovernmentRoute_Art53_di"
