        <di:waypoint x="615" y="190" />
        <di:waypoint x="800" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAppointingBody_To_HeadOfStateRoute_Art53_di"
