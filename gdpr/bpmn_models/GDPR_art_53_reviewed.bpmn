        <di:waypoint x="615" y="375" />
        <di:waypoint x="615" y="300" />
        <di:waypoint x="800" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAppointingBody_To_IndependentBodyRoute_Art53_di"
                       bpmnElement="Flow_GatewayAppointingBody_To_IndependentBodyRoute_Art53">
        <di:waypoint x="640" y="400" />
        <di:waypoint x="800" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ParliamentRoute_To_GatewayAppointmentJoin_Art53_di"
                       bpmnElement="Flow_ParliamentRoute_To_GatewayAppointmentJoin_Art53">
        <di:waypoint x="1020" y="80" />
        <di:waypoint x="1235" y="80" />
        <di:waypoint x="1235" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GovernmentRoute_To_GatewayAppointmentJoin_Art53_di"
                       bpmnElement="Flow_GovernmentRoute_To_GatewayAppointmentJoin_Art53">
        <di:waypoint x="1020" y="190" />
        <di:waypoint x="1235" y="190" />
        <di:waypoint x="1235" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HeadOfStateRoute_To_GatewayAppointmentJoin_Art53_di"
                       bpmnElement="Flow_HeadOfStateRoute_To_GatewayAppointmentJoin_Art53">
        <di:waypoint x="1040" y="300" />
        <di:waypoint x="1235" y="300" />
        <di:waypoint x="1235" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_IndependentBodyRoute_To_GatewayAppointmentJoin_Art53_di"
                       bpmnElement="Flow_IndependentBodyRoute_To_GatewayAppointmentJoin_Art53">
        <di:waypoint x="1050" y="410" />
        <di:waypoint x="1210" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAppointmentJoin_To_AssessQualifications_Art53_di"
                       bpmnElement="Flow_GatewayAppointmentJoin_To_AssessQualifications_Art53">
        <di:waypoint x="1260" y="400" />
        <di:waypoint x="1380" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AssessQualifications_To_AppointMember_Art53_di"
                       bpmnElement="Flow_AssessQualifications_To_AppointMember_Art53">
        <di:waypoint x="1650" y="400" />
        <di:waypoint x="1760" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AppointMember_To_ServeOffice_Art53_di"
                       bpmnElement="Flow_AppointMember_To_ServeOffice_Art53">
        <di:waypoint x="1980" y="400" />
