        <di:waypoint x="2415" y="375" />
        <di:waypoint x="2415" y="100" />
        <di:waypoint x="2600" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayServiceOutcome_To_EndResignation_Art53_di"
                       bpmnElement="Flow_GatewayServiceOutcome_To_EndResignation_Art53">
        <di:waypoint x="2415" y="375" />
