        <dc:Bounds x="800" y="150" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_UseHeadOfStateProcedure_Art53_di"
                        bpmnElement="Task_UseHeadOfStateProcedure_Art53">
        <dc:Bounds x="800" y="260" width="240" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_UseIndependentBodyProcedure_Art53_di"
                        bpmnElement="Task_UseIndependentBodyProcedure_Art53">
        <dc:Bounds x="800" y="370" width="250" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AppointmentJoin_Art53_di"
                        bpmnElement="Gateway_AppointmentJoin_Art53"
                        isMarkerVisible="true">
        <dc:Bounds x="1210" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessQualifications_Art53_di"
                        bpmnElement="Task_AssessQualifications_Art53">
        <dc:Bounds x="1380" y="360" width="270" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AppointMember_Art53_di"
                        bpmnElement="Task_AppointMember_Art53">
        <dc:Bounds x="1760" y="360" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ServeInOffice_Art53_di"
