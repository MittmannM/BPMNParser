      <bpmndi:BPMNEdge id="Flow_GatewayServiceOutcome_To_GatewayDismissalGrounds_Art53_di"
                       bpmnElement="Flow_GatewayServiceOutcome_To_GatewayDismissalGrounds_Art53">
        <di:waypoint x="2415" y="425" />
        <di:waypoint x="2415" y="505" />
        <di:waypoint x="2600" y="505" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayDismissalGrounds_To_DismissMember_Art53_di"
                       bpmnElement="Flow_GatewayDismissalGrounds_To_DismissMember_Art53">
        <di:waypoint x="2625" y="480" />
        <di:waypoint x="2625" y="410" />
        <di:waypoint x="2780" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayDismissalGrounds_To_ServeOffice_Art53_di"
                       bpmnElement="Flow_GatewayDismissalGrounds_To_ServeOffice_Art53">
        <di:waypoint x="2600" y="505" />
        <di:waypoint x="2180" y="505" />
        <di:waypoint x="2180" y="440" />
        <di:waypoint x="2180" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_DismissMember_To_EndDismissal_Art53_di"
                       bpmnElement="Flow_DismissMember_To_EndDismissal_Art53">
        <di:waypoint x="2960" y="410" />
        <di:waypoint x="3090" y="410" />
