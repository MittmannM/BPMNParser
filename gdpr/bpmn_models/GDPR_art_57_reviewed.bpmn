<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art57_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art57_Reviewed">
    <bpmn:participant id="Participant_SupervisoryAuthority_Art57"
                      name="Supervisory Authority"
                      processRef="Process_SupervisoryAuthority_Art57" />
    <bpmn:participant id="Participant_DataSubjectOrArticle80Body_Art57"
                      name="Data Subject or Article 80 Body" />
    <bpmn:participant id="Participant_NationalInstitutions_Art57"
                      name="National Parliament, Government, or Other Institution" />
    <bpmn:participant id="Participant_OtherSupervisoryAuthorities_Art57"
                      name="Other Supervisory Authorities" />
    <bpmn:participant id="Participant_Board_Art57"
                      name="Board" />

    <bpmn:messageFlow id="MessageFlow_RequestRightsInformation_Art57"
                      sourceRef="Participant_DataSubjectOrArticle80Body_Art57"
                      targetRef="Task_ReceiveRightsRequest_Art57" />
    <bpmn:messageFlow id="MessageFlow_ProvideRightsInformation_Art57"
                      sourceRef="Task_ProvideRightsInformation_Art57"
                      targetRef="Participant_DataSubjectOrArticle80Body_Art57" />
    <bpmn:messageFlow id="MessageFlow_FileComplaint_Art57"
                      sourceRef="Participant_DataSubjectOrArticle80Body_Art57"
                      targetRef="Task_ReceiveComplaint_Art57" />
    <bpmn:messageFlow id="MessageFlow_InformComplainant_Art57"
                      sourceRef="Task_InformComplainant_Art57"
                      targetRef="Participant_DataSubjectOrArticle80Body_Art57" />
    <bpmn:messageFlow id="MessageFlow_AdviseNationalInstitutions_Art57"
                      sourceRef="Task_AdviseNationalInstitutions_Art57"
                      targetRef="Participant_NationalInstitutions_Art57" />
    <bpmn:messageFlow id="MessageFlow_CooperateOnRightsRequest_Art57"
                      sourceRef="Task_CooperateOnRightsRequest_Art57"
                      targetRef="Participant_OtherSupervisoryAuthorities_Art57" />
    <bpmn:messageFlow id="MessageFlow_ProvideMutualAssistance_Art57"
                      sourceRef="Task_CooperateAndProvideMutualAssistance_Art57"
                      targetRef="Participant_OtherSupervisoryAuthorities_Art57" />
    <bpmn:messageFlow id="MessageFlow_ContributeToBoard_Art57"
                      sourceRef="Task_ContributeToBoardActivities_Art57"
                      targetRef="Participant_Board_Art57" />
  </bpmn:collaboration>

  <bpmn:process id="Process_SupervisoryAuthority_Art57"
                name="Perform Article 57 supervisory authority tasks"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 57 based on the real English legal text from
      gdpr_articles/article_57.txt. The model groups the full supervisory-authority task set
      into coherent duty blocks while keeping the Article 57(1)(a)-(v) content visible:
      monitoring and enforcement, awareness and advice and obligation-promotion, data-subject
      request handling and complaint handling with Article 57(2)-(4) facilitation and free-of-
      charge and manifestly-unfounded-or-excessive exception logic, cooperation and
      investigations and monitoring of developments, the Article 28 and 35 and 36 and 40 and 41
      and 42 and 43 and 46 and 47 related standard-setting and approval tasks, Board
      contribution, internal infringement records, and residual data-protection tasks.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_PerformArticle57Tasks_Art57"
                     name="Perform Article 57 tasks">
      <bpmn:outgoing>Flow_Start_To_GatewaySplitMainTasks_Art57</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:parallelGateway id="Gateway_SplitMainTasks_Art57">
      <bpmn:incoming>Flow_Start_To_GatewaySplitMainTasks_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitMain_To_GatewaySplitAwareness_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitMain_To_GatewaySplitDataSubjectTasks_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitMain_To_GatewaySplitCooperation_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitMain_To_GatewaySplitStandards_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitMain_To_GatewaySplitInstitutionalTasks_Art57</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="Gateway_SplitAwareness_Art57">
      <bpmn:incoming>Flow_GatewaySplitMain_To_GatewaySplitAwareness_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitAwareness_To_MonitorEnforce_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAwareness_To_PromotePublicAwareness_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAwareness_To_AdviseInstitutions_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitAwareness_To_PromoteControllerAwareness_Art57</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_MonitorAndEnforceApplication_Art57"
               name="Monitor and enforce application">
      <bpmn:incoming>Flow_GatewaySplitAwareness_To_MonitorEnforce_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_MonitorEnforce_To_GatewayJoinAwareness_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PromotePublicAwareness_Art57"
               name="Promote public awareness, with child focus">
      <bpmn:incoming>Flow_GatewaySplitAwareness_To_PromotePublicAwareness_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_PromotePublicAwareness_To_GatewayJoinAwareness_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_AdviseNationalInstitutions_Art57"
                   name="Advise on legislative and administrative measures">
      <bpmn:incoming>Flow_GatewaySplitAwareness_To_AdviseInstitutions_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_AdviseInstitutions_To_GatewayJoinAwareness_Art57</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_PromoteControllerProcessorAwareness_Art57"
               name="Promote controller and processor awareness">
      <bpmn:incoming>Flow_GatewaySplitAwareness_To_PromoteControllerAwareness_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_PromoteControllerAwareness_To_GatewayJoinAwareness_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinAwareness_Art57">
      <bpmn:incoming>Flow_MonitorEnforce_To_GatewayJoinAwareness_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_PromotePublicAwareness_To_GatewayJoinAwareness_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_AdviseInstitutions_To_GatewayJoinAwareness_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_PromoteControllerAwareness_To_GatewayJoinAwareness_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinAwareness_To_GatewayJoinMainTasks_Art57</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="Gateway_SplitDataSubjectTasks_Art57">
      <bpmn:incoming>Flow_GatewaySplitMain_To_GatewaySplitDataSubjectTasks_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitDataSubjectTasks_To_ReceiveRightsRequest_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitDataSubjectTasks_To_FacilitateComplaintSubmission_Art57</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:receiveTask id="Task_ReceiveRightsRequest_Art57"
                      name="Receive rights request">
      <bpmn:incoming>Flow_GatewaySplitDataSubjectTasks_To_ReceiveRightsRequest_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveRightsRequest_To_GatewayExcessiveRequest_Art57</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_ExcessiveRequest_Art57"
                           name="Is the request manifestly unfounded or excessive?">
      <bpmn:incoming>Flow_ReceiveRightsRequest_To_GatewayExcessiveRequest_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayExcessiveRequest_To_ProvideRightsInformation_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayExcessiveRequest_To_DemonstrateExcessiveRequest_Art57</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_ProvideRightsInformation_Art57"
                   name="Provide rights information free of charge">
      <bpmn:incoming>Flow_GatewayExcessiveRequest_To_ProvideRightsInformation_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_ProvideRightsInformation_To_GatewayCooperateRightsRequest_Art57</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_CooperateRightsRequest_Art57"
                           name="Is cooperation with other supervisory authorities appropriate?">
      <bpmn:incoming>Flow_ProvideRightsInformation_To_GatewayCooperateRightsRequest_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayCooperateRightsRequest_To_CooperateOnRightsRequest_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCooperateRightsRequest_To_GatewayJoinDataSubjectTasks_Art57</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_CooperateOnRightsRequest_Art57"
                   name="Cooperate on rights request">
      <bpmn:incoming>Flow_GatewayCooperateRightsRequest_To_CooperateOnRightsRequest_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_CooperateOnRightsRequest_To_GatewayJoinDataSubjectTasks_Art57</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_DemonstrateExcessiveRequest_Art57"
               name="Demonstrate excessive request">
      <bpmn:incoming>Flow_GatewayExcessiveRequest_To_DemonstrateExcessiveRequest_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_DemonstrateExcessiveRequest_To_GatewayChargeFee_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ChargeFee_Art57"
                           name="Will the authority charge a reasonable fee?">
      <bpmn:incoming>Flow_DemonstrateExcessiveRequest_To_GatewayChargeFee_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayChargeFee_To_ChargeReasonableFee_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayChargeFee_To_RefuseRequest_Art57</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ChargeReasonableFee_Art57"
               name="Charge reasonable fee">
      <bpmn:incoming>Flow_GatewayChargeFee_To_ChargeReasonableFee_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_ChargeReasonableFee_To_GatewayJoinDataSubjectTasks_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_RefuseRequest_Art57"
               name="Refuse request">
      <bpmn:incoming>Flow_GatewayChargeFee_To_RefuseRequest_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_RefuseRequest_To_GatewayJoinDataSubjectTasks_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_FacilitateComplaintSubmission_Art57"
               name="Facilitate free complaint submission">
      <bpmn:incoming>Flow_GatewaySplitDataSubjectTasks_To_FacilitateComplaintSubmission_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_FacilitateComplaintSubmission_To_ReceiveComplaint_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:receiveTask id="Task_ReceiveComplaint_Art57"
                      name="Receive complaint">
      <bpmn:incoming>Flow_FacilitateComplaintSubmission_To_ReceiveComplaint_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveComplaint_To_InvestigateComplaint_Art57</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_InvestigateComplaint_Art57"
               name="Investigate complaint as appropriate">
      <bpmn:incoming>Flow_ReceiveComplaint_To_InvestigateComplaint_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_InvestigateComplaint_To_InformComplainant_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_InformComplainant_Art57"
                   name="Inform complainant of progress and outcome">
      <bpmn:incoming>Flow_InvestigateComplaint_To_InformComplainant_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_InformComplainant_To_GatewayJoinDataSubjectTasks_Art57</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:parallelGateway id="Gateway_JoinDataSubjectTasks_Art57">
      <bpmn:incoming>Flow_GatewayCooperateRightsRequest_To_GatewayJoinDataSubjectTasks_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_CooperateOnRightsRequest_To_GatewayJoinDataSubjectTasks_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_ChargeReasonableFee_To_GatewayJoinDataSubjectTasks_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_RefuseRequest_To_GatewayJoinDataSubjectTasks_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_InformComplainant_To_GatewayJoinDataSubjectTasks_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinDataSubjectTasks_To_GatewayJoinMainTasks_Art57</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="Gateway_SplitCooperation_Art57">
      <bpmn:incoming>Flow_GatewaySplitMain_To_GatewaySplitCooperation_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitCooperation_To_CooperateMutualAssistance_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitCooperation_To_ConductInvestigations_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitCooperation_To_MonitorDevelopments_Art57</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:sendTask id="Task_CooperateAndProvideMutualAssistance_Art57"
                   name="Cooperate and provide mutual assistance">
      <bpmn:incoming>Flow_GatewaySplitCooperation_To_CooperateMutualAssistance_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_CooperateMutualAssistance_To_GatewayJoinCooperation_Art57</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ConductInvestigations_Art57"
               name="Conduct investigations">
      <bpmn:incoming>Flow_GatewaySplitCooperation_To_ConductInvestigations_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_ConductInvestigations_To_GatewayJoinCooperation_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_MonitorRelevantDevelopments_Art57"
               name="Monitor relevant developments">
      <bpmn:incoming>Flow_GatewaySplitCooperation_To_MonitorDevelopments_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_MonitorDevelopments_To_GatewayJoinCooperation_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinCooperation_Art57">
      <bpmn:incoming>Flow_CooperateMutualAssistance_To_GatewayJoinCooperation_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_ConductInvestigations_To_GatewayJoinCooperation_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_MonitorDevelopments_To_GatewayJoinCooperation_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinCooperation_To_GatewayJoinMainTasks_Art57</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="Gateway_SplitStandards_Art57">
      <bpmn:incoming>Flow_GatewaySplitMain_To_GatewaySplitStandards_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitStandards_To_AdoptSCCs_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitStandards_To_MaintainDPIAList_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitStandards_To_GiveArticle36Advice_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitStandards_To_EncourageCodes_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitStandards_To_EncourageCertification_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitStandards_To_ReviewCertifications_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitStandards_To_DraftAccreditationCriteria_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitStandards_To_ConductAccreditation_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitStandards_To_AuthoriseArticle46Clauses_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitStandards_To_ApproveBCRs_Art57</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_AdoptStandardContractualClauses_Art57"
               name="Adopt standard contractual clauses">
      <bpmn:incoming>Flow_GatewaySplitStandards_To_AdoptSCCs_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptSCCs_To_GatewayJoinStandards_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_MaintainDPIAList_Art57"
               name="Establish and maintain DPIA list">
      <bpmn:incoming>Flow_GatewaySplitStandards_To_MaintainDPIAList_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_MaintainDPIAList_To_GatewayJoinStandards_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_GiveArticle36Advice_Art57"
               name="Give Article 36(2) advice">
      <bpmn:incoming>Flow_GatewaySplitStandards_To_GiveArticle36Advice_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GiveArticle36Advice_To_GatewayJoinStandards_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EncourageAndApproveCodes_Art57"
               name="Encourage and approve codes of conduct">
      <bpmn:incoming>Flow_GatewaySplitStandards_To_EncourageCodes_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_EncourageCodes_To_GatewayJoinStandards_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EncourageCertification_Art57"
               name="Encourage certification and approve criteria">
      <bpmn:incoming>Flow_GatewaySplitStandards_To_EncourageCertification_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_EncourageCertification_To_GatewayJoinStandards_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ReviewCertifications_Art57"
               name="Review certifications periodically">
      <bpmn:incoming>Flow_GatewaySplitStandards_To_ReviewCertifications_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewCertifications_To_GatewayJoinStandards_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DraftPublishAccreditationCriteria_Art57"
               name="Draft and publish accreditation criteria">
      <bpmn:incoming>Flow_GatewaySplitStandards_To_DraftAccreditationCriteria_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_DraftAccreditationCriteria_To_GatewayJoinStandards_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ConductAccreditation_Art57"
               name="Conduct accreditation">
      <bpmn:incoming>Flow_GatewaySplitStandards_To_ConductAccreditation_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_ConductAccreditation_To_GatewayJoinStandards_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AuthoriseArticle46Clauses_Art57"
               name="Authorise Article 46(3) clauses">
      <bpmn:incoming>Flow_GatewaySplitStandards_To_AuthoriseArticle46Clauses_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_AuthoriseArticle46Clauses_To_GatewayJoinStandards_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ApproveBindingCorporateRules_Art57"
               name="Approve binding corporate rules">
      <bpmn:incoming>Flow_GatewaySplitStandards_To_ApproveBCRs_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_ApproveBCRs_To_GatewayJoinStandards_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinStandards_Art57">
      <bpmn:incoming>Flow_AdoptSCCs_To_GatewayJoinStandards_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_MaintainDPIAList_To_GatewayJoinStandards_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_GiveArticle36Advice_To_GatewayJoinStandards_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_EncourageCodes_To_GatewayJoinStandards_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_EncourageCertification_To_GatewayJoinStandards_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_ReviewCertifications_To_GatewayJoinStandards_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_DraftAccreditationCriteria_To_GatewayJoinStandards_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_ConductAccreditation_To_GatewayJoinStandards_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_AuthoriseArticle46Clauses_To_GatewayJoinStandards_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_ApproveBCRs_To_GatewayJoinStandards_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinStandards_To_GatewayJoinMainTasks_Art57</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="Gateway_SplitInstitutionalTasks_Art57">
      <bpmn:incoming>Flow_GatewaySplitMain_To_GatewaySplitInstitutionalTasks_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitInstitutionalTasks_To_ContributeBoard_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitInstitutionalTasks_To_KeepInfringementRecords_Art57</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitInstitutionalTasks_To_FulfilOtherTasks_Art57</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:sendTask id="Task_ContributeToBoardActivities_Art57"
                   name="Contribute to Board activities">
      <bpmn:incoming>Flow_GatewaySplitInstitutionalTasks_To_ContributeBoard_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_ContributeBoard_To_GatewayJoinInstitutionalTasks_Art57</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_KeepInternalInfringementRecords_Art57"
               name="Keep internal infringement records">
      <bpmn:incoming>Flow_GatewaySplitInstitutionalTasks_To_KeepInfringementRecords_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_KeepInfringementRecords_To_GatewayJoinInstitutionalTasks_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_FulfilOtherDataProtectionTasks_Art57"
               name="Fulfil other data protection tasks">
      <bpmn:incoming>Flow_GatewaySplitInstitutionalTasks_To_FulfilOtherTasks_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_FulfilOtherTasks_To_GatewayJoinInstitutionalTasks_Art57</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinInstitutionalTasks_Art57">
      <bpmn:incoming>Flow_ContributeBoard_To_GatewayJoinInstitutionalTasks_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_KeepInfringementRecords_To_GatewayJoinInstitutionalTasks_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_FulfilOtherTasks_To_GatewayJoinInstitutionalTasks_Art57</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinInstitutionalTasks_To_GatewayJoinMainTasks_Art57</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="Gateway_JoinMainTasks_Art57">
      <bpmn:incoming>Flow_GatewayJoinAwareness_To_GatewayJoinMainTasks_Art57</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayJoinDataSubjectTasks_To_GatewayJoinMainTasks_Art57</bpmn:incoming>
