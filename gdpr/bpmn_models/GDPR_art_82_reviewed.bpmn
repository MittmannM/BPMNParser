<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art82_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art82_Reviewed">
    <bpmn:participant id="Participant_ReceivingParty_Art82"
                      name="Controller or Processor receiving the compensation claim"
                      processRef="Process_ReceivingParty_Art82" />
    <bpmn:participant id="Participant_DamagedPerson_Art82"
                      name="Damaged Person" />
    <bpmn:participant id="Participant_OtherResponsibleParty_Art82"
                      name="Other Responsible Controller or Processor" />
    <bpmn:participant id="Participant_Court_Art82"
                      name="Court" />

    <bpmn:messageFlow id="MessageFlow_Claim_Art82"
                      sourceRef="Participant_DamagedPerson_Art82"
                      targetRef="ReceiveTask_ReceiveCompensationClaim_Art82" />
    <bpmn:messageFlow id="MessageFlow_PayCompensation_Art82"
                      sourceRef="SendTask_PayCompensation_Art82"
                      targetRef="Participant_DamagedPerson_Art82" />
    <bpmn:messageFlow id="MessageFlow_PayFullCompensation_Art82"
                      sourceRef="SendTask_PayFullCompensation_Art82"
                      targetRef="Participant_DamagedPerson_Art82" />
    <bpmn:messageFlow id="MessageFlow_RequestRecourse_Art82"
                      sourceRef="SendTask_RequestRecourse_Art82"
                      targetRef="Participant_OtherResponsibleParty_Art82" />
    <bpmn:messageFlow id="MessageFlow_HandleCourtClaim_Art82"
                      sourceRef="SendTask_HandleCourtClaim_Art82"
                      targetRef="Participant_Court_Art82" />
  </bpmn:collaboration>

  <bpmn:process id="Process_ReceivingParty_Art82"
                name="Handling an Article 82 compensation claim"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 82 based on the real English legal text from
      gdpr_articles/article_82.txt. The model shows the compensation right for material
      or non-material damage, controller liability, processor-specific liability,
      exemption where responsibility is disproved, full liability where more than one
      controller or processor is responsible, recourse against other responsible
      parties, and the Article 82(6) linkage to court proceedings under Article 79(2).
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_DamageReported_Art82"
                     name="Need compensation claim handling">
      <bpmn:outgoing>Flow_Start_To_ReceiveClaim_Art82</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveCompensationClaim_Art82"
                      name="Receive compensation claim">
      <bpmn:incoming>Flow_Start_To_ReceiveClaim_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveClaim_To_AssessDamageLink_Art82</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_AssessDamageLink_Art82"
               name="Check damage from GDPR infringement">
      <bpmn:incoming>Flow_ReceiveClaim_To_AssessDamageLink_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessDamageLink_To_GatewayDamageLink_Art82</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_DamageLink_Art82"
                           name="Did damage result from an infringement of the GDPR?">
      <bpmn:incoming>Flow_AssessDamageLink_To_GatewayDamageLink_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayDamageLink_To_GatewayControllerCheck_Art82</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayDamageLink_To_EndNoCompensationRight_Art82</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NoCompensationRight_Art82"
                   name="No Article 82 compensation right">
      <bpmn:incoming>Flow_GatewayDamageLink_To_EndNoCompensationRight_Art82</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_ControllerCheck_Art82"
                           name="Is the receiving party a controller involved in the processing?">
      <bpmn:incoming>Flow_GatewayDamageLink_To_GatewayControllerCheck_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayControllerCheck_To_GatewayControllerExemption_Art82</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayControllerCheck_To_TaskAssessProcessorCondition_Art82</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_ControllerExemption_Art82"
                           name="Can the controller disprove responsibility for the event?">
      <bpmn:incoming>Flow_GatewayControllerCheck_To_GatewayControllerExemption_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayControllerExemption_To_EndControllerExempt_Art82</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayControllerExemption_To_TaskAcceptControllerLiability_Art82</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_ControllerExempt_Art82"
                   name="Controller exempt">
      <bpmn:incoming>Flow_GatewayControllerExemption_To_EndControllerExempt_Art82</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_AcceptControllerLiability_Art82"
               name="Accept controller liability">
      <bpmn:incoming>Flow_GatewayControllerExemption_To_TaskAcceptControllerLiability_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAcceptControllerLiability_To_GatewayLiableJoin_Art82</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AssessProcessorCondition_Art82"
               name="Check processor-specific breach or unlawful instructions">
      <bpmn:incoming>Flow_GatewayControllerCheck_To_TaskAssessProcessorCondition_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessProcessorCondition_To_GatewayProcessorTrigger_Art82</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ProcessorTrigger_Art82"
                           name="Did the processor breach processor duties or lawful instructions?">
      <bpmn:incoming>Flow_TaskAssessProcessorCondition_To_GatewayProcessorTrigger_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayProcessorTrigger_To_GatewayProcessorExemption_Art82</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayProcessorTrigger_To_EndProcessorNotLiable_Art82</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_ProcessorNotLiable_Art82"
                   name="Processor not liable">
      <bpmn:incoming>Flow_GatewayProcessorTrigger_To_EndProcessorNotLiable_Art82</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_ProcessorExemption_Art82"
                           name="Can the processor disprove responsibility for the event?">
      <bpmn:incoming>Flow_GatewayProcessorTrigger_To_GatewayProcessorExemption_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayProcessorExemption_To_EndProcessorExempt_Art82</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayProcessorExemption_To_TaskAcceptProcessorLiability_Art82</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_ProcessorExempt_Art82"
                   name="Processor exempt">
      <bpmn:incoming>Flow_GatewayProcessorExemption_To_EndProcessorExempt_Art82</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_AcceptProcessorLiability_Art82"
               name="Accept processor liability">
      <bpmn:incoming>Flow_GatewayProcessorExemption_To_TaskAcceptProcessorLiability_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAcceptProcessorLiability_To_GatewayLiableJoin_Art82</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_LiableJoin_Art82">
      <bpmn:incoming>Flow_TaskAcceptControllerLiability_To_GatewayLiableJoin_Art82</bpmn:incoming>
      <bpmn:incoming>Flow_TaskAcceptProcessorLiability_To_GatewayLiableJoin_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayLiableJoin_To_HandleCourtClaim_Art82</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_HandleCourtClaim_Art82"
                   name="Handle claim in Article 79(2) court">
      <bpmn:incoming>Flow_GatewayLiableJoin_To_HandleCourtClaim_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_HandleCourtClaim_To_GatewayMultipleResponsible_Art82</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_MultipleResponsible_Art82"
                           name="Are other controllers or processors also responsible for the same damage?">
      <bpmn:incoming>Flow_HandleCourtClaim_To_GatewayMultipleResponsible_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMultipleResponsible_To_SendTaskPayFullCompensation_Art82</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayMultipleResponsible_To_SendTaskPayCompensation_Art82</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_PayFullCompensation_Art82"
                   name="Pay full compensation">
      <bpmn:incoming>Flow_GatewayMultipleResponsible_To_SendTaskPayFullCompensation_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskPayFullCompensation_To_TaskDetermineOtherShare_Art82</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_DetermineOtherShare_Art82"
               name="Determine other party's share">
      <bpmn:incoming>Flow_SendTaskPayFullCompensation_To_TaskDetermineOtherShare_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDetermineOtherShare_To_SendTaskRequestRecourse_Art82</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_RequestRecourse_Art82"
                   name="Request recourse">
      <bpmn:incoming>Flow_TaskDetermineOtherShare_To_SendTaskRequestRecourse_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskRequestRecourse_To_EndRecourseInitiated_Art82</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_RecourseInitiated_Art82"
                   name="Full compensation and recourse initiated">
      <bpmn:incoming>Flow_SendTaskRequestRecourse_To_EndRecourseInitiated_Art82</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_PayCompensation_Art82"
                   name="Pay compensation">
      <bpmn:incoming>Flow_GatewayMultipleResponsible_To_SendTaskPayCompensation_Art82</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskPayCompensation_To_EndCompensationPaid_Art82</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_CompensationPaid_Art82"
                   name="Compensation paid">
      <bpmn:incoming>Flow_SendTaskPayCompensation_To_EndCompensationPaid_Art82</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_ReceiveClaim_Art82" sourceRef="StartEvent_DamageReported_Art82" targetRef="ReceiveTask_ReceiveCompensationClaim_Art82" />
    <bpmn:sequenceFlow id="Flow_ReceiveClaim_To_AssessDamageLink_Art82" sourceRef="ReceiveTask_ReceiveCompensationClaim_Art82" targetRef="Task_AssessDamageLink_Art82" />
    <bpmn:sequenceFlow id="Flow_AssessDamageLink_To_GatewayDamageLink_Art82" sourceRef="Task_AssessDamageLink_Art82" targetRef="Gateway_DamageLink_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayDamageLink_To_GatewayControllerCheck_Art82" name="Yes" sourceRef="Gateway_DamageLink_Art82" targetRef="Gateway_ControllerCheck_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayDamageLink_To_EndNoCompensationRight_Art82" name="No" sourceRef="Gateway_DamageLink_Art82" targetRef="EndEvent_NoCompensationRight_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayControllerCheck_To_GatewayControllerExemption_Art82" name="Yes" sourceRef="Gateway_ControllerCheck_Art82" targetRef="Gateway_ControllerExemption_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayControllerCheck_To_TaskAssessProcessorCondition_Art82" name="No" sourceRef="Gateway_ControllerCheck_Art82" targetRef="Task_AssessProcessorCondition_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayControllerExemption_To_EndControllerExempt_Art82" name="Yes" sourceRef="Gateway_ControllerExemption_Art82" targetRef="EndEvent_ControllerExempt_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayControllerExemption_To_TaskAcceptControllerLiability_Art82" name="No" sourceRef="Gateway_ControllerExemption_Art82" targetRef="Task_AcceptControllerLiability_Art82" />
    <bpmn:sequenceFlow id="Flow_TaskAcceptControllerLiability_To_GatewayLiableJoin_Art82" sourceRef="Task_AcceptControllerLiability_Art82" targetRef="Gateway_LiableJoin_Art82" />
    <bpmn:sequenceFlow id="Flow_TaskAssessProcessorCondition_To_GatewayProcessorTrigger_Art82" sourceRef="Task_AssessProcessorCondition_Art82" targetRef="Gateway_ProcessorTrigger_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayProcessorTrigger_To_GatewayProcessorExemption_Art82" name="Yes" sourceRef="Gateway_ProcessorTrigger_Art82" targetRef="Gateway_ProcessorExemption_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayProcessorTrigger_To_EndProcessorNotLiable_Art82" name="No" sourceRef="Gateway_ProcessorTrigger_Art82" targetRef="EndEvent_ProcessorNotLiable_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayProcessorExemption_To_EndProcessorExempt_Art82" name="Yes" sourceRef="Gateway_ProcessorExemption_Art82" targetRef="EndEvent_ProcessorExempt_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayProcessorExemption_To_TaskAcceptProcessorLiability_Art82" name="No" sourceRef="Gateway_ProcessorExemption_Art82" targetRef="Task_AcceptProcessorLiability_Art82" />
    <bpmn:sequenceFlow id="Flow_TaskAcceptProcessorLiability_To_GatewayLiableJoin_Art82" sourceRef="Task_AcceptProcessorLiability_Art82" targetRef="Gateway_LiableJoin_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayLiableJoin_To_HandleCourtClaim_Art82" sourceRef="Gateway_LiableJoin_Art82" targetRef="SendTask_HandleCourtClaim_Art82" />
    <bpmn:sequenceFlow id="Flow_HandleCourtClaim_To_GatewayMultipleResponsible_Art82" sourceRef="SendTask_HandleCourtClaim_Art82" targetRef="Gateway_MultipleResponsible_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayMultipleResponsible_To_SendTaskPayFullCompensation_Art82" name="Yes" sourceRef="Gateway_MultipleResponsible_Art82" targetRef="SendTask_PayFullCompensation_Art82" />
    <bpmn:sequenceFlow id="Flow_GatewayMultipleResponsible_To_SendTaskPayCompensation_Art82" name="No" sourceRef="Gateway_MultipleResponsible_Art82" targetRef="SendTask_PayCompensation_Art82" />
    <bpmn:sequenceFlow id="Flow_SendTaskPayFullCompensation_To_TaskDetermineOtherShare_Art82" sourceRef="SendTask_PayFullCompensation_Art82" targetRef="Task_DetermineOtherShare_Art82" />
    <bpmn:sequenceFlow id="Flow_TaskDetermineOtherShare_To_SendTaskRequestRecourse_Art82" sourceRef="Task_DetermineOtherShare_Art82" targetRef="SendTask_RequestRecourse_Art82" />
    <bpmn:sequenceFlow id="Flow_SendTaskRequestRecourse_To_EndRecourseInitiated_Art82" sourceRef="SendTask_RequestRecourse_Art82" targetRef="EndEvent_RecourseInitiated_Art82" />
    <bpmn:sequenceFlow id="Flow_SendTaskPayCompensation_To_EndCompensationPaid_Art82" sourceRef="SendTask_PayCompensation_Art82" targetRef="EndEvent_CompensationPaid_Art82" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art82_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art82_Reviewed"
                      bpmnElement="Collaboration_Art82_Reviewed">
      <bpmndi:BPMNShape id="Participant_ReceivingParty_Art82_di" bpmnElement="Participant_ReceivingParty_Art82" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="6000" height="760" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DamagedPerson_Art82_di" bpmnElement="Participant_DamagedPerson_Art82" isHorizontal="true">
        <dc:Bounds x="60" y="860" width="6000" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_OtherResponsibleParty_Art82_di" bpmnElement="Participant_OtherResponsibleParty_Art82" isHorizontal="true">
        <dc:Bounds x="60" y="1020" width="6000" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Court_Art82_di" bpmnElement="Participant_Court_Art82" isHorizontal="true">
        <dc:Bounds x="60" y="1180" width="6000" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_DamageReported_Art82_di" bpmnElement="StartEvent_DamageReported_Art82">
        <dc:Bounds x="120" y="382" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveCompensationClaim_Art82_di" bpmnElement="ReceiveTask_ReceiveCompensationClaim_Art82">
        <dc:Bounds x="220" y="360" width="300" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessDamageLink_Art82_di" bpmnElement="Task_AssessDamageLink_Art82">
        <dc:Bounds x="620" y="360" width="470" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DamageLink_Art82_di" bpmnElement="Gateway_DamageLink_Art82" isMarkerVisible="true">
        <dc:Bounds x="1210" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoCompensationRight_Art82_di" bpmnElement="EndEvent_NoCompensationRight_Art82">
        <dc:Bounds x="1450" y="662" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ControllerCheck_Art82_di" bpmnElement="Gateway_ControllerCheck_Art82" isMarkerVisible="true">
        <dc:Bounds x="1450" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ControllerExemption_Art82_di" bpmnElement="Gateway_ControllerExemption_Art82" isMarkerVisible="true">
        <dc:Bounds x="1780" y="165" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ControllerExempt_Art82_di" bpmnElement="EndEvent_ControllerExempt_Art82">
        <dc:Bounds x="2140" y="72" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AcceptControllerLiability_Art82_di" bpmnElement="Task_AcceptControllerLiability_Art82">
        <dc:Bounds x="2130" y="150" width="420" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessProcessorCondition_Art82_di" bpmnElement="Task_AssessProcessorCondition_Art82">
        <dc:Bounds x="1700" y="500" width="560" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ProcessorTrigger_Art82_di" bpmnElement="Gateway_ProcessorTrigger_Art82" isMarkerVisible="true">
        <dc:Bounds x="2340" y="515" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ProcessorNotLiable_Art82_di" bpmnElement="EndEvent_ProcessorNotLiable_Art82">
        <dc:Bounds x="2640" y="662" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ProcessorExemption_Art82_di" bpmnElement="Gateway_ProcessorExemption_Art82" isMarkerVisible="true">
        <dc:Bounds x="2640" y="515" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ProcessorExempt_Art82_di" bpmnElement="EndEvent_ProcessorExempt_Art82">
        <dc:Bounds x="2990" y="662" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AcceptProcessorLiability_Art82_di" bpmnElement="Task_AcceptProcessorLiability_Art82">
        <dc:Bounds x="2980" y="500" width="380" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_LiableJoin_Art82_di" bpmnElement="Gateway_LiableJoin_Art82" isMarkerVisible="true">
        <dc:Bounds x="3520" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_HandleCourtClaim_Art82_di" bpmnElement="SendTask_HandleCourtClaim_Art82">
        <dc:Bounds x="3680" y="360" width="280" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MultipleResponsible_Art82_di" bpmnElement="Gateway_MultipleResponsible_Art82" isMarkerVisible="true">
        <dc:Bounds x="4060" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_PayFullCompensation_Art82_di" bpmnElement="SendTask_PayFullCompensation_Art82">
        <dc:Bounds x="4300" y="120" width="400" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DetermineOtherShare_Art82_di" bpmnElement="Task_DetermineOtherShare_Art82">
        <dc:Bounds x="4800" y="120" width="420" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_RequestRecourse_Art82_di" bpmnElement="SendTask_RequestRecourse_Art82">
        <dc:Bounds x="5330" y="120" width="360" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RecourseInitiated_Art82_di" bpmnElement="EndEvent_RecourseInitiated_Art82">
        <dc:Bounds x="5770" y="142" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_PayCompensation_Art82_di" bpmnElement="SendTask_PayCompensation_Art82">
        <dc:Bounds x="4300" y="500" width="360" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_CompensationPaid_Art82_di" bpmnElement="EndEvent_CompensationPaid_Art82">
        <dc:Bounds x="4760" y="522" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_ReceiveClaim_Art82_di" bpmnElement="Flow_Start_To_ReceiveClaim_Art82">
        <di:waypoint x="156" y="400" />
        <di:waypoint x="220" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReceiveClaim_To_AssessDamageLink_Art82_di" bpmnElement="Flow_ReceiveClaim_To_AssessDamageLink_Art82">
        <di:waypoint x="520" y="400" />
        <di:waypoint x="620" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AssessDamageLink_To_GatewayDamageLink_Art82_di" bpmnElement="Flow_AssessDamageLink_To_GatewayDamageLink_Art82">
        <di:waypoint x="1090" y="400" />
        <di:waypoint x="1210" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayDamageLink_To_GatewayControllerCheck_Art82_di" bpmnElement="Flow_GatewayDamageLink_To_GatewayControllerCheck_Art82">
        <di:waypoint x="1260" y="400" />
        <di:waypoint x="1450" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayDamageLink_To_EndNoCompensationRight_Art82_di" bpmnElement="Flow_GatewayDamageLink_To_EndNoCompensationRight_Art82">
        <di:waypoint x="1235" y="425" />
        <di:waypoint x="1235" y="680" />
        <di:waypoint x="1450" y="680" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayControllerCheck_To_GatewayControllerExemption_Art82_di" bpmnElement="Flow_GatewayControllerCheck_To_GatewayControllerExemption_Art82">
        <di:waypoint x="1475" y="375" />
        <di:waypoint x="1475" y="190" />
        <di:waypoint x="1780" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayControllerCheck_To_TaskAssessProcessorCondition_Art82_di" bpmnElement="Flow_GatewayControllerCheck_To_TaskAssessProcessorCondition_Art82">
