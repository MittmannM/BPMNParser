<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Defs_Art37_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collab_Art37_Reviewed">
    <bpmn:participant id="Participant_ControllerOrProcessor_Art37"
                      name="Controller or Processor"
                      processRef="Process_ControllerOrProcessor_Art37" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art37"
                      name="Supervisory Authority" />

    <bpmn:messageFlow id="MessageFlow_NotifyAuthority_Art37"
                      sourceRef="SendTask_NotifyAuthority_Art37"
                      targetRef="Participant_SupervisoryAuthority_Art37" />
  </bpmn:collaboration>

  <bpmn:process id="Process_ControllerOrProcessor_Art37"
                name="Apply Article 37 DPO designation duties"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 37 based on the real English legal
      text in gdpr_articles. The model captures the mandatory designation triggers
      in Article 37(1), the judicial-capacity exception, the additional optional
      or law-required designation path in Article 37(4), the single-DPO routes for
      groups of undertakings and for several public authorities or bodies under
      Article 37(2)-(3), the qualification requirement in Article 37(5), the
      staff-member versus service-contract basis in Article 37(6), and the
      publication plus supervisory-authority notification duty in Article 37(7).
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_AssessDuty_Art37"
                     name="Need DPO designation assessment">
      <bpmn:outgoing>Flow_Start_To_AssessPublic_Art37</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_AssessPublic_Art37"
               name="Check public-authority status">
      <bpmn:incoming>Flow_Start_To_AssessPublic_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessPublic_To_GatewayPublic_Art37</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Public_Art37"
                           name="Is the processing carried out by a public authority or body?">
      <bpmn:incoming>Flow_AssessPublic_To_GatewayPublic_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayPublic_To_TaskCheckCourt_Art37</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayPublic_To_TaskAssessMonitoring_Art37</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_CheckCourt_Art37"
               name="Check judicial-capacity exception">
      <bpmn:incoming>Flow_GatewayPublic_To_TaskCheckCourt_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskCheckCourt_To_GatewayCourt_Art37</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Court_Art37"
                           name="Does the authority act in a judicial capacity?">
      <bpmn:incoming>Flow_TaskCheckCourt_To_GatewayCourt_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayCourt_To_TaskAssessAdditionalDesignation_Art37</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCourt_To_TaskPrepareDesignation_Art37</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessMonitoring_Art37"
               name="Check large-scale monitoring">
      <bpmn:incoming>Flow_GatewayPublic_To_TaskAssessMonitoring_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessMonitoring_To_GatewayMonitoring_Art37</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Monitoring_Art37"
                           name="Do the core activities involve regular and systematic monitoring on a large scale?">
      <bpmn:incoming>Flow_TaskAssessMonitoring_To_GatewayMonitoring_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMonitoring_To_TaskPrepareDesignation_Art37</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayMonitoring_To_TaskAssessLargeScale_Art37</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessLargeScale_Art37"
               name="Check large-scale sensitive or criminal-data processing">
      <bpmn:incoming>Flow_GatewayMonitoring_To_TaskAssessLargeScale_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessLargeScale_To_GatewayLargeScale_Art37</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_LargeScale_Art37"
                           name="Do the core activities involve large-scale Article 9 or Article 10 processing?">
      <bpmn:incoming>Flow_TaskAssessLargeScale_To_GatewayLargeScale_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayLargeScale_To_TaskPrepareDesignation_Art37</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayLargeScale_To_TaskAssessAdditionalDesignation_Art37</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessAdditionalDesignation_Art37"
               name="Check optional or law-required designation">
      <bpmn:incoming>Flow_GatewayCourt_To_TaskAssessAdditionalDesignation_Art37</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayLargeScale_To_TaskAssessAdditionalDesignation_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessAdditionalDesignation_To_GatewayAdditionalDesignation_Art37</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_AdditionalDesignation_Art37"
                           name="Will the controller, processor, association, or body designate a DPO?">
      <bpmn:incoming>Flow_TaskAssessAdditionalDesignation_To_GatewayAdditionalDesignation_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAdditionalDesignation_To_EndNoDesignation_Art37</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAdditionalDesignation_To_TaskPrepareDesignation_Art37</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_PrepareDesignation_Art37"
               name="Prepare DPO designation">
      <bpmn:incoming>Flow_GatewayCourt_To_TaskPrepareDesignation_Art37</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayMonitoring_To_TaskPrepareDesignation_Art37</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayLargeScale_To_TaskPrepareDesignation_Art37</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayAdditionalDesignation_To_TaskPrepareDesignation_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPrepareDesignation_To_GatewayShared_Art37</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Shared_Art37"
                           name="Is a single DPO arrangement needed?">
      <bpmn:incoming>Flow_TaskPrepareDesignation_To_GatewayShared_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayShared_To_GatewaySharedType_Art37</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayShared_To_TaskSelectDPO_Art37</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_SharedType_Art37"
                           name="Is the shared arrangement for a group of undertakings?">
      <bpmn:incoming>Flow_GatewayShared_To_GatewaySharedType_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySharedType_To_TaskGroupArrangement_Art37</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySharedType_To_TaskPublicBodyArrangement_Art37</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_GroupArrangement_Art37"
               name="Set group-wide DPO arrangement with easy accessibility">
      <bpmn:incoming>Flow_GatewaySharedType_To_TaskGroupArrangement_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskGroupArrangement_To_TaskSelectDPO_Art37</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PublicBodyArrangement_Art37"
               name="Set shared public-body arrangement for structure and size">
      <bpmn:incoming>Flow_GatewaySharedType_To_TaskPublicBodyArrangement_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPublicBodyArrangement_To_TaskSelectDPO_Art37</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SelectDPO_Art37"
               name="Select qualified DPO">
      <bpmn:incoming>Flow_GatewayShared_To_TaskSelectDPO_Art37</bpmn:incoming>
      <bpmn:incoming>Flow_TaskGroupArrangement_To_TaskSelectDPO_Art37</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPublicBodyArrangement_To_TaskSelectDPO_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSelectDPO_To_GatewayAppointmentBasis_Art37</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_AppointmentBasis_Art37"
                           name="Will the DPO serve as staff or under a service contract?">
      <bpmn:incoming>Flow_TaskSelectDPO_To_GatewayAppointmentBasis_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAppointmentBasis_To_TaskAppointStaffDPO_Art37</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAppointmentBasis_To_TaskAppointServiceContractDPO_Art37</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AppointStaffDPO_Art37"
               name="Appoint staff-member DPO">
      <bpmn:incoming>Flow_GatewayAppointmentBasis_To_TaskAppointStaffDPO_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAppointStaffDPO_To_TaskPublishContactDetails_Art37</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AppointServiceContractDPO_Art37"
               name="Appoint service-contract DPO">
      <bpmn:incoming>Flow_GatewayAppointmentBasis_To_TaskAppointServiceContractDPO_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAppointServiceContractDPO_To_TaskPublishContactDetails_Art37</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PublishContactDetails_Art37"
               name="Publish DPO contact details">
      <bpmn:incoming>Flow_TaskAppointStaffDPO_To_TaskPublishContactDetails_Art37</bpmn:incoming>
      <bpmn:incoming>Flow_TaskAppointServiceContractDPO_To_TaskPublishContactDetails_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPublishContactDetails_To_SendTaskNotifyAuthority_Art37</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_NotifyAuthority_Art37"
                   name="Notify supervisory authority">
      <bpmn:incoming>Flow_TaskPublishContactDetails_To_SendTaskNotifyAuthority_Art37</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskNotifyAuthority_To_EndCompleted_Art37</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_NoDesignation_Art37"
                   name="No DPO designation required">
      <bpmn:incoming>Flow_GatewayAdditionalDesignation_To_EndNoDesignation_Art37</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Completed_Art37"
                   name="Article 37 completed">
      <bpmn:incoming>Flow_SendTaskNotifyAuthority_To_EndCompleted_Art37</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_AssessPublic_Art37" sourceRef="StartEvent_AssessDuty_Art37" targetRef="Task_AssessPublic_Art37" />
    <bpmn:sequenceFlow id="Flow_AssessPublic_To_GatewayPublic_Art37" sourceRef="Task_AssessPublic_Art37" targetRef="Gateway_Public_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayPublic_To_TaskCheckCourt_Art37" name="Yes" sourceRef="Gateway_Public_Art37" targetRef="Task_CheckCourt_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayPublic_To_TaskAssessMonitoring_Art37" name="No" sourceRef="Gateway_Public_Art37" targetRef="Task_AssessMonitoring_Art37" />
    <bpmn:sequenceFlow id="Flow_TaskCheckCourt_To_GatewayCourt_Art37" sourceRef="Task_CheckCourt_Art37" targetRef="Gateway_Court_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayCourt_To_TaskAssessAdditionalDesignation_Art37" name="Yes" sourceRef="Gateway_Court_Art37" targetRef="Task_AssessAdditionalDesignation_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayCourt_To_TaskPrepareDesignation_Art37" name="No" sourceRef="Gateway_Court_Art37" targetRef="Task_PrepareDesignation_Art37" />
    <bpmn:sequenceFlow id="Flow_TaskAssessMonitoring_To_GatewayMonitoring_Art37" sourceRef="Task_AssessMonitoring_Art37" targetRef="Gateway_Monitoring_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayMonitoring_To_TaskPrepareDesignation_Art37" name="Yes" sourceRef="Gateway_Monitoring_Art37" targetRef="Task_PrepareDesignation_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayMonitoring_To_TaskAssessLargeScale_Art37" name="No" sourceRef="Gateway_Monitoring_Art37" targetRef="Task_AssessLargeScale_Art37" />
    <bpmn:sequenceFlow id="Flow_TaskAssessLargeScale_To_GatewayLargeScale_Art37" sourceRef="Task_AssessLargeScale_Art37" targetRef="Gateway_LargeScale_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayLargeScale_To_TaskPrepareDesignation_Art37" name="Yes" sourceRef="Gateway_LargeScale_Art37" targetRef="Task_PrepareDesignation_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayLargeScale_To_TaskAssessAdditionalDesignation_Art37" name="No" sourceRef="Gateway_LargeScale_Art37" targetRef="Task_AssessAdditionalDesignation_Art37" />
    <bpmn:sequenceFlow id="Flow_TaskAssessAdditionalDesignation_To_GatewayAdditionalDesignation_Art37" sourceRef="Task_AssessAdditionalDesignation_Art37" targetRef="Gateway_AdditionalDesignation_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayAdditionalDesignation_To_EndNoDesignation_Art37" name="No" sourceRef="Gateway_AdditionalDesignation_Art37" targetRef="EndEvent_NoDesignation_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayAdditionalDesignation_To_TaskPrepareDesignation_Art37" name="Yes" sourceRef="Gateway_AdditionalDesignation_Art37" targetRef="Task_PrepareDesignation_Art37" />
    <bpmn:sequenceFlow id="Flow_TaskPrepareDesignation_To_GatewayShared_Art37" sourceRef="Task_PrepareDesignation_Art37" targetRef="Gateway_Shared_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayShared_To_GatewaySharedType_Art37" name="Yes" sourceRef="Gateway_Shared_Art37" targetRef="Gateway_SharedType_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayShared_To_TaskSelectDPO_Art37" name="No" sourceRef="Gateway_Shared_Art37" targetRef="Task_SelectDPO_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewaySharedType_To_TaskGroupArrangement_Art37" name="Yes" sourceRef="Gateway_SharedType_Art37" targetRef="Task_GroupArrangement_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewaySharedType_To_TaskPublicBodyArrangement_Art37" name="No" sourceRef="Gateway_SharedType_Art37" targetRef="Task_PublicBodyArrangement_Art37" />
    <bpmn:sequenceFlow id="Flow_TaskGroupArrangement_To_TaskSelectDPO_Art37" sourceRef="Task_GroupArrangement_Art37" targetRef="Task_SelectDPO_Art37" />
    <bpmn:sequenceFlow id="Flow_TaskPublicBodyArrangement_To_TaskSelectDPO_Art37" sourceRef="Task_PublicBodyArrangement_Art37" targetRef="Task_SelectDPO_Art37" />
    <bpmn:sequenceFlow id="Flow_TaskSelectDPO_To_GatewayAppointmentBasis_Art37" sourceRef="Task_SelectDPO_Art37" targetRef="Gateway_AppointmentBasis_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayAppointmentBasis_To_TaskAppointStaffDPO_Art37" name="Staff member" sourceRef="Gateway_AppointmentBasis_Art37" targetRef="Task_AppointStaffDPO_Art37" />
    <bpmn:sequenceFlow id="Flow_GatewayAppointmentBasis_To_TaskAppointServiceContractDPO_Art37" name="Service contract" sourceRef="Gateway_AppointmentBasis_Art37" targetRef="Task_AppointServiceContractDPO_Art37" />
    <bpmn:sequenceFlow id="Flow_TaskAppointStaffDPO_To_TaskPublishContactDetails_Art37" sourceRef="Task_AppointStaffDPO_Art37" targetRef="Task_PublishContactDetails_Art37" />
    <bpmn:sequenceFlow id="Flow_TaskAppointServiceContractDPO_To_TaskPublishContactDetails_Art37" sourceRef="Task_AppointServiceContractDPO_Art37" targetRef="Task_PublishContactDetails_Art37" />
    <bpmn:sequenceFlow id="Flow_TaskPublishContactDetails_To_SendTaskNotifyAuthority_Art37" sourceRef="Task_PublishContactDetails_Art37" targetRef="SendTask_NotifyAuthority_Art37" />
    <bpmn:sequenceFlow id="Flow_SendTaskNotifyAuthority_To_EndCompleted_Art37" sourceRef="SendTask_NotifyAuthority_Art37" targetRef="EndEvent_Completed_Art37" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art37_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art37_Reviewed" bpmnElement="Collab_Art37_Reviewed">
      <bpmndi:BPMNShape id="Participant_ControllerOrProcessor_Art37_di" bpmnElement="Participant_ControllerOrProcessor_Art37" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="4700" height="540" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_SupervisoryAuthority_Art37_di" bpmnElement="Participant_SupervisoryAuthority_Art37" isHorizontal="true">
        <dc:Bounds x="60" y="620" width="4700" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_AssessDuty_Art37_di" bpmnElement="StartEvent_AssessDuty_Art37">
        <dc:Bounds x="140" y="262" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessPublic_Art37_di" bpmnElement="Task_AssessPublic_Art37">
        <dc:Bounds x="220" y="240" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Public_Art37_di" bpmnElement="Gateway_Public_Art37" isMarkerVisible="true">
        <dc:Bounds x="520" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckCourt_Art37_di" bpmnElement="Task_CheckCourt_Art37">
        <dc:Bounds x="640" y="80" width="250" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Court_Art37_di" bpmnElement="Gateway_Court_Art37" isMarkerVisible="true">
        <dc:Bounds x="960" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessMonitoring_Art37_di" bpmnElement="Task_AssessMonitoring_Art37">
        <dc:Bounds x="640" y="240" width="270" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Monitoring_Art37_di" bpmnElement="Gateway_Monitoring_Art37" isMarkerVisible="true">
        <dc:Bounds x="980" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessLargeScale_Art37_di" bpmnElement="Task_AssessLargeScale_Art37">
        <dc:Bounds x="1100" y="240" width="290" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_LargeScale_Art37_di" bpmnElement="Gateway_LargeScale_Art37" isMarkerVisible="true">
        <dc:Bounds x="1460" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessAdditionalDesignation_Art37_di" bpmnElement="Task_AssessAdditionalDesignation_Art37">
        <dc:Bounds x="1720" y="240" width="270" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AdditionalDesignation_Art37_di" bpmnElement="Gateway_AdditionalDesignation_Art37" isMarkerVisible="true">
        <dc:Bounds x="2060" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoDesignation_Art37_di" bpmnElement="EndEvent_NoDesignation_Art37">
        <dc:Bounds x="2282" y="262" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PrepareDesignation_Art37_di" bpmnElement="Task_PrepareDesignation_Art37">
        <dc:Bounds x="1720" y="80" width="230" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Shared_Art37_di" bpmnElement="Gateway_Shared_Art37" isMarkerVisible="true">
        <dc:Bounds x="2060" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SharedType_Art37_di" bpmnElement="Gateway_SharedType_Art37" isMarkerVisible="true">
        <dc:Bounds x="2350" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GroupArrangement_Art37_di" bpmnElement="Task_GroupArrangement_Art37">
        <dc:Bounds x="2500" y="20" width="300" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PublicBodyArrangement_Art37_di" bpmnElement="Task_PublicBodyArrangement_Art37">
        <dc:Bounds x="2500" y="140" width="310" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SelectDPO_Art37_di" bpmnElement="Task_SelectDPO_Art37">
        <dc:Bounds x="2860" y="80" width="260" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AppointmentBasis_Art37_di" bpmnElement="Gateway_AppointmentBasis_Art37" isMarkerVisible="true">
        <dc:Bounds x="3200" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AppointStaffDPO_Art37_di" bpmnElement="Task_AppointStaffDPO_Art37">
        <dc:Bounds x="3380" y="20" width="260" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AppointServiceContractDPO_Art37_di" bpmnElement="Task_AppointServiceContractDPO_Art37">
        <dc:Bounds x="3380" y="140" width="280" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PublishContactDetails_Art37_di" bpmnElement="Task_PublishContactDetails_Art37">
        <dc:Bounds x="3740" y="80" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_NotifyAuthority_Art37_di" bpmnElement="SendTask_NotifyAuthority_Art37">
        <dc:Bounds x="4040" y="80" width="260" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Completed_Art37_di" bpmnElement="EndEvent_Completed_Art37">
        <dc:Bounds x="4382" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_AssessPublic_Art37_di" bpmnElement="Flow_Start_To_AssessPublic_Art37">
        <di:waypoint x="176" y="280" />
        <di:waypoint x="220" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AssessPublic_To_GatewayPublic_Art37_di" bpmnElement="Flow_AssessPublic_To_GatewayPublic_Art37">
        <di:waypoint x="440" y="280" />
        <di:waypoint x="520" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPublic_To_TaskCheckCourt_Art37_di" bpmnElement="Flow_GatewayPublic_To_TaskCheckCourt_Art37">
        <di:waypoint x="545" y="255" />
        <di:waypoint x="545" y="120" />
        <di:waypoint x="640" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPublic_To_TaskAssessMonitoring_Art37_di" bpmnElement="Flow_GatewayPublic_To_TaskAssessMonitoring_Art37">
        <di:waypoint x="570" y="280" />
