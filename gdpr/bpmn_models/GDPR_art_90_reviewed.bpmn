<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art90_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art90_Reviewed">
    <bpmn:participant id="Participant_MemberState_Art90"
                      name="Member State"
                      processRef="Process_MemberState_Art90" />
    <bpmn:participant id="Participant_Commission_Art90"
                      name="Commission" />

    <bpmn:messageFlow id="MessageFlow_NotifyCommissionOfArticle90Rules_Art90"
                      sourceRef="Task_NotifyCommissionOfArticle90Rules_Art90"
                      targetRef="Participant_Commission_Art90" />
  </bpmn:collaboration>

  <bpmn:process id="Process_MemberState_Art90"
                name="Adopt secrecy-related supervisory-authority rules"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 90 based on the real English legal text from
      gdpr_articles/article_90.txt. This process captures the optional adoption of specific rules
      for the supervisory-authority powers in Article 58(1)(e) and (f) where necessary and
      proportionate to reconcile data protection with obligations of professional secrecy or
      equivalent secrecy, the limitation of those rules to personal data received or obtained in
      activities covered by that secrecy obligation, and the duty to notify the Commission of the
      adopted rules and later amendments.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_AssessSpecificSecrecyRules_Art90"
                     name="Assess specific secrecy rules">
      <bpmn:outgoing>Flow_Start_To_GatewayAdoptSpecificRules_Art90</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_AdoptSpecificRules_Art90"
                           name="Will the Member State adopt specific rules?">
      <bpmn:incoming>Flow_Start_To_GatewayAdoptSpecificRules_Art90</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAdoptSpecificRules_To_GatewayAuthorityPowers_Art90</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAdoptSpecificRules_To_EndNoSpecificRules_Art90</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_AreArticle58PowersConcerned_Art90"
                           name="Do the rules concern Article 58(1)(e) and (f) powers?">
      <bpmn:incoming>Flow_GatewayAdoptSpecificRules_To_GatewayAuthorityPowers_Art90</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAuthorityPowers_To_GatewaySecrecyObligation_Art90</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAuthorityPowers_To_EndNoSpecificRules_Art90</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_IsProfessionalSecrecyContextPresent_Art90"
                           name="Is the controller or processor subject to professional secrecy or equivalent secrecy?">
      <bpmn:incoming>Flow_GatewayAuthorityPowers_To_GatewaySecrecyObligation_Art90</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySecrecyObligation_To_GatewayNecessityAndProportionality_Art90</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySecrecyObligation_To_EndNoSpecificRules_Art90</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_AreRulesNecessaryAndProportionate_Art90"
                           name="Are the rules necessary and proportionate to reconcile the rights and secrecy obligations?">
      <bpmn:incoming>Flow_GatewaySecrecyObligation_To_GatewayNecessityAndProportionality_Art90</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayNecessityAndProportionality_To_AdoptSpecificRules_Art90</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayNecessityAndProportionality_To_EndNoSpecificRules_Art90</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AdoptSpecificRules_Art90"
               name="Adopt specific rules">
      <bpmn:incoming>Flow_GatewayNecessityAndProportionality_To_AdoptSpecificRules_Art90</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptSpecificRules_To_LimitRulesToCoveredData_Art90</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_LimitRulesToCoveredData_Art90"
               name="Limit rules to covered personal data">
      <bpmn:incoming>Flow_AdoptSpecificRules_To_LimitRulesToCoveredData_Art90</bpmn:incoming>
      <bpmn:outgoing>Flow_LimitRulesToCoveredData_To_NotifyCommission_Art90</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_NotifyCommissionOfArticle90Rules_Art90"
                   name="Notify Commission of Article 90 rules">
      <bpmn:incoming>Flow_LimitRulesToCoveredData_To_NotifyCommission_Art90</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyCommission_To_EndRulesNotified_Art90</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_NoSpecificRules_Art90"
                   name="No specific rules adopted">
      <bpmn:incoming>Flow_GatewayAdoptSpecificRules_To_EndNoSpecificRules_Art90</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayAuthorityPowers_To_EndNoSpecificRules_Art90</bpmn:incoming>
      <bpmn:incoming>Flow_GatewaySecrecyObligation_To_EndNoSpecificRules_Art90</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayNecessityAndProportionality_To_EndNoSpecificRules_Art90</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_RulesNotified_Art90"
                   name="Article 90 rules notified">
      <bpmn:incoming>Flow_NotifyCommission_To_EndRulesNotified_Art90</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_GatewayAdoptSpecificRules_Art90"
                       sourceRef="StartEvent_AssessSpecificSecrecyRules_Art90"
                       targetRef="Gateway_AdoptSpecificRules_Art90" />
    <bpmn:sequenceFlow id="Flow_GatewayAdoptSpecificRules_To_GatewayAuthorityPowers_Art90"
                       name="Yes"
                       sourceRef="Gateway_AdoptSpecificRules_Art90"
                       targetRef="Gateway_AreArticle58PowersConcerned_Art90" />
    <bpmn:sequenceFlow id="Flow_GatewayAdoptSpecificRules_To_EndNoSpecificRules_Art90"
                       name="No"
                       sourceRef="Gateway_AdoptSpecificRules_Art90"
                       targetRef="EndEvent_NoSpecificRules_Art90" />
    <bpmn:sequenceFlow id="Flow_GatewayAuthorityPowers_To_GatewaySecrecyObligation_Art90"
                       name="Yes"
                       sourceRef="Gateway_AreArticle58PowersConcerned_Art90"
                       targetRef="Gateway_IsProfessionalSecrecyContextPresent_Art90" />
    <bpmn:sequenceFlow id="Flow_GatewayAuthorityPowers_To_EndNoSpecificRules_Art90"
                       name="No"
                       sourceRef="Gateway_AreArticle58PowersConcerned_Art90"
                       targetRef="EndEvent_NoSpecificRules_Art90" />
    <bpmn:sequenceFlow id="Flow_GatewaySecrecyObligation_To_GatewayNecessityAndProportionality_Art90"
                       name="Yes"
                       sourceRef="Gateway_IsProfessionalSecrecyContextPresent_Art90"
                       targetRef="Gateway_AreRulesNecessaryAndProportionate_Art90" />
    <bpmn:sequenceFlow id="Flow_GatewaySecrecyObligation_To_EndNoSpecificRules_Art90"
                       name="No"
                       sourceRef="Gateway_IsProfessionalSecrecyContextPresent_Art90"
                       targetRef="EndEvent_NoSpecificRules_Art90" />
    <bpmn:sequenceFlow id="Flow_GatewayNecessityAndProportionality_To_AdoptSpecificRules_Art90"
                       name="Yes"
                       sourceRef="Gateway_AreRulesNecessaryAndProportionate_Art90"
                       targetRef="Task_AdoptSpecificRules_Art90" />
    <bpmn:sequenceFlow id="Flow_GatewayNecessityAndProportionality_To_EndNoSpecificRules_Art90"
                       name="No"
                       sourceRef="Gateway_AreRulesNecessaryAndProportionate_Art90"
                       targetRef="EndEvent_NoSpecificRules_Art90" />
    <bpmn:sequenceFlow id="Flow_AdoptSpecificRules_To_LimitRulesToCoveredData_Art90"
                       sourceRef="Task_AdoptSpecificRules_Art90"
                       targetRef="Task_LimitRulesToCoveredData_Art90" />
    <bpmn:sequenceFlow id="Flow_LimitRulesToCoveredData_To_NotifyCommission_Art90"
                       sourceRef="Task_LimitRulesToCoveredData_Art90"
                       targetRef="Task_NotifyCommissionOfArticle90Rules_Art90" />
    <bpmn:sequenceFlow id="Flow_NotifyCommission_To_EndRulesNotified_Art90"
                       sourceRef="Task_NotifyCommissionOfArticle90Rules_Art90"
                       targetRef="EndEvent_RulesNotified_Art90" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art90_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art90_Reviewed"
                      bpmnElement="Collaboration_Art90_Reviewed">
      <bpmndi:BPMNShape id="Participant_MemberState_Art90_di"
                        bpmnElement="Participant_MemberState_Art90"
                        isHorizontal="true">
        <dc:Bounds x="80" y="80" width="2360" height="300" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Commission_Art90_di"
                        bpmnElement="Participant_Commission_Art90"
                        isHorizontal="true">
        <dc:Bounds x="80" y="440" width="2360" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_AssessSpecificSecrecyRules_Art90_di"
                        bpmnElement="StartEvent_AssessSpecificSecrecyRules_Art90">
        <dc:Bounds x="120" y="222" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AdoptSpecificRules_Art90_di"
                        bpmnElement="Gateway_AdoptSpecificRules_Art90"
                        isMarkerVisible="true">
        <dc:Bounds x="220" y="215" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AreArticle58PowersConcerned_Art90_di"
                        bpmnElement="Gateway_AreArticle58PowersConcerned_Art90"
                        isMarkerVisible="true">
        <dc:Bounds x="420" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IsProfessionalSecrecyContextPresent_Art90_di"
                        bpmnElement="Gateway_IsProfessionalSecrecyContextPresent_Art90"
                        isMarkerVisible="true">
        <dc:Bounds x="670" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AreRulesNecessaryAndProportionate_Art90_di"
                        bpmnElement="Gateway_AreRulesNecessaryAndProportionate_Art90"
                        isMarkerVisible="true">
        <dc:Bounds x="940" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdoptSpecificRules_Art90_di"
                        bpmnElement="Task_AdoptSpecificRules_Art90">
        <dc:Bounds x="1120" y="80" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LimitRulesToCoveredData_Art90_di"
                        bpmnElement="Task_LimitRulesToCoveredData_Art90">
        <dc:Bounds x="1380" y="80" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyCommissionOfArticle90Rules_Art90_di"
                        bpmnElement="Task_NotifyCommissionOfArticle90Rules_Art90">
        <dc:Bounds x="1660" y="80" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoSpecificRules_Art90_di"
                        bpmnElement="EndEvent_NoSpecificRules_Art90">
        <dc:Bounds x="762" y="302" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RulesNotified_Art90_di"
                        bpmnElement="EndEvent_RulesNotified_Art90">
        <dc:Bounds x="1962" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_GatewayAdoptSpecificRules_Art90_di"
                       bpmnElement="Flow_Start_To_GatewayAdoptSpecificRules_Art90">
        <di:waypoint x="156" y="240" />
        <di:waypoint x="220" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAdoptSpecificRules_To_GatewayAuthorityPowers_Art90_di"
                       bpmnElement="Flow_GatewayAdoptSpecificRules_To_GatewayAuthorityPowers_Art90">
        <di:waypoint x="245" y="215" />
        <di:waypoint x="245" y="120" />
        <di:waypoint x="420" y="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="280" y="138" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAdoptSpecificRules_To_EndNoSpecificRules_Art90_di"
                       bpmnElement="Flow_GatewayAdoptSpecificRules_To_EndNoSpecificRules_Art90">
        <di:waypoint x="245" y="265" />
        <di:waypoint x="245" y="320" />
        <di:waypoint x="762" y="320" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="280" y="286" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAuthorityPowers_To_GatewaySecrecyObligation_Art90_di"
                       bpmnElement="Flow_GatewayAuthorityPowers_To_GatewaySecrecyObligation_Art90">
        <di:waypoint x="470" y="120" />
        <di:waypoint x="670" y="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="548" y="102" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAuthorityPowers_To_EndNoSpecificRules_Art90_di"
                       bpmnElement="Flow_GatewayAuthorityPowers_To_EndNoSpecificRules_Art90">
        <di:waypoint x="445" y="145" />
        <di:waypoint x="445" y="320" />
        <di:waypoint x="762" y="320" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="458" y="230" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySecrecyObligation_To_GatewayNecessityAndProportionality_Art90_di"
                       bpmnElement="Flow_GatewaySecrecyObligation_To_GatewayNecessityAndProportionality_Art90">
        <di:waypoint x="720" y="120" />
        <di:waypoint x="940" y="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="808" y="102" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySecrecyObligation_To_EndNoSpecificRules_Art90_di"
                       bpmnElement="Flow_GatewaySecrecyObligation_To_EndNoSpecificRules_Art90">
        <di:waypoint x="695" y="145" />
        <di:waypoint x="695" y="320" />
        <di:waypoint x="762" y="320" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="706" y="230" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayNecessityAndProportionality_To_AdoptSpecificRules_Art90_di"
                       bpmnElement="Flow_GatewayNecessityAndProportionality_To_AdoptSpecificRules_Art90">
        <di:waypoint x="990" y="120" />
        <di:waypoint x="1120" y="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1038" y="102" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayNecessityAndProportionality_To_EndNoSpecificRules_Art90_di"
                       bpmnElement="Flow_GatewayNecessityAndProportionality_To_EndNoSpecificRules_Art90">
        <di:waypoint x="965" y="145" />
        <di:waypoint x="965" y="320" />
        <di:waypoint x="762" y="320" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="971" y="230" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdoptSpecificRules_To_LimitRulesToCoveredData_Art90_di"
                       bpmnElement="Flow_AdoptSpecificRules_To_LimitRulesToCoveredData_Art90">
        <di:waypoint x="1290" y="120" />
        <di:waypoint x="1380" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LimitRulesToCoveredData_To_NotifyCommission_Art90_di"
                       bpmnElement="Flow_LimitRulesToCoveredData_To_NotifyCommission_Art90">
        <di:waypoint x="1570" y="120" />
        <di:waypoint x="1660" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotifyCommission_To_EndRulesNotified_Art90_di"
                       bpmnElement="Flow_NotifyCommission_To_EndRulesNotified_Art90">
        <di:waypoint x="1870" y="120" />
        <di:waypoint x="1962" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MessageFlow_NotifyCommissionOfArticle90Rules_Art90_di"
                       bpmnElement="MessageFlow_NotifyCommissionOfArticle90Rules_Art90">
        <di:waypoint x="1765" y="160" />
        <di:waypoint x="1765" y="440" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
