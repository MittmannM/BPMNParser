<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art41_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art41_Reviewed">
    <bpmn:participant id="Participant_MonitoringBody_Art41"
                      name="Monitoring Body"
                      processRef="Process_MonitoringBody_Art41" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art41"
                      name="Supervisory Authority"
                      processRef="Process_SupervisoryAuthority_Art41" />
    <bpmn:participant id="Participant_Board_Art41"
                      name="Board" />
    <bpmn:participant id="Participant_ControllerProcessor_Art41"
                      name="Adhering Controller or Processor" />
    <bpmn:participant id="Participant_DataSubject_Art41"
                      name="Data Subject" />

    <bpmn:messageFlow id="MessageFlow_SubmitAccreditationRequest_Art41"
                      sourceRef="SendTask_SubmitAccreditationRequest_Art41"
                      targetRef="ReceiveTask_ReceiveAccreditationRequest_Art41" />
    <bpmn:messageFlow id="MessageFlow_AccreditationDecision_Art41"
                      sourceRef="SendTask_SendAccreditationDecision_Art41"
                      targetRef="ReceiveTask_ReceiveAccreditationDecision_Art41" />
    <bpmn:messageFlow id="MessageFlow_SubmitRequirementsToBoard_Art41"
                      sourceRef="SendTask_SubmitRequirementsToBoard_Art41"
                      targetRef="Participant_Board_Art41" />
    <bpmn:messageFlow id="MessageFlow_DataSubjectComplaint_Art41"
                      sourceRef="Participant_DataSubject_Art41"
                      targetRef="Task_HandleCodeComplaints_Art41" />
    <bpmn:messageFlow id="MessageFlow_SuspendOrExclude_Art41"
                      sourceRef="SendTask_SuspendOrExcludeAdherent_Art41"
                      targetRef="Participant_ControllerProcessor_Art41" />
    <bpmn:messageFlow id="MessageFlow_InformAuthority_Art41"
                      sourceRef="SendTask_InformAuthority_Art41"
                      targetRef="ReceiveTask_ReceiveInfringementInfo_Art41" />
    <bpmn:messageFlow id="MessageFlow_SendRevocationNotice_Art41"
                      sourceRef="SendTask_SendRevocationNotice_Art41"
                      targetRef="ReceiveTask_ReceiveRevocationNotice_Art41" />
  </bpmn:collaboration>

  <bpmn:process id="Process_MonitoringBody_Art41"
                name="Operating as a monitoring body under Article 41"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 41 based on the real English legal text
      of Regulation (EU) 2016/679. This process captures the Article 41(6) public-body
      exclusion, the Article 41(2) expertise, independence, eligibility-assessment,
      compliance-monitoring, periodic-review, complaint-handling, transparency, and
      no-conflict setup, the accreditation request and decision, the ongoing monitoring
      role under Article 41(1), the infringement-action path under Article 41(4), and
      the possible revocation notice under Article 41(5).
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_ConsiderMonitoringRole_Art41"
                     name="Consider monitoring role">
      <bpmn:outgoing>Flow_StartConsiderMonitoringRole_To_GatewayPublicAuthority_Art41</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_PublicAuthority_Art41"
                           name="Does the code apply to public authorities or bodies?">
      <bpmn:incoming>Flow_StartConsiderMonitoringRole_To_GatewayPublicAuthority_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayPublicAuthority_To_EndNotApplicable_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayPublicAuthority_To_TaskDemonstrateExpertise_Art41</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NotApplicable_Art41"
                   name="Article 41 monitoring does not apply">
      <bpmn:incoming>Flow_GatewayPublicAuthority_To_EndNotApplicable_Art41</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_DemonstrateExpertise_Art41"
               name="Demonstrate expertise">
      <bpmn:incoming>Flow_GatewayPublicAuthority_To_TaskDemonstrateExpertise_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDemonstrateExpertise_To_TaskDemonstrateIndependence_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DemonstrateIndependence_Art41"
               name="Demonstrate independence">
      <bpmn:incoming>Flow_TaskDemonstrateExpertise_To_TaskDemonstrateIndependence_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDemonstrateIndependence_To_TaskShowNoConflicts_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ShowNoConflicts_Art41"
               name="Show no conflicts">
      <bpmn:incoming>Flow_TaskDemonstrateIndependence_To_TaskShowNoConflicts_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskShowNoConflicts_To_GatewaySplitSetup_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_SplitSetup_Art41">
      <bpmn:incoming>Flow_TaskShowNoConflicts_To_GatewaySplitSetup_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitSetup_To_TaskSetEligibilityAssessment_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitSetup_To_TaskSetComplianceMonitoring_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitSetup_To_TaskSetPeriodicReview_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitSetup_To_TaskSetComplaintProcedures_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitSetup_To_TaskPublishProcedures_Art41</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_SetEligibilityAssessment_Art41"
               name="Set eligibility assessment">
      <bpmn:incoming>Flow_GatewaySplitSetup_To_TaskSetEligibilityAssessment_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetEligibilityAssessment_To_GatewayJoinSetup_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetComplianceMonitoring_Art41"
               name="Set compliance monitoring">
      <bpmn:incoming>Flow_GatewaySplitSetup_To_TaskSetComplianceMonitoring_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetComplianceMonitoring_To_GatewayJoinSetup_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetPeriodicReview_Art41"
               name="Set periodic review">
      <bpmn:incoming>Flow_GatewaySplitSetup_To_TaskSetPeriodicReview_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetPeriodicReview_To_GatewayJoinSetup_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetComplaintProcedures_Art41"
               name="Set complaint procedures">
      <bpmn:incoming>Flow_GatewaySplitSetup_To_TaskSetComplaintProcedures_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetComplaintProcedures_To_GatewayJoinSetup_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PublishProcedures_Art41"
               name="Publish procedures">
      <bpmn:incoming>Flow_GatewaySplitSetup_To_TaskPublishProcedures_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPublishProcedures_To_GatewayJoinSetup_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinSetup_Art41">
      <bpmn:incoming>Flow_TaskSetEligibilityAssessment_To_GatewayJoinSetup_Art41</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetComplianceMonitoring_To_GatewayJoinSetup_Art41</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetPeriodicReview_To_GatewayJoinSetup_Art41</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetComplaintProcedures_To_GatewayJoinSetup_Art41</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPublishProcedures_To_GatewayJoinSetup_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinSetup_To_SendTaskSubmitAccreditationRequest_Art41</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:sendTask id="SendTask_SubmitAccreditationRequest_Art41"
                   name="Submit accreditation request">
      <bpmn:incoming>Flow_GatewayJoinSetup_To_SendTaskSubmitAccreditationRequest_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSubmitAccreditationRequest_To_ReceiveTaskReceiveAccreditationDecision_Art41</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAccreditationDecision_Art41"
                      name="Receive accreditation decision">
      <bpmn:incoming>Flow_SendTaskSubmitAccreditationRequest_To_ReceiveTaskReceiveAccreditationDecision_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveAccreditationDecision_To_GatewayAccredited_Art41</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_Accredited_Art41"
                           name="Was the body accredited?">
      <bpmn:incoming>Flow_ReceiveTaskReceiveAccreditationDecision_To_GatewayAccredited_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAccredited_To_EndNotAccredited_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAccredited_To_TaskAssessAdherentEligibility_Art41</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NotAccredited_Art41"
                   name="Monitoring body not accredited">
      <bpmn:incoming>Flow_GatewayAccredited_To_EndNotAccredited_Art41</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_AssessAdherentEligibility_Art41"
               name="Assess adherent eligibility">
      <bpmn:incoming>Flow_GatewayAccredited_To_TaskAssessAdherentEligibility_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessAdherentEligibility_To_TaskMonitorCodeCompliance_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_MonitorCodeCompliance_Art41"
               name="Monitor code compliance">
      <bpmn:incoming>Flow_TaskAssessAdherentEligibility_To_TaskMonitorCodeCompliance_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskMonitorCodeCompliance_To_TaskReviewCodeOperation_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ReviewCodeOperation_Art41"
               name="Review code operation">
      <bpmn:incoming>Flow_TaskMonitorCodeCompliance_To_TaskReviewCodeOperation_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskReviewCodeOperation_To_TaskHandleCodeComplaints_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_HandleCodeComplaints_Art41"
               name="Handle code complaints">
      <bpmn:incoming>Flow_TaskReviewCodeOperation_To_TaskHandleCodeComplaints_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskHandleCodeComplaints_To_GatewayInfringementFound_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_InfringementFound_Art41"
                           name="Was an infringement of the code identified?">
      <bpmn:incoming>Flow_TaskHandleCodeComplaints_To_GatewayInfringementFound_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayInfringementFound_To_EndMonitoringContinues_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayInfringementFound_To_TaskTakeAppropriateAction_Art41</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_MonitoringContinues_Art41"
                   name="Monitoring continues">
      <bpmn:incoming>Flow_GatewayInfringementFound_To_EndMonitoringContinues_Art41</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_TakeAppropriateAction_Art41"
               name="Take appropriate action">
      <bpmn:incoming>Flow_GatewayInfringementFound_To_TaskTakeAppropriateAction_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskTakeAppropriateAction_To_GatewaySuspendExclude_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_SuspendExclude_Art41"
                           name="Is suspension or exclusion required?">
      <bpmn:incoming>Flow_TaskTakeAppropriateAction_To_GatewaySuspendExclude_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySuspendExclude_To_SendTaskSuspendOrExcludeAdherent_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySuspendExclude_To_SendTaskInformAuthority_Art41</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_SuspendOrExcludeAdherent_Art41"
                   name="Suspend or exclude adherent">
      <bpmn:incoming>Flow_GatewaySuspendExclude_To_SendTaskSuspendOrExcludeAdherent_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSuspendOrExcludeAdherent_To_SendTaskInformAuthority_Art41</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_InformAuthority_Art41"
                   name="Inform supervisory authority">
      <bpmn:incoming>Flow_GatewaySuspendExclude_To_SendTaskInformAuthority_Art41</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskSuspendOrExcludeAdherent_To_SendTaskInformAuthority_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskInformAuthority_To_ReceiveTaskReceiveRevocationNotice_Art41</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveRevocationNotice_Art41"
                      name="Receive revocation notice">
      <bpmn:incoming>Flow_SendTaskInformAuthority_To_ReceiveTaskReceiveRevocationNotice_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveRevocationNotice_To_GatewayAccreditationRevoked_Art41</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_AccreditationRevoked_Art41"
                           name="Was the accreditation revoked?">
      <bpmn:incoming>Flow_ReceiveTaskReceiveRevocationNotice_To_GatewayAccreditationRevoked_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAccreditationRevoked_To_EndAccreditationRevoked_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAccreditationRevoked_To_EndAuthorityInformed_Art41</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_AccreditationRevoked_Art41"
                   name="Accreditation revoked">
      <bpmn:incoming>Flow_GatewayAccreditationRevoked_To_EndAccreditationRevoked_Art41</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_AuthorityInformed_Art41"
                   name="Authority informed">
      <bpmn:incoming>Flow_GatewayAccreditationRevoked_To_EndAuthorityInformed_Art41</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartConsiderMonitoringRole_To_GatewayPublicAuthority_Art41" sourceRef="StartEvent_ConsiderMonitoringRole_Art41" targetRef="Gateway_PublicAuthority_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicAuthority_To_EndNotApplicable_Art41" name="Yes" sourceRef="Gateway_PublicAuthority_Art41" targetRef="EndEvent_NotApplicable_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicAuthority_To_TaskDemonstrateExpertise_Art41" name="No" sourceRef="Gateway_PublicAuthority_Art41" targetRef="Task_DemonstrateExpertise_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskDemonstrateExpertise_To_TaskDemonstrateIndependence_Art41" sourceRef="Task_DemonstrateExpertise_Art41" targetRef="Task_DemonstrateIndependence_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskDemonstrateIndependence_To_TaskShowNoConflicts_Art41" sourceRef="Task_DemonstrateIndependence_Art41" targetRef="Task_ShowNoConflicts_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskShowNoConflicts_To_GatewaySplitSetup_Art41" sourceRef="Task_ShowNoConflicts_Art41" targetRef="Gateway_SplitSetup_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitSetup_To_TaskSetEligibilityAssessment_Art41" sourceRef="Gateway_SplitSetup_Art41" targetRef="Task_SetEligibilityAssessment_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitSetup_To_TaskSetComplianceMonitoring_Art41" sourceRef="Gateway_SplitSetup_Art41" targetRef="Task_SetComplianceMonitoring_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitSetup_To_TaskSetPeriodicReview_Art41" sourceRef="Gateway_SplitSetup_Art41" targetRef="Task_SetPeriodicReview_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitSetup_To_TaskSetComplaintProcedures_Art41" sourceRef="Gateway_SplitSetup_Art41" targetRef="Task_SetComplaintProcedures_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitSetup_To_TaskPublishProcedures_Art41" sourceRef="Gateway_SplitSetup_Art41" targetRef="Task_PublishProcedures_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskSetEligibilityAssessment_To_GatewayJoinSetup_Art41" sourceRef="Task_SetEligibilityAssessment_Art41" targetRef="Gateway_JoinSetup_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskSetComplianceMonitoring_To_GatewayJoinSetup_Art41" sourceRef="Task_SetComplianceMonitoring_Art41" targetRef="Gateway_JoinSetup_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskSetPeriodicReview_To_GatewayJoinSetup_Art41" sourceRef="Task_SetPeriodicReview_Art41" targetRef="Gateway_JoinSetup_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskSetComplaintProcedures_To_GatewayJoinSetup_Art41" sourceRef="Task_SetComplaintProcedures_Art41" targetRef="Gateway_JoinSetup_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskPublishProcedures_To_GatewayJoinSetup_Art41" sourceRef="Task_PublishProcedures_Art41" targetRef="Gateway_JoinSetup_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinSetup_To_SendTaskSubmitAccreditationRequest_Art41" sourceRef="Gateway_JoinSetup_Art41" targetRef="SendTask_SubmitAccreditationRequest_Art41" />
    <bpmn:sequenceFlow id="Flow_SendTaskSubmitAccreditationRequest_To_ReceiveTaskReceiveAccreditationDecision_Art41" sourceRef="SendTask_SubmitAccreditationRequest_Art41" targetRef="ReceiveTask_ReceiveAccreditationDecision_Art41" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveAccreditationDecision_To_GatewayAccredited_Art41" sourceRef="ReceiveTask_ReceiveAccreditationDecision_Art41" targetRef="Gateway_Accredited_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayAccredited_To_EndNotAccredited_Art41" name="No" sourceRef="Gateway_Accredited_Art41" targetRef="EndEvent_NotAccredited_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayAccredited_To_TaskAssessAdherentEligibility_Art41" name="Yes" sourceRef="Gateway_Accredited_Art41" targetRef="Task_AssessAdherentEligibility_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskAssessAdherentEligibility_To_TaskMonitorCodeCompliance_Art41" sourceRef="Task_AssessAdherentEligibility_Art41" targetRef="Task_MonitorCodeCompliance_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskMonitorCodeCompliance_To_TaskReviewCodeOperation_Art41" sourceRef="Task_MonitorCodeCompliance_Art41" targetRef="Task_ReviewCodeOperation_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskReviewCodeOperation_To_TaskHandleCodeComplaints_Art41" sourceRef="Task_ReviewCodeOperation_Art41" targetRef="Task_HandleCodeComplaints_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskHandleCodeComplaints_To_GatewayInfringementFound_Art41" sourceRef="Task_HandleCodeComplaints_Art41" targetRef="Gateway_InfringementFound_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayInfringementFound_To_EndMonitoringContinues_Art41" name="No" sourceRef="Gateway_InfringementFound_Art41" targetRef="EndEvent_MonitoringContinues_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayInfringementFound_To_TaskTakeAppropriateAction_Art41" name="Yes" sourceRef="Gateway_InfringementFound_Art41" targetRef="Task_TakeAppropriateAction_Art41" />
    <bpmn:sequenceFlow id="Flow_TaskTakeAppropriateAction_To_GatewaySuspendExclude_Art41" sourceRef="Task_TakeAppropriateAction_Art41" targetRef="Gateway_SuspendExclude_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewaySuspendExclude_To_SendTaskSuspendOrExcludeAdherent_Art41" name="Yes" sourceRef="Gateway_SuspendExclude_Art41" targetRef="SendTask_SuspendOrExcludeAdherent_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewaySuspendExclude_To_SendTaskInformAuthority_Art41" name="No" sourceRef="Gateway_SuspendExclude_Art41" targetRef="SendTask_InformAuthority_Art41" />
    <bpmn:sequenceFlow id="Flow_SendTaskSuspendOrExcludeAdherent_To_SendTaskInformAuthority_Art41" sourceRef="SendTask_SuspendOrExcludeAdherent_Art41" targetRef="SendTask_InformAuthority_Art41" />
    <bpmn:sequenceFlow id="Flow_SendTaskInformAuthority_To_ReceiveTaskReceiveRevocationNotice_Art41" sourceRef="SendTask_InformAuthority_Art41" targetRef="ReceiveTask_ReceiveRevocationNotice_Art41" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveRevocationNotice_To_GatewayAccreditationRevoked_Art41" sourceRef="ReceiveTask_ReceiveRevocationNotice_Art41" targetRef="Gateway_AccreditationRevoked_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayAccreditationRevoked_To_EndAccreditationRevoked_Art41" name="Yes" sourceRef="Gateway_AccreditationRevoked_Art41" targetRef="EndEvent_AccreditationRevoked_Art41" />
    <bpmn:sequenceFlow id="Flow_GatewayAccreditationRevoked_To_EndAuthorityInformed_Art41" name="No" sourceRef="Gateway_AccreditationRevoked_Art41" targetRef="EndEvent_AuthorityInformed_Art41" />
  </bpmn:process>

  <bpmn:process id="Process_SupervisoryAuthority_Art41"
                name="Accrediting and supervising the monitoring body"
                isExecutable="false">
    <bpmn:documentation>
      This process captures the Article 41(3) submission of draft accreditation
      requirements to the Board under Article 63, the accreditation review against the
      Article 41(2) requirements, and the Article 41(5) revocation path where the
      requirements are not, or are no longer, met or where the body's actions infringe
      the GDPR.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_SetAccreditationFramework_Art41"
                     name="Set accreditation framework">
      <bpmn:outgoing>Flow_StartSetAccreditationFramework_To_TaskDraftAccreditationRequirements_Art41</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_DraftAccreditationRequirements_Art41"
               name="Draft accreditation requirements">
      <bpmn:incoming>Flow_StartSetAccreditationFramework_To_TaskDraftAccreditationRequirements_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDraftAccreditationRequirements_To_SendTaskSubmitRequirementsToBoard_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_SubmitRequirementsToBoard_Art41"
                   name="Submit Article 63 draft">
      <bpmn:incoming>Flow_TaskDraftAccreditationRequirements_To_SendTaskSubmitRequirementsToBoard_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSubmitRequirementsToBoard_To_ReceiveTaskReceiveAccreditationRequest_Art41</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAccreditationRequest_Art41"
                      name="Receive accreditation request">
      <bpmn:incoming>Flow_SendTaskSubmitRequirementsToBoard_To_ReceiveTaskReceiveAccreditationRequest_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveAccreditationRequest_To_TaskAssessExpertiseAndIndependence_Art41</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_AssessExpertiseAndIndependence_Art41"
               name="Assess expertise and independence">
      <bpmn:incoming>Flow_ReceiveTaskReceiveAccreditationRequest_To_TaskAssessExpertiseAndIndependence_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessExpertiseAndIndependence_To_TaskAssessProceduresAndSafeguards_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AssessProceduresAndSafeguards_Art41"
               name="Assess procedures and safeguards">
      <bpmn:incoming>Flow_TaskAssessExpertiseAndIndependence_To_TaskAssessProceduresAndSafeguards_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessProceduresAndSafeguards_To_GatewayMeetsRequirements_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_MeetsRequirements_Art41"
                           name="Does the body meet the accreditation requirements?">
      <bpmn:incoming>Flow_TaskAssessProceduresAndSafeguards_To_GatewayMeetsRequirements_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMeetsRequirements_To_SendTaskSendAccreditationDecision_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayMeetsRequirements_To_SendTaskSendAccreditationDecision_Art41_Default</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_SendAccreditationDecision_Art41"
                   name="Send accreditation decision">
      <bpmn:incoming>Flow_GatewayMeetsRequirements_To_SendTaskSendAccreditationDecision_Art41</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayMeetsRequirements_To_SendTaskSendAccreditationDecision_Art41_Default</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendAccreditationDecision_To_ReceiveTaskReceiveInfringementInfo_Art41</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveInfringementInfo_Art41"
                      name="Receive infringement information">
      <bpmn:incoming>Flow_SendTaskSendAccreditationDecision_To_ReceiveTaskReceiveInfringementInfo_Art41</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskInformAuthority_To_ReceiveTaskReceiveInfringementInfo_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveInfringementInfo_To_TaskAssessRevocationGrounds_Art41</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_AssessRevocationGrounds_Art41"
               name="Assess revocation grounds">
      <bpmn:incoming>Flow_ReceiveTaskReceiveInfringementInfo_To_TaskAssessRevocationGrounds_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessRevocationGrounds_To_GatewayRevokeAccreditation_Art41</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_RevokeAccreditation_Art41"
                           name="Should the accreditation be revoked?">
      <bpmn:incoming>Flow_TaskAssessRevocationGrounds_To_GatewayRevokeAccreditation_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRevokeAccreditation_To_EndAccreditationMaintained_Art41</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRevokeAccreditation_To_SendTaskSendRevocationNotice_Art41</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_AccreditationMaintained_Art41"
                   name="Accreditation maintained">
      <bpmn:incoming>Flow_GatewayRevokeAccreditation_To_EndAccreditationMaintained_Art41</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_SendRevocationNotice_Art41"
                   name="Send revocation notice">
      <bpmn:incoming>Flow_GatewayRevokeAccreditation_To_SendTaskSendRevocationNotice_Art41</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendRevocationNotice_To_EndAccreditationRevoked_Art41</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_AccreditationRevoked_Art41_SA"
                   name="Accreditation revoked by authority">
      <bpmn:incoming>Flow_SendTaskSendRevocationNotice_To_EndAccreditationRevoked_Art41</bpmn:incoming>
    </bpmn:endEvent>

