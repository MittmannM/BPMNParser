<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art76_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_Board_Art76"
                name="Apply Board confidentiality and document-access rules"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 76 based on the real English legal text from
      gdpr_articles/article_76.txt. This compact governance process captures the Board's
      confidentiality assessment for discussions under its rules of procedure and the separate
      requirement that access to submitted documents is governed by Regulation (EC) No 1049/2001.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_HandleBoardDiscussionOrDocuments_Art76"
                     name="Handle Board discussion or documents">
      <bpmn:outgoing>Flow_Start_To_GatewaySplitGovernance_Art76</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:parallelGateway id="Gateway_SplitGovernancePaths_Art76">
      <bpmn:incoming>Flow_Start_To_GatewaySplitGovernance_Art76</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplit_To_GatewayConfidentiality_Art76</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplit_To_ApplyDocumentAccessRules_Art76</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:exclusiveGateway id="Gateway_IsConfidentialityNecessary_Art76"
                           name="Is confidentiality necessary under the rules of procedure?">
      <bpmn:incoming>Flow_GatewaySplit_To_GatewayConfidentiality_Art76</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayConfidentiality_To_ApplyConfidentiality_Art76</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayConfidentiality_To_ConductOpenDiscussion_Art76</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ApplyConfidentialityToDiscussion_Art76"
               name="Apply confidentiality to discussion">
      <bpmn:incoming>Flow_GatewayConfidentiality_To_ApplyConfidentiality_Art76</bpmn:incoming>
      <bpmn:outgoing>Flow_ApplyConfidentiality_To_GatewayMergeDiscussion_Art76</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ConductNonConfidentialDiscussion_Art76"
               name="Conduct non-confidential discussion">
      <bpmn:incoming>Flow_GatewayConfidentiality_To_ConductOpenDiscussion_Art76</bpmn:incoming>
      <bpmn:outgoing>Flow_ConductOpenDiscussion_To_GatewayMergeDiscussion_Art76</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_MergeDiscussionPath_Art76">
      <bpmn:incoming>Flow_ApplyConfidentiality_To_GatewayMergeDiscussion_Art76</bpmn:incoming>
      <bpmn:incoming>Flow_ConductOpenDiscussion_To_GatewayMergeDiscussion_Art76</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMergeDiscussion_To_GatewayJoinGovernance_Art76</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ApplyDocumentAccessRules_Art76"
               name="Apply Regulation 1049/2001 access rules">
      <bpmn:incoming>Flow_GatewaySplit_To_ApplyDocumentAccessRules_Art76</bpmn:incoming>
      <bpmn:outgoing>Flow_ApplyDocumentAccessRules_To_GatewayJoinGovernance_Art76</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinGovernancePaths_Art76">
      <bpmn:incoming>Flow_GatewayMergeDiscussion_To_GatewayJoinGovernance_Art76</bpmn:incoming>
      <bpmn:incoming>Flow_ApplyDocumentAccessRules_To_GatewayJoinGovernance_Art76</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinGovernance_To_EndGovernanceApplied_Art76</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:endEvent id="EndEvent_GovernanceApplied_Art76"
                   name="Governance rules applied">
      <bpmn:incoming>Flow_GatewayJoinGovernance_To_EndGovernanceApplied_Art76</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_GatewaySplitGovernance_Art76"
                       sourceRef="StartEvent_HandleBoardDiscussionOrDocuments_Art76"
                       targetRef="Gateway_SplitGovernancePaths_Art76" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_GatewayConfidentiality_Art76"
                       sourceRef="Gateway_SplitGovernancePaths_Art76"
                       targetRef="Gateway_IsConfidentialityNecessary_Art76" />
    <bpmn:sequenceFlow id="Flow_GatewaySplit_To_ApplyDocumentAccessRules_Art76"
                       sourceRef="Gateway_SplitGovernancePaths_Art76"
                       targetRef="Task_ApplyDocumentAccessRules_Art76" />
    <bpmn:sequenceFlow id="Flow_GatewayConfidentiality_To_ApplyConfidentiality_Art76"
                       name="Yes"
                       sourceRef="Gateway_IsConfidentialityNecessary_Art76"
                       targetRef="Task_ApplyConfidentialityToDiscussion_Art76" />
    <bpmn:sequenceFlow id="Flow_GatewayConfidentiality_To_ConductOpenDiscussion_Art76"
                       name="No"
                       sourceRef="Gateway_IsConfidentialityNecessary_Art76"
                       targetRef="Task_ConductNonConfidentialDiscussion_Art76" />
    <bpmn:sequenceFlow id="Flow_ApplyConfidentiality_To_GatewayMergeDiscussion_Art76"
                       sourceRef="Task_ApplyConfidentialityToDiscussion_Art76"
                       targetRef="Gateway_MergeDiscussionPath_Art76" />
    <bpmn:sequenceFlow id="Flow_ConductOpenDiscussion_To_GatewayMergeDiscussion_Art76"
                       sourceRef="Task_ConductNonConfidentialDiscussion_Art76"
                       targetRef="Gateway_MergeDiscussionPath_Art76" />
    <bpmn:sequenceFlow id="Flow_GatewayMergeDiscussion_To_GatewayJoinGovernance_Art76"
                       sourceRef="Gateway_MergeDiscussionPath_Art76"
                       targetRef="Gateway_JoinGovernancePaths_Art76" />
    <bpmn:sequenceFlow id="Flow_ApplyDocumentAccessRules_To_GatewayJoinGovernance_Art76"
                       sourceRef="Task_ApplyDocumentAccessRules_Art76"
                       targetRef="Gateway_JoinGovernancePaths_Art76" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinGovernance_To_EndGovernanceApplied_Art76"
                       sourceRef="Gateway_JoinGovernancePaths_Art76"
                       targetRef="EndEvent_GovernanceApplied_Art76" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art76_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art76_Reviewed"
                      bpmnElement="Process_Board_Art76">
      <bpmndi:BPMNShape id="StartEvent_HandleBoardDiscussionOrDocuments_Art76_di"
                        bpmnElement="StartEvent_HandleBoardDiscussionOrDocuments_Art76">
        <dc:Bounds x="90" y="212" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SplitGovernancePaths_Art76_di"
                        bpmnElement="Gateway_SplitGovernancePaths_Art76"
                        isMarkerVisible="true">
        <dc:Bounds x="190" y="205" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IsConfidentialityNecessary_Art76_di"
                        bpmnElement="Gateway_IsConfidentialityNecessary_Art76"
                        isMarkerVisible="true">
        <dc:Bounds x="360" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ApplyConfidentialityToDiscussion_Art76_di"
                        bpmnElement="Task_ApplyConfidentialityToDiscussion_Art76">
        <dc:Bounds x="500" y="40" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ConductNonConfidentialDiscussion_Art76_di"
                        bpmnElement="Task_ConductNonConfidentialDiscussion_Art76">
        <dc:Bounds x="500" y="150" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MergeDiscussionPath_Art76_di"
                        bpmnElement="Gateway_MergeDiscussionPath_Art76"
                        isMarkerVisible="true">
        <dc:Bounds x="790" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ApplyDocumentAccessRules_Art76_di"
                        bpmnElement="Task_ApplyDocumentAccessRules_Art76">
        <dc:Bounds x="360" y="290" width="240" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_JoinGovernancePaths_Art76_di"
                        bpmnElement="Gateway_JoinGovernancePaths_Art76"
                        isMarkerVisible="true">
        <dc:Bounds x="960" y="205" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_GovernanceApplied_Art76_di"
                        bpmnElement="EndEvent_GovernanceApplied_Art76">
        <dc:Bounds x="1130" y="212" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_GatewaySplitGovernance_Art76_di"
                       bpmnElement="Flow_Start_To_GatewaySplitGovernance_Art76">
        <di:waypoint x="126" y="230" />
        <di:waypoint x="190" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_GatewayConfidentiality_Art76_di"
                       bpmnElement="Flow_GatewaySplit_To_GatewayConfidentiality_Art76">
        <di:waypoint x="215" y="205" />
        <di:waypoint x="215" y="120" />
        <di:waypoint x="360" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplit_To_ApplyDocumentAccessRules_Art76_di"
                       bpmnElement="Flow_GatewaySplit_To_ApplyDocumentAccessRules_Art76">
        <di:waypoint x="215" y="255" />
        <di:waypoint x="215" y="330" />
        <di:waypoint x="360" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayConfidentiality_To_ApplyConfidentiality_Art76_di"
                       bpmnElement="Flow_GatewayConfidentiality_To_ApplyConfidentiality_Art76">
        <di:waypoint x="410" y="120" />
        <di:waypoint x="500" y="80" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="440" y="82" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayConfidentiality_To_ConductOpenDiscussion_Art76_di"
                       bpmnElement="Flow_GatewayConfidentiality_To_ConductOpenDiscussion_Art76">
        <di:waypoint x="410" y="120" />
        <di:waypoint x="500" y="190" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="438" y="151" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ApplyConfidentiality_To_GatewayMergeDiscussion_Art76_di"
                       bpmnElement="Flow_ApplyConfidentiality_To_GatewayMergeDiscussion_Art76">
        <di:waypoint x="690" y="80" />
        <di:waypoint x="815" y="80" />
        <di:waypoint x="815" y="95" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ConductOpenDiscussion_To_GatewayMergeDiscussion_Art76_di"
                       bpmnElement="Flow_ConductOpenDiscussion_To_GatewayMergeDiscussion_Art76">
        <di:waypoint x="700" y="190" />
        <di:waypoint x="815" y="190" />
        <di:waypoint x="815" y="145" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayMergeDiscussion_To_GatewayJoinGovernance_Art76_di"
                       bpmnElement="Flow_GatewayMergeDiscussion_To_GatewayJoinGovernance_Art76">
        <di:waypoint x="840" y="120" />
        <di:waypoint x="985" y="120" />
        <di:waypoint x="985" y="205" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ApplyDocumentAccessRules_To_GatewayJoinGovernance_Art76_di"
                       bpmnElement="Flow_ApplyDocumentAccessRules_To_GatewayJoinGovernance_Art76">
        <di:waypoint x="600" y="330" />
        <di:waypoint x="985" y="330" />
        <di:waypoint x="985" y="255" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayJoinGovernance_To_EndGovernanceApplied_Art76_di"
                       bpmnElement="Flow_GatewayJoinGovernance_To_EndGovernanceApplied_Art76">
        <di:waypoint x="1010" y="230" />
        <di:waypoint x="1130" y="230" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
