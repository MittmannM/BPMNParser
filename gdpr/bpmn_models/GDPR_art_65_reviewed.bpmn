<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art65_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art65_Reviewed">
    <bpmn:participant id="Participant_LeadOrComplaintAuthority_Art65"
                      name="Lead or Complaint Supervisory Authority"
                      processRef="Process_LeadOrComplaintAuthority_Art65" />
    <bpmn:participant id="Participant_Board_Art65"
                      name="Board"
                      processRef="Process_Board_Art65" />
    <bpmn:participant id="Participant_ConcernedAuthorities_Art65"
                      name="Other Concerned Supervisory Authorities" />
    <bpmn:participant id="Participant_Commission_Art65"
                      name="Commission" />
    <bpmn:participant id="Participant_ControllerOrProcessor_Art65"
                      name="Controller or Processor" />
    <bpmn:participant id="Participant_DataSubject_Art65"
                      name="Data Subject" />
    <bpmn:participant id="Participant_Public_Art65"
                      name="Public" />

    <bpmn:messageFlow id="MessageFlow_SendReferralToBoard_Art65"
                      sourceRef="Task_SendReferralToBoard_Art65"
                      targetRef="StartEvent_ReceiveReferral_Art65" />
    <bpmn:messageFlow id="MessageFlow_CommissionReferral_Art65"
                      sourceRef="Participant_Commission_Art65"
                      targetRef="StartEvent_ReceiveReferral_Art65" />
    <bpmn:messageFlow id="MessageFlow_NotifyAuthorities_Art65"
                      sourceRef="Task_NotifyAuthoritiesAndCommission_Art65"
                      targetRef="Task_ReceiveBindingDecision_Art65" />
    <bpmn:messageFlow id="MessageFlow_NotifyConcernedAuthorities_Art65"
                      sourceRef="Task_NotifyAuthoritiesAndCommission_Art65"
                      targetRef="Participant_ConcernedAuthorities_Art65" />
    <bpmn:messageFlow id="MessageFlow_NotifyCommission_Art65"
                      sourceRef="Task_NotifyAuthoritiesAndCommission_Art65"
                      targetRef="Participant_Commission_Art65" />
    <bpmn:messageFlow id="MessageFlow_InformBoardOfNotificationDate_Art65"
                      sourceRef="Task_InformBoardOfNotificationDate_Art65"
                      targetRef="Task_ReceiveNotificationDate_Art65" />
    <bpmn:messageFlow id="MessageFlow_NotifyControllerOrProcessor_Art65"
                      sourceRef="Task_NotifyControllerOrProcessor_Art65"
                      targetRef="Participant_ControllerOrProcessor_Art65" />
    <bpmn:messageFlow id="MessageFlow_NotifyDataSubject_Art65"
                      sourceRef="Task_NotifyDataSubject_Art65"
                      targetRef="Participant_DataSubject_Art65" />
    <bpmn:messageFlow id="MessageFlow_PublishBoardDecision_Art65"
                      sourceRef="Task_PublishBoardDecision_Art65"
                      targetRef="Participant_Public_Art65" />
  </bpmn:collaboration>

  <bpmn:process id="Process_LeadOrComplaintAuthority_Art65"
                name="Refer matter and adopt final decision"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 65 based on the real English legal text from
      gdpr_articles/article_65.txt. This process captures the three Article 65(1) referral
      grounds, the no-adoption duty during the Board-decision periods, receipt of the binding
      Board decision, and the Article 65(6) final-decision path including Board-reference,
      attachment, notification to controller or processor and the data subject, and notification
      of the notification date back to the Board.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_NeedBindingDecision_Art65"
                     name="Need binding decision">
      <bpmn:outgoing>Flow_StartNeedBindingDecision_To_GatewayReferralGround_Art65</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_WhatTriggersReferral_Art65"
                           name="What triggers the Article 65 referral?">
      <bpmn:incoming>Flow_StartNeedBindingDecision_To_GatewayReferralGround_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayReferralGround_To_HandleObjectionConflict_Art65</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayReferralGround_To_HandleCompetenceConflict_Art65</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayReferralGround_To_HandleArticle64Conflict_Art65</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_HandleObjectionConflict_Art65"
               name="Handle Article 60 objection conflict">
      <bpmn:incoming>Flow_GatewayReferralGround_To_HandleObjectionConflict_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_HandleObjectionConflict_To_GatewayMergeReferralGround_Art65</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_HandleCompetenceConflict_Art65"
               name="Handle competence conflict">
      <bpmn:incoming>Flow_GatewayReferralGround_To_HandleCompetenceConflict_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_HandleCompetenceConflict_To_GatewayMergeReferralGround_Art65</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_HandleArticle64Conflict_Art65"
               name="Handle Article 64 conflict">
      <bpmn:incoming>Flow_GatewayReferralGround_To_HandleArticle64Conflict_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_HandleArticle64Conflict_To_GatewayMergeReferralGround_Art65</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_MergeReferralGround_Art65">
      <bpmn:incoming>Flow_HandleObjectionConflict_To_GatewayMergeReferralGround_Art65</bpmn:incoming>
      <bpmn:incoming>Flow_HandleCompetenceConflict_To_GatewayMergeReferralGround_Art65</bpmn:incoming>
      <bpmn:incoming>Flow_HandleArticle64Conflict_To_GatewayMergeReferralGround_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMergeReferralGround_To_SendReferralToBoard_Art65</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_SendReferralToBoard_Art65"
                   name="Send referral to Board">
      <bpmn:incoming>Flow_GatewayMergeReferralGround_To_SendReferralToBoard_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_SendReferralToBoard_To_SuspendAdoption_Art65</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_SuspendAdoptionDuringBoardPeriod_Art65"
               name="Suspend adoption during Board period">
      <bpmn:incoming>Flow_SendReferralToBoard_To_SuspendAdoption_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_SuspendAdoption_To_ReceiveBindingDecision_Art65</bpmn:outgoing>
    </bpmn:task>

    <bpmn:receiveTask id="Task_ReceiveBindingDecision_Art65"
                      name="Receive binding Board decision">
      <bpmn:incoming>Flow_SuspendAdoption_To_ReceiveBindingDecision_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveBindingDecision_To_AdoptFinalDecision_Art65</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_AdoptFinalDecision_Art65"
               name="Adopt final decision within one month">
      <bpmn:incoming>Flow_ReceiveBindingDecision_To_AdoptFinalDecision_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptFinalDecision_To_NotifyControllerOrProcessor_Art65</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_NotifyControllerOrProcessor_Art65"
                   name="Notify controller or processor">
      <bpmn:incoming>Flow_AdoptFinalDecision_To_NotifyControllerOrProcessor_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyControllerOrProcessor_To_NotifyDataSubject_Art65</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_NotifyDataSubject_Art65"
                   name="Notify data subject">
      <bpmn:incoming>Flow_NotifyControllerOrProcessor_To_NotifyDataSubject_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyDataSubject_To_InformBoardOfNotificationDate_Art65</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_InformBoardOfNotificationDate_Art65"
                   name="Inform Board of notification date">
      <bpmn:incoming>Flow_NotifyDataSubject_To_InformBoardOfNotificationDate_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_InformBoardOfNotificationDate_To_EndFinalDecisionNotified_Art65</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_FinalDecisionNotified_Art65"
                   name="Final decision notified">
      <bpmn:incoming>Flow_InformBoardOfNotificationDate_To_EndFinalDecisionNotified_Art65</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartNeedBindingDecision_To_GatewayReferralGround_Art65"
                       sourceRef="StartEvent_NeedBindingDecision_Art65"
                       targetRef="Gateway_WhatTriggersReferral_Art65" />
    <bpmn:sequenceFlow id="Flow_GatewayReferralGround_To_HandleObjectionConflict_Art65"
                       name="Article 60(4)"
                       sourceRef="Gateway_WhatTriggersReferral_Art65"
                       targetRef="Task_HandleObjectionConflict_Art65" />
    <bpmn:sequenceFlow id="Flow_GatewayReferralGround_To_HandleCompetenceConflict_Art65"
                       name="Competence"
                       sourceRef="Gateway_WhatTriggersReferral_Art65"
                       targetRef="Task_HandleCompetenceConflict_Art65" />
    <bpmn:sequenceFlow id="Flow_GatewayReferralGround_To_HandleArticle64Conflict_Art65"
                       name="Article 64"
                       sourceRef="Gateway_WhatTriggersReferral_Art65"
                       targetRef="Task_HandleArticle64Conflict_Art65" />
    <bpmn:sequenceFlow id="Flow_HandleObjectionConflict_To_GatewayMergeReferralGround_Art65"
                       sourceRef="Task_HandleObjectionConflict_Art65"
                       targetRef="Gateway_MergeReferralGround_Art65" />
    <bpmn:sequenceFlow id="Flow_HandleCompetenceConflict_To_GatewayMergeReferralGround_Art65"
                       sourceRef="Task_HandleCompetenceConflict_Art65"
                       targetRef="Gateway_MergeReferralGround_Art65" />
    <bpmn:sequenceFlow id="Flow_HandleArticle64Conflict_To_GatewayMergeReferralGround_Art65"
                       sourceRef="Task_HandleArticle64Conflict_Art65"
                       targetRef="Gateway_MergeReferralGround_Art65" />
    <bpmn:sequenceFlow id="Flow_GatewayMergeReferralGround_To_SendReferralToBoard_Art65"
                       sourceRef="Gateway_MergeReferralGround_Art65"
                       targetRef="Task_SendReferralToBoard_Art65" />
    <bpmn:sequenceFlow id="Flow_SendReferralToBoard_To_SuspendAdoption_Art65"
                       sourceRef="Task_SendReferralToBoard_Art65"
                       targetRef="Task_SuspendAdoptionDuringBoardPeriod_Art65" />
    <bpmn:sequenceFlow id="Flow_SuspendAdoption_To_ReceiveBindingDecision_Art65"
                       sourceRef="Task_SuspendAdoptionDuringBoardPeriod_Art65"
                       targetRef="Task_ReceiveBindingDecision_Art65" />
    <bpmn:sequenceFlow id="Flow_ReceiveBindingDecision_To_AdoptFinalDecision_Art65"
                       sourceRef="Task_ReceiveBindingDecision_Art65"
                       targetRef="Task_AdoptFinalDecision_Art65" />
    <bpmn:sequenceFlow id="Flow_AdoptFinalDecision_To_NotifyControllerOrProcessor_Art65"
                       sourceRef="Task_AdoptFinalDecision_Art65"
                       targetRef="Task_NotifyControllerOrProcessor_Art65" />
    <bpmn:sequenceFlow id="Flow_NotifyControllerOrProcessor_To_NotifyDataSubject_Art65"
                       sourceRef="Task_NotifyControllerOrProcessor_Art65"
                       targetRef="Task_NotifyDataSubject_Art65" />
    <bpmn:sequenceFlow id="Flow_NotifyDataSubject_To_InformBoardOfNotificationDate_Art65"
                       sourceRef="Task_NotifyDataSubject_Art65"
                       targetRef="Task_InformBoardOfNotificationDate_Art65" />
    <bpmn:sequenceFlow id="Flow_InformBoardOfNotificationDate_To_EndFinalDecisionNotified_Art65"
                       sourceRef="Task_InformBoardOfNotificationDate_Art65"
                       targetRef="EndEvent_FinalDecisionNotified_Art65" />
  </bpmn:process>

  <bpmn:process id="Process_Board_Art65"
                name="Adopt and publish binding decision"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 65 based on the real English legal text from
      gdpr_articles/article_65.txt. This process captures the Board's binding-decision workflow:
      receipt of the referral, reasoned binding decision route by two-thirds majority within one
      month with optional one-month extension for complexity, fallback adoption within two weeks
      by simple majority, Chair vote where the Board is split, notification to the supervisory
      authorities concerned and the Commission, and publication after notification of the final
      supervisory-authority decision.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_ReceiveReferral_Art65"
                     name="Receive referral">
      <bpmn:messageEventDefinition />
      <bpmn:outgoing>Flow_StartReceiveReferral_To_GatewayComplexMatter_Art65</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_IsMatterComplex_Art65"
                           name="Is the subject matter complex?">
      <bpmn:incoming>Flow_StartReceiveReferral_To_GatewayComplexMatter_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayComplexMatter_To_ExtendDecisionPeriod_Art65</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayComplexMatter_To_GatewayMergeDecisionPeriod_Art65</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ExtendDecisionPeriod_Art65"
               name="Extend decision period by one month">
      <bpmn:incoming>Flow_GatewayComplexMatter_To_ExtendDecisionPeriod_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_ExtendDecisionPeriod_To_GatewayMergeDecisionPeriod_Art65</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_MergeDecisionPeriod_Art65">
      <bpmn:incoming>Flow_GatewayComplexMatter_To_GatewayMergeDecisionPeriod_Art65</bpmn:incoming>
      <bpmn:incoming>Flow_ExtendDecisionPeriod_To_GatewayMergeDecisionPeriod_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMergeDecisionPeriod_To_GatewayCanAdoptByTwoThirds_Art65</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_CanBoardAdoptByTwoThirds_Art65"
                           name="Can the Board adopt by two-thirds majority?">
      <bpmn:incoming>Flow_GatewayMergeDecisionPeriod_To_GatewayCanAdoptByTwoThirds_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayCanAdoptByTwoThirds_To_AdoptReasonedBindingDecision_Art65</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCanAdoptByTwoThirds_To_AdoptBySimpleMajority_Art65</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AdoptReasonedBindingDecision_Art65"
               name="Adopt reasoned binding decision">
      <bpmn:incoming>Flow_GatewayCanAdoptByTwoThirds_To_AdoptReasonedBindingDecision_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptReasonedBindingDecision_To_NotifyAuthoritiesAndCommission_Art65</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AdoptBySimpleMajority_Art65"
               name="Adopt decision within two weeks">
      <bpmn:incoming>Flow_GatewayCanAdoptByTwoThirds_To_AdoptBySimpleMajority_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptBySimpleMajority_To_GatewayBoardSplit_Art65</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_IsBoardSplit_Art65"
                           name="Are Board members split?">
      <bpmn:incoming>Flow_AdoptBySimpleMajority_To_GatewayBoardSplit_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayBoardSplit_To_UseChairVote_Art65</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayBoardSplit_To_GatewayMergeDecisionOutcome_Art65</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_UseChairVote_Art65"
               name="Use Chair vote">
      <bpmn:incoming>Flow_GatewayBoardSplit_To_UseChairVote_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_UseChairVote_To_GatewayMergeDecisionOutcome_Art65</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_MergeDecisionOutcome_Art65">
      <bpmn:incoming>Flow_GatewayBoardSplit_To_GatewayMergeDecisionOutcome_Art65</bpmn:incoming>
      <bpmn:incoming>Flow_UseChairVote_To_GatewayMergeDecisionOutcome_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMergeDecisionOutcome_To_NotifyAuthoritiesAndCommission_Art65</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_NotifyAuthoritiesAndCommission_Art65"
                   name="Notify authorities and Commission">
      <bpmn:incoming>Flow_AdoptReasonedBindingDecision_To_NotifyAuthoritiesAndCommission_Art65</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayMergeDecisionOutcome_To_NotifyAuthoritiesAndCommission_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyAuthoritiesAndCommission_To_ReceiveNotificationDate_Art65</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="Task_ReceiveNotificationDate_Art65"
                      name="Receive final-decision notification date">
      <bpmn:incoming>Flow_NotifyAuthoritiesAndCommission_To_ReceiveNotificationDate_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveNotificationDate_To_PublishBoardDecision_Art65</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:sendTask id="Task_PublishBoardDecision_Art65"
                   name="Publish Board decision">
      <bpmn:incoming>Flow_ReceiveNotificationDate_To_PublishBoardDecision_Art65</bpmn:incoming>
      <bpmn:outgoing>Flow_PublishBoardDecision_To_EndDecisionPublished_Art65</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_BoardDecisionPublished_Art65"
                   name="Board decision published">
      <bpmn:incoming>Flow_PublishBoardDecision_To_EndDecisionPublished_Art65</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartReceiveReferral_To_GatewayComplexMatter_Art65"
                       sourceRef="StartEvent_ReceiveReferral_Art65"
                       targetRef="Gateway_IsMatterComplex_Art65" />
    <bpmn:sequenceFlow id="Flow_GatewayComplexMatter_To_ExtendDecisionPeriod_Art65"
                       name="Yes"
                       sourceRef="Gateway_IsMatterComplex_Art65"
                       targetRef="Task_ExtendDecisionPeriod_Art65" />
    <bpmn:sequenceFlow id="Flow_GatewayComplexMatter_To_GatewayMergeDecisionPeriod_Art65"
                       name="No"
                       sourceRef="Gateway_IsMatterComplex_Art65"
                       targetRef="Gateway_MergeDecisionPeriod_Art65" />
    <bpmn:sequenceFlow id="Flow_ExtendDecisionPeriod_To_GatewayMergeDecisionPeriod_Art65"
                       sourceRef="Task_ExtendDecisionPeriod_Art65"
                       targetRef="Gateway_MergeDecisionPeriod_Art65" />
    <bpmn:sequenceFlow id="Flow_GatewayMergeDecisionPeriod_To_GatewayCanAdoptByTwoThirds_Art65"
                       sourceRef="Gateway_MergeDecisionPeriod_Art65"
                       targetRef="Gateway_CanBoardAdoptByTwoThirds_Art65" />
    <bpmn:sequenceFlow id="Flow_GatewayCanAdoptByTwoThirds_To_AdoptReasonedBindingDecision_Art65"
                       name="Yes"
                       sourceRef="Gateway_CanBoardAdoptByTwoThirds_Art65"
                       targetRef="Task_AdoptReasonedBindingDecision_Art65" />
    <bpmn:sequenceFlow id="Flow_GatewayCanAdoptByTwoThirds_To_AdoptBySimpleMajority_Art65"
                       name="No"
                       sourceRef="Gateway_CanBoardAdoptByTwoThirds_Art65"
                       targetRef="Task_AdoptBySimpleMajority_Art65" />
    <bpmn:sequenceFlow id="Flow_AdoptReasonedBindingDecision_To_NotifyAuthoritiesAndCommission_Art65"
                       sourceRef="Task_AdoptReasonedBindingDecision_Art65"
                       targetRef="Task_NotifyAuthoritiesAndCommission_Art65" />
    <bpmn:sequenceFlow id="Flow_AdoptBySimpleMajority_To_GatewayBoardSplit_Art65"
                       sourceRef="Task_AdoptBySimpleMajority_Art65"
                       targetRef="Gateway_IsBoardSplit_Art65" />
    <bpmn:sequenceFlow id="Flow_GatewayBoardSplit_To_UseChairVote_Art65"
                       name="Yes"
                       sourceRef="Gateway_IsBoardSplit_Art65"
                       targetRef="Task_UseChairVote_Art65" />
    <bpmn:sequenceFlow id="Flow_GatewayBoardSplit_To_GatewayMergeDecisionOutcome_Art65"
                       name="No"
                       sourceRef="Gateway_IsBoardSplit_Art65"
                       targetRef="Gateway_MergeDecisionOutcome_Art65" />
    <bpmn:sequenceFlow id="Flow_UseChairVote_To_GatewayMergeDecisionOutcome_Art65"
                       sourceRef="Task_UseChairVote_Art65"
                       targetRef="Gateway_MergeDecisionOutcome_Art65" />
    <bpmn:sequenceFlow id="Flow_GatewayMergeDecisionOutcome_To_NotifyAuthoritiesAndCommission_Art65"
                       sourceRef="Gateway_MergeDecisionOutcome_Art65"
                       targetRef="Task_NotifyAuthoritiesAndCommission_Art65" />
    <bpmn:sequenceFlow id="Flow_NotifyAuthoritiesAndCommission_To_ReceiveNotificationDate_Art65"
                       sourceRef="Task_NotifyAuthoritiesAndCommission_Art65"
                       targetRef="Task_ReceiveNotificationDate_Art65" />
    <bpmn:sequenceFlow id="Flow_ReceiveNotificationDate_To_PublishBoardDecision_Art65"
                       sourceRef="Task_ReceiveNotificationDate_Art65"
                       targetRef="Task_PublishBoardDecision_Art65" />
    <bpmn:sequenceFlow id="Flow_PublishBoardDecision_To_EndDecisionPublished_Art65"
                       sourceRef="Task_PublishBoardDecision_Art65"
                       targetRef="EndEvent_BoardDecisionPublished_Art65" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art65_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art65_Reviewed"
                      bpmnElement="Collaboration_Art65_Reviewed">
      <bpmndi:BPMNShape id="Participant_LeadOrComplaintAuthority_Art65_di"
                        bpmnElement="Participant_LeadOrComplaintAuthority_Art65"
                        isHorizontal="true">
        <dc:Bounds x="20" y="20" width="3200" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Board_Art65_di"
                        bpmnElement="Participant_Board_Art65"
                        isHorizontal="true">
        <dc:Bounds x="20" y="400" width="3200" height="340" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_ConcernedAuthorities_Art65_di"
                        bpmnElement="Participant_ConcernedAuthorities_Art65"
                        isHorizontal="true">
        <dc:Bounds x="20" y="760" width="3200" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Commission_Art65_di"
                        bpmnElement="Participant_Commission_Art65"
                        isHorizontal="true">
        <dc:Bounds x="20" y="880" width="3200" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_ControllerOrProcessor_Art65_di"
                        bpmnElement="Participant_ControllerOrProcessor_Art65"
                        isHorizontal="true">
        <dc:Bounds x="20" y="1000" width="3200" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art65_di"
                        bpmnElement="Participant_DataSubject_Art65"
                        isHorizontal="true">
        <dc:Bounds x="20" y="1120" width="3200" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Public_Art65_di"
                        bpmnElement="Participant_Public_Art65"
                        isHorizontal="true">
        <dc:Bounds x="20" y="1240" width="3200" height="100" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_NeedBindingDecision_Art65_di"
                        bpmnElement="StartEvent_NeedBindingDecision_Art65">
        <dc:Bounds x="120" y="172" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_WhatTriggersReferral_Art65_di"
                        bpmnElement="Gateway_WhatTriggersReferral_Art65"
                        isMarkerVisible="true">
        <dc:Bounds x="230" y="165" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HandleObjectionConflict_Art65_di"
                        bpmnElement="Task_HandleObjectionConflict_Art65">
        <dc:Bounds x="380" y="60" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HandleCompetenceConflict_Art65_di"
                        bpmnElement="Task_HandleCompetenceConflict_Art65">
        <dc:Bounds x="380" y="160" width="190" height="80" />
