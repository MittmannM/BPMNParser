<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art98_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_Art98"
                name="Prepare legislative proposals to amend Union legal acts"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 98 based on the real English legal text from
      gdpr_articles/article_98.txt. This compact process captures the conditional submission of
      legislative proposals by the Commission to amend other Union legal acts in order to ensure
      uniform and consistent protection of natural persons with regard to processing, with
      particular regard to Union institutions, bodies, offices and agencies and the free movement
      of such data.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_AssessNeedForLegislativeProposals_Art98"
                     name="Assess need for legislative proposals">
      <bpmn:outgoing>Flow_Start_To_GatewayAppropriateness_Art98</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_IsSubmissionAppropriate_Art98"
                           name="Is it appropriate to submit legislative proposals?">
      <bpmn:incoming>Flow_Start_To_GatewayAppropriateness_Art98</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAppropriateness_To_PrepareLegislativeProposals_Art98</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAppropriateness_To_EndNoProposalSubmitted_Art98</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_PrepareLegislativeProposals_Art98"
               name="Prepare legislative proposals">
      <bpmn:incoming>Flow_GatewayAppropriateness_To_PrepareLegislativeProposals_Art98</bpmn:incoming>
      <bpmn:outgoing>Flow_PrepareLegislativeProposals_To_TargetUnionActs_Art98</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_TargetUnionActsOnDataProtection_Art98"
               name="Target Union acts on data protection">
      <bpmn:incoming>Flow_PrepareLegislativeProposals_To_TargetUnionActs_Art98</bpmn:incoming>
      <bpmn:outgoing>Flow_TargetUnionActs_To_EnsureUniformProtection_Art98</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EnsureUniformAndConsistentProtection_Art98"
               name="Ensure uniform and consistent protection">
      <bpmn:incoming>Flow_TargetUnionActs_To_EnsureUniformProtection_Art98</bpmn:incoming>
      <bpmn:outgoing>Flow_EnsureUniformProtection_To_EndProposalSubmitted_Art98</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_NoProposalSubmitted_Art98"
                   name="No proposal submitted">
      <bpmn:incoming>Flow_GatewayAppropriateness_To_EndNoProposalSubmitted_Art98</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_ProposalSubmitted_Art98"
                   name="Proposal submitted">
      <bpmn:incoming>Flow_EnsureUniformProtection_To_EndProposalSubmitted_Art98</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_GatewayAppropriateness_Art98"
                       sourceRef="StartEvent_AssessNeedForLegislativeProposals_Art98"
                       targetRef="Gateway_IsSubmissionAppropriate_Art98" />
    <bpmn:sequenceFlow id="Flow_GatewayAppropriateness_To_PrepareLegislativeProposals_Art98"
                       name="Yes"
                       sourceRef="Gateway_IsSubmissionAppropriate_Art98"
                       targetRef="Task_PrepareLegislativeProposals_Art98" />
    <bpmn:sequenceFlow id="Flow_GatewayAppropriateness_To_EndNoProposalSubmitted_Art98"
                       name="No"
                       sourceRef="Gateway_IsSubmissionAppropriate_Art98"
                       targetRef="EndEvent_NoProposalSubmitted_Art98" />
    <bpmn:sequenceFlow id="Flow_PrepareLegislativeProposals_To_TargetUnionActs_Art98"
                       sourceRef="Task_PrepareLegislativeProposals_Art98"
                       targetRef="Task_TargetUnionActsOnDataProtection_Art98" />
    <bpmn:sequenceFlow id="Flow_TargetUnionActs_To_EnsureUniformProtection_Art98"
                       sourceRef="Task_TargetUnionActsOnDataProtection_Art98"
                       targetRef="Task_EnsureUniformAndConsistentProtection_Art98" />
    <bpmn:sequenceFlow id="Flow_EnsureUniformProtection_To_EndProposalSubmitted_Art98"
                       sourceRef="Task_EnsureUniformAndConsistentProtection_Art98"
                       targetRef="EndEvent_ProposalSubmitted_Art98" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art98_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art98_Reviewed"
                      bpmnElement="Process_Art98">
      <bpmndi:BPMNShape id="StartEvent_AssessNeedForLegislativeProposals_Art98_di"
                        bpmnElement="StartEvent_AssessNeedForLegislativeProposals_Art98">
        <dc:Bounds x="120" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IsSubmissionAppropriate_Art98_di"
                        bpmnElement="Gateway_IsSubmissionAppropriate_Art98"
                        isMarkerVisible="true">
        <dc:Bounds x="250" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PrepareLegislativeProposals_Art98_di"
                        bpmnElement="Task_PrepareLegislativeProposals_Art98">
        <dc:Bounds x="410" y="130" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_TargetUnionActsOnDataProtection_Art98_di"
                        bpmnElement="Task_TargetUnionActsOnDataProtection_Art98">
        <dc:Bounds x="700" y="130" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EnsureUniformAndConsistentProtection_Art98_di"
                        bpmnElement="Task_EnsureUniformAndConsistentProtection_Art98">
        <dc:Bounds x="1000" y="130" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoProposalSubmitted_Art98_di"
                        bpmnElement="EndEvent_NoProposalSubmitted_Art98">
        <dc:Bounds x="412" y="272" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ProposalSubmitted_Art98_di"
                        bpmnElement="EndEvent_ProposalSubmitted_Art98">
        <dc:Bounds x="1302" y="152" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_GatewayAppropriateness_Art98_di"
                       bpmnElement="Flow_Start_To_GatewayAppropriateness_Art98">
        <di:waypoint x="156" y="210" />
        <di:waypoint x="250" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAppropriateness_To_PrepareLegislativeProposals_Art98_di"
                       bpmnElement="Flow_GatewayAppropriateness_To_PrepareLegislativeProposals_Art98">
        <di:waypoint x="275" y="185" />
        <di:waypoint x="275" y="170" />
        <di:waypoint x="410" y="170" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="308" y="172" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAppropriateness_To_EndNoProposalSubmitted_Art98_di"
                       bpmnElement="Flow_GatewayAppropriateness_To_EndNoProposalSubmitted_Art98">
        <di:waypoint x="275" y="235" />
        <di:waypoint x="275" y="290" />
        <di:waypoint x="412" y="290" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="308" y="254" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PrepareLegislativeProposals_To_TargetUnionActs_Art98_di"
                       bpmnElement="Flow_PrepareLegislativeProposals_To_TargetUnionActs_Art98">
        <di:waypoint x="590" y="170" />
        <di:waypoint x="700" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TargetUnionActs_To_EnsureUniformProtection_Art98_di"
                       bpmnElement="Flow_TargetUnionActs_To_EnsureUniformProtection_Art98">
        <di:waypoint x="890" y="170" />
        <di:waypoint x="1000" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EnsureUniformProtection_To_EndProposalSubmitted_Art98_di"
                       bpmnElement="Flow_EnsureUniformProtection_To_EndProposalSubmitted_Art98">
        <di:waypoint x="1220" y="170" />
        <di:waypoint x="1302" y="170" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
