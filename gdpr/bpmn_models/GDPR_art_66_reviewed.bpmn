<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art66_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art66_Reviewed">
    <bpmn:participant id="Participant_SupervisoryAuthority_Art66"
                      name="Supervisory Authority"
                      processRef="Process_SupervisoryAuthority_Art66" />
    <bpmn:participant id="Participant_Board_Art66"
                      name="Board"
                      processRef="Process_Board_Art66" />
    <bpmn:participant id="Participant_OtherConcernedAuthorities_Art66"
                      name="Other Concerned Supervisory Authorities" />
    <bpmn:participant id="Participant_Commission_Art66"
                      name="Commission" />

    <bpmn:messageFlow id="MessageFlow_CommunicateMeasuresToBoard_Art66"
                      sourceRef="Task_CommunicateMeasuresAndReasons_Art66"
                      targetRef="Participant_Board_Art66" />
    <bpmn:messageFlow id="MessageFlow_CommunicateMeasuresToAuthorities_Art66"
                      sourceRef="Task_CommunicateMeasuresAndReasons_Art66"
                      targetRef="Participant_OtherConcernedAuthorities_Art66" />
    <bpmn:messageFlow id="MessageFlow_CommunicateMeasuresToCommission_Art66"
                      sourceRef="Task_CommunicateMeasuresAndReasons_Art66"
                      targetRef="Participant_Commission_Art66" />
    <bpmn:messageFlow id="MessageFlow_RequestUrgentBoardAction_Art66"
                      sourceRef="Task_RequestUrgentBoardAction_Art66"
                      targetRef="StartEvent_ReceiveUrgentRequest_Art66" />
    <bpmn:messageFlow id="MessageFlow_SendUrgentBoardOutcome_Art66"
                      sourceRef="Task_AdoptUrgentBoardOutcome_Art66"
                      targetRef="Task_ReceiveUrgentBoardOutcome_Art66" />
  </bpmn:collaboration>

  <bpmn:process id="Process_SupervisoryAuthority_Art66"
                name="Use Article 66 urgency procedure"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 66 based on the real English legal text from
      gdpr_articles/article_66.txt. This process captures the exceptional urgent-need trigger,
      immediate provisional measures limited to the authority's own territory and to a specified
      validity period not exceeding three months, the without-delay communication of measures and
      reasons, the urgent request path where final measures are urgently needed, and the separate
      request path where another competent authority has not taken an appropriate measure in an
      urgent situation.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_UrgentNeedToAct_Art66"
                     name="Urgent need to act">
      <bpmn:outgoing>Flow_StartUrgentNeed_To_GatewayUrgencyRoute_Art66</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_WhichUrgencyRouteApplies_Art66"
                           name="Which urgency route applies?">
      <bpmn:incoming>Flow_StartUrgentNeed_To_GatewayUrgencyRoute_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayUrgencyRoute_To_AdoptProvisionalMeasures_Art66</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayUrgencyRoute_To_RequestUrgentActionForOtherAuthorityFailure_Art66</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AdoptProvisionalMeasures_Art66"
               name="Adopt provisional measures">
      <bpmn:incoming>Flow_GatewayUrgencyRoute_To_AdoptProvisionalMeasures_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptProvisionalMeasures_To_CommunicateMeasuresAndReasons_Art66</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_CommunicateMeasuresAndReasons_Art66"
                   name="Communicate measures and reasons">
      <bpmn:incoming>Flow_AdoptProvisionalMeasures_To_CommunicateMeasuresAndReasons_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_CommunicateMeasuresAndReasons_To_GatewayNeedFinalMeasures_Art66</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_AreFinalMeasuresUrgentlyNeeded_Art66"
                           name="Are final measures urgently needed?">
      <bpmn:incoming>Flow_CommunicateMeasuresAndReasons_To_GatewayNeedFinalMeasures_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayNeedFinalMeasures_To_RequestUrgentBoardAction_Art66</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayNeedFinalMeasures_To_EndProvisionalMeasuresActive_Art66</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_RequestUrgentActionForOtherAuthorityFailure_Art66"
               name="Assess other authority failure">
      <bpmn:incoming>Flow_GatewayUrgencyRoute_To_RequestUrgentActionForOtherAuthorityFailure_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestUrgentActionForOtherAuthorityFailure_To_RequestUrgentBoardAction_Art66</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_RequestUrgentBoardAction_Art66"
                   name="Request urgent opinion or binding decision">
      <bpmn:incoming>Flow_GatewayNeedFinalMeasures_To_RequestUrgentBoardAction_Art66</bpmn:incoming>
      <bpmn:incoming>Flow_RequestUrgentActionForOtherAuthorityFailure_To_RequestUrgentBoardAction_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestUrgentBoardAction_To_ReceiveUrgentBoardOutcome_Art66</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="Task_ReceiveUrgentBoardOutcome_Art66"
                      name="Receive urgent Board outcome">
      <bpmn:incoming>Flow_RequestUrgentBoardAction_To_ReceiveUrgentBoardOutcome_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveUrgentBoardOutcome_To_EndUrgentOutcomeReceived_Art66</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:endEvent id="EndEvent_ProvisionalMeasuresActive_Art66"
                   name="Provisional measures active">
      <bpmn:incoming>Flow_GatewayNeedFinalMeasures_To_EndProvisionalMeasuresActive_Art66</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_UrgentOutcomeReceived_Art66"
                   name="Urgent Board outcome received">
      <bpmn:incoming>Flow_ReceiveUrgentBoardOutcome_To_EndUrgentOutcomeReceived_Art66</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartUrgentNeed_To_GatewayUrgencyRoute_Art66"
                       sourceRef="StartEvent_UrgentNeedToAct_Art66"
                       targetRef="Gateway_WhichUrgencyRouteApplies_Art66" />
    <bpmn:sequenceFlow id="Flow_GatewayUrgencyRoute_To_AdoptProvisionalMeasures_Art66"
                       name="Own provisional measures"
                       sourceRef="Gateway_WhichUrgencyRouteApplies_Art66"
                       targetRef="Task_AdoptProvisionalMeasures_Art66" />
    <bpmn:sequenceFlow id="Flow_GatewayUrgencyRoute_To_RequestUrgentActionForOtherAuthorityFailure_Art66"
                       name="Other authority failed"
                       sourceRef="Gateway_WhichUrgencyRouteApplies_Art66"
                       targetRef="Task_RequestUrgentActionForOtherAuthorityFailure_Art66" />
    <bpmn:sequenceFlow id="Flow_AdoptProvisionalMeasures_To_CommunicateMeasuresAndReasons_Art66"
                       sourceRef="Task_AdoptProvisionalMeasures_Art66"
                       targetRef="Task_CommunicateMeasuresAndReasons_Art66" />
    <bpmn:sequenceFlow id="Flow_CommunicateMeasuresAndReasons_To_GatewayNeedFinalMeasures_Art66"
                       sourceRef="Task_CommunicateMeasuresAndReasons_Art66"
                       targetRef="Gateway_AreFinalMeasuresUrgentlyNeeded_Art66" />
    <bpmn:sequenceFlow id="Flow_GatewayNeedFinalMeasures_To_RequestUrgentBoardAction_Art66"
                       name="Yes"
                       sourceRef="Gateway_AreFinalMeasuresUrgentlyNeeded_Art66"
                       targetRef="Task_RequestUrgentBoardAction_Art66" />
    <bpmn:sequenceFlow id="Flow_GatewayNeedFinalMeasures_To_EndProvisionalMeasuresActive_Art66"
                       name="No"
                       sourceRef="Gateway_AreFinalMeasuresUrgentlyNeeded_Art66"
                       targetRef="EndEvent_ProvisionalMeasuresActive_Art66" />
    <bpmn:sequenceFlow id="Flow_RequestUrgentActionForOtherAuthorityFailure_To_RequestUrgentBoardAction_Art66"
                       sourceRef="Task_RequestUrgentActionForOtherAuthorityFailure_Art66"
                       targetRef="Task_RequestUrgentBoardAction_Art66" />
    <bpmn:sequenceFlow id="Flow_RequestUrgentBoardAction_To_ReceiveUrgentBoardOutcome_Art66"
                       sourceRef="Task_RequestUrgentBoardAction_Art66"
                       targetRef="Task_ReceiveUrgentBoardOutcome_Art66" />
    <bpmn:sequenceFlow id="Flow_ReceiveUrgentBoardOutcome_To_EndUrgentOutcomeReceived_Art66"
                       sourceRef="Task_ReceiveUrgentBoardOutcome_Art66"
                       targetRef="EndEvent_UrgentOutcomeReceived_Art66" />
  </bpmn:process>

  <bpmn:process id="Process_Board_Art66"
                name="Adopt urgent opinion or binding decision"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 66 based on the real English legal text from
      gdpr_articles/article_66.txt. This process captures the Board's urgent route for an urgent
      opinion or an urgent binding decision, adopted within two weeks by simple majority of the
      members of the Board as a derogation from Articles 64(3) and 65(2).
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_ReceiveUrgentRequest_Art66"
                     name="Receive urgent request">
      <bpmn:messageEventDefinition />
      <bpmn:outgoing>Flow_StartReceiveUrgentRequest_To_AssessUrgentRequest_Art66</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_AssessUrgentRequest_Art66"
               name="Assess urgent request">
      <bpmn:incoming>Flow_StartReceiveUrgentRequest_To_AssessUrgentRequest_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessUrgentRequest_To_GatewayUrgentOutcomeType_Art66</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_WhichUrgentOutcomeWillBoardAdopt_Art66"
                           name="Which urgent outcome will the Board adopt?">
      <bpmn:incoming>Flow_AssessUrgentRequest_To_GatewayUrgentOutcomeType_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayUrgentOutcomeType_To_AdoptUrgentOpinion_Art66</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayUrgentOutcomeType_To_AdoptUrgentBindingDecision_Art66</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AdoptUrgentOpinion_Art66"
               name="Adopt urgent opinion within two weeks">
      <bpmn:incoming>Flow_GatewayUrgentOutcomeType_To_AdoptUrgentOpinion_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptUrgentOpinion_To_GatewayMergeUrgentOutcome_Art66</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AdoptUrgentBindingDecision_Art66"
               name="Adopt urgent binding decision within two weeks">
      <bpmn:incoming>Flow_GatewayUrgentOutcomeType_To_AdoptUrgentBindingDecision_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptUrgentBindingDecision_To_GatewayMergeUrgentOutcome_Art66</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_MergeUrgentOutcome_Art66">
      <bpmn:incoming>Flow_AdoptUrgentOpinion_To_GatewayMergeUrgentOutcome_Art66</bpmn:incoming>
      <bpmn:incoming>Flow_AdoptUrgentBindingDecision_To_GatewayMergeUrgentOutcome_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMergeUrgentOutcome_To_AdoptUrgentBoardOutcome_Art66</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_AdoptUrgentBoardOutcome_Art66"
                   name="Send urgent Board outcome">
      <bpmn:incoming>Flow_GatewayMergeUrgentOutcome_To_AdoptUrgentBoardOutcome_Art66</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptUrgentBoardOutcome_To_EndUrgentOutcomeSent_Art66</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_UrgentOutcomeSent_Art66"
                   name="Urgent outcome sent">
      <bpmn:incoming>Flow_AdoptUrgentBoardOutcome_To_EndUrgentOutcomeSent_Art66</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartReceiveUrgentRequest_To_AssessUrgentRequest_Art66"
                       sourceRef="StartEvent_ReceiveUrgentRequest_Art66"
                       targetRef="Task_AssessUrgentRequest_Art66" />
    <bpmn:sequenceFlow id="Flow_AssessUrgentRequest_To_GatewayUrgentOutcomeType_Art66"
                       sourceRef="Task_AssessUrgentRequest_Art66"
                       targetRef="Gateway_WhichUrgentOutcomeWillBoardAdopt_Art66" />
    <bpmn:sequenceFlow id="Flow_GatewayUrgentOutcomeType_To_AdoptUrgentOpinion_Art66"
                       name="Urgent opinion"
                       sourceRef="Gateway_WhichUrgentOutcomeWillBoardAdopt_Art66"
                       targetRef="Task_AdoptUrgentOpinion_Art66" />
    <bpmn:sequenceFlow id="Flow_GatewayUrgentOutcomeType_To_AdoptUrgentBindingDecision_Art66"
                       name="Urgent binding decision"
                       sourceRef="Gateway_WhichUrgentOutcomeWillBoardAdopt_Art66"
                       targetRef="Task_AdoptUrgentBindingDecision_Art66" />
    <bpmn:sequenceFlow id="Flow_AdoptUrgentOpinion_To_GatewayMergeUrgentOutcome_Art66"
                       sourceRef="Task_AdoptUrgentOpinion_Art66"
                       targetRef="Gateway_MergeUrgentOutcome_Art66" />
    <bpmn:sequenceFlow id="Flow_AdoptUrgentBindingDecision_To_GatewayMergeUrgentOutcome_Art66"
                       sourceRef="Task_AdoptUrgentBindingDecision_Art66"
                       targetRef="Gateway_MergeUrgentOutcome_Art66" />
    <bpmn:sequenceFlow id="Flow_GatewayMergeUrgentOutcome_To_AdoptUrgentBoardOutcome_Art66"
                       sourceRef="Gateway_MergeUrgentOutcome_Art66"
                       targetRef="Task_AdoptUrgentBoardOutcome_Art66" />
    <bpmn:sequenceFlow id="Flow_AdoptUrgentBoardOutcome_To_EndUrgentOutcomeSent_Art66"
                       sourceRef="Task_AdoptUrgentBoardOutcome_Art66"
                       targetRef="EndEvent_UrgentOutcomeSent_Art66" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art66_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art66_Reviewed"
                      bpmnElement="Collaboration_Art66_Reviewed">
      <bpmndi:BPMNShape id="Participant_SupervisoryAuthority_Art66_di"
                        bpmnElement="Participant_SupervisoryAuthority_Art66"
                        isHorizontal="true">
        <dc:Bounds x="20" y="20" width="2600" height="320" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Board_Art66_di"
                        bpmnElement="Participant_Board_Art66"
                        isHorizontal="true">
        <dc:Bounds x="20" y="360" width="2600" height="260" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_OtherConcernedAuthorities_Art66_di"
                        bpmnElement="Participant_OtherConcernedAuthorities_Art66"
                        isHorizontal="true">
        <dc:Bounds x="20" y="650" width="2600" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Commission_Art66_di"
                        bpmnElement="Participant_Commission_Art66"
                        isHorizontal="true">
        <dc:Bounds x="20" y="770" width="2600" height="100" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_UrgentNeedToAct_Art66_di"
                        bpmnElement="StartEvent_UrgentNeedToAct_Art66">
        <dc:Bounds x="120" y="162" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_WhichUrgencyRouteApplies_Art66_di"
                        bpmnElement="Gateway_WhichUrgencyRouteApplies_Art66"
                        isMarkerVisible="true">
        <dc:Bounds x="240" y="155" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdoptProvisionalMeasures_Art66_di"
                        bpmnElement="Task_AdoptProvisionalMeasures_Art66">
        <dc:Bounds x="390" y="60" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CommunicateMeasuresAndReasons_Art66_di"
                        bpmnElement="Task_CommunicateMeasuresAndReasons_Art66">
        <dc:Bounds x="650" y="60" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AreFinalMeasuresUrgentlyNeeded_Art66_di"
                        bpmnElement="Gateway_AreFinalMeasuresUrgentlyNeeded_Art66"
                        isMarkerVisible="true">
        <dc:Bounds x="950" y="75" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RequestUrgentActionForOtherAuthorityFailure_Art66_di"
                        bpmnElement="Task_RequestUrgentActionForOtherAuthorityFailure_Art66">
        <dc:Bounds x="390" y="240" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RequestUrgentBoardAction_Art66_di"
                        bpmnElement="Task_RequestUrgentBoardAction_Art66">
        <dc:Bounds x="1100" y="150" width="230" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReceiveUrgentBoardOutcome_Art66_di"
                        bpmnElement="Task_ReceiveUrgentBoardOutcome_Art66">
        <dc:Bounds x="1420" y="150" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ProvisionalMeasuresActive_Art66_di"
                        bpmnElement="EndEvent_ProvisionalMeasuresActive_Art66">
        <dc:Bounds x="1110" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_UrgentOutcomeReceived_Art66_di"
                        bpmnElement="EndEvent_UrgentOutcomeReceived_Art66">
        <dc:Bounds x="1710" y="172" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_ReceiveUrgentRequest_Art66_di"
                        bpmnElement="StartEvent_ReceiveUrgentRequest_Art66">
        <dc:Bounds x="120" y="462" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessUrgentRequest_Art66_di"
                        bpmnElement="Task_AssessUrgentRequest_Art66">
        <dc:Bounds x="240" y="440" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_WhichUrgentOutcomeWillBoardAdopt_Art66_di"
                        bpmnElement="Gateway_WhichUrgentOutcomeWillBoardAdopt_Art66"
                        isMarkerVisible="true">
        <dc:Bounds x="500" y="455" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdoptUrgentOpinion_Art66_di"
                        bpmnElement="Task_AdoptUrgentOpinion_Art66">
        <dc:Bounds x="650" y="380" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdoptUrgentBindingDecision_Art66_di"
                        bpmnElement="Task_AdoptUrgentBindingDecision_Art66">
        <dc:Bounds x="650" y="500" width="240" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MergeUrgentOutcome_Art66_di"
                        bpmnElement="Gateway_MergeUrgentOutcome_Art66"
                        isMarkerVisible="true">
        <dc:Bounds x="980" y="455" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdoptUrgentBoardOutcome_Art66_di"
                        bpmnElement="Task_AdoptUrgentBoardOutcome_Art66">
        <dc:Bounds x="1120" y="440" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_UrgentOutcomeSent_Art66_di"
                        bpmnElement="EndEvent_UrgentOutcomeSent_Art66">
        <dc:Bounds x="1390" y="462" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_StartUrgentNeed_To_GatewayUrgencyRoute_Art66_di"
                       bpmnElement="Flow_StartUrgentNeed_To_GatewayUrgencyRoute_Art66">
        <di:waypoint x="156" y="180" />
        <di:waypoint x="240" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayUrgencyRoute_To_AdoptProvisionalMeasures_Art66_di"
                       bpmnElement="Flow_GatewayUrgencyRoute_To_AdoptProvisionalMeasures_Art66">
        <di:waypoint x="265" y="155" />
        <di:waypoint x="265" y="100" />
        <di:waypoint x="390" y="100" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="274" y="101" width="112" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayUrgencyRoute_To_RequestUrgentActionForOtherAuthorityFailure_Art66_di"
                       bpmnElement="Flow_GatewayUrgencyRoute_To_RequestUrgentActionForOtherAuthorityFailure_Art66">
        <di:waypoint x="265" y="205" />
        <di:waypoint x="265" y="280" />
        <di:waypoint x="390" y="280" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="274" y="252" width="117" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AdoptProvisionalMeasures_To_CommunicateMeasuresAndReasons_Art66_di"
                       bpmnElement="Flow_AdoptProvisionalMeasures_To_CommunicateMeasuresAndReasons_Art66">
        <di:waypoint x="570" y="100" />
        <di:waypoint x="650" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_CommunicateMeasuresAndReasons_To_GatewayNeedFinalMeasures_Art66_di"
                       bpmnElement="Flow_CommunicateMeasuresAndReasons_To_GatewayNeedFinalMeasures_Art66">
        <di:waypoint x="860" y="100" />
        <di:waypoint x="950" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayNeedFinalMeasures_To_RequestUrgentBoardAction_Art66_di"
                       bpmnElement="Flow_GatewayNeedFinalMeasures_To_RequestUrgentBoardAction_Art66">
        <di:waypoint x="1000" y="100" />
        <di:waypoint x="1000" y="190" />
        <di:waypoint x="1100" y="190" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1008" y="145" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayNeedFinalMeasures_To_EndProvisionalMeasuresActive_Art66_di"
                       bpmnElement="Flow_GatewayNeedFinalMeasures_To_EndProvisionalMeasuresActive_Art66">
        <di:waypoint x="1000" y="100" />
        <di:waypoint x="1110" y="100" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1042" y="82" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RequestUrgentActionForOtherAuthorityFailure_To_RequestUrgentBoardAction_Art66_di"
                       bpmnElement="Flow_RequestUrgentActionForOtherAuthorityFailure_To_RequestUrgentBoardAction_Art66">
        <di:waypoint x="600" y="280" />
        <di:waypoint x="1215" y="280" />
        <di:waypoint x="1215" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RequestUrgentBoardAction_To_ReceiveUrgentBoardOutcome_Art66_di"
                       bpmnElement="Flow_RequestUrgentBoardAction_To_ReceiveUrgentBoardOutcome_Art66">
        <di:waypoint x="1330" y="190" />
        <di:waypoint x="1420" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReceiveUrgentBoardOutcome_To_EndUrgentOutcomeReceived_Art66_di"
                       bpmnElement="Flow_ReceiveUrgentBoardOutcome_To_EndUrgentOutcomeReceived_Art66">
        <di:waypoint x="1620" y="190" />
        <di:waypoint x="1710" y="190" />
      </bpmndi:BPMNEdge>

