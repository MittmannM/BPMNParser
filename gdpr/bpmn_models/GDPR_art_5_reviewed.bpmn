<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art5_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_Controller_Art5"
                name="Applying Article 5 principles"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 5 based on the real English legal text from
      gdpr_articles/article_5.txt. The model covers the six principles in Article 5(1),
      including the Article 89(1) compatibility and longer-storage qualifications in
      points (b) and (e), and the separate accountability duty in Article 5(2).
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_PlanProcessing_Art5"
                     name="Need processing design">
      <bpmn:outgoing>Flow_Start_To_TaskPlanProcessing_Art5</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_PlanProcessing_Art5"
               name="Define processing and purposes">
      <bpmn:incoming>Flow_Start_To_TaskPlanProcessing_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPlanProcessing_To_GatewaySplitPrinciples_Art5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_SplitPrinciples_Art5">
      <bpmn:incoming>Flow_TaskPlanProcessing_To_GatewaySplitPrinciples_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitPrinciples_To_TaskLawfulnessFairnessTransparency_Art5</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitPrinciples_To_TaskPurposeLimitation_Art5</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitPrinciples_To_TaskDataMinimisation_Art5</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitPrinciples_To_TaskAccuracy_Art5</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitPrinciples_To_TaskStorageLimitation_Art5</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitPrinciples_To_TaskSecurity_Art5</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_LawfulnessFairnessTransparency_Art5"
               name="Ensure lawful, fair, and transparent processing">
      <bpmn:incoming>Flow_GatewaySplitPrinciples_To_TaskLawfulnessFairnessTransparency_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskLawfulnessFairnessTransparency_To_GatewayJoinPrinciples_Art5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PurposeLimitation_Art5"
               name="Define purposes and check further-processing compatibility">
      <bpmn:incoming>Flow_GatewaySplitPrinciples_To_TaskPurposeLimitation_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPurposeLimitation_To_GatewayJoinPrinciples_Art5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DataMinimisation_Art5"
               name="Limit data to what is necessary">
      <bpmn:incoming>Flow_GatewaySplitPrinciples_To_TaskDataMinimisation_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDataMinimisation_To_GatewayJoinPrinciples_Art5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Accuracy_Art5"
               name="Keep data accurate and up to date">
      <bpmn:incoming>Flow_GatewaySplitPrinciples_To_TaskAccuracy_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAccuracy_To_GatewayInaccurateData_Art5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_InaccurateData_Art5"
                           name="Is inaccurate personal data identified for the processing purpose?">
      <bpmn:incoming>Flow_TaskAccuracy_To_GatewayInaccurateData_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayInaccurateData_To_TaskRectifyOrErase_Art5</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayInaccurateData_To_GatewayAccuracyJoin_Art5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_RectifyOrErase_Art5"
               name="Rectify or erase inaccurate data">
      <bpmn:incoming>Flow_GatewayInaccurateData_To_TaskRectifyOrErase_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRectifyOrErase_To_GatewayAccuracyJoin_Art5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_AccuracyJoin_Art5">
      <bpmn:incoming>Flow_GatewayInaccurateData_To_GatewayAccuracyJoin_Art5</bpmn:incoming>
      <bpmn:incoming>Flow_TaskRectifyOrErase_To_GatewayAccuracyJoin_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAccuracyJoin_To_GatewayJoinPrinciples_Art5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_StorageLimitation_Art5"
               name="Limit retention and apply Article 89 safeguards for longer storage">
      <bpmn:incoming>Flow_GatewaySplitPrinciples_To_TaskStorageLimitation_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskStorageLimitation_To_GatewayJoinPrinciples_Art5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Security_Art5"
               name="Protect data with appropriate security measures">
      <bpmn:incoming>Flow_GatewaySplitPrinciples_To_TaskSecurity_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSecurity_To_GatewayJoinPrinciples_Art5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinPrinciples_Art5">
      <bpmn:incoming>Flow_TaskLawfulnessFairnessTransparency_To_GatewayJoinPrinciples_Art5</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPurposeLimitation_To_GatewayJoinPrinciples_Art5</bpmn:incoming>
      <bpmn:incoming>Flow_TaskDataMinimisation_To_GatewayJoinPrinciples_Art5</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayAccuracyJoin_To_GatewayJoinPrinciples_Art5</bpmn:incoming>
      <bpmn:incoming>Flow_TaskStorageLimitation_To_GatewayJoinPrinciples_Art5</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSecurity_To_GatewayJoinPrinciples_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinPrinciples_To_DemonstrateCompliance_Art5</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_DemonstrateCompliance_Art5"
               name="Demonstrate compliance">
      <bpmn:incoming>Flow_GatewayJoinPrinciples_To_DemonstrateCompliance_Art5</bpmn:incoming>
      <bpmn:outgoing>Flow_DemonstrateCompliance_To_EndPrinciplesConfigured_Art5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_PrinciplesConfigured_Art5"
                   name="Article 5 principles applied">
      <bpmn:incoming>Flow_DemonstrateCompliance_To_EndPrinciplesConfigured_Art5</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_TaskPlanProcessing_Art5" sourceRef="StartEvent_PlanProcessing_Art5" targetRef="Task_PlanProcessing_Art5" />
    <bpmn:sequenceFlow id="Flow_TaskPlanProcessing_To_GatewaySplitPrinciples_Art5" sourceRef="Task_PlanProcessing_Art5" targetRef="Gateway_SplitPrinciples_Art5" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitPrinciples_To_TaskLawfulnessFairnessTransparency_Art5" sourceRef="Gateway_SplitPrinciples_Art5" targetRef="Task_LawfulnessFairnessTransparency_Art5" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitPrinciples_To_TaskPurposeLimitation_Art5" sourceRef="Gateway_SplitPrinciples_Art5" targetRef="Task_PurposeLimitation_Art5" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitPrinciples_To_TaskDataMinimisation_Art5" sourceRef="Gateway_SplitPrinciples_Art5" targetRef="Task_DataMinimisation_Art5" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitPrinciples_To_TaskAccuracy_Art5" sourceRef="Gateway_SplitPrinciples_Art5" targetRef="Task_Accuracy_Art5" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitPrinciples_To_TaskStorageLimitation_Art5" sourceRef="Gateway_SplitPrinciples_Art5" targetRef="Task_StorageLimitation_Art5" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitPrinciples_To_TaskSecurity_Art5" sourceRef="Gateway_SplitPrinciples_Art5" targetRef="Task_Security_Art5" />
    <bpmn:sequenceFlow id="Flow_TaskLawfulnessFairnessTransparency_To_GatewayJoinPrinciples_Art5" sourceRef="Task_LawfulnessFairnessTransparency_Art5" targetRef="Gateway_JoinPrinciples_Art5" />
    <bpmn:sequenceFlow id="Flow_TaskPurposeLimitation_To_GatewayJoinPrinciples_Art5" sourceRef="Task_PurposeLimitation_Art5" targetRef="Gateway_JoinPrinciples_Art5" />
    <bpmn:sequenceFlow id="Flow_TaskDataMinimisation_To_GatewayJoinPrinciples_Art5" sourceRef="Task_DataMinimisation_Art5" targetRef="Gateway_JoinPrinciples_Art5" />
    <bpmn:sequenceFlow id="Flow_TaskAccuracy_To_GatewayInaccurateData_Art5" sourceRef="Task_Accuracy_Art5" targetRef="Gateway_InaccurateData_Art5" />
    <bpmn:sequenceFlow id="Flow_GatewayInaccurateData_To_TaskRectifyOrErase_Art5" name="Yes" sourceRef="Gateway_InaccurateData_Art5" targetRef="Task_RectifyOrErase_Art5" />
    <bpmn:sequenceFlow id="Flow_GatewayInaccurateData_To_GatewayAccuracyJoin_Art5" name="No" sourceRef="Gateway_InaccurateData_Art5" targetRef="Gateway_AccuracyJoin_Art5" />
    <bpmn:sequenceFlow id="Flow_TaskRectifyOrErase_To_GatewayAccuracyJoin_Art5" sourceRef="Task_RectifyOrErase_Art5" targetRef="Gateway_AccuracyJoin_Art5" />
    <bpmn:sequenceFlow id="Flow_GatewayAccuracyJoin_To_GatewayJoinPrinciples_Art5" sourceRef="Gateway_AccuracyJoin_Art5" targetRef="Gateway_JoinPrinciples_Art5" />
    <bpmn:sequenceFlow id="Flow_TaskStorageLimitation_To_GatewayJoinPrinciples_Art5" sourceRef="Task_StorageLimitation_Art5" targetRef="Gateway_JoinPrinciples_Art5" />
    <bpmn:sequenceFlow id="Flow_TaskSecurity_To_GatewayJoinPrinciples_Art5" sourceRef="Task_Security_Art5" targetRef="Gateway_JoinPrinciples_Art5" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinPrinciples_To_DemonstrateCompliance_Art5" sourceRef="Gateway_JoinPrinciples_Art5" targetRef="Task_DemonstrateCompliance_Art5" />
    <bpmn:sequenceFlow id="Flow_DemonstrateCompliance_To_EndPrinciplesConfigured_Art5" sourceRef="Task_DemonstrateCompliance_Art5" targetRef="EndEvent_PrinciplesConfigured_Art5" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art5_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art5_Reviewed" bpmnElement="Process_Controller_Art5">
      <bpmndi:BPMNShape id="StartEvent_PlanProcessing_Art5_di" bpmnElement="StartEvent_PlanProcessing_Art5"><dc:Bounds x="120" y="382" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PlanProcessing_Art5_di" bpmnElement="Task_PlanProcessing_Art5"><dc:Bounds x="230" y="360" width="320" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SplitPrinciples_Art5_di" bpmnElement="Gateway_SplitPrinciples_Art5" isMarkerVisible="true"><dc:Bounds x="660" y="375" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LawfulnessFairnessTransparency_Art5_di" bpmnElement="Task_LawfulnessFairnessTransparency_Art5"><dc:Bounds x="890" y="40" width="470" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PurposeLimitation_Art5_di" bpmnElement="Task_PurposeLimitation_Art5"><dc:Bounds x="890" y="160" width="470" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DataMinimisation_Art5_di" bpmnElement="Task_DataMinimisation_Art5"><dc:Bounds x="890" y="280" width="470" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Accuracy_Art5_di" bpmnElement="Task_Accuracy_Art5"><dc:Bounds x="890" y="400" width="410" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_InaccurateData_Art5_di" bpmnElement="Gateway_InaccurateData_Art5" isMarkerVisible="true"><dc:Bounds x="1440" y="415" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RectifyOrErase_Art5_di" bpmnElement="Task_RectifyOrErase_Art5"><dc:Bounds x="1630" y="360" width="380" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AccuracyJoin_Art5_di" bpmnElement="Gateway_AccuracyJoin_Art5" isMarkerVisible="true"><dc:Bounds x="2140" y="415" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_StorageLimitation_Art5_di" bpmnElement="Task_StorageLimitation_Art5"><dc:Bounds x="890" y="540" width="430" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Security_Art5_di" bpmnElement="Task_Security_Art5"><dc:Bounds x="890" y="660" width="500" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_JoinPrinciples_Art5_di" bpmnElement="Gateway_JoinPrinciples_Art5" isMarkerVisible="true"><dc:Bounds x="2470" y="375" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DemonstrateCompliance_Art5_di" bpmnElement="Task_DemonstrateCompliance_Art5"><dc:Bounds x="2650" y="360" width="230" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_PrinciplesConfigured_Art5_di" bpmnElement="EndEvent_PrinciplesConfigured_Art5"><dc:Bounds x="3010" y="382" width="36" height="36" /></bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_TaskPlanProcessing_Art5_di" bpmnElement="Flow_Start_To_TaskPlanProcessing_Art5"><di:waypoint x="156" y="400" /><di:waypoint x="230" y="400" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskPlanProcessing_To_GatewaySplitPrinciples_Art5_di" bpmnElement="Flow_TaskPlanProcessing_To_GatewaySplitPrinciples_Art5"><di:waypoint x="550" y="400" /><di:waypoint x="660" y="400" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitPrinciples_To_TaskLawfulnessFairnessTransparency_Art5_di" bpmnElement="Flow_GatewaySplitPrinciples_To_TaskLawfulnessFairnessTransparency_Art5"><di:waypoint x="685" y="375" /><di:waypoint x="685" y="80" /><di:waypoint x="890" y="80" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitPrinciples_To_TaskPurposeLimitation_Art5_di" bpmnElement="Flow_GatewaySplitPrinciples_To_TaskPurposeLimitation_Art5"><di:waypoint x="685" y="375" /><di:waypoint x="685" y="200" /><di:waypoint x="890" y="200" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitPrinciples_To_TaskDataMinimisation_Art5_di" bpmnElement="Flow_GatewaySplitPrinciples_To_TaskDataMinimisation_Art5"><di:waypoint x="685" y="375" /><di:waypoint x="685" y="320" /><di:waypoint x="890" y="320" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitPrinciples_To_TaskAccuracy_Art5_di" bpmnElement="Flow_GatewaySplitPrinciples_To_TaskAccuracy_Art5"><di:waypoint x="710" y="400" /><di:waypoint x="890" y="440" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitPrinciples_To_TaskStorageLimitation_Art5_di" bpmnElement="Flow_GatewaySplitPrinciples_To_TaskStorageLimitation_Art5"><di:waypoint x="685" y="425" /><di:waypoint x="685" y="580" /><di:waypoint x="890" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitPrinciples_To_TaskSecurity_Art5_di" bpmnElement="Flow_GatewaySplitPrinciples_To_TaskSecurity_Art5"><di:waypoint x="685" y="425" /><di:waypoint x="685" y="700" /><di:waypoint x="890" y="700" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskLawfulnessFairnessTransparency_To_GatewayJoinPrinciples_Art5_di" bpmnElement="Flow_TaskLawfulnessFairnessTransparency_To_GatewayJoinPrinciples_Art5"><di:waypoint x="1360" y="80" /><di:waypoint x="2495" y="80" /><di:waypoint x="2495" y="375" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskPurposeLimitation_To_GatewayJoinPrinciples_Art5_di" bpmnElement="Flow_TaskPurposeLimitation_To_GatewayJoinPrinciples_Art5"><di:waypoint x="1360" y="200" /><di:waypoint x="2495" y="200" /><di:waypoint x="2495" y="375" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskDataMinimisation_To_GatewayJoinPrinciples_Art5_di" bpmnElement="Flow_TaskDataMinimisation_To_GatewayJoinPrinciples_Art5"><di:waypoint x="1360" y="320" /><di:waypoint x="2495" y="320" /><di:waypoint x="2495" y="375" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskAccuracy_To_GatewayInaccurateData_Art5_di" bpmnElement="Flow_TaskAccuracy_To_GatewayInaccurateData_Art5"><di:waypoint x="1300" y="440" /><di:waypoint x="1440" y="440" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayInaccurateData_To_TaskRectifyOrErase_Art5_di" bpmnElement="Flow_GatewayInaccurateData_To_TaskRectifyOrErase_Art5"><di:waypoint x="1490" y="440" /><di:waypoint x="1630" y="400" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayInaccurateData_To_GatewayAccuracyJoin_Art5_di" bpmnElement="Flow_GatewayInaccurateData_To_GatewayAccuracyJoin_Art5"><di:waypoint x="1490" y="440" /><di:waypoint x="2140" y="440" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskRectifyOrErase_To_GatewayAccuracyJoin_Art5_di" bpmnElement="Flow_TaskRectifyOrErase_To_GatewayAccuracyJoin_Art5"><di:waypoint x="2010" y="400" /><di:waypoint x="2165" y="400" /><di:waypoint x="2165" y="415" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAccuracyJoin_To_GatewayJoinPrinciples_Art5_di" bpmnElement="Flow_GatewayAccuracyJoin_To_GatewayJoinPrinciples_Art5"><di:waypoint x="2190" y="440" /><di:waypoint x="2470" y="400" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskStorageLimitation_To_GatewayJoinPrinciples_Art5_di" bpmnElement="Flow_TaskStorageLimitation_To_GatewayJoinPrinciples_Art5"><di:waypoint x="1320" y="580" /><di:waypoint x="2495" y="580" /><di:waypoint x="2495" y="425" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskSecurity_To_GatewayJoinPrinciples_Art5_di" bpmnElement="Flow_TaskSecurity_To_GatewayJoinPrinciples_Art5"><di:waypoint x="1390" y="700" /><di:waypoint x="2495" y="700" /><di:waypoint x="2495" y="425" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayJoinPrinciples_To_DemonstrateCompliance_Art5_di" bpmnElement="Flow_GatewayJoinPrinciples_To_DemonstrateCompliance_Art5"><di:waypoint x="2520" y="400" /><di:waypoint x="2650" y="400" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_DemonstrateCompliance_To_EndPrinciplesConfigured_Art5_di" bpmnElement="Flow_DemonstrateCompliance_To_EndPrinciplesConfigured_Art5"><di:waypoint x="2880" y="400" /><di:waypoint x="3010" y="400" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
