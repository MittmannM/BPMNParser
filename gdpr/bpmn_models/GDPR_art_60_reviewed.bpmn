<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art60_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art60_Reviewed">
    <bpmn:participant id="Participant_LeadSupervisoryAuthority_Art60"
                      name="Lead Supervisory Authority"
                      processRef="Process_LeadSupervisoryAuthority_Art60" />
    <bpmn:participant id="Participant_ConcernedOrComplaintAuthority_Art60"
                      name="Concerned or Complaint Supervisory Authority"
                      processRef="Process_ConcernedOrComplaintAuthority_Art60" />
    <bpmn:participant id="Participant_ControllerOrProcessor_Art60"
                      name="Controller or Processor" />
    <bpmn:participant id="Participant_Complainant_Art60"
                      name="Complainant" />
    <bpmn:participant id="Participant_Board_Art60"
                      name="Board" />

    <bpmn:messageFlow id="MessageFlow_RequestMutualAssistance_Art60"
                      sourceRef="Task_RequestMutualAssistanceOrJointOperations_Art60"
                      targetRef="Participant_ConcernedOrComplaintAuthority_Art60" />
    <bpmn:messageFlow id="MessageFlow_SendRelevantInformation_Art60"
                      sourceRef="Task_SendRelevantInformation_Art60"
                      targetRef="Participant_ConcernedOrComplaintAuthority_Art60" />
    <bpmn:messageFlow id="MessageFlow_SendDraftDecision_Art60"
                      sourceRef="Task_SendDraftDecision_Art60"
                      targetRef="StartEvent_ReceiveDraftDecision_Art60" />
    <bpmn:messageFlow id="MessageFlow_SendObjection_Art60"
                      sourceRef="Task_SendRelevantReasonedObjection_Art60"
                      targetRef="IntermediateCatchEvent_ReceiveObjection_Art60" />
    <bpmn:messageFlow id="MessageFlow_SendRevisedDraftDecision_Art60"
                      sourceRef="Task_SendRevisedDraftDecision_Art60"
                      targetRef="StartEvent_ReceiveRevisedDraftDecision_Art60" />
    <bpmn:messageFlow id="MessageFlow_SendRevisedObjection_Art60"
                      sourceRef="Task_SendRevisedDraftObjection_Art60"
                      targetRef="IntermediateCatchEvent_ReceiveRevisedObjection_Art60" />
    <bpmn:messageFlow id="MessageFlow_SubmitConsistencyMechanism_Art60"
                      sourceRef="Task_SubmitMatterToConsistencyMechanism_Art60"
                      targetRef="Participant_Board_Art60" />
    <bpmn:messageFlow id="MessageFlow_InformDecision_Art60"
                      sourceRef="Task_InformConcernedAuthoritiesAndBoard_Art60"
                      targetRef="Participant_ConcernedOrComplaintAuthority_Art60" />
    <bpmn:messageFlow id="MessageFlow_InformBoardDecision_Art60"
                      sourceRef="Task_InformConcernedAuthoritiesAndBoard_Art60"
                      targetRef="Participant_Board_Art60" />
    <bpmn:messageFlow id="MessageFlow_SendFinalLeadDecision_Art60"
                      sourceRef="Task_InformConcernedAuthoritiesAndBoard_Art60"
                      targetRef="StartEvent_ReceiveFinalLeadDecision_Art60" />
    <bpmn:messageFlow id="MessageFlow_SendDismissalOutcome_Art60"
                      sourceRef="Task_SendDismissalOutcome_Art60"
                      targetRef="StartEvent_ReceiveDismissalOutcome_Art60" />
    <bpmn:messageFlow id="MessageFlow_SendSplitOutcome_Art60"
                      sourceRef="Task_SendSplitDismissalOutcome_Art60"
                      targetRef="StartEvent_ReceiveSplitDismissalOutcome_Art60" />
    <bpmn:messageFlow id="MessageFlow_NotifyControllerDecision_Art60"
                      sourceRef="Task_NotifyControllerOfDecision_Art60"
                      targetRef="Participant_ControllerOrProcessor_Art60" />
    <bpmn:messageFlow id="MessageFlow_NotifyControllerActionPart_Art60"
                      sourceRef="Task_NotifyControllerOfActionPartDecision_Art60"
                      targetRef="Participant_ControllerOrProcessor_Art60" />
    <bpmn:messageFlow id="MessageFlow_InformComplainantActionPart_Art60"
                      sourceRef="Task_InformComplainantOfActionPart_Art60"
                      targetRef="Participant_Complainant_Art60" />
    <bpmn:messageFlow id="MessageFlow_ComplianceNotification_Art60"
                      sourceRef="Participant_ControllerOrProcessor_Art60"
                      targetRef="Task_ReceiveComplianceNotification_Art60" />
    <bpmn:messageFlow id="MessageFlow_ComplianceNotificationActionPart_Art60"
                      sourceRef="Participant_ControllerOrProcessor_Art60"
                      targetRef="Task_ReceiveActionPartComplianceNotification_Art60" />
    <bpmn:messageFlow id="MessageFlow_InformComplianceMeasures_Art60"
                      sourceRef="Task_InformConcernedAuthoritiesOfComplianceMeasures_Art60"
                      targetRef="Participant_ConcernedOrComplaintAuthority_Art60" />
    <bpmn:messageFlow id="MessageFlow_InformActionPartComplianceMeasures_Art60"
                      sourceRef="Task_InformConcernedAuthoritiesOfActionPartCompliance_Art60"
                      targetRef="Participant_ConcernedOrComplaintAuthority_Art60" />
    <bpmn:messageFlow id="MessageFlow_InformComplainantDecision_Art60"
                      sourceRef="Task_InformComplainantOfDecision_Art60"
                      targetRef="Participant_Complainant_Art60" />
    <bpmn:messageFlow id="MessageFlow_NotifyComplainantDismissal_Art60"
                      sourceRef="Task_NotifyComplainantOfDismissal_Art60"
                      targetRef="Participant_Complainant_Art60" />
    <bpmn:messageFlow id="MessageFlow_InformControllerDismissal_Art60"
                      sourceRef="Task_InformControllerOfDismissal_Art60"
                      targetRef="Participant_ControllerOrProcessor_Art60" />
    <bpmn:messageFlow id="MessageFlow_NotifyComplainantSplitDismissal_Art60"
                      sourceRef="Task_NotifyComplainantOfSplitDismissal_Art60"
                      targetRef="Participant_Complainant_Art60" />
    <bpmn:messageFlow id="MessageFlow_InformControllerSplitDismissal_Art60"
                      sourceRef="Task_InformControllerOfSplitDismissal_Art60"
                      targetRef="Participant_ControllerOrProcessor_Art60" />
    <bpmn:messageFlow id="MessageFlow_TriggerUrgencyProcedure_Art60"
                      sourceRef="Task_TriggerArticle66UrgencyProcedure_Art60"
                      targetRef="Participant_Board_Art60" />
  </bpmn:collaboration>

  <bpmn:process id="Process_LeadSupervisoryAuthority_Art60"
                name="Run Article 60 lead-authority cooperation procedure"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 60 based on the real English legal text from
      gdpr_articles/article_60.txt. The model captures the lead supervisory authority's
      cooperation and consensus effort with the concerned supervisory authorities, the exchange
      of relevant information, the optional request for mutual assistance or joint operations,
      draft and revised-draft decision circulation, four-week and two-week objection windows,
      escalation to the Article 63 consistency mechanism where required, decision adoption and
      notification logic under paragraphs 7 to 9, compliance follow-up under paragraph 10, and
      information exchange by electronic means in standardized form as background context.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_HandleCrossBorderMatter_Art60"
                     name="Handle cross-border matter">
      <bpmn:outgoing>Flow_StartLead_To_ExchangeRelevantInformation_Art60</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_ExchangeRelevantInformation_Art60"
               name="Exchange relevant information">
      <bpmn:incoming>Flow_StartLead_To_ExchangeRelevantInformation_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_ExchangeRelevantInformation_To_GatewayNeedAssistance_Art60</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_NeedAssistance_Art60"
                           name="Are mutual assistance or joint operations needed?">
      <bpmn:incoming>Flow_ExchangeRelevantInformation_To_GatewayNeedAssistance_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayNeedAssistance_To_RequestAssistance_Art60</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayNeedAssistance_To_SendRelevantInformation_Art60</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_RequestMutualAssistanceOrJointOperations_Art60"
                   name="Request mutual assistance or joint operations">
      <bpmn:incoming>Flow_GatewayNeedAssistance_To_RequestAssistance_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestAssistance_To_SendRelevantInformation_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_SendRelevantInformation_Art60"
                   name="Send relevant information">
      <bpmn:incoming>Flow_GatewayNeedAssistance_To_SendRelevantInformation_Art60</bpmn:incoming>
      <bpmn:incoming>Flow_RequestAssistance_To_SendRelevantInformation_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRelevantInformation_To_SendDraftDecision_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_SendDraftDecision_Art60"
                   name="Send draft decision for opinion">
      <bpmn:incoming>Flow_SendRelevantInformation_To_SendDraftDecision_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_SendDraftDecision_To_GatewayObjectionWindow_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="Gateway_ObjectionWindow_Art60"
                            name="What is received within four weeks?">
      <bpmn:incoming>Flow_SendDraftDecision_To_GatewayObjectionWindow_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayObjectionWindow_To_ReceiveObjection_Art60</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayObjectionWindow_To_FourWeeksElapsed_Art60</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="IntermediateCatchEvent_ReceiveObjection_Art60"
                                 name="Receive relevant and reasoned objection">
      <bpmn:incoming>Flow_GatewayObjectionWindow_To_ReceiveObjection_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveObjection_To_GatewayFollowObjection_Art60</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="IntermediateCatchEvent_FourWeeksElapsed_Art60"
                                 name="Four weeks elapsed without objection">
      <bpmn:incoming>Flow_GatewayObjectionWindow_To_FourWeeksElapsed_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_FourWeeksElapsed_To_GatewayMatterResolved_Art60</bpmn:outgoing>
      <bpmn:timerEventDefinition />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="Gateway_FollowObjection_Art60"
                           name="Will the lead authority follow the objection?">
      <bpmn:incoming>Flow_ReceiveObjection_To_GatewayFollowObjection_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayFollowObjection_To_SendRevisedDraftDecision_Art60</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFollowObjection_To_SubmitConsistencyMechanism_Art60</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_SendRevisedDraftDecision_Art60"
                   name="Send revised draft decision">
      <bpmn:incoming>Flow_GatewayFollowObjection_To_SendRevisedDraftDecision_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRevisedDraftDecision_To_GatewayRevisedObjectionWindow_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:eventBasedGateway id="Gateway_RevisedObjectionWindow_Art60"
                            name="What is received within two weeks?">
      <bpmn:incoming>Flow_SendRevisedDraftDecision_To_GatewayRevisedObjectionWindow_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRevisedObjectionWindow_To_ReceiveRevisedObjection_Art60</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRevisedObjectionWindow_To_TwoWeeksElapsed_Art60</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="IntermediateCatchEvent_ReceiveRevisedObjection_Art60"
                                 name="Receive revised-draft objection">
      <bpmn:incoming>Flow_GatewayRevisedObjectionWindow_To_ReceiveRevisedObjection_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveRevisedObjection_To_SubmitConsistencyMechanism_Art60</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="IntermediateCatchEvent_TwoWeeksElapsed_Art60"
                                 name="Two weeks elapsed without objection">
      <bpmn:incoming>Flow_GatewayRevisedObjectionWindow_To_TwoWeeksElapsed_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_TwoWeeksElapsed_To_GatewayMatterResolved_Art60</bpmn:outgoing>
      <bpmn:timerEventDefinition />
    </bpmn:intermediateCatchEvent>

    <bpmn:sendTask id="Task_SubmitMatterToConsistencyMechanism_Art60"
                   name="Submit matter to Article 63 consistency mechanism">
      <bpmn:incoming>Flow_GatewayFollowObjection_To_SubmitConsistencyMechanism_Art60</bpmn:incoming>
      <bpmn:incoming>Flow_ReceiveRevisedObjection_To_SubmitConsistencyMechanism_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_SubmitConsistencyMechanism_To_EndConsistencyTriggered_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_MatterResolved_Art60"
                           name="How is the matter resolved?">
      <bpmn:incoming>Flow_FourWeeksElapsed_To_GatewayMatterResolved_Art60</bpmn:incoming>
      <bpmn:incoming>Flow_TwoWeeksElapsed_To_GatewayMatterResolved_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMatterResolved_To_SendDismissalOutcome_Art60</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayMatterResolved_To_AdoptDecision_Art60</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayMatterResolved_To_AdoptActionPartDecision_Art60</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_SendDismissalOutcome_Art60"
                   name="Send dismissal or rejection outcome">
      <bpmn:incoming>Flow_GatewayMatterResolved_To_SendDismissalOutcome_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_SendDismissalOutcome_To_EndDismissalOutcomeSent_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_AdoptDecision_Art60"
               name="Adopt decision">
      <bpmn:incoming>Flow_GatewayMatterResolved_To_AdoptDecision_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptDecision_To_NotifyController_Art60</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_NotifyControllerOfDecision_Art60"
                   name="Notify controller or processor of decision">
      <bpmn:incoming>Flow_AdoptDecision_To_NotifyController_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyController_To_InformAuthoritiesBoard_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_InformConcernedAuthoritiesAndBoard_Art60"
                   name="Inform concerned authorities and Board of decision">
      <bpmn:incoming>Flow_NotifyController_To_InformAuthoritiesBoard_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_InformAuthoritiesBoard_To_ReceiveComplianceNotification_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="Task_ReceiveComplianceNotification_Art60"
                      name="Receive compliance notification">
      <bpmn:incoming>Flow_InformAuthoritiesBoard_To_ReceiveComplianceNotification_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveComplianceNotification_To_InformComplianceMeasures_Art60</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:sendTask id="Task_InformConcernedAuthoritiesOfComplianceMeasures_Art60"
                   name="Inform concerned authorities of compliance measures">
      <bpmn:incoming>Flow_ReceiveComplianceNotification_To_InformComplianceMeasures_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_InformComplianceMeasures_To_EndDecisionImplemented_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_AdoptActionPartDecision_Art60"
               name="Adopt action-part decision">
      <bpmn:incoming>Flow_GatewayMatterResolved_To_AdoptActionPartDecision_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptActionPartDecision_To_NotifyControllerActionPart_Art60</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_NotifyControllerOfActionPartDecision_Art60"
                   name="Notify controller or processor of action part">
      <bpmn:incoming>Flow_AdoptActionPartDecision_To_NotifyControllerActionPart_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyControllerActionPart_To_InformComplainantActionPart_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_InformComplainantOfActionPart_Art60"
                   name="Inform complainant of action part">
      <bpmn:incoming>Flow_NotifyControllerActionPart_To_InformComplainantActionPart_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_InformComplainantActionPart_To_SendSplitOutcome_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_SendSplitDismissalOutcome_Art60"
                   name="Send split dismissal or rejection outcome">
      <bpmn:incoming>Flow_InformComplainantActionPart_To_SendSplitOutcome_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_SendSplitOutcome_To_ReceiveActionPartComplianceNotification_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="Task_ReceiveActionPartComplianceNotification_Art60"
                      name="Receive action-part compliance notification">
      <bpmn:incoming>Flow_SendSplitOutcome_To_ReceiveActionPartComplianceNotification_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveActionPartComplianceNotification_To_InformActionPartCompliance_Art60</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:sendTask id="Task_InformConcernedAuthoritiesOfActionPartCompliance_Art60"
                   name="Inform concerned authorities of action-part compliance">
      <bpmn:incoming>Flow_ReceiveActionPartComplianceNotification_To_InformActionPartCompliance_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_InformActionPartCompliance_To_EndSplitDecisionImplemented_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_ConsistencyMechanismTriggered_Art60"
                   name="Consistency mechanism triggered">
      <bpmn:incoming>Flow_SubmitConsistencyMechanism_To_EndConsistencyTriggered_Art60</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_DismissalOutcomeSent_Art60"
                   name="Dismissal outcome sent">
      <bpmn:incoming>Flow_SendDismissalOutcome_To_EndDismissalOutcomeSent_Art60</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_DecisionImplemented_Art60"
                   name="Decision implemented">
      <bpmn:incoming>Flow_InformComplianceMeasures_To_EndDecisionImplemented_Art60</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_SplitDecisionImplemented_Art60"
                   name="Split decision implemented">
      <bpmn:incoming>Flow_InformActionPartCompliance_To_EndSplitDecisionImplemented_Art60</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartLead_To_ExchangeRelevantInformation_Art60"
                       sourceRef="StartEvent_HandleCrossBorderMatter_Art60"
                       targetRef="Task_ExchangeRelevantInformation_Art60" />
    <bpmn:sequenceFlow id="Flow_ExchangeRelevantInformation_To_GatewayNeedAssistance_Art60"
                       sourceRef="Task_ExchangeRelevantInformation_Art60"
                       targetRef="Gateway_NeedAssistance_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayNeedAssistance_To_RequestAssistance_Art60"
                       name="Yes"
                       sourceRef="Gateway_NeedAssistance_Art60"
                       targetRef="Task_RequestMutualAssistanceOrJointOperations_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayNeedAssistance_To_SendRelevantInformation_Art60"
                       name="No"
                       sourceRef="Gateway_NeedAssistance_Art60"
                       targetRef="Task_SendRelevantInformation_Art60" />
    <bpmn:sequenceFlow id="Flow_RequestAssistance_To_SendRelevantInformation_Art60"
                       sourceRef="Task_RequestMutualAssistanceOrJointOperations_Art60"
                       targetRef="Task_SendRelevantInformation_Art60" />
    <bpmn:sequenceFlow id="Flow_SendRelevantInformation_To_SendDraftDecision_Art60"
                       sourceRef="Task_SendRelevantInformation_Art60"
                       targetRef="Task_SendDraftDecision_Art60" />
    <bpmn:sequenceFlow id="Flow_SendDraftDecision_To_GatewayObjectionWindow_Art60"
                       sourceRef="Task_SendDraftDecision_Art60"
                       targetRef="Gateway_ObjectionWindow_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayObjectionWindow_To_ReceiveObjection_Art60"
                       sourceRef="Gateway_ObjectionWindow_Art60"
                       targetRef="IntermediateCatchEvent_ReceiveObjection_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayObjectionWindow_To_FourWeeksElapsed_Art60"
                       sourceRef="Gateway_ObjectionWindow_Art60"
                       targetRef="IntermediateCatchEvent_FourWeeksElapsed_Art60" />
    <bpmn:sequenceFlow id="Flow_ReceiveObjection_To_GatewayFollowObjection_Art60"
                       sourceRef="IntermediateCatchEvent_ReceiveObjection_Art60"
                       targetRef="Gateway_FollowObjection_Art60" />
    <bpmn:sequenceFlow id="Flow_FourWeeksElapsed_To_GatewayMatterResolved_Art60"
                       sourceRef="IntermediateCatchEvent_FourWeeksElapsed_Art60"
                       targetRef="Gateway_MatterResolved_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayFollowObjection_To_SendRevisedDraftDecision_Art60"
                       name="Yes"
                       sourceRef="Gateway_FollowObjection_Art60"
                       targetRef="Task_SendRevisedDraftDecision_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayFollowObjection_To_SubmitConsistencyMechanism_Art60"
                       name="No"
                       sourceRef="Gateway_FollowObjection_Art60"
                       targetRef="Task_SubmitMatterToConsistencyMechanism_Art60" />
    <bpmn:sequenceFlow id="Flow_SendRevisedDraftDecision_To_GatewayRevisedObjectionWindow_Art60"
                       sourceRef="Task_SendRevisedDraftDecision_Art60"
                       targetRef="Gateway_RevisedObjectionWindow_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayRevisedObjectionWindow_To_ReceiveRevisedObjection_Art60"
                       sourceRef="Gateway_RevisedObjectionWindow_Art60"
                       targetRef="IntermediateCatchEvent_ReceiveRevisedObjection_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayRevisedObjectionWindow_To_TwoWeeksElapsed_Art60"
                       sourceRef="Gateway_RevisedObjectionWindow_Art60"
                       targetRef="IntermediateCatchEvent_TwoWeeksElapsed_Art60" />
    <bpmn:sequenceFlow id="Flow_ReceiveRevisedObjection_To_SubmitConsistencyMechanism_Art60"
                       sourceRef="IntermediateCatchEvent_ReceiveRevisedObjection_Art60"
                       targetRef="Task_SubmitMatterToConsistencyMechanism_Art60" />
    <bpmn:sequenceFlow id="Flow_TwoWeeksElapsed_To_GatewayMatterResolved_Art60"
                       sourceRef="IntermediateCatchEvent_TwoWeeksElapsed_Art60"
                       targetRef="Gateway_MatterResolved_Art60" />
    <bpmn:sequenceFlow id="Flow_SubmitConsistencyMechanism_To_EndConsistencyTriggered_Art60"
                       sourceRef="Task_SubmitMatterToConsistencyMechanism_Art60"
                       targetRef="EndEvent_ConsistencyMechanismTriggered_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayMatterResolved_To_SendDismissalOutcome_Art60"
                       name="Complaint fully dismissed or rejected"
                       sourceRef="Gateway_MatterResolved_Art60"
                       targetRef="Task_SendDismissalOutcome_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayMatterResolved_To_AdoptDecision_Art60"
                       name="Action decision"
                       sourceRef="Gateway_MatterResolved_Art60"
                       targetRef="Task_AdoptDecision_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayMatterResolved_To_AdoptActionPartDecision_Art60"
                       name="Action and dismissal split"
                       sourceRef="Gateway_MatterResolved_Art60"
                       targetRef="Task_AdoptActionPartDecision_Art60" />
    <bpmn:sequenceFlow id="Flow_SendDismissalOutcome_To_EndDismissalOutcomeSent_Art60"
                       sourceRef="Task_SendDismissalOutcome_Art60"
                       targetRef="EndEvent_DismissalOutcomeSent_Art60" />
    <bpmn:sequenceFlow id="Flow_AdoptDecision_To_NotifyController_Art60"
                       sourceRef="Task_AdoptDecision_Art60"
                       targetRef="Task_NotifyControllerOfDecision_Art60" />
    <bpmn:sequenceFlow id="Flow_NotifyController_To_InformAuthoritiesBoard_Art60"
                       sourceRef="Task_NotifyControllerOfDecision_Art60"
                       targetRef="Task_InformConcernedAuthoritiesAndBoard_Art60" />
    <bpmn:sequenceFlow id="Flow_InformAuthoritiesBoard_To_ReceiveComplianceNotification_Art60"
                       sourceRef="Task_InformConcernedAuthoritiesAndBoard_Art60"
                       targetRef="Task_ReceiveComplianceNotification_Art60" />
    <bpmn:sequenceFlow id="Flow_ReceiveComplianceNotification_To_InformComplianceMeasures_Art60"
                       sourceRef="Task_ReceiveComplianceNotification_Art60"
                       targetRef="Task_InformConcernedAuthoritiesOfComplianceMeasures_Art60" />
    <bpmn:sequenceFlow id="Flow_InformComplianceMeasures_To_EndDecisionImplemented_Art60"
                       sourceRef="Task_InformConcernedAuthoritiesOfComplianceMeasures_Art60"
                       targetRef="EndEvent_DecisionImplemented_Art60" />
    <bpmn:sequenceFlow id="Flow_AdoptActionPartDecision_To_NotifyControllerActionPart_Art60"
                       sourceRef="Task_AdoptActionPartDecision_Art60"
                       targetRef="Task_NotifyControllerOfActionPartDecision_Art60" />
    <bpmn:sequenceFlow id="Flow_NotifyControllerActionPart_To_InformComplainantActionPart_Art60"
                       sourceRef="Task_NotifyControllerOfActionPartDecision_Art60"
                       targetRef="Task_InformComplainantOfActionPart_Art60" />
    <bpmn:sequenceFlow id="Flow_InformComplainantActionPart_To_SendSplitOutcome_Art60"
                       sourceRef="Task_InformComplainantOfActionPart_Art60"
                       targetRef="Task_SendSplitDismissalOutcome_Art60" />
    <bpmn:sequenceFlow id="Flow_SendSplitOutcome_To_ReceiveActionPartComplianceNotification_Art60"
                       sourceRef="Task_SendSplitDismissalOutcome_Art60"
                       targetRef="Task_ReceiveActionPartComplianceNotification_Art60" />
    <bpmn:sequenceFlow id="Flow_ReceiveActionPartComplianceNotification_To_InformActionPartCompliance_Art60"
                       sourceRef="Task_ReceiveActionPartComplianceNotification_Art60"
                       targetRef="Task_InformConcernedAuthoritiesOfActionPartCompliance_Art60" />
    <bpmn:sequenceFlow id="Flow_InformActionPartCompliance_To_EndSplitDecisionImplemented_Art60"
                       sourceRef="Task_InformConcernedAuthoritiesOfActionPartCompliance_Art60"
                       targetRef="EndEvent_SplitDecisionImplemented_Art60" />
  </bpmn:process>

  <bpmn:process id="Process_ConcernedOrComplaintAuthority_Art60"
                name="Respond as concerned or complaint supervisory authority"
                isExecutable="false">
    <bpmn:documentation>
      This process captures the concerned or complaint supervisory authority's receipt and
      assessment of draft and revised draft decisions, the optional sending of relevant and
      reasoned objections, the informing of the complainant about the final lead decision, the
      adoption of dismissal or split-dismissal decisions where Article 60(8) or (9) applies,
      the informing of the controller or processor in those paths, and the urgent-need route
      that triggers the Article 66 urgency procedure.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_ReceiveDraftDecision_Art60"
                     name="Receive draft decision">
      <bpmn:outgoing>Flow_StartReceiveDraft_To_AssessDraft_Art60</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:startEvent>

    <bpmn:task id="Task_AssessDraftWithinFourWeeks_Art60"
               name="Assess draft within four weeks">
      <bpmn:incoming>Flow_StartReceiveDraft_To_AssessDraft_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessDraft_To_GatewayObjectDraft_Art60</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ObjectDraft_Art60"
                           name="Is a relevant and reasoned objection warranted?">
      <bpmn:incoming>Flow_AssessDraft_To_GatewayObjectDraft_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayObjectDraft_To_SendObjection_Art60</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayObjectDraft_To_EndNoDraftObjection_Art60</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_SendRelevantReasonedObjection_Art60"
                   name="Send relevant and reasoned objection">
      <bpmn:incoming>Flow_GatewayObjectDraft_To_SendObjection_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_SendObjection_To_EndDraftObjectionSent_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:startEvent id="StartEvent_ReceiveRevisedDraftDecision_Art60"
                     name="Receive revised draft decision">
      <bpmn:outgoing>Flow_StartReceiveRevisedDraft_To_AssessRevisedDraft_Art60</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:startEvent>

    <bpmn:task id="Task_AssessRevisedDraftWithinTwoWeeks_Art60"
               name="Assess revised draft within two weeks">
      <bpmn:incoming>Flow_StartReceiveRevisedDraft_To_AssessRevisedDraft_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessRevisedDraft_To_GatewayObjectRevisedDraft_Art60</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ObjectRevisedDraft_Art60"
                           name="Is an objection to the revised draft warranted?">
      <bpmn:incoming>Flow_AssessRevisedDraft_To_GatewayObjectRevisedDraft_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayObjectRevisedDraft_To_SendRevisedObjection_Art60</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayObjectRevisedDraft_To_EndNoRevisedObjection_Art60</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_SendRevisedDraftObjection_Art60"
                   name="Send revised-draft objection">
      <bpmn:incoming>Flow_GatewayObjectRevisedDraft_To_SendRevisedObjection_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRevisedObjection_To_EndRevisedObjectionSent_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:startEvent id="StartEvent_ReceiveFinalLeadDecision_Art60"
                     name="Receive final lead decision">
      <bpmn:outgoing>Flow_StartReceiveFinalDecision_To_InformComplainantDecision_Art60</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:startEvent>

    <bpmn:sendTask id="Task_InformComplainantOfDecision_Art60"
                   name="Inform complainant of decision">
      <bpmn:incoming>Flow_StartReceiveFinalDecision_To_InformComplainantDecision_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_InformComplainantDecision_To_EndComplainantInformed_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:startEvent id="StartEvent_ReceiveDismissalOutcome_Art60"
                     name="Receive dismissal or rejection outcome">
      <bpmn:outgoing>Flow_StartReceiveDismissalOutcome_To_AdoptDismissalDecision_Art60</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:startEvent>

    <bpmn:task id="Task_AdoptDismissalDecision_Art60"
               name="Adopt dismissal or rejection decision">
      <bpmn:incoming>Flow_StartReceiveDismissalOutcome_To_AdoptDismissalDecision_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptDismissalDecision_To_NotifyComplainantDismissal_Art60</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_NotifyComplainantOfDismissal_Art60"
                   name="Notify complainant of dismissal">
      <bpmn:incoming>Flow_AdoptDismissalDecision_To_NotifyComplainantDismissal_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyComplainantDismissal_To_InformControllerDismissal_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_InformControllerOfDismissal_Art60"
                   name="Inform controller or processor of dismissal">
      <bpmn:incoming>Flow_NotifyComplainantDismissal_To_InformControllerDismissal_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_InformControllerDismissal_To_EndDismissalHandled_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:startEvent id="StartEvent_ReceiveSplitDismissalOutcome_Art60"
                     name="Receive split dismissal or rejection outcome">
      <bpmn:outgoing>Flow_StartReceiveSplitOutcome_To_AdoptSplitDismissalDecision_Art60</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:startEvent>

    <bpmn:task id="Task_AdoptSplitDismissalDecision_Art60"
               name="Adopt dismissal or rejection part decision">
      <bpmn:incoming>Flow_StartReceiveSplitOutcome_To_AdoptSplitDismissalDecision_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_AdoptSplitDismissalDecision_To_NotifyComplainantSplitDismissal_Art60</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_NotifyComplainantOfSplitDismissal_Art60"
                   name="Notify complainant of dismissal part">
      <bpmn:incoming>Flow_AdoptSplitDismissalDecision_To_NotifyComplainantSplitDismissal_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyComplainantSplitDismissal_To_InformControllerSplitDismissal_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="Task_InformControllerOfSplitDismissal_Art60"
                   name="Inform controller or processor of dismissal part">
      <bpmn:incoming>Flow_NotifyComplainantSplitDismissal_To_InformControllerSplitDismissal_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_InformControllerSplitDismissal_To_EndSplitDismissalHandled_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:startEvent id="StartEvent_IdentifyUrgentNeed_Art60"
                     name="Identify urgent need to protect data subjects">
      <bpmn:outgoing>Flow_StartUrgentNeed_To_TriggerUrgencyProcedure_Art60</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sendTask id="Task_TriggerArticle66UrgencyProcedure_Art60"
                   name="Trigger Article 66 urgency procedure">
      <bpmn:incoming>Flow_StartUrgentNeed_To_TriggerUrgencyProcedure_Art60</bpmn:incoming>
      <bpmn:outgoing>Flow_TriggerUrgencyProcedure_To_EndUrgencyTriggered_Art60</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_NoDraftObjection_Art60"
                   name="No draft objection sent">
      <bpmn:incoming>Flow_GatewayObjectDraft_To_EndNoDraftObjection_Art60</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_DraftObjectionSent_Art60"
                   name="Draft objection sent">
      <bpmn:incoming>Flow_SendObjection_To_EndDraftObjectionSent_Art60</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_NoRevisedObjection_Art60"
                   name="No revised-draft objection sent">
      <bpmn:incoming>Flow_GatewayObjectRevisedDraft_To_EndNoRevisedObjection_Art60</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_RevisedObjectionSent_Art60"
                   name="Revised-draft objection sent">
      <bpmn:incoming>Flow_SendRevisedObjection_To_EndRevisedObjectionSent_Art60</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_ComplainantInformed_Art60"
                   name="Complainant informed of decision">
      <bpmn:incoming>Flow_InformComplainantDecision_To_EndComplainantInformed_Art60</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_DismissalHandled_Art60"
                   name="Dismissal handled">
      <bpmn:incoming>Flow_InformControllerDismissal_To_EndDismissalHandled_Art60</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_SplitDismissalHandled_Art60"
                   name="Split dismissal handled">
      <bpmn:incoming>Flow_InformControllerSplitDismissal_To_EndSplitDismissalHandled_Art60</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_UrgencyTriggered_Art60"
                   name="Urgency procedure triggered">
      <bpmn:incoming>Flow_TriggerUrgencyProcedure_To_EndUrgencyTriggered_Art60</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartReceiveDraft_To_AssessDraft_Art60"
                       sourceRef="StartEvent_ReceiveDraftDecision_Art60"
                       targetRef="Task_AssessDraftWithinFourWeeks_Art60" />
    <bpmn:sequenceFlow id="Flow_AssessDraft_To_GatewayObjectDraft_Art60"
                       sourceRef="Task_AssessDraftWithinFourWeeks_Art60"
                       targetRef="Gateway_ObjectDraft_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayObjectDraft_To_SendObjection_Art60"
                       name="Yes"
                       sourceRef="Gateway_ObjectDraft_Art60"
                       targetRef="Task_SendRelevantReasonedObjection_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayObjectDraft_To_EndNoDraftObjection_Art60"
                       name="No"
                       sourceRef="Gateway_ObjectDraft_Art60"
                       targetRef="EndEvent_NoDraftObjection_Art60" />
    <bpmn:sequenceFlow id="Flow_SendObjection_To_EndDraftObjectionSent_Art60"
                       sourceRef="Task_SendRelevantReasonedObjection_Art60"
                       targetRef="EndEvent_DraftObjectionSent_Art60" />

    <bpmn:sequenceFlow id="Flow_StartReceiveRevisedDraft_To_AssessRevisedDraft_Art60"
                       sourceRef="StartEvent_ReceiveRevisedDraftDecision_Art60"
                       targetRef="Task_AssessRevisedDraftWithinTwoWeeks_Art60" />
    <bpmn:sequenceFlow id="Flow_AssessRevisedDraft_To_GatewayObjectRevisedDraft_Art60"
                       sourceRef="Task_AssessRevisedDraftWithinTwoWeeks_Art60"
                       targetRef="Gateway_ObjectRevisedDraft_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayObjectRevisedDraft_To_SendRevisedObjection_Art60"
                       name="Yes"
                       sourceRef="Gateway_ObjectRevisedDraft_Art60"
                       targetRef="Task_SendRevisedDraftObjection_Art60" />
    <bpmn:sequenceFlow id="Flow_GatewayObjectRevisedDraft_To_EndNoRevisedObjection_Art60"
                       name="No"
                       sourceRef="Gateway_ObjectRevisedDraft_Art60"
                       targetRef="EndEvent_NoRevisedObjection_Art60" />
    <bpmn:sequenceFlow id="Flow_SendRevisedObjection_To_EndRevisedObjectionSent_Art60"
                       sourceRef="Task_SendRevisedDraftObjection_Art60"
                       targetRef="EndEvent_RevisedObjectionSent_Art60" />

    <bpmn:sequenceFlow id="Flow_StartReceiveFinalDecision_To_InformComplainantDecision_Art60"
                       sourceRef="StartEvent_ReceiveFinalLeadDecision_Art60"
                       targetRef="Task_InformComplainantOfDecision_Art60" />
    <bpmn:sequenceFlow id="Flow_InformComplainantDecision_To_EndComplainantInformed_Art60"
                       sourceRef="Task_InformComplainantOfDecision_Art60"
                       targetRef="EndEvent_ComplainantInformed_Art60" />

    <bpmn:sequenceFlow id="Flow_StartReceiveDismissalOutcome_To_AdoptDismissalDecision_Art60"
                       sourceRef="StartEvent_ReceiveDismissalOutcome_Art60"
                       targetRef="Task_AdoptDismissalDecision_Art60" />
    <bpmn:sequenceFlow id="Flow_AdoptDismissalDecision_To_NotifyComplainantDismissal_Art60"
                       sourceRef="Task_AdoptDismissalDecision_Art60"
                       targetRef="Task_NotifyComplainantOfDismissal_Art60" />
    <bpmn:sequenceFlow id="Flow_NotifyComplainantDismissal_To_InformControllerDismissal_Art60"
                       sourceRef="Task_NotifyComplainantOfDismissal_Art60"
                       targetRef="Task_InformControllerOfDismissal_Art60" />
    <bpmn:sequenceFlow id="Flow_InformControllerDismissal_To_EndDismissalHandled_Art60"
                       sourceRef="Task_InformControllerOfDismissal_Art60"
                       targetRef="EndEvent_DismissalHandled_Art60" />

    <bpmn:sequenceFlow id="Flow_StartReceiveSplitOutcome_To_AdoptSplitDismissalDecision_Art60"
                       sourceRef="StartEvent_ReceiveSplitDismissalOutcome_Art60"
                       targetRef="Task_AdoptSplitDismissalDecision_Art60" />
    <bpmn:sequenceFlow id="Flow_AdoptSplitDismissalDecision_To_NotifyComplainantSplitDismissal_Art60"
                       sourceRef="Task_AdoptSplitDismissalDecision_Art60"
                       targetRef="Task_NotifyComplainantOfSplitDismissal_Art60" />
    <bpmn:sequenceFlow id="Flow_NotifyComplainantSplitDismissal_To_InformControllerSplitDismissal_Art60"
                       sourceRef="Task_NotifyComplainantOfSplitDismissal_Art60"
                       targetRef="Task_InformControllerOfSplitDismissal_Art60" />
    <bpmn:sequenceFlow id="Flow_InformControllerSplitDismissal_To_EndSplitDismissalHandled_Art60"
                       sourceRef="Task_InformControllerOfSplitDismissal_Art60"
                       targetRef="EndEvent_SplitDismissalHandled_Art60" />

    <bpmn:sequenceFlow id="Flow_StartUrgentNeed_To_TriggerUrgencyProcedure_Art60"
                       sourceRef="StartEvent_IdentifyUrgentNeed_Art60"
                       targetRef="Task_TriggerArticle66UrgencyProcedure_Art60" />
    <bpmn:sequenceFlow id="Flow_TriggerUrgencyProcedure_To_EndUrgencyTriggered_Art60"
                       sourceRef="Task_TriggerArticle66UrgencyProcedure_Art60"
                       targetRef="EndEvent_UrgencyTriggered_Art60" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art60_Reviewed">
