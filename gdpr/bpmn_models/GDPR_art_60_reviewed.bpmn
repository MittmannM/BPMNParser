        <dc:Bounds x="3600" y="200" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_InformConcernedAuthoritiesOfComplianceMeasures_Art60_di"
                        bpmnElement="Task_InformConcernedAuthoritiesOfComplianceMeasures_Art60">
        <dc:Bounds x="3920" y="200" width="250" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdoptActionPartDecision_Art60_di"
                        bpmnElement="Task_AdoptActionPartDecision_Art60">
        <dc:Bounds x="2580" y="500" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyControllerOfActionPartDecision_Art60_di"
                        bpmnElement="Task_NotifyControllerOfActionPartDecision_Art60">
