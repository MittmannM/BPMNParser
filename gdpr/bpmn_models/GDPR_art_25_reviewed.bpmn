<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art25_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_Controller_Art25"
                name="Applying data protection by design and by default under Article 25"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 25 based on the real English legal text
      of Regulation (EU) 2016/679. The model captures the Article 25(1) assessment of
      state of the art, implementation cost, processing context, and risk; the
      implementation of design-phase and processing-phase safeguards; the Article
      25(2) default-setting duties for data amount, processing extent, storage period,
      and accessibility; the special restriction against default accessibility to an
      indefinite number of natural persons without the individual's intervention; and
      the optional Article 42 certification path in Article 25(3).
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_DesignProcessing_Art25"
                     name="Design a processing operation">
      <bpmn:outgoing>Flow_StartDesignProcessing_To_TaskAssessDesignFactors_Art25</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_AssessDesignFactors_Art25"
               name="Assess design factors">
      <bpmn:incoming>Flow_StartDesignProcessing_To_TaskAssessDesignFactors_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessDesignFactors_To_TaskDefineDesignMeasures_Art25</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DefineDesignMeasures_Art25"
               name="Define design measures">
      <bpmn:incoming>Flow_TaskAssessDesignFactors_To_TaskDefineDesignMeasures_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDefineDesignMeasures_To_TaskImplementDesignPhaseMeasures_Art25</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ImplementDesignPhaseMeasures_Art25"
               name="Implement design-phase measures">
      <bpmn:incoming>Flow_TaskDefineDesignMeasures_To_TaskImplementDesignPhaseMeasures_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskImplementDesignPhaseMeasures_To_TaskImplementProcessingPhaseMeasures_Art25</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ImplementProcessingPhaseMeasures_Art25"
               name="Implement processing-phase measures">
      <bpmn:incoming>Flow_TaskImplementDesignPhaseMeasures_To_TaskImplementProcessingPhaseMeasures_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskImplementProcessingPhaseMeasures_To_TaskIntegrateSafeguards_Art25</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_IntegrateSafeguards_Art25"
               name="Integrate safeguards">
      <bpmn:incoming>Flow_TaskImplementProcessingPhaseMeasures_To_TaskIntegrateSafeguards_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskIntegrateSafeguards_To_TaskConfigureDefaultSettings_Art25</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ConfigureDefaultSettings_Art25"
               name="Configure default settings">
      <bpmn:incoming>Flow_TaskIntegrateSafeguards_To_TaskConfigureDefaultSettings_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskConfigureDefaultSettings_To_GatewaySplitDefaults_Art25</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_SplitDefaults_Art25">
      <bpmn:incoming>Flow_TaskConfigureDefaultSettings_To_GatewaySplitDefaults_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitDefaults_To_TaskLimitDataAmount_Art25</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitDefaults_To_TaskLimitProcessingExtent_Art25</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitDefaults_To_TaskLimitStoragePeriod_Art25</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitDefaults_To_TaskRestrictAccessibility_Art25</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_LimitDataAmount_Art25"
               name="Limit data amount">
      <bpmn:incoming>Flow_GatewaySplitDefaults_To_TaskLimitDataAmount_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskLimitDataAmount_To_GatewayJoinDefaults_Art25</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_LimitProcessingExtent_Art25"
               name="Limit processing extent">
      <bpmn:incoming>Flow_GatewaySplitDefaults_To_TaskLimitProcessingExtent_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskLimitProcessingExtent_To_GatewayJoinDefaults_Art25</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_LimitStoragePeriod_Art25"
               name="Limit storage period">
      <bpmn:incoming>Flow_GatewaySplitDefaults_To_TaskLimitStoragePeriod_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskLimitStoragePeriod_To_GatewayJoinDefaults_Art25</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_RestrictAccessibility_Art25"
               name="Restrict accessibility">
      <bpmn:incoming>Flow_GatewaySplitDefaults_To_TaskRestrictAccessibility_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRestrictAccessibility_To_GatewayJoinDefaults_Art25</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinDefaults_Art25">
      <bpmn:incoming>Flow_TaskLimitDataAmount_To_GatewayJoinDefaults_Art25</bpmn:incoming>
      <bpmn:incoming>Flow_TaskLimitProcessingExtent_To_GatewayJoinDefaults_Art25</bpmn:incoming>
      <bpmn:incoming>Flow_TaskLimitStoragePeriod_To_GatewayJoinDefaults_Art25</bpmn:incoming>
      <bpmn:incoming>Flow_TaskRestrictAccessibility_To_GatewayJoinDefaults_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinDefaults_To_GatewayIndefiniteAccess_Art25</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:exclusiveGateway id="Gateway_IndefiniteAccess_Art25"
                           name="Could the data be accessible without the individual's intervention to an indefinite number of natural persons?">
      <bpmn:incoming>Flow_GatewayJoinDefaults_To_GatewayIndefiniteAccess_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayIndefiniteAccess_To_TaskPreventIndefiniteAccess_Art25</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayIndefiniteAccess_To_GatewayUseCertification_Art25</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_PreventIndefiniteAccess_Art25"
               name="Prevent indefinite access">
      <bpmn:incoming>Flow_GatewayIndefiniteAccess_To_TaskPreventIndefiniteAccess_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPreventIndefiniteAccess_To_GatewayUseCertification_Art25</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_UseCertification_Art25"
                           name="Use approved Article 42 certification to demonstrate compliance?">
      <bpmn:incoming>Flow_GatewayIndefiniteAccess_To_GatewayUseCertification_Art25</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPreventIndefiniteAccess_To_GatewayUseCertification_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayUseCertification_To_TaskUseCertification_Art25</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayUseCertification_To_EndDesignDefaultApplied_Art25</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_UseCertification_Art25"
               name="Use Article 42 certification">
      <bpmn:incoming>Flow_GatewayUseCertification_To_TaskUseCertification_Art25</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskUseCertification_To_EndDesignDefaultApplied_Art25</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_DesignDefaultApplied_Art25"
                   name="Article 25 design and default measures applied">
      <bpmn:incoming>Flow_GatewayUseCertification_To_EndDesignDefaultApplied_Art25</bpmn:incoming>
      <bpmn:incoming>Flow_TaskUseCertification_To_EndDesignDefaultApplied_Art25</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartDesignProcessing_To_TaskAssessDesignFactors_Art25" sourceRef="StartEvent_DesignProcessing_Art25" targetRef="Task_AssessDesignFactors_Art25" />
    <bpmn:sequenceFlow id="Flow_TaskAssessDesignFactors_To_TaskDefineDesignMeasures_Art25" sourceRef="Task_AssessDesignFactors_Art25" targetRef="Task_DefineDesignMeasures_Art25" />
    <bpmn:sequenceFlow id="Flow_TaskDefineDesignMeasures_To_TaskImplementDesignPhaseMeasures_Art25" sourceRef="Task_DefineDesignMeasures_Art25" targetRef="Task_ImplementDesignPhaseMeasures_Art25" />
    <bpmn:sequenceFlow id="Flow_TaskImplementDesignPhaseMeasures_To_TaskImplementProcessingPhaseMeasures_Art25" sourceRef="Task_ImplementDesignPhaseMeasures_Art25" targetRef="Task_ImplementProcessingPhaseMeasures_Art25" />
    <bpmn:sequenceFlow id="Flow_TaskImplementProcessingPhaseMeasures_To_TaskIntegrateSafeguards_Art25" sourceRef="Task_ImplementProcessingPhaseMeasures_Art25" targetRef="Task_IntegrateSafeguards_Art25" />
    <bpmn:sequenceFlow id="Flow_TaskIntegrateSafeguards_To_TaskConfigureDefaultSettings_Art25" sourceRef="Task_IntegrateSafeguards_Art25" targetRef="Task_ConfigureDefaultSettings_Art25" />
    <bpmn:sequenceFlow id="Flow_TaskConfigureDefaultSettings_To_GatewaySplitDefaults_Art25" sourceRef="Task_ConfigureDefaultSettings_Art25" targetRef="Gateway_SplitDefaults_Art25" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitDefaults_To_TaskLimitDataAmount_Art25" sourceRef="Gateway_SplitDefaults_Art25" targetRef="Task_LimitDataAmount_Art25" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitDefaults_To_TaskLimitProcessingExtent_Art25" sourceRef="Gateway_SplitDefaults_Art25" targetRef="Task_LimitProcessingExtent_Art25" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitDefaults_To_TaskLimitStoragePeriod_Art25" sourceRef="Gateway_SplitDefaults_Art25" targetRef="Task_LimitStoragePeriod_Art25" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitDefaults_To_TaskRestrictAccessibility_Art25" sourceRef="Gateway_SplitDefaults_Art25" targetRef="Task_RestrictAccessibility_Art25" />
    <bpmn:sequenceFlow id="Flow_TaskLimitDataAmount_To_GatewayJoinDefaults_Art25" sourceRef="Task_LimitDataAmount_Art25" targetRef="Gateway_JoinDefaults_Art25" />
    <bpmn:sequenceFlow id="Flow_TaskLimitProcessingExtent_To_GatewayJoinDefaults_Art25" sourceRef="Task_LimitProcessingExtent_Art25" targetRef="Gateway_JoinDefaults_Art25" />
    <bpmn:sequenceFlow id="Flow_TaskLimitStoragePeriod_To_GatewayJoinDefaults_Art25" sourceRef="Task_LimitStoragePeriod_Art25" targetRef="Gateway_JoinDefaults_Art25" />
    <bpmn:sequenceFlow id="Flow_TaskRestrictAccessibility_To_GatewayJoinDefaults_Art25" sourceRef="Task_RestrictAccessibility_Art25" targetRef="Gateway_JoinDefaults_Art25" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinDefaults_To_GatewayIndefiniteAccess_Art25" sourceRef="Gateway_JoinDefaults_Art25" targetRef="Gateway_IndefiniteAccess_Art25" />
    <bpmn:sequenceFlow id="Flow_GatewayIndefiniteAccess_To_TaskPreventIndefiniteAccess_Art25" name="Yes" sourceRef="Gateway_IndefiniteAccess_Art25" targetRef="Task_PreventIndefiniteAccess_Art25" />
    <bpmn:sequenceFlow id="Flow_GatewayIndefiniteAccess_To_GatewayUseCertification_Art25" name="No" sourceRef="Gateway_IndefiniteAccess_Art25" targetRef="Gateway_UseCertification_Art25" />
    <bpmn:sequenceFlow id="Flow_TaskPreventIndefiniteAccess_To_GatewayUseCertification_Art25" sourceRef="Task_PreventIndefiniteAccess_Art25" targetRef="Gateway_UseCertification_Art25" />
    <bpmn:sequenceFlow id="Flow_GatewayUseCertification_To_TaskUseCertification_Art25" name="Yes" sourceRef="Gateway_UseCertification_Art25" targetRef="Task_UseCertification_Art25" />
    <bpmn:sequenceFlow id="Flow_GatewayUseCertification_To_EndDesignDefaultApplied_Art25" name="No" sourceRef="Gateway_UseCertification_Art25" targetRef="EndEvent_DesignDefaultApplied_Art25" />
    <bpmn:sequenceFlow id="Flow_TaskUseCertification_To_EndDesignDefaultApplied_Art25" sourceRef="Task_UseCertification_Art25" targetRef="EndEvent_DesignDefaultApplied_Art25" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art25_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art25_Reviewed" bpmnElement="Process_Controller_Art25">
      <bpmndi:BPMNShape id="StartEvent_DesignProcessing_Art25_di" bpmnElement="StartEvent_DesignProcessing_Art25">
        <dc:Bounds x="120" y="382" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessDesignFactors_Art25_di" bpmnElement="Task_AssessDesignFactors_Art25">
        <dc:Bounds x="220" y="360" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DefineDesignMeasures_Art25_di" bpmnElement="Task_DefineDesignMeasures_Art25">
        <dc:Bounds x="510" y="360" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ImplementDesignPhaseMeasures_Art25_di" bpmnElement="Task_ImplementDesignPhaseMeasures_Art25">
        <dc:Bounds x="800" y="360" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ImplementProcessingPhaseMeasures_Art25_di" bpmnElement="Task_ImplementProcessingPhaseMeasures_Art25">
        <dc:Bounds x="1110" y="360" width="240" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IntegrateSafeguards_Art25_di" bpmnElement="Task_IntegrateSafeguards_Art25">
        <dc:Bounds x="1450" y="360" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ConfigureDefaultSettings_Art25_di" bpmnElement="Task_ConfigureDefaultSettings_Art25">
        <dc:Bounds x="1730" y="360" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SplitDefaults_Art25_di" bpmnElement="Gateway_SplitDefaults_Art25" isMarkerVisible="true">
        <dc:Bounds x="2040" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LimitDataAmount_Art25_di" bpmnElement="Task_LimitDataAmount_Art25">
        <dc:Bounds x="2230" y="50" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LimitProcessingExtent_Art25_di" bpmnElement="Task_LimitProcessingExtent_Art25">
        <dc:Bounds x="2230" y="180" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LimitStoragePeriod_Art25_di" bpmnElement="Task_LimitStoragePeriod_Art25">
        <dc:Bounds x="2230" y="310" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RestrictAccessibility_Art25_di" bpmnElement="Task_RestrictAccessibility_Art25">
        <dc:Bounds x="2230" y="440" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_JoinDefaults_Art25_di" bpmnElement="Gateway_JoinDefaults_Art25" isMarkerVisible="true">
        <dc:Bounds x="2590" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IndefiniteAccess_Art25_di" bpmnElement="Gateway_IndefiniteAccess_Art25" isMarkerVisible="true">
        <dc:Bounds x="2780" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PreventIndefiniteAccess_Art25_di" bpmnElement="Task_PreventIndefiniteAccess_Art25">
        <dc:Bounds x="2960" y="220" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_UseCertification_Art25_di" bpmnElement="Gateway_UseCertification_Art25" isMarkerVisible="true">
        <dc:Bounds x="3300" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_UseCertification_Art25_di" bpmnElement="Task_UseCertification_Art25">
        <dc:Bounds x="3470" y="220" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_DesignDefaultApplied_Art25_di" bpmnElement="EndEvent_DesignDefaultApplied_Art25">
        <dc:Bounds x="3790" y="382" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_StartDesignProcessing_To_TaskAssessDesignFactors_Art25_di" bpmnElement="Flow_StartDesignProcessing_To_TaskAssessDesignFactors_Art25">
        <di:waypoint x="156" y="400" />
        <di:waypoint x="220" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskAssessDesignFactors_To_TaskDefineDesignMeasures_Art25_di" bpmnElement="Flow_TaskAssessDesignFactors_To_TaskDefineDesignMeasures_Art25">
        <di:waypoint x="420" y="400" />
        <di:waypoint x="510" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskDefineDesignMeasures_To_TaskImplementDesignPhaseMeasures_Art25_di" bpmnElement="Flow_TaskDefineDesignMeasures_To_TaskImplementDesignPhaseMeasures_Art25">
        <di:waypoint x="710" y="400" />
        <di:waypoint x="800" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskImplementDesignPhaseMeasures_To_TaskImplementProcessingPhaseMeasures_Art25_di" bpmnElement="Flow_TaskImplementDesignPhaseMeasures_To_TaskImplementProcessingPhaseMeasures_Art25">
        <di:waypoint x="1020" y="400" />
        <di:waypoint x="1110" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskImplementProcessingPhaseMeasures_To_TaskIntegrateSafeguards_Art25_di" bpmnElement="Flow_TaskImplementProcessingPhaseMeasures_To_TaskIntegrateSafeguards_Art25">
        <di:waypoint x="1350" y="400" />
        <di:waypoint x="1450" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskIntegrateSafeguards_To_TaskConfigureDefaultSettings_Art25_di" bpmnElement="Flow_TaskIntegrateSafeguards_To_TaskConfigureDefaultSettings_Art25">
        <di:waypoint x="1630" y="400" />
        <di:waypoint x="1730" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskConfigureDefaultSettings_To_GatewaySplitDefaults_Art25_di" bpmnElement="Flow_TaskConfigureDefaultSettings_To_GatewaySplitDefaults_Art25">
        <di:waypoint x="1940" y="400" />
        <di:waypoint x="2040" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitDefaults_To_TaskLimitDataAmount_Art25_di" bpmnElement="Flow_GatewaySplitDefaults_To_TaskLimitDataAmount_Art25">
        <di:waypoint x="2065" y="375" />
        <di:waypoint x="2065" y="90" />
        <di:waypoint x="2230" y="90" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitDefaults_To_TaskLimitProcessingExtent_Art25_di" bpmnElement="Flow_GatewaySplitDefaults_To_TaskLimitProcessingExtent_Art25">
        <di:waypoint x="2065" y="375" />
        <di:waypoint x="2065" y="220" />
        <di:waypoint x="2230" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitDefaults_To_TaskLimitStoragePeriod_Art25_di" bpmnElement="Flow_GatewaySplitDefaults_To_TaskLimitStoragePeriod_Art25">
        <di:waypoint x="2065" y="375" />
        <di:waypoint x="2065" y="350" />
        <di:waypoint x="2230" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySplitDefaults_To_TaskRestrictAccessibility_Art25_di" bpmnElement="Flow_GatewaySplitDefaults_To_TaskRestrictAccessibility_Art25">
        <di:waypoint x="2065" y="425" />
        <di:waypoint x="2065" y="480" />
        <di:waypoint x="2230" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskLimitDataAmount_To_GatewayJoinDefaults_Art25_di" bpmnElement="Flow_TaskLimitDataAmount_To_GatewayJoinDefaults_Art25">
        <di:waypoint x="2420" y="90" />
        <di:waypoint x="2615" y="90" />
        <di:waypoint x="2615" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskLimitProcessingExtent_To_GatewayJoinDefaults_Art25_di" bpmnElement="Flow_TaskLimitProcessingExtent_To_GatewayJoinDefaults_Art25">
        <di:waypoint x="2440" y="220" />
        <di:waypoint x="2615" y="220" />
        <di:waypoint x="2615" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskLimitStoragePeriod_To_GatewayJoinDefaults_Art25_di" bpmnElement="Flow_TaskLimitStoragePeriod_To_GatewayJoinDefaults_Art25">
        <di:waypoint x="2430" y="350" />
        <di:waypoint x="2615" y="350" />
        <di:waypoint x="2615" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskRestrictAccessibility_To_GatewayJoinDefaults_Art25_di" bpmnElement="Flow_TaskRestrictAccessibility_To_GatewayJoinDefaults_Art25">
        <di:waypoint x="2430" y="480" />
        <di:waypoint x="2615" y="480" />
        <di:waypoint x="2615" y="425" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayJoinDefaults_To_GatewayIndefiniteAccess_Art25_di" bpmnElement="Flow_GatewayJoinDefaults_To_GatewayIndefiniteAccess_Art25">
        <di:waypoint x="2640" y="400" />
        <di:waypoint x="2780" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayIndefiniteAccess_To_TaskPreventIndefiniteAccess_Art25_di" bpmnElement="Flow_GatewayIndefiniteAccess_To_TaskPreventIndefiniteAccess_Art25">
        <di:waypoint x="2805" y="375" />
        <di:waypoint x="2805" y="260" />
        <di:waypoint x="2960" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayIndefiniteAccess_To_GatewayUseCertification_Art25_di" bpmnElement="Flow_GatewayIndefiniteAccess_To_GatewayUseCertification_Art25">
        <di:waypoint x="2830" y="400" />
        <di:waypoint x="3300" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskPreventIndefiniteAccess_To_GatewayUseCertification_Art25_di" bpmnElement="Flow_TaskPreventIndefiniteAccess_To_GatewayUseCertification_Art25">
        <di:waypoint x="3170" y="260" />
        <di:waypoint x="3325" y="260" />
        <di:waypoint x="3325" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayUseCertification_To_TaskUseCertification_Art25_di" bpmnElement="Flow_GatewayUseCertification_To_TaskUseCertification_Art25">
        <di:waypoint x="3325" y="375" />
        <di:waypoint x="3325" y="260" />
        <di:waypoint x="3470" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayUseCertification_To_EndDesignDefaultApplied_Art25_di" bpmnElement="Flow_GatewayUseCertification_To_EndDesignDefaultApplied_Art25">
        <di:waypoint x="3350" y="400" />
        <di:waypoint x="3790" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskUseCertification_To_EndDesignDefaultApplied_Art25_di" bpmnElement="Flow_TaskUseCertification_To_EndDesignDefaultApplied_Art25">
        <di:waypoint x="3670" y="260" />
        <di:waypoint x="3808" y="260" />
        <di:waypoint x="3808" y="382" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
