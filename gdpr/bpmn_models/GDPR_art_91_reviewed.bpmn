<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art91_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art91_Reviewed">
    <bpmn:participant id="Participant_ChurchOrReligiousAssociation_Art91"
                      name="Church or Religious Association"
                      processRef="Process_ChurchOrReligiousAssociation_Art91" />
    <bpmn:participant id="Participant_IndependentSupervisoryAuthority_Art91"
                      name="Independent Supervisory Authority"
                      processRef="Process_IndependentSupervisoryAuthority_Art91" />

    <bpmn:messageFlow id="MessageFlow_SubmitRulesForSupervision_Art91"
                      sourceRef="Task_SubmitRulesForSupervision_Art91"
                      targetRef="StartEvent_ReceiveSupervisionMandate_Art91" />
  </bpmn:collaboration>

  <bpmn:process id="Process_ChurchOrReligiousAssociation_Art91"
                name="Continue and align comprehensive rules"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 91 based on the real English legal text from
      gdpr_articles/article_91.txt. This collaboration captures the continued application of
      comprehensive church or religious-association rules that existed at the entry into force of
      the Regulation, subject to alignment with the Regulation, and the resulting supervision by
      an independent supervisory authority, which may be specific if it fulfils the Chapter VI
      conditions.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_AssessExistingComprehensiveRules_Art91"
                     name="Assess existing comprehensive rules">
      <bpmn:outgoing>Flow_Start_To_GatewayExistingRules_Art91</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_DoComprehensiveRulesExistAtEntryIntoForce_Art91"
                           name="Did comprehensive rules apply at the entry into force of the Regulation?">
      <bpmn:incoming>Flow_Start_To_GatewayExistingRules_Art91</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayExistingRules_To_AlignRules_Art91</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayExistingRules_To_EndNoContinuedRules_Art91</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AlignRulesWithRegulation_Art91"
               name="Align rules with the Regulation">
      <bpmn:incoming>Flow_GatewayExistingRules_To_AlignRules_Art91</bpmn:incoming>
      <bpmn:outgoing>Flow_AlignRules_To_GatewaySpecificAuthority_Art91</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_IsSpecificAuthorityUsed_Art91"
                           name="Will supervision be carried out by a specific authority?">
      <bpmn:incoming>Flow_AlignRules_To_GatewaySpecificAuthority_Art91</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySpecificAuthority_To_VerifyChapterVIConditions_Art91</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySpecificAuthority_To_SubmitRulesForSupervision_Art91</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_VerifyChapterVIConditions_Art91"
               name="Verify Chapter VI conditions">
      <bpmn:incoming>Flow_GatewaySpecificAuthority_To_VerifyChapterVIConditions_Art91</bpmn:incoming>
      <bpmn:outgoing>Flow_VerifyChapterVIConditions_To_SubmitRulesForSupervision_Art91</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_SubmitRulesForSupervision_Art91"
                   name="Submit rules for supervision">
      <bpmn:incoming>Flow_GatewaySpecificAuthority_To_SubmitRulesForSupervision_Art91</bpmn:incoming>
      <bpmn:incoming>Flow_VerifyChapterVIConditions_To_SubmitRulesForSupervision_Art91</bpmn:incoming>
      <bpmn:outgoing>Flow_SubmitRulesForSupervision_To_EndRulesContinueUnderSupervision_Art91</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_NoContinuedRules_Art91"
                   name="No continued Article 91 rules">
      <bpmn:incoming>Flow_GatewayExistingRules_To_EndNoContinuedRules_Art91</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_RulesContinueUnderSupervision_Art91"
                   name="Rules continue under supervision">
      <bpmn:incoming>Flow_SubmitRulesForSupervision_To_EndRulesContinueUnderSupervision_Art91</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_GatewayExistingRules_Art91"
                       sourceRef="StartEvent_AssessExistingComprehensiveRules_Art91"
                       targetRef="Gateway_DoComprehensiveRulesExistAtEntryIntoForce_Art91" />
    <bpmn:sequenceFlow id="Flow_GatewayExistingRules_To_AlignRules_Art91"
                       name="Yes"
                       sourceRef="Gateway_DoComprehensiveRulesExistAtEntryIntoForce_Art91"
                       targetRef="Task_AlignRulesWithRegulation_Art91" />
    <bpmn:sequenceFlow id="Flow_GatewayExistingRules_To_EndNoContinuedRules_Art91"
                       name="No"
                       sourceRef="Gateway_DoComprehensiveRulesExistAtEntryIntoForce_Art91"
                       targetRef="EndEvent_NoContinuedRules_Art91" />
    <bpmn:sequenceFlow id="Flow_AlignRules_To_GatewaySpecificAuthority_Art91"
                       sourceRef="Task_AlignRulesWithRegulation_Art91"
                       targetRef="Gateway_IsSpecificAuthorityUsed_Art91" />
    <bpmn:sequenceFlow id="Flow_GatewaySpecificAuthority_To_VerifyChapterVIConditions_Art91"
                       name="Yes"
                       sourceRef="Gateway_IsSpecificAuthorityUsed_Art91"
                       targetRef="Task_VerifyChapterVIConditions_Art91" />
    <bpmn:sequenceFlow id="Flow_GatewaySpecificAuthority_To_SubmitRulesForSupervision_Art91"
                       name="No"
                       sourceRef="Gateway_IsSpecificAuthorityUsed_Art91"
                       targetRef="Task_SubmitRulesForSupervision_Art91" />
    <bpmn:sequenceFlow id="Flow_VerifyChapterVIConditions_To_SubmitRulesForSupervision_Art91"
                       sourceRef="Task_VerifyChapterVIConditions_Art91"
                       targetRef="Task_SubmitRulesForSupervision_Art91" />
    <bpmn:sequenceFlow id="Flow_SubmitRulesForSupervision_To_EndRulesContinueUnderSupervision_Art91"
                       sourceRef="Task_SubmitRulesForSupervision_Art91"
                       targetRef="EndEvent_RulesContinueUnderSupervision_Art91" />
  </bpmn:process>

  <bpmn:process id="Process_IndependentSupervisoryAuthority_Art91"
                name="Exercise independent supervision"
                isExecutable="false">
    <bpmn:startEvent id="StartEvent_ReceiveSupervisionMandate_Art91"
                     name="Receive supervision mandate">
      <bpmn:messageEventDefinition />
      <bpmn:outgoing>Flow_StartSupervision_To_ExerciseIndependentSupervision_Art91</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_ExerciseIndependentSupervision_Art91"
               name="Exercise independent supervision">
      <bpmn:incoming>Flow_StartSupervision_To_ExerciseIndependentSupervision_Art91</bpmn:incoming>
      <bpmn:outgoing>Flow_ExerciseIndependentSupervision_To_EndSupervisionActive_Art91</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_SupervisionActive_Art91"
                   name="Supervision active">
      <bpmn:incoming>Flow_ExerciseIndependentSupervision_To_EndSupervisionActive_Art91</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartSupervision_To_ExerciseIndependentSupervision_Art91"
                       sourceRef="StartEvent_ReceiveSupervisionMandate_Art91"
                       targetRef="Task_ExerciseIndependentSupervision_Art91" />
    <bpmn:sequenceFlow id="Flow_ExerciseIndependentSupervision_To_EndSupervisionActive_Art91"
                       sourceRef="Task_ExerciseIndependentSupervision_Art91"
                       targetRef="EndEvent_SupervisionActive_Art91" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art91_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art91_Reviewed"
                      bpmnElement="Collaboration_Art91_Reviewed">
      <bpmndi:BPMNShape id="Participant_ChurchOrReligiousAssociation_Art91_di"
                        bpmnElement="Participant_ChurchOrReligiousAssociation_Art91"
                        isHorizontal="true">
        <dc:Bounds x="80" y="80" width="1800" height="260" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_IndependentSupervisoryAuthority_Art91_di"
                        bpmnElement="Participant_IndependentSupervisoryAuthority_Art91"
                        isHorizontal="true">
        <dc:Bounds x="80" y="400" width="1800" height="140" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_AssessExistingComprehensiveRules_Art91_di"
                        bpmnElement="StartEvent_AssessExistingComprehensiveRules_Art91">
        <dc:Bounds x="120" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DoComprehensiveRulesExistAtEntryIntoForce_Art91_di"
                        bpmnElement="Gateway_DoComprehensiveRulesExistAtEntryIntoForce_Art91"
                        isMarkerVisible="true">
        <dc:Bounds x="220" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AlignRulesWithRegulation_Art91_di"
                        bpmnElement="Task_AlignRulesWithRegulation_Art91">
        <dc:Bounds x="380" y="170" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IsSpecificAuthorityUsed_Art91_di"
                        bpmnElement="Gateway_IsSpecificAuthorityUsed_Art91"
                        isMarkerVisible="true">
        <dc:Bounds x="660" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_VerifyChapterVIConditions_Art91_di"
                        bpmnElement="Task_VerifyChapterVIConditions_Art91">
        <dc:Bounds x="820" y="90" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SubmitRulesForSupervision_Art91_di"
                        bpmnElement="Task_SubmitRulesForSupervision_Art91">
        <dc:Bounds x="1110" y="170" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoContinuedRules_Art91_di"
                        bpmnElement="EndEvent_NoContinuedRules_Art91">
        <dc:Bounds x="382" y="272" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RulesContinueUnderSupervision_Art91_di"
                        bpmnElement="EndEvent_RulesContinueUnderSupervision_Art91">
        <dc:Bounds x="1382" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_ReceiveSupervisionMandate_Art91_di"
                        bpmnElement="StartEvent_ReceiveSupervisionMandate_Art91">
        <dc:Bounds x="1260" y="452" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ExerciseIndependentSupervision_Art91_di"
                        bpmnElement="Task_ExerciseIndependentSupervision_Art91">
        <dc:Bounds x="1360" y="430" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_SupervisionActive_Art91_di"
                        bpmnElement="EndEvent_SupervisionActive_Art91">
        <dc:Bounds x="1630" y="452" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_GatewayExistingRules_Art91_di"
                       bpmnElement="Flow_Start_To_GatewayExistingRules_Art91">
        <di:waypoint x="156" y="210" />
        <di:waypoint x="220" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayExistingRules_To_AlignRules_Art91_di"
                       bpmnElement="Flow_GatewayExistingRules_To_AlignRules_Art91">
        <di:waypoint x="270" y="210" />
        <di:waypoint x="380" y="210" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="304" y="192" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayExistingRules_To_EndNoContinuedRules_Art91_di"
                       bpmnElement="Flow_GatewayExistingRules_To_EndNoContinuedRules_Art91">
        <di:waypoint x="245" y="235" />
        <di:waypoint x="245" y="290" />
        <di:waypoint x="382" y="290" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="278" y="254" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AlignRules_To_GatewaySpecificAuthority_Art91_di"
                       bpmnElement="Flow_AlignRules_To_GatewaySpecificAuthority_Art91">
        <di:waypoint x="560" y="210" />
        <di:waypoint x="660" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySpecificAuthority_To_VerifyChapterVIConditions_Art91_di"
                       bpmnElement="Flow_GatewaySpecificAuthority_To_VerifyChapterVIConditions_Art91">
        <di:waypoint x="685" y="185" />
        <di:waypoint x="685" y="130" />
        <di:waypoint x="820" y="130" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="718" y="146" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySpecificAuthority_To_SubmitRulesForSupervision_Art91_di"
                       bpmnElement="Flow_GatewaySpecificAuthority_To_SubmitRulesForSupervision_Art91">
        <di:waypoint x="710" y="210" />
        <di:waypoint x="1110" y="210" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="898" y="192" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_VerifyChapterVIConditions_To_SubmitRulesForSupervision_Art91_di"
                       bpmnElement="Flow_VerifyChapterVIConditions_To_SubmitRulesForSupervision_Art91">
        <di:waypoint x="1000" y="130" />
        <di:waypoint x="1135" y="130" />
        <di:waypoint x="1135" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SubmitRulesForSupervision_To_EndRulesContinueUnderSupervision_Art91_di"
                       bpmnElement="Flow_SubmitRulesForSupervision_To_EndRulesContinueUnderSupervision_Art91">
        <di:waypoint x="1290" y="210" />
        <di:waypoint x="1382" y="210" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_StartSupervision_To_ExerciseIndependentSupervision_Art91_di"
                       bpmnElement="Flow_StartSupervision_To_ExerciseIndependentSupervision_Art91">
        <di:waypoint x="1296" y="470" />
        <di:waypoint x="1360" y="470" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ExerciseIndependentSupervision_To_EndSupervisionActive_Art91_di"
                       bpmnElement="Flow_ExerciseIndependentSupervision_To_EndSupervisionActive_Art91">
        <di:waypoint x="1550" y="470" />
        <di:waypoint x="1630" y="470" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MessageFlow_SubmitRulesForSupervision_Art91_di"
                       bpmnElement="MessageFlow_SubmitRulesForSupervision_Art91">
        <di:waypoint x="1200" y="250" />
        <di:waypoint x="1200" y="470" />
        <di:waypoint x="1260" y="470" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
