<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art84_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art84_Reviewed">
    <bpmn:participant id="Participant_MemberState_Art84"
                      name="Member State"
                      processRef="Process_MemberState_Art84" />
    <bpmn:participant id="Participant_Commission_Art84"
                      name="Commission" />

    <bpmn:messageFlow id="MessageFlow_NotifyCommissionOfPenaltyProvisions_Art84"
                      sourceRef="Task_NotifyCommissionOfPenaltyProvisions_Art84"
                      targetRef="Participant_Commission_Art84" />
  </bpmn:collaboration>

  <bpmn:process id="Process_MemberState_Art84"
                name="Lay down and notify other penalty rules"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 84 based on the real English legal text from
      gdpr_articles/article_84.txt. This process captures the Member State duty to lay down rules
      on other penalties, especially for infringements not subject to administrative fines under
      Article 83, to take all necessary implementation measures, to ensure that the penalties are
      effective and proportionate and dissuasive, and to notify the Commission of the adopted
      provisions and any subsequent amendments.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_AssessNeedForOtherPenalties_Art84"
                     name="Assess need for other penalties">
      <bpmn:outgoing>Flow_Start_To_GatewayArticle83Scope_Art84</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_IsInfringementSubjectToArticle83Fines_Art84"
                           name="Is the infringement subject to administrative fines under Article 83?">
      <bpmn:incoming>Flow_Start_To_GatewayArticle83Scope_Art84</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayArticle83Scope_To_LayDownPenaltyRules_Art84</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayArticle83Scope_To_GatewayMergePenaltyScope_Art84</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_LayDownPenaltyRules_Art84"
               name="Lay down other penalty rules">
      <bpmn:incoming>Flow_GatewayArticle83Scope_To_LayDownPenaltyRules_Art84</bpmn:incoming>
      <bpmn:outgoing>Flow_LayDownPenaltyRules_To_GatewayMergePenaltyScope_Art84</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_MergePenaltyScope_Art84">
      <bpmn:incoming>Flow_GatewayArticle83Scope_To_GatewayMergePenaltyScope_Art84</bpmn:incoming>
      <bpmn:incoming>Flow_LayDownPenaltyRules_To_GatewayMergePenaltyScope_Art84</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMergePenaltyScope_To_TakeImplementationMeasures_Art84</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_TakeImplementationMeasures_Art84"
               name="Take implementation measures">
      <bpmn:incoming>Flow_GatewayMergePenaltyScope_To_TakeImplementationMeasures_Art84</bpmn:incoming>
      <bpmn:outgoing>Flow_TakeImplementationMeasures_To_EnsurePenaltyQuality_Art84</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EnsurePenaltyQuality_Art84"
               name="Ensure effective proportionate dissuasive penalties">
      <bpmn:incoming>Flow_TakeImplementationMeasures_To_EnsurePenaltyQuality_Art84</bpmn:incoming>
      <bpmn:outgoing>Flow_EnsurePenaltyQuality_To_NotifyCommission_Art84</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="Task_NotifyCommissionOfPenaltyProvisions_Art84"
                   name="Notify Commission of penalty provisions">
      <bpmn:incoming>Flow_EnsurePenaltyQuality_To_NotifyCommission_Art84</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyCommission_To_EndPenaltyFrameworkNotified_Art84</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_PenaltyFrameworkNotified_Art84"
                   name="Penalty framework notified">
      <bpmn:incoming>Flow_NotifyCommission_To_EndPenaltyFrameworkNotified_Art84</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_GatewayArticle83Scope_Art84"
                       sourceRef="StartEvent_AssessNeedForOtherPenalties_Art84"
                       targetRef="Gateway_IsInfringementSubjectToArticle83Fines_Art84" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle83Scope_To_LayDownPenaltyRules_Art84"
                       name="No"
                       sourceRef="Gateway_IsInfringementSubjectToArticle83Fines_Art84"
                       targetRef="Task_LayDownPenaltyRules_Art84" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle83Scope_To_GatewayMergePenaltyScope_Art84"
                       name="Yes"
                       sourceRef="Gateway_IsInfringementSubjectToArticle83Fines_Art84"
                       targetRef="Gateway_MergePenaltyScope_Art84" />
    <bpmn:sequenceFlow id="Flow_LayDownPenaltyRules_To_GatewayMergePenaltyScope_Art84"
                       sourceRef="Task_LayDownPenaltyRules_Art84"
                       targetRef="Gateway_MergePenaltyScope_Art84" />
    <bpmn:sequenceFlow id="Flow_GatewayMergePenaltyScope_To_TakeImplementationMeasures_Art84"
                       sourceRef="Gateway_MergePenaltyScope_Art84"
                       targetRef="Task_TakeImplementationMeasures_Art84" />
    <bpmn:sequenceFlow id="Flow_TakeImplementationMeasures_To_EnsurePenaltyQuality_Art84"
                       sourceRef="Task_TakeImplementationMeasures_Art84"
                       targetRef="Task_EnsurePenaltyQuality_Art84" />
    <bpmn:sequenceFlow id="Flow_EnsurePenaltyQuality_To_NotifyCommission_Art84"
                       sourceRef="Task_EnsurePenaltyQuality_Art84"
                       targetRef="Task_NotifyCommissionOfPenaltyProvisions_Art84" />
    <bpmn:sequenceFlow id="Flow_NotifyCommission_To_EndPenaltyFrameworkNotified_Art84"
                       sourceRef="Task_NotifyCommissionOfPenaltyProvisions_Art84"
                       targetRef="EndEvent_PenaltyFrameworkNotified_Art84" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art84_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art84_Reviewed"
                      bpmnElement="Collaboration_Art84_Reviewed">
      <bpmndi:BPMNShape id="Participant_MemberState_Art84_di"
                        bpmnElement="Participant_MemberState_Art84"
                        isHorizontal="true">
        <dc:Bounds x="80" y="80" width="1680" height="260" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Commission_Art84_di"
                        bpmnElement="Participant_Commission_Art84"
                        isHorizontal="true">
        <dc:Bounds x="80" y="400" width="1680" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_AssessNeedForOtherPenalties_Art84_di"
                        bpmnElement="StartEvent_AssessNeedForOtherPenalties_Art84">
        <dc:Bounds x="120" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IsInfringementSubjectToArticle83Fines_Art84_di"
                        bpmnElement="Gateway_IsInfringementSubjectToArticle83Fines_Art84"
                        isMarkerVisible="true">
        <dc:Bounds x="230" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LayDownPenaltyRules_Art84_di"
                        bpmnElement="Task_LayDownPenaltyRules_Art84">
        <dc:Bounds x="390" y="90" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MergePenaltyScope_Art84_di"
                        bpmnElement="Gateway_MergePenaltyScope_Art84"
                        isMarkerVisible="true">
        <dc:Bounds x="660" y="185" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_TakeImplementationMeasures_Art84_di"
                        bpmnElement="Task_TakeImplementationMeasures_Art84">
        <dc:Bounds x="790" y="170" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EnsurePenaltyQuality_Art84_di"
                        bpmnElement="Task_EnsurePenaltyQuality_Art84">
        <dc:Bounds x="1060" y="170" width="240" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyCommissionOfPenaltyProvisions_Art84_di"
                        bpmnElement="Task_NotifyCommissionOfPenaltyProvisions_Art84">
        <dc:Bounds x="1380" y="170" width="210" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_PenaltyFrameworkNotified_Art84_di"
                        bpmnElement="EndEvent_PenaltyFrameworkNotified_Art84">
        <dc:Bounds x="1660" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_GatewayArticle83Scope_Art84_di"
                       bpmnElement="Flow_Start_To_GatewayArticle83Scope_Art84">
        <di:waypoint x="156" y="210" />
        <di:waypoint x="230" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayArticle83Scope_To_LayDownPenaltyRules_Art84_di"
                       bpmnElement="Flow_GatewayArticle83Scope_To_LayDownPenaltyRules_Art84">
        <di:waypoint x="255" y="185" />
        <di:waypoint x="255" y="130" />
        <di:waypoint x="390" y="130" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="288" y="146" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayArticle83Scope_To_GatewayMergePenaltyScope_Art84_di"
                       bpmnElement="Flow_GatewayArticle83Scope_To_GatewayMergePenaltyScope_Art84">
        <di:waypoint x="280" y="210" />
        <di:waypoint x="660" y="210" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="458" y="192" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LayDownPenaltyRules_To_GatewayMergePenaltyScope_Art84_di"
                       bpmnElement="Flow_LayDownPenaltyRules_To_GatewayMergePenaltyScope_Art84">
        <di:waypoint x="580" y="130" />
        <di:waypoint x="685" y="130" />
        <di:waypoint x="685" y="185" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayMergePenaltyScope_To_TakeImplementationMeasures_Art84_di"
                       bpmnElement="Flow_GatewayMergePenaltyScope_To_TakeImplementationMeasures_Art84">
        <di:waypoint x="710" y="210" />
        <di:waypoint x="790" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TakeImplementationMeasures_To_EnsurePenaltyQuality_Art84_di"
                       bpmnElement="Flow_TakeImplementationMeasures_To_EnsurePenaltyQuality_Art84">
        <di:waypoint x="980" y="210" />
        <di:waypoint x="1060" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EnsurePenaltyQuality_To_NotifyCommission_Art84_di"
                       bpmnElement="Flow_EnsurePenaltyQuality_To_NotifyCommission_Art84">
        <di:waypoint x="1300" y="210" />
        <di:waypoint x="1380" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NotifyCommission_To_EndPenaltyFrameworkNotified_Art84_di"
                       bpmnElement="Flow_NotifyCommission_To_EndPenaltyFrameworkNotified_Art84">
        <di:waypoint x="1590" y="210" />
        <di:waypoint x="1660" y="210" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MessageFlow_NotifyCommissionOfPenaltyProvisions_Art84_di"
                       bpmnElement="MessageFlow_NotifyCommissionOfPenaltyProvisions_Art84">
        <di:waypoint x="1485" y="250" />
        <di:waypoint x="1485" y="400" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
