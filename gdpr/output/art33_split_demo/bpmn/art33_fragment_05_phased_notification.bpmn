<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  id="Definitions_Art33_Fragment_05"
  targetNamespace="https://example.org/gdpr/bpmn/art33/fragment05">
  <bpmn:collaboration id="Collaboration_Art33_Fragment_05">
    <bpmn:participant id="Participant_Controller_F05" name="Controller" processRef="Process_Controller_F05" />
    <bpmn:participant id="Participant_SupervisoryAuthority_F05" name="Supervisory Authority" />
    <bpmn:messageFlow id="MessageFlow_ControllerInitialToAuthority_F05" sourceRef="Task_SendInitialNotification_F05" targetRef="Participant_SupervisoryAuthority_F05" />
    <bpmn:messageFlow id="MessageFlow_ControllerFollowUpToAuthority_F05" sourceRef="Task_SendFollowUpInformation_F05" targetRef="Participant_SupervisoryAuthority_F05" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Controller_F05" name="Phased authority notification" isExecutable="false">
    <bpmn:startEvent id="StartEvent_PhasedNotificationNeeded_F05" name="Phased notification needed">
      <bpmn:outgoing>Flow_Start_To_PhasedWithin72h_F05</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_PhasedWithin72h_F05" name="72 hours elapsed since awareness?">
      <bpmn:incoming>Flow_Start_To_PhasedWithin72h_F05</bpmn:incoming>
      <bpmn:outgoing>Flow_PhasedWithin72h_To_SendInitial_F05</bpmn:outgoing>
      <bpmn:outgoing>Flow_PhasedWithin72h_To_RecordDelay_F05</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_RecordDelayReasonsInitial_F05" name="Record reasons for delay">
      <bpmn:incoming>Flow_PhasedWithin72h_To_RecordDelay_F05</bpmn:incoming>
      <bpmn:outgoing>Flow_RecordDelay_To_SendInitial_F05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_SendInitialNotification_F05" name="Send initial breach notification">
      <bpmn:incoming>Flow_PhasedWithin72h_To_SendInitial_F05</bpmn:incoming>
      <bpmn:incoming>Flow_RecordDelay_To_SendInitial_F05</bpmn:incoming>
      <bpmn:outgoing>Flow_SendInitial_To_CollectRemaining_F05</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:task id="Task_CollectRemainingInformation_F05" name="Collect remaining information">
      <bpmn:incoming>Flow_SendInitial_To_CollectRemaining_F05</bpmn:incoming>
      <bpmn:outgoing>Flow_CollectRemaining_To_SendFollowUp_F05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_SendFollowUpInformation_F05" name="Send follow-up information without undue delay">
      <bpmn:incoming>Flow_CollectRemaining_To_SendFollowUp_F05</bpmn:incoming>
      <bpmn:outgoing>Flow_SendFollowUp_To_DocumentBreach_F05</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:task id="Task_DocumentBreach_F05" name="Document breach, effects, and remedial action">
      <bpmn:incoming>Flow_SendFollowUp_To_DocumentBreach_F05</bpmn:incoming>
      <bpmn:outgoing>Flow_DocumentBreach_To_End_F05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_PhasedNotificationHandled_F05" name="Phased notification completed and documented">
      <bpmn:incoming>Flow_DocumentBreach_To_End_F05</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_PhasedWithin72h_F05" sourceRef="StartEvent_PhasedNotificationNeeded_F05" targetRef="Gateway_PhasedWithin72h_F05" />
    <bpmn:sequenceFlow id="Flow_PhasedWithin72h_To_SendInitial_F05" name="No" sourceRef="Gateway_PhasedWithin72h_F05" targetRef="Task_SendInitialNotification_F05" />
    <bpmn:sequenceFlow id="Flow_PhasedWithin72h_To_RecordDelay_F05" name="Yes" sourceRef="Gateway_PhasedWithin72h_F05" targetRef="Task_RecordDelayReasonsInitial_F05" />
    <bpmn:sequenceFlow id="Flow_RecordDelay_To_SendInitial_F05" sourceRef="Task_RecordDelayReasonsInitial_F05" targetRef="Task_SendInitialNotification_F05" />
    <bpmn:sequenceFlow id="Flow_SendInitial_To_CollectRemaining_F05" sourceRef="Task_SendInitialNotification_F05" targetRef="Task_CollectRemainingInformation_F05" />
    <bpmn:sequenceFlow id="Flow_CollectRemaining_To_SendFollowUp_F05" sourceRef="Task_CollectRemainingInformation_F05" targetRef="Task_SendFollowUpInformation_F05" />
    <bpmn:sequenceFlow id="Flow_SendFollowUp_To_DocumentBreach_F05" sourceRef="Task_SendFollowUpInformation_F05" targetRef="Task_DocumentBreach_F05" />
    <bpmn:sequenceFlow id="Flow_DocumentBreach_To_End_F05" sourceRef="Task_DocumentBreach_F05" targetRef="EndEvent_PhasedNotificationHandled_F05" />
  </bpmn:process>
</bpmn:definitions>
