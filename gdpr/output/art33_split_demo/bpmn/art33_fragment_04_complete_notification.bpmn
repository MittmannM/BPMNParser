<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  id="Definitions_Art33_Fragment_04"
  targetNamespace="https://example.org/gdpr/bpmn/art33/fragment04">
  <bpmn:collaboration id="Collaboration_Art33_Fragment_04">
    <bpmn:participant id="Participant_Controller_F04" name="Controller" processRef="Process_Controller_F04" />
    <bpmn:participant id="Participant_SupervisoryAuthority_F04" name="Supervisory Authority" />
    <bpmn:messageFlow id="MessageFlow_ControllerToAuthority_F04" sourceRef="Task_SendFullNotification_F04" targetRef="Participant_SupervisoryAuthority_F04" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Controller_F04" name="Complete authority notification" isExecutable="false">
    <bpmn:startEvent id="StartEvent_CompleteDossierReady_F04" name="Complete dossier ready">
      <bpmn:outgoing>Flow_Start_To_FullWithin72h_F04</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_FullWithin72h_F04" name="72 hours elapsed since awareness?">
      <bpmn:incoming>Flow_Start_To_FullWithin72h_F04</bpmn:incoming>
      <bpmn:outgoing>Flow_FullWithin72h_To_SendFull_F04</bpmn:outgoing>
      <bpmn:outgoing>Flow_FullWithin72h_To_RecordDelay_F04</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_RecordDelayReasonsFull_F04" name="Record reasons for delay">
      <bpmn:incoming>Flow_FullWithin72h_To_RecordDelay_F04</bpmn:incoming>
      <bpmn:outgoing>Flow_RecordDelay_To_SendFull_F04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sendTask id="Task_SendFullNotification_F04" name="Notify supervisory authority">
      <bpmn:incoming>Flow_FullWithin72h_To_SendFull_F04</bpmn:incoming>
      <bpmn:incoming>Flow_RecordDelay_To_SendFull_F04</bpmn:incoming>
      <bpmn:outgoing>Flow_SendFull_To_DocumentBreach_F04</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:task id="Task_DocumentBreach_F04" name="Document breach, effects, and remedial action">
      <bpmn:incoming>Flow_SendFull_To_DocumentBreach_F04</bpmn:incoming>
      <bpmn:outgoing>Flow_DocumentBreach_To_End_F04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_CompleteNotificationHandled_F04" name="Notification sent and documented">
      <bpmn:incoming>Flow_DocumentBreach_To_End_F04</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_FullWithin72h_F04" sourceRef="StartEvent_CompleteDossierReady_F04" targetRef="Gateway_FullWithin72h_F04" />
    <bpmn:sequenceFlow id="Flow_FullWithin72h_To_SendFull_F04" name="No" sourceRef="Gateway_FullWithin72h_F04" targetRef="Task_SendFullNotification_F04" />
    <bpmn:sequenceFlow id="Flow_FullWithin72h_To_RecordDelay_F04" name="Yes" sourceRef="Gateway_FullWithin72h_F04" targetRef="Task_RecordDelayReasonsFull_F04" />
    <bpmn:sequenceFlow id="Flow_RecordDelay_To_SendFull_F04" sourceRef="Task_RecordDelayReasonsFull_F04" targetRef="Task_SendFullNotification_F04" />
    <bpmn:sequenceFlow id="Flow_SendFull_To_DocumentBreach_F04" sourceRef="Task_SendFullNotification_F04" targetRef="Task_DocumentBreach_F04" />
    <bpmn:sequenceFlow id="Flow_DocumentBreach_To_End_F04" sourceRef="Task_DocumentBreach_F04" targetRef="EndEvent_CompleteNotificationHandled_F04" />
  </bpmn:process>
</bpmn:definitions>
