<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  id="Definitions_Art33_Fragment_06"
  targetNamespace="https://example.org/gdpr/bpmn/art33/fragment06">
  <bpmn:process id="Process_Controller_F06" name="Documentation duty" isExecutable="false">
    <bpmn:startEvent id="StartEvent_DocumentationDuty_F06" name="Personal data breach known">
      <bpmn:outgoing>Flow_Start_To_DocumentBreach_F06</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_DocumentBreach_F06" name="Document facts, effects, and remedial action">
      <bpmn:incoming>Flow_Start_To_DocumentBreach_F06</bpmn:incoming>
      <bpmn:outgoing>Flow_DocumentBreach_To_End_F06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_DocumentationComplete_F06" name="Compliance evidence available">
      <bpmn:incoming>Flow_DocumentBreach_To_End_F06</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:textAnnotation id="Annotation_DocumentationDuty_F06">
      <bpmn:text>Documentation must enable the supervisory authority to verify compliance with Article 33.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_DocumentationDuty_F06" sourceRef="Task_DocumentBreach_F06" targetRef="Annotation_DocumentationDuty_F06" />
    <bpmn:sequenceFlow id="Flow_Start_To_DocumentBreach_F06" sourceRef="StartEvent_DocumentationDuty_F06" targetRef="Task_DocumentBreach_F06" />
    <bpmn:sequenceFlow id="Flow_DocumentBreach_To_End_F06" sourceRef="Task_DocumentBreach_F06" targetRef="EndEvent_DocumentationComplete_F06" />
  </bpmn:process>
</bpmn:definitions>
