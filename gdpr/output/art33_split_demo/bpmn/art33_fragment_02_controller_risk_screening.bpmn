<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  id="Definitions_Art33_Fragment_02"
  targetNamespace="https://example.org/gdpr/bpmn/art33/fragment02">
  <bpmn:process id="Process_Controller_F02" name="Controller risk screening" isExecutable="false">
    <bpmn:startEvent id="StartEvent_ControllerAware_F02" name="Controller becomes aware of breach">
      <bpmn:outgoing>Flow_Aware_To_AssessRisk_F02</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_AssessRisk_F02" name="Assess risk to rights and freedoms">
      <bpmn:incoming>Flow_Aware_To_AssessRisk_F02</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessRisk_To_RiskGateway_F02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_RiskUnlikely_F02" name="Risk unlikely?">
      <bpmn:incoming>Flow_AssessRisk_To_RiskGateway_F02</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskGateway_To_DocumentOnly_F02</bpmn:outgoing>
      <bpmn:outgoing>Flow_RiskGateway_To_NotificationRequired_F02</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_DocumentBreach_F02" name="Document breach, effects, and remedial action">
      <bpmn:incoming>Flow_RiskGateway_To_DocumentOnly_F02</bpmn:incoming>
      <bpmn:outgoing>Flow_DocumentOnly_To_End_F02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_NoAuthorityNotice_F02" name="No authority notification required">
      <bpmn:incoming>Flow_DocumentOnly_To_End_F02</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_NotificationRequired_F02" name="Authority notification required">
      <bpmn:incoming>Flow_RiskGateway_To_NotificationRequired_F02</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Aware_To_AssessRisk_F02" sourceRef="StartEvent_ControllerAware_F02" targetRef="Task_AssessRisk_F02" />
    <bpmn:sequenceFlow id="Flow_AssessRisk_To_RiskGateway_F02" sourceRef="Task_AssessRisk_F02" targetRef="Gateway_RiskUnlikely_F02" />
    <bpmn:sequenceFlow id="Flow_RiskGateway_To_DocumentOnly_F02" name="Yes" sourceRef="Gateway_RiskUnlikely_F02" targetRef="Task_DocumentBreach_F02" />
    <bpmn:sequenceFlow id="Flow_RiskGateway_To_NotificationRequired_F02" name="No" sourceRef="Gateway_RiskUnlikely_F02" targetRef="EndEvent_NotificationRequired_F02" />
    <bpmn:sequenceFlow id="Flow_DocumentOnly_To_End_F02" sourceRef="Task_DocumentBreach_F02" targetRef="EndEvent_NoAuthorityNotice_F02" />
  </bpmn:process>
</bpmn:definitions>
