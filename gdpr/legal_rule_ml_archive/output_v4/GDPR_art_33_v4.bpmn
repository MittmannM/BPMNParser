    <bpmn:textAnnotation id="Annotation_1321ea25"><bpmn:text>Notify the competent supervisory authority&#10;Applies when: Data Breach Detected AND Became Aware of Breach&#10;Perform without undue delay&#10;Applies when: Data Breach Detected AND Likely to Cause Risk AND High Risk to Individuals AND Risk to Rights & Freedoms</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_85b11454"><bpmn:text>Perform without undue delay&#10;Applies when: Became Aware of Breach AND Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_eb999471"><bpmn:text>Further information may be provided later&#10;Applies when: Data Breach Detected AND Data Stored</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_1c0128f4"><bpmn:text>Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_bf5627c7"><bpmn:text>Applies when: Data Breach Detected AND Likely to Cause Risk</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_2603d5f9"><bpmn:text>Applies when: Data Breach Detected&#10;Applies when: Data Breach Detected AND High Risk to Individuals</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_ba4c70ca"><bpmn:text>Notify the competent supervisory authority&#10;Further information may be provided later&#10;Perform without undue delay&#10;Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_610e556d"><bpmn:text>Notify the competent supervisory authority&#10;Relates to Article 33&#10;Outcome should be verifiable&#10;Applies when: Data Breach Detected</bpmn:text></bpmn:textAnnotation>
