<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art46_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art46_Reviewed">
    <bpmn:participant id="Participant_ControllerProcessor_Art46"
                      name="Controller or Processor"
                      processRef="Process_ControllerProcessor_Art46" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art46"
                      name="Supervisory Authority" />
    <bpmn:participant id="Participant_Counterparty_Art46"
                      name="Third-country recipient or public authority" />

    <bpmn:messageFlow id="MessageFlow_PublicBodyInstrument_Art46"
                      sourceRef="SendTask_UsePublicBodyInstrument_Art46"
                      targetRef="Participant_Counterparty_Art46" />
    <bpmn:messageFlow id="MessageFlow_CodeCommitments_Art46"
                      sourceRef="SendTask_AgreeCodeCommitments_Art46"
                      targetRef="Participant_Counterparty_Art46" />
    <bpmn:messageFlow id="MessageFlow_CertificationCommitments_Art46"
                      sourceRef="SendTask_AgreeCertificationCommitments_Art46"
                      targetRef="Participant_Counterparty_Art46" />
    <bpmn:messageFlow id="MessageFlow_RequestClauseAuthorisation_Art46"
                      sourceRef="SendTask_RequestClauseAuthorisation_Art46"
                      targetRef="Participant_SupervisoryAuthority_Art46" />
    <bpmn:messageFlow id="MessageFlow_ClauseAuthorisationDecision_Art46"
                      sourceRef="Participant_SupervisoryAuthority_Art46"
                      targetRef="ReceiveTask_ReceiveClauseAuthorisation_Art46" />
    <bpmn:messageFlow id="MessageFlow_ConcludeClauses_Art46"
                      sourceRef="SendTask_ConcludeContractualClauses_Art46"
                      targetRef="Participant_Counterparty_Art46" />
    <bpmn:messageFlow id="MessageFlow_RequestArrangementAuthorisation_Art46"
                      sourceRef="SendTask_RequestArrangementAuthorisation_Art46"
                      targetRef="Participant_SupervisoryAuthority_Art46" />
    <bpmn:messageFlow id="MessageFlow_ArrangementAuthorisationDecision_Art46"
                      sourceRef="Participant_SupervisoryAuthority_Art46"
                      targetRef="ReceiveTask_ReceiveArrangementAuthorisation_Art46" />
    <bpmn:messageFlow id="MessageFlow_ConcludeArrangement_Art46"
                      sourceRef="SendTask_ConcludeAdministrativeArrangement_Art46"
                      targetRef="Participant_Counterparty_Art46" />
    <bpmn:messageFlow id="MessageFlow_TransferPersonalData_Art46"
                      sourceRef="SendTask_TransferData_Art46"
                      targetRef="Participant_Counterparty_Art46" />
  </bpmn:collaboration>

  <bpmn:process id="Process_ControllerProcessor_Art46"
                name="Transfers subject to appropriate safeguards"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 46 based on the real English legal text from
      gdpr_articles/article_46.txt. The model shows the absence-of-adequacy precondition,
      enforceable-rights and effective-remedies requirement, the six Article 46(2) safeguard
      routes that do not require specific supervisory-authority authorisation, the two
      Article 46(3) safeguard routes that do require authorisation and Article 63 consistency
      handling, and the continuing validity of legacy authorisations and Commission decisions
      under Article 46(5).
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_LegacyApproval_Art46"
                     name="Existing legacy approval">
      <bpmn:outgoing>Flow_LegacyStart_To_ContinueLegacyApproval_Art46</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_ContinueLegacyApproval_Art46"
               name="Continue relying on legacy approval">
      <bpmn:incoming>Flow_LegacyStart_To_ContinueLegacyApproval_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_ContinueLegacyApproval_To_EndLegacyApproval_Art46</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_LegacyApprovalValid_Art46"
                   name="Legacy approval remains valid">
      <bpmn:incoming>Flow_ContinueLegacyApproval_To_EndLegacyApproval_Art46</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="StartEvent_NeedTransfer_Art46"
                     name="Need transfer">
      <bpmn:outgoing>Flow_Start_To_GatewayAdequacy_Art46</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_AdequacyDecision_Art46"
                           name="Is an Article 45(3) adequacy decision in force?">
      <bpmn:incoming>Flow_Start_To_GatewayAdequacy_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAdequacy_To_EndUseArticle45_Art46</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAdequacy_To_CheckRightsRemedies_Art46</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_UseArticle45Route_Art46"
                   name="Use Article 45 route">
      <bpmn:incoming>Flow_GatewayAdequacy_To_EndUseArticle45_Art46</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_CheckRightsRemedies_Art46"
               name="Check rights and remedies">
      <bpmn:incoming>Flow_GatewayAdequacy_To_CheckRightsRemedies_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckRightsRemedies_To_GatewayRightsRemedies_Art46</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_RightsRemedies_Art46"
                           name="Are enforceable rights and remedies available?">
      <bpmn:incoming>Flow_CheckRightsRemedies_To_GatewayRightsRemedies_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRightsRemedies_To_EndNoTransfer_Art46</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRightsRemedies_To_GatewayAuthorisationRequired_Art46</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NoTransfer_Art46"
                   name="Do not transfer">
      <bpmn:incoming>Flow_GatewayRightsRemedies_To_EndNoTransfer_Art46</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_AuthorisationRequired_Art46"
                           name="Does the safeguard need SA authorisation?">
      <bpmn:incoming>Flow_GatewayRightsRemedies_To_GatewayAuthorisationRequired_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAuthorisationRequired_To_GatewayArticle462_Art46</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAuthorisationRequired_To_GatewayArticle463_Art46</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_Article462Safeguard_Art46"
                           name="Which Article 46(2) safeguard applies?">
      <bpmn:incoming>Flow_GatewayAuthorisationRequired_To_GatewayArticle462_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayArticle462_To_PublicBodyInstrument_Art46</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayArticle462_To_BCRs_Art46</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayArticle462_To_CommissionSCCs_Art46</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayArticle462_To_SASCCs_Art46</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayArticle462_To_CodeCommitments_Art46</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayArticle462_To_CertificationCommitments_Art46</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_UsePublicBodyInstrument_Art46"
                   name="Use public-body instrument">
      <bpmn:incoming>Flow_GatewayArticle462_To_PublicBodyInstrument_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_PublicBodyInstrument_To_GatewaySafeguardsReady_Art46</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_UseBCRs_Art46"
               name="Use Article 47 BCRs">
      <bpmn:incoming>Flow_GatewayArticle462_To_BCRs_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_BCRs_To_GatewaySafeguardsReady_Art46</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_UseCommissionSCCs_Art46"
               name="Use Commission SCCs">
      <bpmn:incoming>Flow_GatewayArticle462_To_CommissionSCCs_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_CommissionSCCs_To_GatewaySafeguardsReady_Art46</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_UseSASCCs_Art46"
               name="Use SA SCCs approved by the Commission">
      <bpmn:incoming>Flow_GatewayArticle462_To_SASCCs_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_SASCCs_To_GatewaySafeguardsReady_Art46</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_AgreeCodeCommitments_Art46"
                   name="Agree code commitments">
      <bpmn:incoming>Flow_GatewayArticle462_To_CodeCommitments_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_CodeCommitments_To_GatewaySafeguardsReady_Art46</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_AgreeCertificationCommitments_Art46"
                   name="Agree certification commitments">
      <bpmn:incoming>Flow_GatewayArticle462_To_CertificationCommitments_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_CertificationCommitments_To_GatewaySafeguardsReady_Art46</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_Article463Safeguard_Art46"
                           name="Which Article 46(3) safeguard applies?">
      <bpmn:incoming>Flow_GatewayAuthorisationRequired_To_GatewayArticle463_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayArticle463_To_PrepareContractualClauses_Art46</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayArticle463_To_PrepareAdministrativeArrangement_Art46</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_PrepareContractualClauses_Art46"
               name="Prepare contractual clauses">
      <bpmn:incoming>Flow_GatewayArticle463_To_PrepareContractualClauses_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_PrepareContractualClauses_To_RequestClauseAuthorisation_Art46</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_RequestClauseAuthorisation_Art46"
                   name="Request clause authorisation">
      <bpmn:incoming>Flow_PrepareContractualClauses_To_RequestClauseAuthorisation_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestClauseAuthorisation_To_ReceiveClauseAuthorisation_Art46</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveClauseAuthorisation_Art46"
                      name="Receive clause authorisation">
      <bpmn:incoming>Flow_RequestClauseAuthorisation_To_ReceiveClauseAuthorisation_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveClauseAuthorisation_To_GatewayClauseAuthorised_Art46</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_ClauseAuthorised_Art46"
                           name="Was clause authorisation granted?">
      <bpmn:incoming>Flow_ReceiveClauseAuthorisation_To_GatewayClauseAuthorised_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayClauseAuthorised_To_EndClauseRejected_Art46</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayClauseAuthorised_To_ConcludeContractualClauses_Art46</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_ClauseRejected_Art46"
                   name="Clause authorisation denied">
      <bpmn:incoming>Flow_GatewayClauseAuthorised_To_EndClauseRejected_Art46</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_ConcludeContractualClauses_Art46"
                   name="Conclude contractual clauses">
      <bpmn:incoming>Flow_GatewayClauseAuthorised_To_ConcludeContractualClauses_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_ConcludeContractualClauses_To_GatewaySafeguardsReady_Art46</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_PrepareAdministrativeArrangement_Art46"
               name="Prepare administrative arrangement">
      <bpmn:incoming>Flow_GatewayArticle463_To_PrepareAdministrativeArrangement_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_PrepareAdministrativeArrangement_To_RequestArrangementAuthorisation_Art46</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_RequestArrangementAuthorisation_Art46"
                   name="Request arrangement authorisation">
      <bpmn:incoming>Flow_PrepareAdministrativeArrangement_To_RequestArrangementAuthorisation_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestArrangementAuthorisation_To_ReceiveArrangementAuthorisation_Art46</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveArrangementAuthorisation_Art46"
                      name="Receive arrangement authorisation">
      <bpmn:incoming>Flow_RequestArrangementAuthorisation_To_ReceiveArrangementAuthorisation_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveArrangementAuthorisation_To_GatewayArrangementAuthorised_Art46</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_ArrangementAuthorised_Art46"
                           name="Was arrangement authorisation granted?">
      <bpmn:incoming>Flow_ReceiveArrangementAuthorisation_To_GatewayArrangementAuthorised_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayArrangementAuthorised_To_EndArrangementRejected_Art46</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayArrangementAuthorised_To_ConcludeAdministrativeArrangement_Art46</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_ArrangementRejected_Art46"
                   name="Arrangement authorisation denied">
      <bpmn:incoming>Flow_GatewayArrangementAuthorised_To_EndArrangementRejected_Art46</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_ConcludeAdministrativeArrangement_Art46"
                   name="Conclude administrative arrangement">
      <bpmn:incoming>Flow_GatewayArrangementAuthorised_To_ConcludeAdministrativeArrangement_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_ConcludeAdministrativeArrangement_To_GatewaySafeguardsReady_Art46</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_SafeguardsReady_Art46">
      <bpmn:incoming>Flow_PublicBodyInstrument_To_GatewaySafeguardsReady_Art46</bpmn:incoming>
      <bpmn:incoming>Flow_BCRs_To_GatewaySafeguardsReady_Art46</bpmn:incoming>
      <bpmn:incoming>Flow_CommissionSCCs_To_GatewaySafeguardsReady_Art46</bpmn:incoming>
      <bpmn:incoming>Flow_SASCCs_To_GatewaySafeguardsReady_Art46</bpmn:incoming>
      <bpmn:incoming>Flow_CodeCommitments_To_GatewaySafeguardsReady_Art46</bpmn:incoming>
      <bpmn:incoming>Flow_CertificationCommitments_To_GatewaySafeguardsReady_Art46</bpmn:incoming>
      <bpmn:incoming>Flow_ConcludeContractualClauses_To_GatewaySafeguardsReady_Art46</bpmn:incoming>
      <bpmn:incoming>Flow_ConcludeAdministrativeArrangement_To_GatewaySafeguardsReady_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySafeguardsReady_To_TransferData_Art46</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_TransferData_Art46"
                   name="Transfer data">
      <bpmn:incoming>Flow_GatewaySafeguardsReady_To_TransferData_Art46</bpmn:incoming>
      <bpmn:outgoing>Flow_TransferData_To_EndTransferCompleted_Art46</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_TransferCompleted_Art46"
                   name="Transfer completed">
      <bpmn:incoming>Flow_TransferData_To_EndTransferCompleted_Art46</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_LegacyStart_To_ContinueLegacyApproval_Art46" sourceRef="StartEvent_LegacyApproval_Art46" targetRef="Task_ContinueLegacyApproval_Art46" />
    <bpmn:sequenceFlow id="Flow_ContinueLegacyApproval_To_EndLegacyApproval_Art46" sourceRef="Task_ContinueLegacyApproval_Art46" targetRef="EndEvent_LegacyApprovalValid_Art46" />
    <bpmn:sequenceFlow id="Flow_Start_To_GatewayAdequacy_Art46" sourceRef="StartEvent_NeedTransfer_Art46" targetRef="Gateway_AdequacyDecision_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayAdequacy_To_EndUseArticle45_Art46" name="Yes" sourceRef="Gateway_AdequacyDecision_Art46" targetRef="EndEvent_UseArticle45Route_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayAdequacy_To_CheckRightsRemedies_Art46" name="No" sourceRef="Gateway_AdequacyDecision_Art46" targetRef="Task_CheckRightsRemedies_Art46" />
    <bpmn:sequenceFlow id="Flow_CheckRightsRemedies_To_GatewayRightsRemedies_Art46" sourceRef="Task_CheckRightsRemedies_Art46" targetRef="Gateway_RightsRemedies_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayRightsRemedies_To_EndNoTransfer_Art46" name="No" sourceRef="Gateway_RightsRemedies_Art46" targetRef="EndEvent_NoTransfer_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayRightsRemedies_To_GatewayAuthorisationRequired_Art46" name="Yes" sourceRef="Gateway_RightsRemedies_Art46" targetRef="Gateway_AuthorisationRequired_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayAuthorisationRequired_To_GatewayArticle462_Art46" name="No" sourceRef="Gateway_AuthorisationRequired_Art46" targetRef="Gateway_Article462Safeguard_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayAuthorisationRequired_To_GatewayArticle463_Art46" name="Yes" sourceRef="Gateway_AuthorisationRequired_Art46" targetRef="Gateway_Article463Safeguard_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle462_To_PublicBodyInstrument_Art46" name="Public-body instrument" sourceRef="Gateway_Article462Safeguard_Art46" targetRef="SendTask_UsePublicBodyInstrument_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle462_To_BCRs_Art46" name="Article 47 BCRs" sourceRef="Gateway_Article462Safeguard_Art46" targetRef="Task_UseBCRs_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle462_To_CommissionSCCs_Art46" name="Commission SCCs" sourceRef="Gateway_Article462Safeguard_Art46" targetRef="Task_UseCommissionSCCs_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle462_To_SASCCs_Art46" name="SA SCCs approved by the Commission" sourceRef="Gateway_Article462Safeguard_Art46" targetRef="Task_UseSASCCs_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle462_To_CodeCommitments_Art46" name="Approved code commitments" sourceRef="Gateway_Article462Safeguard_Art46" targetRef="SendTask_AgreeCodeCommitments_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle462_To_CertificationCommitments_Art46" name="Approved certification commitments" sourceRef="Gateway_Article462Safeguard_Art46" targetRef="SendTask_AgreeCertificationCommitments_Art46" />
    <bpmn:sequenceFlow id="Flow_PublicBodyInstrument_To_GatewaySafeguardsReady_Art46" sourceRef="SendTask_UsePublicBodyInstrument_Art46" targetRef="Gateway_SafeguardsReady_Art46" />
    <bpmn:sequenceFlow id="Flow_BCRs_To_GatewaySafeguardsReady_Art46" sourceRef="Task_UseBCRs_Art46" targetRef="Gateway_SafeguardsReady_Art46" />
    <bpmn:sequenceFlow id="Flow_CommissionSCCs_To_GatewaySafeguardsReady_Art46" sourceRef="Task_UseCommissionSCCs_Art46" targetRef="Gateway_SafeguardsReady_Art46" />
    <bpmn:sequenceFlow id="Flow_SASCCs_To_GatewaySafeguardsReady_Art46" sourceRef="Task_UseSASCCs_Art46" targetRef="Gateway_SafeguardsReady_Art46" />
    <bpmn:sequenceFlow id="Flow_CodeCommitments_To_GatewaySafeguardsReady_Art46" sourceRef="SendTask_AgreeCodeCommitments_Art46" targetRef="Gateway_SafeguardsReady_Art46" />
    <bpmn:sequenceFlow id="Flow_CertificationCommitments_To_GatewaySafeguardsReady_Art46" sourceRef="SendTask_AgreeCertificationCommitments_Art46" targetRef="Gateway_SafeguardsReady_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle463_To_PrepareContractualClauses_Art46" name="Contractual clauses" sourceRef="Gateway_Article463Safeguard_Art46" targetRef="Task_PrepareContractualClauses_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle463_To_PrepareAdministrativeArrangement_Art46" name="Administrative arrangement" sourceRef="Gateway_Article463Safeguard_Art46" targetRef="Task_PrepareAdministrativeArrangement_Art46" />
    <bpmn:sequenceFlow id="Flow_PrepareContractualClauses_To_RequestClauseAuthorisation_Art46" sourceRef="Task_PrepareContractualClauses_Art46" targetRef="SendTask_RequestClauseAuthorisation_Art46" />
    <bpmn:sequenceFlow id="Flow_RequestClauseAuthorisation_To_ReceiveClauseAuthorisation_Art46" sourceRef="SendTask_RequestClauseAuthorisation_Art46" targetRef="ReceiveTask_ReceiveClauseAuthorisation_Art46" />
    <bpmn:sequenceFlow id="Flow_ReceiveClauseAuthorisation_To_GatewayClauseAuthorised_Art46" sourceRef="ReceiveTask_ReceiveClauseAuthorisation_Art46" targetRef="Gateway_ClauseAuthorised_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayClauseAuthorised_To_EndClauseRejected_Art46" name="No" sourceRef="Gateway_ClauseAuthorised_Art46" targetRef="EndEvent_ClauseRejected_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayClauseAuthorised_To_ConcludeContractualClauses_Art46" name="Yes" sourceRef="Gateway_ClauseAuthorised_Art46" targetRef="SendTask_ConcludeContractualClauses_Art46" />
    <bpmn:sequenceFlow id="Flow_ConcludeContractualClauses_To_GatewaySafeguardsReady_Art46" sourceRef="SendTask_ConcludeContractualClauses_Art46" targetRef="Gateway_SafeguardsReady_Art46" />
    <bpmn:sequenceFlow id="Flow_PrepareAdministrativeArrangement_To_RequestArrangementAuthorisation_Art46" sourceRef="Task_PrepareAdministrativeArrangement_Art46" targetRef="SendTask_RequestArrangementAuthorisation_Art46" />
    <bpmn:sequenceFlow id="Flow_RequestArrangementAuthorisation_To_ReceiveArrangementAuthorisation_Art46" sourceRef="SendTask_RequestArrangementAuthorisation_Art46" targetRef="ReceiveTask_ReceiveArrangementAuthorisation_Art46" />
    <bpmn:sequenceFlow id="Flow_ReceiveArrangementAuthorisation_To_GatewayArrangementAuthorised_Art46" sourceRef="ReceiveTask_ReceiveArrangementAuthorisation_Art46" targetRef="Gateway_ArrangementAuthorised_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayArrangementAuthorised_To_EndArrangementRejected_Art46" name="No" sourceRef="Gateway_ArrangementAuthorised_Art46" targetRef="EndEvent_ArrangementRejected_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewayArrangementAuthorised_To_ConcludeAdministrativeArrangement_Art46" name="Yes" sourceRef="Gateway_ArrangementAuthorised_Art46" targetRef="SendTask_ConcludeAdministrativeArrangement_Art46" />
    <bpmn:sequenceFlow id="Flow_ConcludeAdministrativeArrangement_To_GatewaySafeguardsReady_Art46" sourceRef="SendTask_ConcludeAdministrativeArrangement_Art46" targetRef="Gateway_SafeguardsReady_Art46" />
    <bpmn:sequenceFlow id="Flow_GatewaySafeguardsReady_To_TransferData_Art46" sourceRef="Gateway_SafeguardsReady_Art46" targetRef="SendTask_TransferData_Art46" />
    <bpmn:sequenceFlow id="Flow_TransferData_To_EndTransferCompleted_Art46" sourceRef="SendTask_TransferData_Art46" targetRef="EndEvent_TransferCompleted_Art46" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art46_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art46_Reviewed"
                      bpmnElement="Collaboration_Art46_Reviewed">
      <bpmndi:BPMNShape id="Participant_ControllerProcessor_Art46_di"
                        bpmnElement="Participant_ControllerProcessor_Art46"
                        isHorizontal="true">
        <dc:Bounds x="60" y="40" width="4300" height="940" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_SupervisoryAuthority_Art46_di"
                        bpmnElement="Participant_SupervisoryAuthority_Art46"
                        isHorizontal="true">
        <dc:Bounds x="60" y="1020" width="4300" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Counterparty_Art46_di"
                        bpmnElement="Participant_Counterparty_Art46"
