<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art80_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art80_Reviewed">
    <bpmn:participant id="Participant_NotForProfitBody_Art80"
                      name="Not-for-profit body, organisation, or association"
                      processRef="Process_NotForProfitBody_Art80" />
    <bpmn:participant id="Participant_DataSubject_Art80"
                      name="Data Subject" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art80"
                      name="Supervisory Authority" />
    <bpmn:participant id="Participant_Court_Art80"
                      name="Court" />

    <bpmn:messageFlow id="MessageFlow_RequestMandate_Art80"
                      sourceRef="SendTask_RequestMandate_Art80"
                      targetRef="Participant_DataSubject_Art80" />
    <bpmn:messageFlow id="MessageFlow_ReceiveMandate_Art80"
                      sourceRef="Participant_DataSubject_Art80"
                      targetRef="ReceiveTask_ReceiveMandate_Art80" />
    <bpmn:messageFlow id="MessageFlow_LodgeComplaint_Art80"
                      sourceRef="SendTask_LodgeComplaint_Art80"
                      targetRef="Participant_SupervisoryAuthority_Art80" />
    <bpmn:messageFlow id="MessageFlow_RequestJudicialRemedy_Art80"
                      sourceRef="SendTask_RequestJudicialRemedy_Art80"
                      targetRef="Participant_Court_Art80" />
    <bpmn:messageFlow id="MessageFlow_RequestCompensation_Art80"
                      sourceRef="SendTask_RequestCompensation_Art80"
                      targetRef="Participant_Court_Art80" />
  </bpmn:collaboration>

  <bpmn:process id="Process_NotForProfitBody_Art80"
                name="Representing a data subject under Article 80"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 80 based on the real English legal text from
      gdpr_articles/article_80.txt. The model shows the mandated representation route in
      Article 80(1) and the optional Member-State no-mandate route in Article 80(2).
      The no-mandate route is limited to complaints and the exercise of rights under
      Articles 78 and 79; compensation under Article 82 remains only on the mandated
      route and only where Member State law provides for it.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_AssessRepresentation_Art80"
                     name="Need representation">
      <bpmn:outgoing>Flow_Start_To_VerifyBodyCriteria_Art80</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_VerifyBodyCriteria_Art80"
               name="Check body criteria">
      <bpmn:incoming>Flow_Start_To_VerifyBodyCriteria_Art80</bpmn:incoming>
      <bpmn:outgoing>Flow_VerifyBodyCriteria_To_GatewayMandate_Art80</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_MandateStatus_Art80"
                           name="Is there a data-subject mandate?">
      <bpmn:incoming>Flow_VerifyBodyCriteria_To_GatewayMandate_Art80</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMandate_To_RequestMandate_Art80</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayMandate_To_GatewayMemberStateOption_Art80</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_RequestMandate_Art80"
                   name="Request mandate">
      <bpmn:incoming>Flow_GatewayMandate_To_RequestMandate_Art80</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestMandate_To_ReceiveMandate_Art80</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveMandate_Art80"
                      name="Receive mandate">
      <bpmn:incoming>Flow_RequestMandate_To_ReceiveMandate_Art80</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveMandate_To_GatewayActionScope_Art80</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_MemberStateOption_Art80"
                           name="Does Member State law allow a no-mandate route?">
      <bpmn:incoming>Flow_GatewayMandate_To_GatewayMemberStateOption_Art80</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayMemberStateOption_To_EndNoRepresentation_Art80</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayMemberStateOption_To_TaskAssessIndependentComplaint_Art80</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NoRepresentation_Art80"
                   name="No Article 80 route available">
      <bpmn:incoming>Flow_GatewayMemberStateOption_To_EndNoRepresentation_Art80</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_AssessIndependentComplaint_Art80"
               name="Check no-mandate action basis">
      <bpmn:incoming>Flow_GatewayMemberStateOption_To_TaskAssessIndependentComplaint_Art80</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessIndependentComplaint_To_GatewayActionScope_Art80</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_ActionScope_Art80"
                           name="Which Article 80 action will be exercised?">
      <bpmn:incoming>Flow_ReceiveMandate_To_GatewayActionScope_Art80</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayActionScope_To_LodgeComplaint_Art80</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayActionScope_To_RequestJudicialRemedy_Art80</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayActionScope_To_RequestCompensation_Art80</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_NoMandateActionScope_Art80"
                           name="Which no-mandate action will be exercised?">
      <bpmn:incoming>Flow_AssessIndependentComplaint_To_GatewayNoMandateActionScope_Art80</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayNoMandateActionScope_To_LodgeComplaint_Art80</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayNoMandateActionScope_To_RequestJudicialRemedy_Art80</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayNoMandateActionScope_To_EndNoRepresentation_Art80</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_LodgeComplaint_Art80"
                   name="Lodge complaint">
      <bpmn:incoming>Flow_GatewayActionScope_To_LodgeComplaint_Art80</bpmn:incoming>
      <bpmn:outgoing>Flow_LodgeComplaint_To_EndActionCompleted_Art80</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_RequestJudicialRemedy_Art80"
                   name="Request judicial remedy">
      <bpmn:incoming>Flow_GatewayActionScope_To_RequestJudicialRemedy_Art80</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestJudicialRemedy_To_EndActionCompleted_Art80</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_RequestCompensation_Art80"
                   name="Request compensation">
      <bpmn:incoming>Flow_GatewayActionScope_To_RequestCompensation_Art80</bpmn:incoming>
      <bpmn:outgoing>Flow_RequestCompensation_To_EndActionCompleted_Art80</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_ActionCompleted_Art80">
      <bpmn:incoming>Flow_LodgeComplaint_To_EndActionCompleted_Art80</bpmn:incoming>
      <bpmn:incoming>Flow_RequestJudicialRemedy_To_EndActionCompleted_Art80</bpmn:incoming>
      <bpmn:incoming>Flow_RequestCompensation_To_EndActionCompleted_Art80</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayActionCompleted_To_EndRepresentationCompleted_Art80</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_RepresentationCompleted_Art80"
                   name="Representation action completed">
      <bpmn:incoming>Flow_GatewayActionCompleted_To_EndRepresentationCompleted_Art80</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_VerifyBodyCriteria_Art80" sourceRef="StartEvent_AssessRepresentation_Art80" targetRef="Task_VerifyBodyCriteria_Art80" />
    <bpmn:sequenceFlow id="Flow_VerifyBodyCriteria_To_GatewayMandate_Art80" sourceRef="Task_VerifyBodyCriteria_Art80" targetRef="Gateway_MandateStatus_Art80" />
    <bpmn:sequenceFlow id="Flow_GatewayMandate_To_RequestMandate_Art80" name="Yes, obtain or confirm mandate" sourceRef="Gateway_MandateStatus_Art80" targetRef="SendTask_RequestMandate_Art80" />
    <bpmn:sequenceFlow id="Flow_GatewayMandate_To_GatewayMemberStateOption_Art80" name="No mandate available" sourceRef="Gateway_MandateStatus_Art80" targetRef="Gateway_MemberStateOption_Art80" />
    <bpmn:sequenceFlow id="Flow_RequestMandate_To_ReceiveMandate_Art80" sourceRef="SendTask_RequestMandate_Art80" targetRef="ReceiveTask_ReceiveMandate_Art80" />
    <bpmn:sequenceFlow id="Flow_ReceiveMandate_To_GatewayActionScope_Art80" sourceRef="ReceiveTask_ReceiveMandate_Art80" targetRef="Gateway_ActionScope_Art80" />
    <bpmn:sequenceFlow id="Flow_GatewayMemberStateOption_To_EndNoRepresentation_Art80" name="No" sourceRef="Gateway_MemberStateOption_Art80" targetRef="EndEvent_NoRepresentation_Art80" />
    <bpmn:sequenceFlow id="Flow_GatewayMemberStateOption_To_TaskAssessIndependentComplaint_Art80" name="Yes" sourceRef="Gateway_MemberStateOption_Art80" targetRef="Task_AssessIndependentComplaint_Art80" />
    <bpmn:sequenceFlow id="Flow_AssessIndependentComplaint_To_GatewayNoMandateActionScope_Art80" sourceRef="Task_AssessIndependentComplaint_Art80" targetRef="Gateway_NoMandateActionScope_Art80" />
    <bpmn:sequenceFlow id="Flow_GatewayActionScope_To_LodgeComplaint_Art80" name="Complaint under Article 77" sourceRef="Gateway_ActionScope_Art80" targetRef="SendTask_LodgeComplaint_Art80" />
    <bpmn:sequenceFlow id="Flow_GatewayActionScope_To_RequestJudicialRemedy_Art80" name="Judicial remedy under Articles 78 or 79" sourceRef="Gateway_ActionScope_Art80" targetRef="SendTask_RequestJudicialRemedy_Art80" />
    <bpmn:sequenceFlow id="Flow_GatewayActionScope_To_RequestCompensation_Art80" name="Compensation under Article 82" sourceRef="Gateway_ActionScope_Art80" targetRef="SendTask_RequestCompensation_Art80" />
    <bpmn:sequenceFlow id="Flow_GatewayNoMandateActionScope_To_LodgeComplaint_Art80" name="Complaint under Article 77" sourceRef="Gateway_NoMandateActionScope_Art80" targetRef="SendTask_LodgeComplaint_Art80" />
    <bpmn:sequenceFlow id="Flow_GatewayNoMandateActionScope_To_RequestJudicialRemedy_Art80" name="Judicial remedy under Articles 78 or 79" sourceRef="Gateway_NoMandateActionScope_Art80" targetRef="SendTask_RequestJudicialRemedy_Art80" />
    <bpmn:sequenceFlow id="Flow_GatewayNoMandateActionScope_To_EndNoRepresentation_Art80" name="None" sourceRef="Gateway_NoMandateActionScope_Art80" targetRef="EndEvent_NoRepresentation_Art80" />
    <bpmn:sequenceFlow id="Flow_LodgeComplaint_To_EndActionCompleted_Art80" sourceRef="SendTask_LodgeComplaint_Art80" targetRef="Gateway_ActionCompleted_Art80" />
    <bpmn:sequenceFlow id="Flow_RequestJudicialRemedy_To_EndActionCompleted_Art80" sourceRef="SendTask_RequestJudicialRemedy_Art80" targetRef="Gateway_ActionCompleted_Art80" />
    <bpmn:sequenceFlow id="Flow_RequestCompensation_To_EndActionCompleted_Art80" sourceRef="SendTask_RequestCompensation_Art80" targetRef="Gateway_ActionCompleted_Art80" />
    <bpmn:sequenceFlow id="Flow_GatewayActionCompleted_To_EndRepresentationCompleted_Art80" sourceRef="Gateway_ActionCompleted_Art80" targetRef="EndEvent_RepresentationCompleted_Art80" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art80_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art80_Reviewed"
                      bpmnElement="Collaboration_Art80_Reviewed">
      <bpmndi:BPMNShape id="Participant_NotForProfitBody_Art80_di" bpmnElement="Participant_NotForProfitBody_Art80" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="3900" height="760" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art80_di" bpmnElement="Participant_DataSubject_Art80" isHorizontal="true">
        <dc:Bounds x="60" y="860" width="3900" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_SupervisoryAuthority_Art80_di" bpmnElement="Participant_SupervisoryAuthority_Art80" isHorizontal="true">
        <dc:Bounds x="60" y="1020" width="3900" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Court_Art80_di" bpmnElement="Participant_Court_Art80" isHorizontal="true">
        <dc:Bounds x="60" y="1180" width="3900" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_AssessRepresentation_Art80_di" bpmnElement="StartEvent_AssessRepresentation_Art80">
        <dc:Bounds x="120" y="382" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_VerifyBodyCriteria_Art80_di" bpmnElement="Task_VerifyBodyCriteria_Art80">
        <dc:Bounds x="240" y="360" width="520" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MandateStatus_Art80_di" bpmnElement="Gateway_MandateStatus_Art80" isMarkerVisible="true">
        <dc:Bounds x="880" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_RequestMandate_Art80_di" bpmnElement="SendTask_RequestMandate_Art80">
        <dc:Bounds x="1090" y="170" width="300" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceiveMandate_Art80_di" bpmnElement="ReceiveTask_ReceiveMandate_Art80">
        <dc:Bounds x="1520" y="170" width="290" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MemberStateOption_Art80_di" bpmnElement="Gateway_MemberStateOption_Art80" isMarkerVisible="true">
        <dc:Bounds x="1090" y="535" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoRepresentation_Art80_di" bpmnElement="EndEvent_NoRepresentation_Art80">
        <dc:Bounds x="1290" y="662" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessIndependentComplaint_Art80_di" bpmnElement="Task_AssessIndependentComplaint_Art80">
        <dc:Bounds x="1280" y="520" width="520" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ActionScope_Art80_di" bpmnElement="Gateway_ActionScope_Art80" isMarkerVisible="true">
        <dc:Bounds x="2010" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_NoMandateActionScope_Art80_di" bpmnElement="Gateway_NoMandateActionScope_Art80" isMarkerVisible="true">
        <dc:Bounds x="2010" y="535" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_LodgeComplaint_Art80_di" bpmnElement="SendTask_LodgeComplaint_Art80">
        <dc:Bounds x="2230" y="120" width="450" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_RequestJudicialRemedy_Art80_di" bpmnElement="SendTask_RequestJudicialRemedy_Art80">
        <dc:Bounds x="2230" y="330" width="360" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_RequestCompensation_Art80_di" bpmnElement="SendTask_RequestCompensation_Art80">
        <dc:Bounds x="2230" y="540" width="420" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ActionCompleted_Art80_di" bpmnElement="Gateway_ActionCompleted_Art80" isMarkerVisible="true">
        <dc:Bounds x="2890" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RepresentationCompleted_Art80_di" bpmnElement="EndEvent_RepresentationCompleted_Art80">
        <dc:Bounds x="3100" y="382" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_VerifyBodyCriteria_Art80_di" bpmnElement="Flow_Start_To_VerifyBodyCriteria_Art80">
        <di:waypoint x="156" y="400" />
        <di:waypoint x="240" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_VerifyBodyCriteria_To_GatewayMandate_Art80_di" bpmnElement="Flow_VerifyBodyCriteria_To_GatewayMandate_Art80">
        <di:waypoint x="760" y="400" />
        <di:waypoint x="880" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayMandate_To_RequestMandate_Art80_di" bpmnElement="Flow_GatewayMandate_To_RequestMandate_Art80">
        <di:waypoint x="905" y="375" />
        <di:waypoint x="905" y="210" />
        <di:waypoint x="1090" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayMandate_To_GatewayMemberStateOption_Art80_di" bpmnElement="Flow_GatewayMandate_To_GatewayMemberStateOption_Art80">
        <di:waypoint x="905" y="425" />
        <di:waypoint x="905" y="560" />
        <di:waypoint x="1090" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RequestMandate_To_ReceiveMandate_Art80_di" bpmnElement="Flow_RequestMandate_To_ReceiveMandate_Art80">
        <di:waypoint x="1390" y="210" />
        <di:waypoint x="1520" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReceiveMandate_To_GatewayActionScope_Art80_di" bpmnElement="Flow_ReceiveMandate_To_GatewayActionScope_Art80">
        <di:waypoint x="1810" y="210" />
        <di:waypoint x="2035" y="210" />
        <di:waypoint x="2035" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayMemberStateOption_To_EndNoRepresentation_Art80_di" bpmnElement="Flow_GatewayMemberStateOption_To_EndNoRepresentation_Art80">
        <di:waypoint x="1115" y="585" />
        <di:waypoint x="1115" y="680" />
        <di:waypoint x="1290" y="680" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayMemberStateOption_To_TaskAssessIndependentComplaint_Art80_di" bpmnElement="Flow_GatewayMemberStateOption_To_TaskAssessIndependentComplaint_Art80">
        <di:waypoint x="1140" y="560" />
        <di:waypoint x="1280" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AssessIndependentComplaint_To_GatewayNoMandateActionScope_Art80_di" bpmnElement="Flow_AssessIndependentComplaint_To_GatewayNoMandateActionScope_Art80">
        <di:waypoint x="1800" y="560" />
        <di:waypoint x="2010" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayActionScope_To_LodgeComplaint_Art80_di" bpmnElement="Flow_GatewayActionScope_To_LodgeComplaint_Art80">
        <di:waypoint x="2035" y="375" />
        <di:waypoint x="2035" y="160" />
        <di:waypoint x="2230" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayActionScope_To_RequestJudicialRemedy_Art80_di" bpmnElement="Flow_GatewayActionScope_To_RequestJudicialRemedy_Art80">
        <di:waypoint x="2060" y="400" />
        <di:waypoint x="2230" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayActionScope_To_RequestCompensation_Art80_di" bpmnElement="Flow_GatewayActionScope_To_RequestCompensation_Art80">
        <di:waypoint x="2035" y="425" />
        <di:waypoint x="2035" y="580" />
        <di:waypoint x="2230" y="580" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayNoMandateActionScope_To_LodgeComplaint_Art80_di" bpmnElement="Flow_GatewayNoMandateActionScope_To_LodgeComplaint_Art80">
        <di:waypoint x="2035" y="535" />
        <di:waypoint x="2035" y="160" />
        <di:waypoint x="2230" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayNoMandateActionScope_To_RequestJudicialRemedy_Art80_di" bpmnElement="Flow_GatewayNoMandateActionScope_To_RequestJudicialRemedy_Art80">
        <di:waypoint x="2060" y="560" />
        <di:waypoint x="2230" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayNoMandateActionScope_To_EndNoRepresentation_Art80_di" bpmnElement="Flow_GatewayNoMandateActionScope_To_EndNoRepresentation_Art80">
        <di:waypoint x="2035" y="585" />
        <di:waypoint x="2035" y="680" />
        <di:waypoint x="1326" y="680" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LodgeComplaint_To_EndActionCompleted_Art80_di" bpmnElement="Flow_LodgeComplaint_To_EndActionCompleted_Art80">
        <di:waypoint x="2680" y="160" />
        <di:waypoint x="2915" y="160" />
        <di:waypoint x="2915" y="375" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RequestJudicialRemedy_To_EndActionCompleted_Art80_di" bpmnElement="Flow_RequestJudicialRemedy_To_EndActionCompleted_Art80">
        <di:waypoint x="2590" y="370" />
        <di:waypoint x="2890" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RequestCompensation_To_EndActionCompleted_Art80_di" bpmnElement="Flow_RequestCompensation_To_EndActionCompleted_Art80">
        <di:waypoint x="2650" y="580" />
        <di:waypoint x="2915" y="580" />
        <di:waypoint x="2915" y="425" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayActionCompleted_To_EndRepresentationCompleted_Art80_di" bpmnElement="Flow_GatewayActionCompleted_To_EndRepresentationCompleted_Art80">
        <di:waypoint x="2940" y="400" />
        <di:waypoint x="3100" y="400" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MessageFlow_RequestMandate_Art80_di" bpmnElement="MessageFlow_RequestMandate_Art80">
        <di:waypoint x="1240" y="250" />
        <di:waypoint x="1240" y="860" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_ReceiveMandate_Art80_di" bpmnElement="MessageFlow_ReceiveMandate_Art80">
        <di:waypoint x="1665" y="860" />
        <di:waypoint x="1665" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_LodgeComplaint_Art80_di" bpmnElement="MessageFlow_LodgeComplaint_Art80">
        <di:waypoint x="2455" y="200" />
        <di:waypoint x="2455" y="1020" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_RequestJudicialRemedy_Art80_di" bpmnElement="MessageFlow_RequestJudicialRemedy_Art80">
        <di:waypoint x="2410" y="410" />
