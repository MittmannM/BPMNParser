<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art40_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art40_Reviewed">
    <bpmn:participant id="Participant_Association_Art40"
                      name="Association or Other Body"
                      processRef="Process_Association_Art40" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art40"
                      name="Supervisory Authority"
                      processRef="Process_SupervisoryAuthority_Art40" />
    <bpmn:participant id="Participant_Board_Art40"
                      name="Board"
                      processRef="Process_Board_Art40" />
    <bpmn:participant id="Participant_Commission_Art40"
                      name="Commission"
                      processRef="Process_Commission_Art40" />

    <bpmn:messageFlow id="MessageFlow_SubmitDraft_Art40"
                      sourceRef="SendTask_SubmitDraft_Art40"
                      targetRef="ReceiveTask_ReceiveDraft_Art40" />
    <bpmn:messageFlow id="MessageFlow_RejectionNotice_Art40"
                      sourceRef="SendTask_SendRejectionNotice_Art40"
                      targetRef="ReceiveTask_ReceiveAuthorityOutcome_Art40" />
    <bpmn:messageFlow id="MessageFlow_ApprovalNotice_Art40"
                      sourceRef="SendTask_SendApprovalNotice_Art40"
                      targetRef="ReceiveTask_ReceiveAuthorityOutcome_Art40" />
    <bpmn:messageFlow id="MessageFlow_SubmitToBoard_Art40"
                      sourceRef="SendTask_SubmitDraftToBoard_Art40"
                      targetRef="ReceiveTask_ReceiveArticle63Draft_Art40" />
    <bpmn:messageFlow id="MessageFlow_BoardOpinionToSA_Art40"
                      sourceRef="SendTask_SendBoardOpinionToSA_Art40"
                      targetRef="ReceiveTask_ReceiveBoardOpinion_Art40" />
    <bpmn:messageFlow id="MessageFlow_BoardOpinionToCommission_Art40"
                      sourceRef="SendTask_SendBoardOpinionToCommission_Art40"
                      targetRef="ReceiveTask_ReceiveBoardOpinion_Commission_Art40" />
    <bpmn:messageFlow id="MessageFlow_SendApprovedCodeToBoard_Art40"
                      sourceRef="SendTask_SendApprovedCodeToBoard_Art40"
                      targetRef="ReceiveTask_ReceiveApprovedCode_Art40" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Association_Art40"
                name="Preparing a code of conduct under Article 40"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 40 based on the real English legal text
      of Regulation (EU) 2016/679. This process captures the Article 40(1) sector-code
      encouragement context, preparation, amendment, or extension of a code of conduct
      by an association or other body representing categories of controllers or
      processors, grouped coverage of the Article 40(2)(a)-(k) subject areas, the
      Article 40(3) transfer-safeguard adherence option for non-Article-3 entities,
      the Article 40(4) monitoring-mechanism requirement, submission under Article 40(5),
      and the authority outcome path.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_NeedCode_Art40"
                     name="Encourage sector code">
      <bpmn:outgoing>Flow_StartNeedCode_To_TaskDraftCode_Art40</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_DraftCode_Art40"
               name="Draft or amend code">
      <bpmn:incoming>Flow_StartNeedCode_To_TaskDraftCode_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_TaskReviseDraft_To_TaskDraftCode_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDraftCode_To_GatewaySplitContent_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_SplitContent_Art40">
      <bpmn:incoming>Flow_TaskDraftCode_To_GatewaySplitContent_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitContent_To_TaskSetFairProcessingRules_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitContent_To_TaskSetDataHandlingRules_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitContent_To_TaskSetInformationRightsRules_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitContent_To_TaskSetChildrenRules_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitContent_To_TaskSetSecurityAndBreachRules_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitContent_To_TaskSetTransferDisputeRules_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitContent_To_TaskAddMonitoringMechanisms_Art40</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_SetFairProcessingRules_Art40"
               name="Set fair-processing and legitimate-interest rules">
      <bpmn:incoming>Flow_GatewaySplitContent_To_TaskSetFairProcessingRules_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetFairProcessingRules_To_GatewayJoinContent_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetDataHandlingRules_Art40"
               name="Set collection and pseudonymisation rules">
      <bpmn:incoming>Flow_GatewaySplitContent_To_TaskSetDataHandlingRules_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetDataHandlingRules_To_GatewayJoinContent_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetInformationRightsRules_Art40"
               name="Set information and rights rules">
      <bpmn:incoming>Flow_GatewaySplitContent_To_TaskSetInformationRightsRules_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetInformationRightsRules_To_GatewayJoinContent_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetChildrenRules_Art40"
               name="Set child-protection and consent rules">
      <bpmn:incoming>Flow_GatewaySplitContent_To_TaskSetChildrenRules_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetChildrenRules_To_GatewayJoinContent_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetSecurityAndBreachRules_Art40"
               name="Set safeguards and breach rules">
      <bpmn:incoming>Flow_GatewaySplitContent_To_TaskSetSecurityAndBreachRules_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetSecurityAndBreachRules_To_GatewayJoinContent_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SetTransferDisputeRules_Art40"
               name="Set transfer and dispute rules">
      <bpmn:incoming>Flow_GatewaySplitContent_To_TaskSetTransferDisputeRules_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetTransferDisputeRules_To_GatewayJoinContent_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AddMonitoringMechanisms_Art40"
               name="Add Article 41 monitoring mechanisms">
      <bpmn:incoming>Flow_GatewaySplitContent_To_TaskAddMonitoringMechanisms_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAddMonitoringMechanisms_To_GatewayJoinContent_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_JoinContent_Art40">
      <bpmn:incoming>Flow_TaskSetFairProcessingRules_To_GatewayJoinContent_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetDataHandlingRules_To_GatewayJoinContent_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetInformationRightsRules_To_GatewayJoinContent_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetChildrenRules_To_GatewayJoinContent_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetSecurityAndBreachRules_To_GatewayJoinContent_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetTransferDisputeRules_To_GatewayJoinContent_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_TaskAddMonitoringMechanisms_To_GatewayJoinContent_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinContent_To_GatewayTransferAdherence_Art40</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:exclusiveGateway id="Gateway_TransferAdherence_Art40"
                           name="Will non-Article 3 entities adhere for Article 46(2)(e) transfers?">
      <bpmn:incoming>Flow_GatewayJoinContent_To_GatewayTransferAdherence_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayTransferAdherence_To_TaskSetBindingCommitments_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayTransferAdherence_To_GatewayRepresentCategories_Art40</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_SetBindingCommitments_Art40"
               name="Set binding and enforceable commitments">
      <bpmn:incoming>Flow_GatewayTransferAdherence_To_TaskSetBindingCommitments_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSetBindingCommitments_To_GatewayRepresentCategories_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_RepresentCategories_Art40"
                           name="Does the body represent controller or processor categories?">
      <bpmn:incoming>Flow_GatewayTransferAdherence_To_GatewayRepresentCategories_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSetBindingCommitments_To_GatewayRepresentCategories_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRepresentCategories_To_EndCannotSubmit_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRepresentCategories_To_SendTaskSubmitDraft_Art40</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_CannotSubmit_Art40"
                   name="Draft cannot be submitted">
      <bpmn:incoming>Flow_GatewayRepresentCategories_To_EndCannotSubmit_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_SubmitDraft_Art40"
                   name="Submit draft to authority">
      <bpmn:incoming>Flow_GatewayRepresentCategories_To_SendTaskSubmitDraft_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSubmitDraft_To_ReceiveTaskReceiveAuthorityOutcome_Art40</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAuthorityOutcome_Art40"
                      name="Receive authority outcome">
      <bpmn:incoming>Flow_SendTaskSubmitDraft_To_ReceiveTaskReceiveAuthorityOutcome_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveAuthorityOutcome_To_GatewayApproved_Art40</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_Approved_Art40"
                           name="Was the draft approved?">
      <bpmn:incoming>Flow_ReceiveTaskReceiveAuthorityOutcome_To_GatewayApproved_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayApproved_To_TaskReviseDraft_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayApproved_To_EndApproved_Art40</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ReviseDraft_Art40"
               name="Revise draft">
      <bpmn:incoming>Flow_GatewayApproved_To_TaskReviseDraft_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskReviseDraft_To_TaskDraftCode_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_Approved_Art40"
                   name="Code approved">
      <bpmn:incoming>Flow_GatewayApproved_To_EndApproved_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartNeedCode_To_TaskDraftCode_Art40" sourceRef="StartEvent_NeedCode_Art40" targetRef="Task_DraftCode_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskDraftCode_To_GatewaySplitContent_Art40" sourceRef="Task_DraftCode_Art40" targetRef="Gateway_SplitContent_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitContent_To_TaskSetFairProcessingRules_Art40" sourceRef="Gateway_SplitContent_Art40" targetRef="Task_SetFairProcessingRules_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitContent_To_TaskSetDataHandlingRules_Art40" sourceRef="Gateway_SplitContent_Art40" targetRef="Task_SetDataHandlingRules_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitContent_To_TaskSetInformationRightsRules_Art40" sourceRef="Gateway_SplitContent_Art40" targetRef="Task_SetInformationRightsRules_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitContent_To_TaskSetChildrenRules_Art40" sourceRef="Gateway_SplitContent_Art40" targetRef="Task_SetChildrenRules_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitContent_To_TaskSetSecurityAndBreachRules_Art40" sourceRef="Gateway_SplitContent_Art40" targetRef="Task_SetSecurityAndBreachRules_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitContent_To_TaskSetTransferDisputeRules_Art40" sourceRef="Gateway_SplitContent_Art40" targetRef="Task_SetTransferDisputeRules_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitContent_To_TaskAddMonitoringMechanisms_Art40" sourceRef="Gateway_SplitContent_Art40" targetRef="Task_AddMonitoringMechanisms_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskSetFairProcessingRules_To_GatewayJoinContent_Art40" sourceRef="Task_SetFairProcessingRules_Art40" targetRef="Gateway_JoinContent_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskSetDataHandlingRules_To_GatewayJoinContent_Art40" sourceRef="Task_SetDataHandlingRules_Art40" targetRef="Gateway_JoinContent_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskSetInformationRightsRules_To_GatewayJoinContent_Art40" sourceRef="Task_SetInformationRightsRules_Art40" targetRef="Gateway_JoinContent_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskSetChildrenRules_To_GatewayJoinContent_Art40" sourceRef="Task_SetChildrenRules_Art40" targetRef="Gateway_JoinContent_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskSetSecurityAndBreachRules_To_GatewayJoinContent_Art40" sourceRef="Task_SetSecurityAndBreachRules_Art40" targetRef="Gateway_JoinContent_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskSetTransferDisputeRules_To_GatewayJoinContent_Art40" sourceRef="Task_SetTransferDisputeRules_Art40" targetRef="Gateway_JoinContent_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskAddMonitoringMechanisms_To_GatewayJoinContent_Art40" sourceRef="Task_AddMonitoringMechanisms_Art40" targetRef="Gateway_JoinContent_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinContent_To_GatewayTransferAdherence_Art40" sourceRef="Gateway_JoinContent_Art40" targetRef="Gateway_TransferAdherence_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayTransferAdherence_To_TaskSetBindingCommitments_Art40" name="Yes" sourceRef="Gateway_TransferAdherence_Art40" targetRef="Task_SetBindingCommitments_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayTransferAdherence_To_GatewayRepresentCategories_Art40" name="No" sourceRef="Gateway_TransferAdherence_Art40" targetRef="Gateway_RepresentCategories_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskSetBindingCommitments_To_GatewayRepresentCategories_Art40" sourceRef="Task_SetBindingCommitments_Art40" targetRef="Gateway_RepresentCategories_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayRepresentCategories_To_EndCannotSubmit_Art40" name="No" sourceRef="Gateway_RepresentCategories_Art40" targetRef="EndEvent_CannotSubmit_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayRepresentCategories_To_SendTaskSubmitDraft_Art40" name="Yes" sourceRef="Gateway_RepresentCategories_Art40" targetRef="SendTask_SubmitDraft_Art40" />
    <bpmn:sequenceFlow id="Flow_SendTaskSubmitDraft_To_ReceiveTaskReceiveAuthorityOutcome_Art40" sourceRef="SendTask_SubmitDraft_Art40" targetRef="ReceiveTask_ReceiveAuthorityOutcome_Art40" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveAuthorityOutcome_To_GatewayApproved_Art40" sourceRef="ReceiveTask_ReceiveAuthorityOutcome_Art40" targetRef="Gateway_Approved_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayApproved_To_TaskReviseDraft_Art40" name="No" sourceRef="Gateway_Approved_Art40" targetRef="Task_ReviseDraft_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayApproved_To_EndApproved_Art40" name="Yes" sourceRef="Gateway_Approved_Art40" targetRef="EndEvent_Approved_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskReviseDraft_To_TaskDraftCode_Art40" sourceRef="Task_ReviseDraft_Art40" targetRef="Task_DraftCode_Art40" />
  </bpmn:process>

  <bpmn:process id="Process_SupervisoryAuthority_Art40"
                name="Reviewing the code of conduct under Article 40"
                isExecutable="false">
    <bpmn:documentation>
      This process captures the supervisory-authority workflow in Article 40(5)-(7):
      receipt and review of the draft, rejection or approval, the single-Member-State
      register/publication path, and the submission of multi-Member-State drafts to the
      Board under Article 63 before approval.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_ReviewDraft_Art40"
                     name="Review draft code">
      <bpmn:outgoing>Flow_StartReviewDraft_To_ReceiveTaskReceiveDraft_Art40</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveDraft_Art40"
                      name="Receive draft code">
      <bpmn:incoming>Flow_StartReviewDraft_To_ReceiveTaskReceiveDraft_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveDraft_To_TaskAssessCompliance_Art40</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_AssessCompliance_Art40"
               name="Assess GDPR compliance and safeguards">
      <bpmn:incoming>Flow_ReceiveTaskReceiveDraft_To_TaskAssessCompliance_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessCompliance_To_GatewayCompliant_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Compliant_Art40"
                           name="Does the draft comply and provide safeguards?">
      <bpmn:incoming>Flow_TaskAssessCompliance_To_GatewayCompliant_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayCompliant_To_SendTaskSendRejectionNotice_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCompliant_To_GatewaySeveralMemberStates_Art40</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_SendRejectionNotice_Art40"
                   name="Send rejection or revision request">
      <bpmn:incoming>Flow_GatewayCompliant_To_SendTaskSendRejectionNotice_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendRejectionNotice_To_EndRejected_Art40</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_Rejected_Art40"
                   name="Draft rejected">
      <bpmn:incoming>Flow_SendTaskSendRejectionNotice_To_EndRejected_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_SeveralMemberStates_Art40"
                           name="Does the code relate to several Member States?">
      <bpmn:incoming>Flow_GatewayCompliant_To_GatewaySeveralMemberStates_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySeveralMemberStates_To_TaskApproveSingleStateCode_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySeveralMemberStates_To_SendTaskSubmitDraftToBoard_Art40</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ApproveSingleStateCode_Art40"
               name="Approve single-state code">
      <bpmn:incoming>Flow_GatewaySeveralMemberStates_To_TaskApproveSingleStateCode_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskApproveSingleStateCode_To_TaskRegisterPublishCode_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_RegisterPublishCode_Art40"
               name="Register and publish code">
      <bpmn:incoming>Flow_TaskApproveSingleStateCode_To_TaskRegisterPublishCode_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRegisterPublishCode_To_SendTaskSendApprovedCodeToBoard_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_SubmitDraftToBoard_Art40"
                   name="Submit draft to Board">
      <bpmn:incoming>Flow_GatewaySeveralMemberStates_To_SendTaskSubmitDraftToBoard_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSubmitDraftToBoard_To_ReceiveTaskReceiveBoardOpinion_Art40</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveBoardOpinion_Art40"
                      name="Receive Board opinion">
      <bpmn:incoming>Flow_SendTaskSubmitDraftToBoard_To_ReceiveTaskReceiveBoardOpinion_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveBoardOpinion_To_GatewayBoardConfirms_Art40</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_BoardConfirms_Art40"
                           name="Did the Board confirm compliance or safeguards?">
      <bpmn:incoming>Flow_ReceiveTaskReceiveBoardOpinion_To_GatewayBoardConfirms_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayBoardConfirms_To_SendTaskSendRejectionNotice_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayBoardConfirms_To_TaskApproveMultiStateCode_Art40</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ApproveMultiStateCode_Art40"
               name="Approve multi-state code">
      <bpmn:incoming>Flow_GatewayBoardConfirms_To_TaskApproveMultiStateCode_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskApproveMultiStateCode_To_SendTaskSendApprovedCodeToBoard_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_SendApprovedCodeToBoard_Art40"
                   name="Send approved code to Board register">
      <bpmn:incoming>Flow_TaskRegisterPublishCode_To_SendTaskSendApprovedCodeToBoard_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_TaskApproveMultiStateCode_To_SendTaskSendApprovedCodeToBoard_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendApprovedCodeToBoard_To_SendTaskSendApprovalNotice_Art40</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_SendApprovalNotice_Art40"
                   name="Send approval notice">
      <bpmn:incoming>Flow_SendTaskSendApprovedCodeToBoard_To_SendTaskSendApprovalNotice_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendApprovalNotice_To_EndApproved_Art40</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_AuthorityApproved_Art40"
                   name="Authority approval path completed">
      <bpmn:incoming>Flow_SendTaskSendApprovalNotice_To_EndApproved_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartReviewDraft_To_ReceiveTaskReceiveDraft_Art40" sourceRef="StartEvent_ReviewDraft_Art40" targetRef="ReceiveTask_ReceiveDraft_Art40" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveDraft_To_TaskAssessCompliance_Art40" sourceRef="ReceiveTask_ReceiveDraft_Art40" targetRef="Task_AssessCompliance_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskAssessCompliance_To_GatewayCompliant_Art40" sourceRef="Task_AssessCompliance_Art40" targetRef="Gateway_Compliant_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayCompliant_To_SendTaskSendRejectionNotice_Art40" name="No" sourceRef="Gateway_Compliant_Art40" targetRef="SendTask_SendRejectionNotice_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayCompliant_To_GatewaySeveralMemberStates_Art40" name="Yes" sourceRef="Gateway_Compliant_Art40" targetRef="Gateway_SeveralMemberStates_Art40" />
    <bpmn:sequenceFlow id="Flow_SendTaskSendRejectionNotice_To_EndRejected_Art40" sourceRef="SendTask_SendRejectionNotice_Art40" targetRef="EndEvent_Rejected_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySeveralMemberStates_To_TaskApproveSingleStateCode_Art40" name="No" sourceRef="Gateway_SeveralMemberStates_Art40" targetRef="Task_ApproveSingleStateCode_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySeveralMemberStates_To_SendTaskSubmitDraftToBoard_Art40" name="Yes" sourceRef="Gateway_SeveralMemberStates_Art40" targetRef="SendTask_SubmitDraftToBoard_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskApproveSingleStateCode_To_TaskRegisterPublishCode_Art40" sourceRef="Task_ApproveSingleStateCode_Art40" targetRef="Task_RegisterPublishCode_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskRegisterPublishCode_To_SendTaskSendApprovedCodeToBoard_Art40" sourceRef="Task_RegisterPublishCode_Art40" targetRef="SendTask_SendApprovedCodeToBoard_Art40" />
    <bpmn:sequenceFlow id="Flow_SendTaskSubmitDraftToBoard_To_ReceiveTaskReceiveBoardOpinion_Art40" sourceRef="SendTask_SubmitDraftToBoard_Art40" targetRef="ReceiveTask_ReceiveBoardOpinion_Art40" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveBoardOpinion_To_GatewayBoardConfirms_Art40" sourceRef="ReceiveTask_ReceiveBoardOpinion_Art40" targetRef="Gateway_BoardConfirms_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayBoardConfirms_To_SendTaskSendRejectionNotice_Art40" name="No" sourceRef="Gateway_BoardConfirms_Art40" targetRef="SendTask_SendRejectionNotice_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayBoardConfirms_To_TaskApproveMultiStateCode_Art40" name="Yes" sourceRef="Gateway_BoardConfirms_Art40" targetRef="Task_ApproveMultiStateCode_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskApproveMultiStateCode_To_SendTaskSendApprovedCodeToBoard_Art40" sourceRef="Task_ApproveMultiStateCode_Art40" targetRef="SendTask_SendApprovedCodeToBoard_Art40" />
    <bpmn:sequenceFlow id="Flow_SendTaskSendApprovedCodeToBoard_To_SendTaskSendApprovalNotice_Art40" sourceRef="SendTask_SendApprovedCodeToBoard_Art40" targetRef="SendTask_SendApprovalNotice_Art40" />
    <bpmn:sequenceFlow id="Flow_SendTaskSendApprovalNotice_To_EndApproved_Art40" sourceRef="SendTask_SendApprovalNotice_Art40" targetRef="EndEvent_AuthorityApproved_Art40" />
  </bpmn:process>

  <bpmn:process id="Process_Board_Art40"
                name="Board actions under Article 40"
                isExecutable="false">
    <bpmn:documentation>
      This process captures the Board opinion in Article 40(7), submission of a
      confirming opinion to the Commission in Article 40(8), and the public register
      duty in Article 40(11).
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_ReviewArticle63Draft_Art40"
                     name="Receive Article 63 draft">
      <bpmn:outgoing>Flow_StartReviewArticle63Draft_To_ReceiveTaskReceiveArticle63Draft_Art40</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveArticle63Draft_Art40"
                      name="Receive Article 63 draft">
      <bpmn:incoming>Flow_StartReviewArticle63Draft_To_ReceiveTaskReceiveArticle63Draft_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveArticle63Draft_To_TaskIssueBoardOpinion_Art40</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_IssueBoardOpinion_Art40"
               name="Issue Board opinion">
      <bpmn:incoming>Flow_ReceiveTaskReceiveArticle63Draft_To_TaskIssueBoardOpinion_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskIssueBoardOpinion_To_GatewayOpinionConfirms_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_OpinionConfirms_Art40"
                           name="Does the opinion confirm compliance or safeguards?">
      <bpmn:incoming>Flow_TaskIssueBoardOpinion_To_GatewayOpinionConfirms_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayOpinionConfirms_To_SendTaskSendBoardOpinionToSA_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayOpinionConfirms_To_GatewaySplitConfirmedOpinion_Art40</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_SendBoardOpinionToSA_Art40"
                   name="Send Board opinion to authority">
      <bpmn:incoming>Flow_GatewayOpinionConfirms_To_SendTaskSendBoardOpinionToSA_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendBoardOpinionToSA_To_EndOpinionSent_Art40</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:parallelGateway id="Gateway_SplitConfirmedOpinion_Art40">
      <bpmn:incoming>Flow_GatewayOpinionConfirms_To_GatewaySplitConfirmedOpinion_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySplitConfirmedOpinion_To_SendTaskSendBoardOpinionToSAConfirmed_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySplitConfirmedOpinion_To_SendTaskSendBoardOpinionToCommission_Art40</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:sendTask id="SendTask_SendBoardOpinionToSAConfirmed_Art40"
                   name="Send confirmed opinion to authority">
      <bpmn:incoming>Flow_GatewaySplitConfirmedOpinion_To_SendTaskSendBoardOpinionToSAConfirmed_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendBoardOpinionToSAConfirmed_To_GatewayJoinConfirmedOpinion_Art40</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_SendBoardOpinionToCommission_Art40"
                   name="Send confirmed opinion to Commission">
      <bpmn:incoming>Flow_GatewaySplitConfirmedOpinion_To_SendTaskSendBoardOpinionToCommission_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskSendBoardOpinionToCommission_To_GatewayJoinConfirmedOpinion_Art40</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:parallelGateway id="Gateway_JoinConfirmedOpinion_Art40">
      <bpmn:incoming>Flow_SendTaskSendBoardOpinionToSAConfirmed_To_GatewayJoinConfirmedOpinion_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskSendBoardOpinionToCommission_To_GatewayJoinConfirmedOpinion_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayJoinConfirmedOpinion_To_EndOpinionSent_Art40</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:endEvent id="EndEvent_OpinionSent_Art40"
                   name="Board opinion handled">
      <bpmn:incoming>Flow_SendTaskSendBoardOpinionToSA_To_EndOpinionSent_Art40</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayJoinConfirmedOpinion_To_EndOpinionSent_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="StartEvent_RegisterApprovedCode_Art40"
                     name="Receive approved code">
      <bpmn:outgoing>Flow_StartRegisterApprovedCode_To_ReceiveTaskReceiveApprovedCode_Art40</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveApprovedCode_Art40"
                      name="Receive approved code">
      <bpmn:incoming>Flow_StartRegisterApprovedCode_To_ReceiveTaskReceiveApprovedCode_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveApprovedCode_To_TaskUpdateBoardRegister_Art40</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_UpdateBoardRegister_Art40"
               name="Update public Board register">
      <bpmn:incoming>Flow_ReceiveTaskReceiveApprovedCode_To_TaskUpdateBoardRegister_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskUpdateBoardRegister_To_EndRegisterUpdated_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_RegisterUpdated_Art40"
                   name="Board register updated">
      <bpmn:incoming>Flow_TaskUpdateBoardRegister_To_EndRegisterUpdated_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartReviewArticle63Draft_To_ReceiveTaskReceiveArticle63Draft_Art40" sourceRef="StartEvent_ReviewArticle63Draft_Art40" targetRef="ReceiveTask_ReceiveArticle63Draft_Art40" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveArticle63Draft_To_TaskIssueBoardOpinion_Art40" sourceRef="ReceiveTask_ReceiveArticle63Draft_Art40" targetRef="Task_IssueBoardOpinion_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskIssueBoardOpinion_To_GatewayOpinionConfirms_Art40" sourceRef="Task_IssueBoardOpinion_Art40" targetRef="Gateway_OpinionConfirms_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayOpinionConfirms_To_SendTaskSendBoardOpinionToSA_Art40" name="No" sourceRef="Gateway_OpinionConfirms_Art40" targetRef="SendTask_SendBoardOpinionToSA_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayOpinionConfirms_To_GatewaySplitConfirmedOpinion_Art40" name="Yes" sourceRef="Gateway_OpinionConfirms_Art40" targetRef="Gateway_SplitConfirmedOpinion_Art40" />
    <bpmn:sequenceFlow id="Flow_SendTaskSendBoardOpinionToSA_To_EndOpinionSent_Art40" sourceRef="SendTask_SendBoardOpinionToSA_Art40" targetRef="EndEvent_OpinionSent_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitConfirmedOpinion_To_SendTaskSendBoardOpinionToSAConfirmed_Art40" sourceRef="Gateway_SplitConfirmedOpinion_Art40" targetRef="SendTask_SendBoardOpinionToSAConfirmed_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewaySplitConfirmedOpinion_To_SendTaskSendBoardOpinionToCommission_Art40" sourceRef="Gateway_SplitConfirmedOpinion_Art40" targetRef="SendTask_SendBoardOpinionToCommission_Art40" />
    <bpmn:sequenceFlow id="Flow_SendTaskSendBoardOpinionToSAConfirmed_To_GatewayJoinConfirmedOpinion_Art40" sourceRef="SendTask_SendBoardOpinionToSAConfirmed_Art40" targetRef="Gateway_JoinConfirmedOpinion_Art40" />
    <bpmn:sequenceFlow id="Flow_SendTaskSendBoardOpinionToCommission_To_GatewayJoinConfirmedOpinion_Art40" sourceRef="SendTask_SendBoardOpinionToCommission_Art40" targetRef="Gateway_JoinConfirmedOpinion_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayJoinConfirmedOpinion_To_EndOpinionSent_Art40" sourceRef="Gateway_JoinConfirmedOpinion_Art40" targetRef="EndEvent_OpinionSent_Art40" />
    <bpmn:sequenceFlow id="Flow_StartRegisterApprovedCode_To_ReceiveTaskReceiveApprovedCode_Art40" sourceRef="StartEvent_RegisterApprovedCode_Art40" targetRef="ReceiveTask_ReceiveApprovedCode_Art40" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveApprovedCode_To_TaskUpdateBoardRegister_Art40" sourceRef="ReceiveTask_ReceiveApprovedCode_Art40" targetRef="Task_UpdateBoardRegister_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskUpdateBoardRegister_To_EndRegisterUpdated_Art40" sourceRef="Task_UpdateBoardRegister_Art40" targetRef="EndEvent_RegisterUpdated_Art40" />
  </bpmn:process>

  <bpmn:process id="Process_Commission_Art40"
                name="Commission actions under Article 40"
                isExecutable="false">
    <bpmn:documentation>
      This process captures the optional general-validity decision in Article 40(9)
      and the publicity duty in Article 40(10).
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_ConsiderGeneralValidity_Art40"
                     name="Receive Board opinion">
      <bpmn:outgoing>Flow_StartConsiderGeneralValidity_To_ReceiveTaskReceiveBoardOpinion_Art40</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveBoardOpinion_Commission_Art40"
                      name="Receive Board opinion">
      <bpmn:incoming>Flow_StartConsiderGeneralValidity_To_ReceiveTaskReceiveBoardOpinion_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceiveBoardOpinionCommission_To_GatewayGrantGeneralValidity_Art40</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_GrantGeneralValidity_Art40"
                           name="Grant general validity within the Union?">
      <bpmn:incoming>Flow_ReceiveTaskReceiveBoardOpinionCommission_To_GatewayGrantGeneralValidity_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayGrantGeneralValidity_To_EndNoGeneralValidity_Art40</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayGrantGeneralValidity_To_TaskEnsurePublicity_Art40</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_EnsurePublicity_Art40"
               name="Ensure publicity for approved code">
      <bpmn:incoming>Flow_GatewayGrantGeneralValidity_To_TaskEnsurePublicity_Art40</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskEnsurePublicity_To_EndGeneralValidity_Art40</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_NoGeneralValidity_Art40"
                   name="No general-validity decision">
      <bpmn:incoming>Flow_GatewayGrantGeneralValidity_To_EndNoGeneralValidity_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_GeneralValidity_Art40"
                   name="General validity publicized">
      <bpmn:incoming>Flow_TaskEnsurePublicity_To_EndGeneralValidity_Art40</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartConsiderGeneralValidity_To_ReceiveTaskReceiveBoardOpinion_Art40" sourceRef="StartEvent_ConsiderGeneralValidity_Art40" targetRef="ReceiveTask_ReceiveBoardOpinion_Commission_Art40" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceiveBoardOpinionCommission_To_GatewayGrantGeneralValidity_Art40" sourceRef="ReceiveTask_ReceiveBoardOpinion_Commission_Art40" targetRef="Gateway_GrantGeneralValidity_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayGrantGeneralValidity_To_EndNoGeneralValidity_Art40" name="No" sourceRef="Gateway_GrantGeneralValidity_Art40" targetRef="EndEvent_NoGeneralValidity_Art40" />
    <bpmn:sequenceFlow id="Flow_GatewayGrantGeneralValidity_To_TaskEnsurePublicity_Art40" name="Yes" sourceRef="Gateway_GrantGeneralValidity_Art40" targetRef="Task_EnsurePublicity_Art40" />
    <bpmn:sequenceFlow id="Flow_TaskEnsurePublicity_To_EndGeneralValidity_Art40" sourceRef="Task_EnsurePublicity_Art40" targetRef="EndEvent_GeneralValidity_Art40" />
  </bpmn:process>

