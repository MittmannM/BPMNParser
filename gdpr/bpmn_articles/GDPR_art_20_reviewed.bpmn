<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art20_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_Art20_Reviewed">
    <bpmn:participant id="Participant_Controller_Art20" name="Controller" processRef="Process_Controller_Art20" />
    <bpmn:participant id="Participant_DataSubject_Art20" name="Data Subject" />
    <bpmn:participant id="Participant_ReceivingController_Art20" name="Receiving Controller" />

    <bpmn:messageFlow id="MessageFlow_ReceivePortabilityRequest_Art20" sourceRef="Participant_DataSubject_Art20" targetRef="ReceiveTask_ReceivePortabilityRequest_Art20" />
    <bpmn:messageFlow id="MessageFlow_ProvidePortableDataToDataSubject_Art20" sourceRef="SendTask_ProvidePortableDataToDataSubject_Art20" targetRef="Participant_DataSubject_Art20" />
    <bpmn:messageFlow id="MessageFlow_TransmitDataToReceivingController_Art20" sourceRef="SendTask_TransmitDataToReceivingController_Art20" targetRef="Participant_ReceivingController_Art20" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Controller_Art20" name="Handling the data subject's right to data portability" isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 20 based on the English legal text of
      Regulation (EU) 2016/679. The model keeps the article's own visible
      cross-references: the portability right depends on Article 6(1)(a), Article
      9(2)(a), or Article 6(1)(b), is limited by Article 20(3) and Article 20(4), and
      is exercised without prejudice to Article 17. Direct transmission to another
      controller is modeled as a separate branch subject to technical feasibility.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_PortabilityRequested_Art20" name="Data subject seeks data portability">
      <bpmn:outgoing>Flow_Start_To_ReceiveTaskReceivePortabilityRequest_Art20</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceivePortabilityRequest_Art20" name="Receive portability request">
      <bpmn:incoming>Flow_Start_To_ReceiveTaskReceivePortabilityRequest_Art20</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveTaskReceivePortabilityRequest_To_GatewayRequestExceptions_Art20</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_RequestExceptions_Art20" name="Were the relevant personal data provided by the data subject and are they available in a portable electronic form?">
      <bpmn:incoming>Flow_ReceiveTaskReceivePortabilityRequest_To_GatewayRequestExceptions_Art20</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRequestExceptions_To_EndRequestBlocked_Art20</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRequestExceptions_To_GatewayProvidedData_Art20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_ProvidedData_Art20" name="Is the processing based on Article 6(1)(a), Article 9(2)(a), or Article 6(1)(b)?">
      <bpmn:incoming>Flow_GatewayRequestExceptions_To_GatewayProvidedData_Art20</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayProvidedData_To_EndNoPortableDataset_Art20</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayProvidedData_To_GatewayLegalBasis_Art20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_LegalBasis_Art20" name="Is the processing carried out by automated means?">
      <bpmn:incoming>Flow_GatewayProvidedData_To_GatewayLegalBasis_Art20</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayLegalBasis_To_EndNoPortabilityBasis_Art20</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayLegalBasis_To_GatewayAutomatedProcessing_Art20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_AutomatedProcessing_Art20" name="Is the processing carried out by automated means?">
      <bpmn:incoming>Flow_GatewayLegalBasis_To_GatewayAutomatedProcessing_Art20</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAutomatedProcessing_To_EndNotAutomated_Art20</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAutomatedProcessing_To_GatewayPublicTaskException_Art20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_PublicTaskException_Art20" name="Is the processing necessary for a task carried out in the public interest or in the exercise of official authority?">
      <bpmn:incoming>Flow_GatewayAutomatedProcessing_To_GatewayPublicTaskException_Art20</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayPublicTaskException_To_EndPublicTaskException_Art20</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayPublicTaskException_To_GatewayRightsFreedoms_Art20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_RightsFreedoms_Art20" name="Would portability adversely affect the rights and freedoms of others?">
      <bpmn:incoming>Flow_GatewayPublicTaskException_To_GatewayRightsFreedoms_Art20</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRightsFreedoms_To_EndRightsFreedomsLimit_Art20</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRightsFreedoms_To_TaskPreparePortableDataset_Art20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_PreparePortableDataset_Art20" name="Prepare portable data set">
      <bpmn:incoming>Flow_GatewayRightsFreedoms_To_TaskPreparePortableDataset_Art20</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPreparePortableDataset_To_GatewayDirectTransmissionRequested_Art20</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_DirectTransmissionRequested_Art20" name="Did the data subject request direct transmission to another controller?">
      <bpmn:incoming>Flow_TaskPreparePortableDataset_To_GatewayDirectTransmissionRequested_Art20</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayDirectTransmissionRequested_To_SendTaskProvidePortableDataToDataSubject_Art20</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayDirectTransmissionRequested_To_GatewayTechnicalFeasibility_Art20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_TechnicalFeasibility_Art20" name="Is direct controller-to-controller transmission technically feasible?">
      <bpmn:incoming>Flow_GatewayDirectTransmissionRequested_To_GatewayTechnicalFeasibility_Art20</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayTechnicalFeasibility_To_SendTaskProvidePortableDataToDataSubject_Art20</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayTechnicalFeasibility_To_SendTaskTransmitDataToReceivingController_Art20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_ProvidePortableDataToDataSubject_Art20" name="Provide portable data set">
      <bpmn:incoming>Flow_GatewayDirectTransmissionRequested_To_SendTaskProvidePortableDataToDataSubject_Art20</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayTechnicalFeasibility_To_SendTaskProvidePortableDataToDataSubject_Art20</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskProvidePortableDataToDataSubject_To_EndPortabilityCompleted_Art20</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:sendTask id="SendTask_TransmitDataToReceivingController_Art20" name="Transmit portable data to receiving controller">
      <bpmn:incoming>Flow_GatewayTechnicalFeasibility_To_SendTaskTransmitDataToReceivingController_Art20</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskTransmitDataToReceivingController_To_EndPortabilityCompleted_Art20</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_RequestBlocked_Art20" name="No portability right arises because the relevant data were not provided by the data subject in a portable electronic form">
      <bpmn:incoming>Flow_GatewayRequestExceptions_To_EndRequestBlocked_Art20</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_NoPortableDataset_Art20" name="No portability right arises because the processing is not based on Article 6(1)(a), Article 9(2)(a), or Article 6(1)(b)">
      <bpmn:incoming>Flow_GatewayProvidedData_To_EndNoPortableDataset_Art20</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_NoPortabilityBasis_Art20" name="No portability right arises because the processing is not carried out by automated means">
      <bpmn:incoming>Flow_GatewayLegalBasis_To_EndNoPortabilityBasis_Art20</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_NotAutomated_Art20" name="No portability right arises because the processing is not carried out by automated means">
      <bpmn:incoming>Flow_GatewayAutomatedProcessing_To_EndNotAutomated_Art20</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_PublicTaskException_Art20" name="The portability right does not apply because the processing is necessary for a public-interest task or official authority">
      <bpmn:incoming>Flow_GatewayPublicTaskException_To_EndPublicTaskException_Art20</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_RightsFreedomsLimit_Art20" name="The portability request is not fulfilled because it would adversely affect the rights and freedoms of others">
      <bpmn:incoming>Flow_GatewayRightsFreedoms_To_EndRightsFreedomsLimit_Art20</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_PortabilityCompleted_Art20" name="Article 20 portability handling is completed without prejudice to Article 17">
      <bpmn:incoming>Flow_SendTaskProvidePortableDataToDataSubject_To_EndPortabilityCompleted_Art20</bpmn:incoming>
      <bpmn:incoming>Flow_SendTaskTransmitDataToReceivingController_To_EndPortabilityCompleted_Art20</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_ReceiveTaskReceivePortabilityRequest_Art20" sourceRef="StartEvent_PortabilityRequested_Art20" targetRef="ReceiveTask_ReceivePortabilityRequest_Art20" />
    <bpmn:sequenceFlow id="Flow_ReceiveTaskReceivePortabilityRequest_To_GatewayRequestExceptions_Art20" sourceRef="ReceiveTask_ReceivePortabilityRequest_Art20" targetRef="Gateway_RequestExceptions_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayRequestExceptions_To_EndRequestBlocked_Art20" name="No" sourceRef="Gateway_RequestExceptions_Art20" targetRef="EndEvent_RequestBlocked_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayRequestExceptions_To_GatewayProvidedData_Art20" name="Yes" sourceRef="Gateway_RequestExceptions_Art20" targetRef="Gateway_ProvidedData_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayProvidedData_To_EndNoPortableDataset_Art20" name="No" sourceRef="Gateway_ProvidedData_Art20" targetRef="EndEvent_NoPortableDataset_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayProvidedData_To_GatewayLegalBasis_Art20" name="Yes" sourceRef="Gateway_ProvidedData_Art20" targetRef="Gateway_LegalBasis_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayLegalBasis_To_EndNoPortabilityBasis_Art20" name="No" sourceRef="Gateway_LegalBasis_Art20" targetRef="EndEvent_NoPortabilityBasis_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayLegalBasis_To_GatewayAutomatedProcessing_Art20" name="Yes" sourceRef="Gateway_LegalBasis_Art20" targetRef="Gateway_AutomatedProcessing_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayAutomatedProcessing_To_EndNotAutomated_Art20" name="No" sourceRef="Gateway_AutomatedProcessing_Art20" targetRef="EndEvent_NotAutomated_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayAutomatedProcessing_To_GatewayPublicTaskException_Art20" name="Yes" sourceRef="Gateway_AutomatedProcessing_Art20" targetRef="Gateway_PublicTaskException_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicTaskException_To_EndPublicTaskException_Art20" name="Yes" sourceRef="Gateway_PublicTaskException_Art20" targetRef="EndEvent_PublicTaskException_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicTaskException_To_GatewayRightsFreedoms_Art20" name="No" sourceRef="Gateway_PublicTaskException_Art20" targetRef="Gateway_RightsFreedoms_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayRightsFreedoms_To_EndRightsFreedomsLimit_Art20" name="Yes" sourceRef="Gateway_RightsFreedoms_Art20" targetRef="EndEvent_RightsFreedomsLimit_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayRightsFreedoms_To_TaskPreparePortableDataset_Art20" name="No" sourceRef="Gateway_RightsFreedoms_Art20" targetRef="Task_PreparePortableDataset_Art20" />
    <bpmn:sequenceFlow id="Flow_TaskPreparePortableDataset_To_GatewayDirectTransmissionRequested_Art20" sourceRef="Task_PreparePortableDataset_Art20" targetRef="Gateway_DirectTransmissionRequested_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayDirectTransmissionRequested_To_SendTaskProvidePortableDataToDataSubject_Art20" name="No" sourceRef="Gateway_DirectTransmissionRequested_Art20" targetRef="SendTask_ProvidePortableDataToDataSubject_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayDirectTransmissionRequested_To_GatewayTechnicalFeasibility_Art20" name="Yes" sourceRef="Gateway_DirectTransmissionRequested_Art20" targetRef="Gateway_TechnicalFeasibility_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayTechnicalFeasibility_To_SendTaskProvidePortableDataToDataSubject_Art20" name="No" sourceRef="Gateway_TechnicalFeasibility_Art20" targetRef="SendTask_ProvidePortableDataToDataSubject_Art20" />
    <bpmn:sequenceFlow id="Flow_GatewayTechnicalFeasibility_To_SendTaskTransmitDataToReceivingController_Art20" name="Yes" sourceRef="Gateway_TechnicalFeasibility_Art20" targetRef="SendTask_TransmitDataToReceivingController_Art20" />
    <bpmn:sequenceFlow id="Flow_SendTaskProvidePortableDataToDataSubject_To_EndPortabilityCompleted_Art20" sourceRef="SendTask_ProvidePortableDataToDataSubject_Art20" targetRef="EndEvent_PortabilityCompleted_Art20" />
    <bpmn:sequenceFlow id="Flow_SendTaskTransmitDataToReceivingController_To_EndPortabilityCompleted_Art20" sourceRef="SendTask_TransmitDataToReceivingController_Art20" targetRef="EndEvent_PortabilityCompleted_Art20" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art20_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art20_Reviewed" bpmnElement="Collaboration_Art20_Reviewed">
      <bpmndi:BPMNShape id="Participant_Controller_Art20_di" bpmnElement="Participant_Controller_Art20" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="5100" height="980" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art20_di" bpmnElement="Participant_DataSubject_Art20" isHorizontal="true">
        <dc:Bounds x="60" y="1060" width="5100" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_ReceivingController_Art20_di" bpmnElement="Participant_ReceivingController_Art20" isHorizontal="true">
        <dc:Bounds x="60" y="1200" width="5100" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_PortabilityRequested_Art20_di" bpmnElement="StartEvent_PortabilityRequested_Art20">
        <dc:Bounds x="120" y="472" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReceiveTask_ReceivePortabilityRequest_Art20_di" bpmnElement="ReceiveTask_ReceivePortabilityRequest_Art20">
        <dc:Bounds x="240" y="450" width="300" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RequestExceptions_Art20_di" bpmnElement="Gateway_RequestExceptions_Art20" isMarkerVisible="true">
        <dc:Bounds x="640" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ProvidedData_Art20_di" bpmnElement="Gateway_ProvidedData_Art20" isMarkerVisible="true">
        <dc:Bounds x="900" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_LegalBasis_Art20_di" bpmnElement="Gateway_LegalBasis_Art20" isMarkerVisible="true">
        <dc:Bounds x="1160" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AutomatedProcessing_Art20_di" bpmnElement="Gateway_AutomatedProcessing_Art20" isMarkerVisible="true">
        <dc:Bounds x="1420" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PublicTaskException_Art20_di" bpmnElement="Gateway_PublicTaskException_Art20" isMarkerVisible="true">
        <dc:Bounds x="1680" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RightsFreedoms_Art20_di" bpmnElement="Gateway_RightsFreedoms_Art20" isMarkerVisible="true">
        <dc:Bounds x="1940" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PreparePortableDataset_Art20_di" bpmnElement="Task_PreparePortableDataset_Art20">
        <dc:Bounds x="2160" y="450" width="460" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DirectTransmissionRequested_Art20_di" bpmnElement="Gateway_DirectTransmissionRequested_Art20" isMarkerVisible="true">
        <dc:Bounds x="2780" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_TechnicalFeasibility_Art20_di" bpmnElement="Gateway_TechnicalFeasibility_Art20" isMarkerVisible="true">
        <dc:Bounds x="3040" y="465" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_ProvidePortableDataToDataSubject_Art20_di" bpmnElement="SendTask_ProvidePortableDataToDataSubject_Art20">
        <dc:Bounds x="3260" y="330" width="420" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_TransmitDataToReceivingController_Art20_di" bpmnElement="SendTask_TransmitDataToReceivingController_Art20">
        <dc:Bounds x="3260" y="550" width="430" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_RequestBlocked_Art20_di" bpmnElement="EndEvent_RequestBlocked_Art20">
        <dc:Bounds x="737" y="717" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoPortableDataset_Art20_di" bpmnElement="EndEvent_NoPortableDataset_Art20">
        <dc:Bounds x="997" y="717" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoPortabilityBasis_Art20_di" bpmnElement="EndEvent_NoPortabilityBasis_Art20">
        <dc:Bounds x="1257" y="717" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NotAutomated_Art20_di" bpmnElement="EndEvent_NotAutomated_Art20">
        <dc:Bounds x="1517" y="717" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_PublicTaskException_Art20_di" bpmnElement="EndEvent_PublicTaskException_Art20">
        <dc:Bounds x="1777" y="717" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RightsFreedomsLimit_Art20_di" bpmnElement="EndEvent_RightsFreedomsLimit_Art20">
        <dc:Bounds x="2037" y="717" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_PortabilityCompleted_Art20_di" bpmnElement="EndEvent_PortabilityCompleted_Art20">
        <dc:Bounds x="3902" y="472" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_ReceiveTaskReceivePortabilityRequest_Art20_di" bpmnElement="Flow_Start_To_ReceiveTaskReceivePortabilityRequest_Art20">
        <di:waypoint x="156" y="490" />
        <di:waypoint x="240" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReceiveTaskReceivePortabilityRequest_To_GatewayRequestExceptions_Art20_di" bpmnElement="Flow_ReceiveTaskReceivePortabilityRequest_To_GatewayRequestExceptions_Art20">
        <di:waypoint x="540" y="490" />
        <di:waypoint x="640" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayRequestExceptions_To_EndRequestBlocked_Art20_di" bpmnElement="Flow_GatewayRequestExceptions_To_EndRequestBlocked_Art20">
        <di:waypoint x="665" y="515" />
        <di:waypoint x="665" y="735" />
        <di:waypoint x="737" y="735" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayRequestExceptions_To_GatewayProvidedData_Art20_di" bpmnElement="Flow_GatewayRequestExceptions_To_GatewayProvidedData_Art20">
        <di:waypoint x="690" y="490" />
        <di:waypoint x="900" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayProvidedData_To_EndNoPortableDataset_Art20_di" bpmnElement="Flow_GatewayProvidedData_To_EndNoPortableDataset_Art20">
        <di:waypoint x="925" y="515" />
        <di:waypoint x="925" y="735" />
        <di:waypoint x="997" y="735" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayProvidedData_To_GatewayLegalBasis_Art20_di" bpmnElement="Flow_GatewayProvidedData_To_GatewayLegalBasis_Art20">
        <di:waypoint x="950" y="490" />
        <di:waypoint x="1160" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayLegalBasis_To_EndNoPortabilityBasis_Art20_di" bpmnElement="Flow_GatewayLegalBasis_To_EndNoPortabilityBasis_Art20">
        <di:waypoint x="1185" y="515" />
        <di:waypoint x="1185" y="735" />
        <di:waypoint x="1257" y="735" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayLegalBasis_To_GatewayAutomatedProcessing_Art20_di" bpmnElement="Flow_GatewayLegalBasis_To_GatewayAutomatedProcessing_Art20">
        <di:waypoint x="1210" y="490" />
        <di:waypoint x="1420" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAutomatedProcessing_To_EndNotAutomated_Art20_di" bpmnElement="Flow_GatewayAutomatedProcessing_To_EndNotAutomated_Art20">
        <di:waypoint x="1445" y="515" />
        <di:waypoint x="1445" y="735" />
        <di:waypoint x="1517" y="735" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayAutomatedProcessing_To_GatewayPublicTaskException_Art20_di" bpmnElement="Flow_GatewayAutomatedProcessing_To_GatewayPublicTaskException_Art20">
        <di:waypoint x="1470" y="490" />
        <di:waypoint x="1680" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPublicTaskException_To_EndPublicTaskException_Art20_di" bpmnElement="Flow_GatewayPublicTaskException_To_EndPublicTaskException_Art20">
        <di:waypoint x="1705" y="515" />
        <di:waypoint x="1705" y="735" />
        <di:waypoint x="1777" y="735" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPublicTaskException_To_GatewayRightsFreedoms_Art20_di" bpmnElement="Flow_GatewayPublicTaskException_To_GatewayRightsFreedoms_Art20">
        <di:waypoint x="1730" y="490" />
        <di:waypoint x="1940" y="490" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayRightsFreedoms_To_EndRightsFreedomsLimit_Art20_di" bpmnElement="Flow_GatewayRightsFreedoms_To_EndRightsFreedomsLimit_Art20">
