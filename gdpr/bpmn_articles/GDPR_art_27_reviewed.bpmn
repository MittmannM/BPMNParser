<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art27_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art27_Reviewed">
    <bpmn:participant id="Participant_ControllerOrProcessor_Art27"
                      name="Controller or Processor"
                      processRef="Process_ControllerOrProcessor_Art27" />
    <bpmn:participant id="Participant_Representative_Art27"
                      name="Representative in the Union" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art27"
                      name="Supervisory Authority" />
    <bpmn:participant id="Participant_DataSubject_Art27"
                      name="Data Subject" />

    <bpmn:messageFlow id="MessageFlow_IssueWrittenDesignation_Art27"
                      sourceRef="SendTask_IssueWrittenDesignation_Art27"
                      targetRef="Participant_Representative_Art27" />
    <bpmn:messageFlow id="MessageFlow_SA_To_Representative_Art27"
                      sourceRef="Participant_SupervisoryAuthority_Art27"
                      targetRef="Participant_Representative_Art27" />
    <bpmn:messageFlow id="MessageFlow_DataSubject_To_Representative_Art27"
                      sourceRef="Participant_DataSubject_Art27"
                      targetRef="Participant_Representative_Art27" />
    <bpmn:messageFlow id="MessageFlow_SA_To_ControllerOrProcessor_Art27"
                      sourceRef="Participant_SupervisoryAuthority_Art27"
                      targetRef="Participant_ControllerOrProcessor_Art27" />
    <bpmn:messageFlow id="MessageFlow_DataSubject_To_ControllerOrProcessor_Art27"
                      sourceRef="Participant_DataSubject_Art27"
                      targetRef="Participant_ControllerOrProcessor_Art27" />
  </bpmn:collaboration>

  <bpmn:process id="Process_ControllerOrProcessor_Art27"
                name="Designating an Article 27 representative"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 27 based on the real English legal text
      of Regulation (EU) 2016/679. The model captures the Article 3(2) trigger, the
      Article 27(2) exception structure for occasional low-risk processing and for
      public authorities or bodies, the written designation of a representative in the
      Union, the Article 27(3) Member-State selection tied to the relevant data
      subjects, the Article 27(4) mandate enabling supervisory authorities and data
      subjects to address the representative in addition to or instead of the
      controller or processor, and the Article 27(5) rule that legal actions may
      still be initiated against the controller or processor themselves.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_PlanUnionFacingProcessing_Art27"
                     name="Plan Union-facing processing">
      <bpmn:outgoing>Flow_StartPlanUnionFacingProcessing_To_GatewayArticle3Scope_Art27</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_Article3Scope_Art27"
                           name="Does Article 3(2) apply?">
      <bpmn:incoming>Flow_StartPlanUnionFacingProcessing_To_GatewayArticle3Scope_Art27</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayArticle3Scope_To_GatewayPublicAuthority_Art27</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayArticle3Scope_To_EndNoRepresentativeRequired_Art27</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NoRepresentativeRequired_Art27"
                   name="No Article 27 representative required">
      <bpmn:incoming>Flow_GatewayArticle3Scope_To_EndNoRepresentativeRequired_Art27</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayPublicAuthority_To_EndNoRepresentativeRequired_Art27</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayUnlikelyRisk_To_EndNoRepresentativeRequired_Art27</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_PublicAuthority_Art27"
                           name="Is the actor a public authority or body?">
      <bpmn:incoming>Flow_GatewayArticle3Scope_To_GatewayPublicAuthority_Art27</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayPublicAuthority_To_EndNoRepresentativeRequired_Art27</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayPublicAuthority_To_GatewayOccasionalProcessing_Art27</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_OccasionalProcessing_Art27"
                           name="Is the processing occasional?">
      <bpmn:incoming>Flow_GatewayPublicAuthority_To_GatewayOccasionalProcessing_Art27</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayOccasionalProcessing_To_GatewayArticle9Or10LargeScale_Art27</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayOccasionalProcessing_To_SendTaskIssueWrittenDesignation_Art27</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_Article9Or10LargeScale_Art27"
                           name="Does the processing include large-scale Article 9(1) or Article 10 data?">
      <bpmn:incoming>Flow_GatewayOccasionalProcessing_To_GatewayArticle9Or10LargeScale_Art27</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayArticle9Or10LargeScale_To_SendTaskIssueWrittenDesignation_Art27</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayArticle9Or10LargeScale_To_GatewayUnlikelyRisk_Art27</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_UnlikelyRisk_Art27"
                           name="Is the processing unlikely to result in a risk to rights and freedoms?">
      <bpmn:incoming>Flow_GatewayArticle9Or10LargeScale_To_GatewayUnlikelyRisk_Art27</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayUnlikelyRisk_To_EndNoRepresentativeRequired_Art27</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayUnlikelyRisk_To_SendTaskIssueWrittenDesignation_Art27</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_IssueWrittenDesignation_Art27"
                   name="Issue written designation">
      <bpmn:incoming>Flow_GatewayOccasionalProcessing_To_SendTaskIssueWrittenDesignation_Art27</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayArticle9Or10LargeScale_To_SendTaskIssueWrittenDesignation_Art27</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayUnlikelyRisk_To_SendTaskIssueWrittenDesignation_Art27</bpmn:incoming>
      <bpmn:outgoing>Flow_SendTaskIssueWrittenDesignation_To_TaskSelectMemberState_Art27</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_SelectMemberState_Art27"
               name="Select representative Member State">
      <bpmn:incoming>Flow_SendTaskIssueWrittenDesignation_To_TaskSelectMemberState_Art27</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSelectMemberState_To_TaskMandateRepresentative_Art27</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_MandateRepresentative_Art27"
               name="Mandate representative">
      <bpmn:incoming>Flow_TaskSelectMemberState_To_TaskMandateRepresentative_Art27</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskMandateRepresentative_To_EndRepresentativeDesignated_Art27</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_RepresentativeDesignated_Art27"
                   name="Article 27 representative designated">
      <bpmn:incoming>Flow_TaskMandateRepresentative_To_EndRepresentativeDesignated_Art27</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartPlanUnionFacingProcessing_To_GatewayArticle3Scope_Art27" sourceRef="StartEvent_PlanUnionFacingProcessing_Art27" targetRef="Gateway_Article3Scope_Art27" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle3Scope_To_GatewayPublicAuthority_Art27" name="Yes" sourceRef="Gateway_Article3Scope_Art27" targetRef="Gateway_PublicAuthority_Art27" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle3Scope_To_EndNoRepresentativeRequired_Art27" name="No" sourceRef="Gateway_Article3Scope_Art27" targetRef="EndEvent_NoRepresentativeRequired_Art27" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicAuthority_To_EndNoRepresentativeRequired_Art27" name="Yes" sourceRef="Gateway_PublicAuthority_Art27" targetRef="EndEvent_NoRepresentativeRequired_Art27" />
    <bpmn:sequenceFlow id="Flow_GatewayPublicAuthority_To_GatewayOccasionalProcessing_Art27" name="No" sourceRef="Gateway_PublicAuthority_Art27" targetRef="Gateway_OccasionalProcessing_Art27" />
    <bpmn:sequenceFlow id="Flow_GatewayOccasionalProcessing_To_GatewayArticle9Or10LargeScale_Art27" name="Yes" sourceRef="Gateway_OccasionalProcessing_Art27" targetRef="Gateway_Article9Or10LargeScale_Art27" />
    <bpmn:sequenceFlow id="Flow_GatewayOccasionalProcessing_To_SendTaskIssueWrittenDesignation_Art27" name="No" sourceRef="Gateway_OccasionalProcessing_Art27" targetRef="SendTask_IssueWrittenDesignation_Art27" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle9Or10LargeScale_To_SendTaskIssueWrittenDesignation_Art27" name="Yes" sourceRef="Gateway_Article9Or10LargeScale_Art27" targetRef="SendTask_IssueWrittenDesignation_Art27" />
    <bpmn:sequenceFlow id="Flow_GatewayArticle9Or10LargeScale_To_GatewayUnlikelyRisk_Art27" name="No" sourceRef="Gateway_Article9Or10LargeScale_Art27" targetRef="Gateway_UnlikelyRisk_Art27" />
    <bpmn:sequenceFlow id="Flow_GatewayUnlikelyRisk_To_EndNoRepresentativeRequired_Art27" name="Yes" sourceRef="Gateway_UnlikelyRisk_Art27" targetRef="EndEvent_NoRepresentativeRequired_Art27" />
    <bpmn:sequenceFlow id="Flow_GatewayUnlikelyRisk_To_SendTaskIssueWrittenDesignation_Art27" name="No" sourceRef="Gateway_UnlikelyRisk_Art27" targetRef="SendTask_IssueWrittenDesignation_Art27" />
    <bpmn:sequenceFlow id="Flow_SendTaskIssueWrittenDesignation_To_TaskSelectMemberState_Art27" sourceRef="SendTask_IssueWrittenDesignation_Art27" targetRef="Task_SelectMemberState_Art27" />
    <bpmn:sequenceFlow id="Flow_TaskSelectMemberState_To_TaskMandateRepresentative_Art27" sourceRef="Task_SelectMemberState_Art27" targetRef="Task_MandateRepresentative_Art27" />
    <bpmn:sequenceFlow id="Flow_TaskMandateRepresentative_To_EndRepresentativeDesignated_Art27" sourceRef="Task_MandateRepresentative_Art27" targetRef="EndEvent_RepresentativeDesignated_Art27" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art27_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art27_Reviewed" bpmnElement="Collaboration_Art27_Reviewed">
      <bpmndi:BPMNShape id="Participant_ControllerOrProcessor_Art27_di"
                        bpmnElement="Participant_ControllerOrProcessor_Art27"
                        isHorizontal="true">
        <dc:Bounds x="60" y="40" width="3800" height="420" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Representative_Art27_di"
                        bpmnElement="Participant_Representative_Art27"
                        isHorizontal="true">
        <dc:Bounds x="60" y="500" width="3800" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_SupervisoryAuthority_Art27_di"
                        bpmnElement="Participant_SupervisoryAuthority_Art27"
                        isHorizontal="true">
        <dc:Bounds x="60" y="660" width="3800" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_DataSubject_Art27_di"
                        bpmnElement="Participant_DataSubject_Art27"
                        isHorizontal="true">
        <dc:Bounds x="60" y="820" width="3800" height="120" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_PlanUnionFacingProcessing_Art27_di" bpmnElement="StartEvent_PlanUnionFacingProcessing_Art27">
        <dc:Bounds x="120" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Article3Scope_Art27_di" bpmnElement="Gateway_Article3Scope_Art27" isMarkerVisible="true">
        <dc:Bounds x="260" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NoRepresentativeRequired_Art27_di" bpmnElement="EndEvent_NoRepresentativeRequired_Art27">
        <dc:Bounds x="1782" y="352" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PublicAuthority_Art27_di" bpmnElement="Gateway_PublicAuthority_Art27" isMarkerVisible="true">
        <dc:Bounds x="460" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_OccasionalProcessing_Art27_di" bpmnElement="Gateway_OccasionalProcessing_Art27" isMarkerVisible="true">
        <dc:Bounds x="680" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Article9Or10LargeScale_Art27_di" bpmnElement="Gateway_Article9Or10LargeScale_Art27" isMarkerVisible="true">
        <dc:Bounds x="930" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_UnlikelyRisk_Art27_di" bpmnElement="Gateway_UnlikelyRisk_Art27" isMarkerVisible="true">
        <dc:Bounds x="1220" y="235" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_IssueWrittenDesignation_Art27_di" bpmnElement="SendTask_IssueWrittenDesignation_Art27">
        <dc:Bounds x="1520" y="220" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SelectMemberState_Art27_di" bpmnElement="Task_SelectMemberState_Art27">
        <dc:Bounds x="2010" y="120" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_MandateRepresentative_Art27_di" bpmnElement="Task_MandateRepresentative_Art27">
        <dc:Bounds x="2380" y="220" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RepresentativeDesignated_Art27_di" bpmnElement="EndEvent_RepresentativeDesignated_Art27">
        <dc:Bounds x="2732" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_StartPlanUnionFacingProcessing_To_GatewayArticle3Scope_Art27_di" bpmnElement="Flow_StartPlanUnionFacingProcessing_To_GatewayArticle3Scope_Art27">
        <di:waypoint x="156" y="260" />
        <di:waypoint x="260" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayArticle3Scope_To_GatewayPublicAuthority_Art27_di" bpmnElement="Flow_GatewayArticle3Scope_To_GatewayPublicAuthority_Art27">
        <di:waypoint x="310" y="260" />
        <di:waypoint x="460" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayArticle3Scope_To_EndNoRepresentativeRequired_Art27_di" bpmnElement="Flow_GatewayArticle3Scope_To_EndNoRepresentativeRequired_Art27">
        <di:waypoint x="285" y="285" />
        <di:waypoint x="285" y="370" />
        <di:waypoint x="1782" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPublicAuthority_To_EndNoRepresentativeRequired_Art27_di" bpmnElement="Flow_GatewayPublicAuthority_To_EndNoRepresentativeRequired_Art27">
        <di:waypoint x="485" y="285" />
        <di:waypoint x="485" y="410" />
        <di:waypoint x="1800" y="410" />
        <di:waypoint x="1800" y="388" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayPublicAuthority_To_GatewayOccasionalProcessing_Art27_di" bpmnElement="Flow_GatewayPublicAuthority_To_GatewayOccasionalProcessing_Art27">
        <di:waypoint x="510" y="260" />
        <di:waypoint x="680" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayOccasionalProcessing_To_GatewayArticle9Or10LargeScale_Art27_di" bpmnElement="Flow_GatewayOccasionalProcessing_To_GatewayArticle9Or10LargeScale_Art27">
        <di:waypoint x="730" y="260" />
        <di:waypoint x="930" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayOccasionalProcessing_To_SendTaskIssueWrittenDesignation_Art27_di" bpmnElement="Flow_GatewayOccasionalProcessing_To_SendTaskIssueWrittenDesignation_Art27">
        <di:waypoint x="705" y="285" />
        <di:waypoint x="705" y="330" />
        <di:waypoint x="1620" y="330" />
        <di:waypoint x="1620" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayArticle9Or10LargeScale_To_SendTaskIssueWrittenDesignation_Art27_di" bpmnElement="Flow_GatewayArticle9Or10LargeScale_To_SendTaskIssueWrittenDesignation_Art27">
        <di:waypoint x="955" y="285" />
        <di:waypoint x="955" y="360" />
        <di:waypoint x="1620" y="360" />
        <di:waypoint x="1620" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayArticle9Or10LargeScale_To_GatewayUnlikelyRisk_Art27_di" bpmnElement="Flow_GatewayArticle9Or10LargeScale_To_GatewayUnlikelyRisk_Art27">
        <di:waypoint x="980" y="260" />
        <di:waypoint x="1220" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayUnlikelyRisk_To_EndNoRepresentativeRequired_Art27_di" bpmnElement="Flow_GatewayUnlikelyRisk_To_EndNoRepresentativeRequired_Art27">
        <di:waypoint x="1245" y="285" />
        <di:waypoint x="1245" y="440" />
        <di:waypoint x="1800" y="440" />
        <di:waypoint x="1800" y="388" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayUnlikelyRisk_To_SendTaskIssueWrittenDesignation_Art27_di" bpmnElement="Flow_GatewayUnlikelyRisk_To_SendTaskIssueWrittenDesignation_Art27">
        <di:waypoint x="1270" y="260" />
        <di:waypoint x="1520" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SendTaskIssueWrittenDesignation_To_TaskSelectMemberState_Art27_di" bpmnElement="Flow_SendTaskIssueWrittenDesignation_To_TaskSelectMemberState_Art27">
        <di:waypoint x="1720" y="260" />
        <di:waypoint x="1850" y="260" />
        <di:waypoint x="1850" y="160" />
        <di:waypoint x="2010" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskSelectMemberState_To_TaskMandateRepresentative_Art27_di" bpmnElement="Flow_TaskSelectMemberState_To_TaskMandateRepresentative_Art27">
        <di:waypoint x="2230" y="160" />
        <di:waypoint x="2475" y="160" />
        <di:waypoint x="2475" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskMandateRepresentative_To_EndRepresentativeDesignated_Art27_di" bpmnElement="Flow_TaskMandateRepresentative_To_EndRepresentativeDesignated_Art27">
        <di:waypoint x="2570" y="260" />
        <di:waypoint x="2732" y="260" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MessageFlow_IssueWrittenDesignation_Art27_di" bpmnElement="MessageFlow_IssueWrittenDesignation_Art27">
        <di:waypoint x="1620" y="300" />
        <di:waypoint x="1620" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_SA_To_Representative_Art27_di" bpmnElement="MessageFlow_SA_To_Representative_Art27">
        <di:waypoint x="2280" y="660" />
        <di:waypoint x="2280" y="620" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_DataSubject_To_Representative_Art27_di" bpmnElement="MessageFlow_DataSubject_To_Representative_Art27">
        <di:waypoint x="2470" y="820" />
        <di:waypoint x="2470" y="620" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_SA_To_ControllerOrProcessor_Art27_di" bpmnElement="MessageFlow_SA_To_ControllerOrProcessor_Art27">
        <di:waypoint x="3160" y="660" />
        <di:waypoint x="3160" y="460" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_DataSubject_To_ControllerOrProcessor_Art27_di" bpmnElement="MessageFlow_DataSubject_To_ControllerOrProcessor_Art27">
        <di:waypoint x="3340" y="820" />
        <di:waypoint x="3340" y="460" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
