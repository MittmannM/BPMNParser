<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art42_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:collaboration id="Collaboration_Art42_Reviewed">
    <bpmn:participant id="Participant_ControllerProcessor_Art42"
                      name="Controller or Processor"
                      processRef="Process_ControllerProcessor_Art42" />
    <bpmn:participant id="Participant_CertificationBody_Art42"
                      name="Accredited Certification Body"
                      processRef="Process_CertificationBody_Art42" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art42"
                      name="Supervisory Authority"
                      processRef="Process_SupervisoryAuthority_Art42" />
    <bpmn:participant id="Participant_Board_Art42"
                      name="Board" />

    <bpmn:messageFlow id="MessageFlow_RequestBodyCertification_Art42"
                      sourceRef="SendTask_RequestBodyCertification_Art42"
                      targetRef="ReceiveTask_ReceiveBodyCertificationRequest_Art42" />
    <bpmn:messageFlow id="MessageFlow_RequestAuthorityCertification_Art42"
                      sourceRef="SendTask_RequestAuthorityCertification_Art42"
                      targetRef="ReceiveTask_ReceiveAuthorityCertificationRequest_Art42" />
    <bpmn:messageFlow id="MessageFlow_RequestBodyInfo_Art42"
                      sourceRef="SendTask_RequestBodyInfo_Art42"
                      targetRef="Task_ProvideBodyInfo_Art42" />
    <bpmn:messageFlow id="MessageFlow_RequestAuthorityInfo_Art42"
                      sourceRef="SendTask_RequestAuthorityInfo_Art42"
                      targetRef="Task_ProvideAuthorityInfo_Art42" />
    <bpmn:messageFlow id="MessageFlow_ProvideBodyInfo_Art42"
                      sourceRef="Task_ProvideBodyInfo_Art42"
                      targetRef="ReceiveTask_ReceiveBodyInfo_Art42" />
    <bpmn:messageFlow id="MessageFlow_ProvideAuthorityInfo_Art42"
                      sourceRef="Task_ProvideAuthorityInfo_Art42"
                      targetRef="ReceiveTask_ReceiveAuthorityInfo_Art42" />
    <bpmn:messageFlow id="MessageFlow_RejectBodyCertification_Art42"
                      sourceRef="SendTask_RejectBodyCertification_Art42"
                      targetRef="ReceiveTask_ReceiveBodyStatus_Art42" />
    <bpmn:messageFlow id="MessageFlow_IssueBodyCertification_Art42"
                      sourceRef="SendTask_IssueBodyCertification_Art42"
                      targetRef="ReceiveTask_ReceiveBodyStatus_Art42" />
    <bpmn:messageFlow id="MessageFlow_RequestBodyRenewal_Art42"
                      sourceRef="SendTask_RequestBodyRenewal_Art42"
                      targetRef="ReceiveTask_ReceiveBodyRenewalRequest_Art42" />
    <bpmn:messageFlow id="MessageFlow_RequestBodyRenewalInfo_Art42"
                      sourceRef="SendTask_RequestBodyRenewalInfo_Art42"
                      targetRef="Task_ProvideBodyRenewalInfo_Art42" />
    <bpmn:messageFlow id="MessageFlow_ProvideBodyRenewalInfo_Art42"
                      sourceRef="Task_ProvideBodyRenewalInfo_Art42"
                      targetRef="ReceiveTask_ReceiveBodyRenewalInfo_Art42" />
    <bpmn:messageFlow id="MessageFlow_RenewBodyCertification_Art42"
                      sourceRef="SendTask_RenewBodyCertification_Art42"
                      targetRef="ReceiveTask_ReceiveBodyRenewalStatus_Art42" />
    <bpmn:messageFlow id="MessageFlow_WithdrawBodyCertification_Art42"
                      sourceRef="SendTask_WithdrawBodyCertification_Art42"
                      targetRef="Participant_ControllerProcessor_Art42" />
    <bpmn:messageFlow id="MessageFlow_RejectAuthorityCertification_Art42"
                      sourceRef="SendTask_RejectAuthorityCertification_Art42"
                      targetRef="ReceiveTask_ReceiveAuthorityStatus_Art42" />
    <bpmn:messageFlow id="MessageFlow_IssueAuthorityCertification_Art42"
                      sourceRef="SendTask_IssueAuthorityCertification_Art42"
                      targetRef="ReceiveTask_ReceiveAuthorityStatus_Art42" />
    <bpmn:messageFlow id="MessageFlow_RequestAuthorityRenewal_Art42"
                      sourceRef="SendTask_RequestAuthorityRenewal_Art42"
                      targetRef="ReceiveTask_ReceiveAuthorityRenewalRequest_Art42" />
    <bpmn:messageFlow id="MessageFlow_RequestAuthorityRenewalInfo_Art42"
                      sourceRef="SendTask_RequestAuthorityRenewalInfo_Art42"
                      targetRef="Task_ProvideAuthorityRenewalInfo_Art42" />
    <bpmn:messageFlow id="MessageFlow_ProvideAuthorityRenewalInfo_Art42"
                      sourceRef="Task_ProvideAuthorityRenewalInfo_Art42"
                      targetRef="ReceiveTask_ReceiveAuthorityRenewalInfo_Art42" />
    <bpmn:messageFlow id="MessageFlow_RenewAuthorityCertification_Art42"
                      sourceRef="SendTask_RenewAuthorityCertification_Art42"
                      targetRef="ReceiveTask_ReceiveAuthorityRenewalStatus_Art42" />
    <bpmn:messageFlow id="MessageFlow_WithdrawAuthorityCertification_Art42"
                      sourceRef="SendTask_WithdrawAuthorityCertification_Art42"
                      targetRef="Participant_ControllerProcessor_Art42" />
    <bpmn:messageFlow id="MessageFlow_IssueBodyCertificationToBoard_Art42"
                      sourceRef="SendTask_IssueBodyCertification_Art42"
                      targetRef="Participant_Board_Art42" />
    <bpmn:messageFlow id="MessageFlow_IssueAuthorityCertificationToBoard_Art42"
                      sourceRef="SendTask_IssueAuthorityCertification_Art42"
                      targetRef="Participant_Board_Art42" />
  </bpmn:collaboration>

  <bpmn:process id="Process_ControllerProcessor_Art42"
                name="Seeking certification under Article 42"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 42 based on the real English legal text
      copied into gdpr_articles/article_42.txt. This model captures the voluntary and
      transparent certification route, the Article 42(2) safeguard option for non-
      Article-3 entities under Article 46(2)(f), the rule that certification does not
      reduce compliance responsibility, the alternative certification-body and
      supervisory-authority issuance routes, the information-and-access duty, and the
      renewal handling for certifications issued for up to three years.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_NeedComplianceSignal_Art42"
                     name="Need compliance signal">
      <bpmn:outgoing>Flow_Start_To_TaskRetainResponsibility_Art42</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_RetainResponsibility_Art42"
               name="Retain compliance responsibility">
      <bpmn:incoming>Flow_Start_To_TaskRetainResponsibility_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRetainResponsibility_To_GatewayVoluntary_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_VoluntaryCertification_Art42"
                           name="Will certification be sought voluntarily?">
      <bpmn:incoming>Flow_TaskRetainResponsibility_To_GatewayVoluntary_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayVoluntary_To_EndNoCertification_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayVoluntary_To_GatewayTransferSafeguards_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NoCertification_Art42"
                   name="No certification is sought">
      <bpmn:incoming>Flow_GatewayVoluntary_To_EndNoCertification_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_TransferSafeguards_Art42"
                           name="Is Article 46(2)(f) safeguard certification needed?">
      <bpmn:incoming>Flow_GatewayVoluntary_To_GatewayTransferSafeguards_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayTransferSafeguards_To_TaskBindingCommitments_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayTransferSafeguards_To_GatewayIssuingRoute_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_MakeBindingCommitments_Art42"
               name="Make binding commitments">
      <bpmn:incoming>Flow_GatewayTransferSafeguards_To_TaskBindingCommitments_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskBindingCommitments_To_GatewayIssuingRoute_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_IssuingRoute_Art42"
                           name="Will an accredited certification body handle the certification?">
      <bpmn:incoming>Flow_GatewayTransferSafeguards_To_GatewayIssuingRoute_Art42</bpmn:incoming>
      <bpmn:incoming>Flow_TaskBindingCommitments_To_GatewayIssuingRoute_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayIssuingRoute_To_SendBodyRequest_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayIssuingRoute_To_SendAuthorityRequest_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_RequestBodyCertification_Art42"
                   name="Request body certification">
      <bpmn:incoming>Flow_GatewayIssuingRoute_To_SendBodyRequest_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendBodyRequest_To_TaskProvideBodyInfo_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ProvideBodyInfo_Art42"
               name="Provide body information and access">
      <bpmn:incoming>Flow_SendBodyRequest_To_TaskProvideBodyInfo_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskProvideBodyInfo_To_ReceiveBodyStatus_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:receiveTask id="ReceiveTask_ReceiveBodyStatus_Art42"
                      name="Receive body certification status">
      <bpmn:incoming>Flow_TaskProvideBodyInfo_To_ReceiveBodyStatus_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveBodyStatus_To_GatewayBodyCertified_Art42</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_BodyCertified_Art42"
                           name="Was body certification issued?">
      <bpmn:incoming>Flow_ReceiveBodyStatus_To_GatewayBodyCertified_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayBodyCertified_To_EndBodyNotCertified_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayBodyCertified_To_TaskUseBodyCertification_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_BodyNotCertified_Art42"
                   name="Body certification not issued">
      <bpmn:incoming>Flow_GatewayBodyCertified_To_EndBodyNotCertified_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_UseBodyCertification_Art42"
               name="Use body certification">
      <bpmn:incoming>Flow_GatewayBodyCertified_To_TaskUseBodyCertification_Art42</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayBodyRenewed_To_TaskUseBodyCertification_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskUseBodyCertification_To_GatewayBodyRenewalRequested_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_BodyRenewalRequested_Art42"
                           name="Will renewal be requested before expiry?">
      <bpmn:incoming>Flow_TaskUseBodyCertification_To_GatewayBodyRenewalRequested_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayBodyRenewalRequested_To_EndBodyTermEnded_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayBodyRenewalRequested_To_SendBodyRenewalRequest_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_BodyTermEnded_Art42"
                   name="Body certification term ended">
      <bpmn:incoming>Flow_GatewayBodyRenewalRequested_To_EndBodyTermEnded_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_RequestBodyRenewal_Art42"
                   name="Request body renewal">
      <bpmn:incoming>Flow_GatewayBodyRenewalRequested_To_SendBodyRenewalRequest_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendBodyRenewalRequest_To_TaskProvideBodyRenewalInfo_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ProvideBodyRenewalInfo_Art42"
               name="Provide body renewal information">
      <bpmn:incoming>Flow_SendBodyRenewalRequest_To_TaskProvideBodyRenewalInfo_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskProvideBodyRenewalInfo_To_ReceiveBodyRenewalStatus_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:receiveTask id="ReceiveTask_ReceiveBodyRenewalStatus_Art42"
                      name="Receive body renewal status">
      <bpmn:incoming>Flow_TaskProvideBodyRenewalInfo_To_ReceiveBodyRenewalStatus_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveBodyRenewalStatus_To_GatewayBodyRenewed_Art42</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_BodyRenewed_Art42"
                           name="Was body certification renewed?">
      <bpmn:incoming>Flow_ReceiveBodyRenewalStatus_To_GatewayBodyRenewed_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayBodyRenewed_To_EndBodyCertificationInvalid_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayBodyRenewed_To_TaskUseBodyCertification_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_BodyCertificationInvalid_Art42"
                   name="Body certification no longer valid">
      <bpmn:incoming>Flow_GatewayBodyRenewed_To_EndBodyCertificationInvalid_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_RequestAuthorityCertification_Art42"
                   name="Request authority certification">
      <bpmn:incoming>Flow_GatewayIssuingRoute_To_SendAuthorityRequest_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendAuthorityRequest_To_TaskProvideAuthorityInfo_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ProvideAuthorityInfo_Art42"
               name="Provide authority information and access">
      <bpmn:incoming>Flow_SendAuthorityRequest_To_TaskProvideAuthorityInfo_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskProvideAuthorityInfo_To_ReceiveAuthorityStatus_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAuthorityStatus_Art42"
                      name="Receive authority certification status">
      <bpmn:incoming>Flow_TaskProvideAuthorityInfo_To_ReceiveAuthorityStatus_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveAuthorityStatus_To_GatewayAuthorityCertified_Art42</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_AuthorityCertified_Art42"
                           name="Was authority certification issued?">
      <bpmn:incoming>Flow_ReceiveAuthorityStatus_To_GatewayAuthorityCertified_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAuthorityCertified_To_EndAuthorityNotCertified_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAuthorityCertified_To_TaskUseAuthorityCertification_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_AuthorityNotCertified_Art42"
                   name="Authority certification not issued">
      <bpmn:incoming>Flow_GatewayAuthorityCertified_To_EndAuthorityNotCertified_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="Task_UseAuthorityCertification_Art42"
               name="Use authority certification">
      <bpmn:incoming>Flow_GatewayAuthorityCertified_To_TaskUseAuthorityCertification_Art42</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayAuthorityRenewed_To_TaskUseAuthorityCertification_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskUseAuthorityCertification_To_GatewayAuthorityRenewalRequested_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_AuthorityRenewalRequested_Art42"
                           name="Will authority renewal be requested before expiry?">
      <bpmn:incoming>Flow_TaskUseAuthorityCertification_To_GatewayAuthorityRenewalRequested_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAuthorityRenewalRequested_To_EndAuthorityTermEnded_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAuthorityRenewalRequested_To_SendAuthorityRenewalRequest_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_AuthorityTermEnded_Art42"
                   name="Authority certification term ended">
      <bpmn:incoming>Flow_GatewayAuthorityRenewalRequested_To_EndAuthorityTermEnded_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_RequestAuthorityRenewal_Art42"
                   name="Request authority renewal">
      <bpmn:incoming>Flow_GatewayAuthorityRenewalRequested_To_SendAuthorityRenewalRequest_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendAuthorityRenewalRequest_To_TaskProvideAuthorityRenewalInfo_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_ProvideAuthorityRenewalInfo_Art42"
               name="Provide authority renewal information">
      <bpmn:incoming>Flow_SendAuthorityRenewalRequest_To_TaskProvideAuthorityRenewalInfo_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskProvideAuthorityRenewalInfo_To_ReceiveAuthorityRenewalStatus_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAuthorityRenewalStatus_Art42"
                      name="Receive authority renewal status">
      <bpmn:incoming>Flow_TaskProvideAuthorityRenewalInfo_To_ReceiveAuthorityRenewalStatus_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveAuthorityRenewalStatus_To_GatewayAuthorityRenewed_Art42</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:exclusiveGateway id="Gateway_AuthorityRenewed_Art42"
                           name="Was authority certification renewed?">
      <bpmn:incoming>Flow_ReceiveAuthorityRenewalStatus_To_GatewayAuthorityRenewed_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAuthorityRenewed_To_EndAuthorityCertificationInvalid_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAuthorityRenewed_To_TaskUseAuthorityCertification_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_AuthorityCertificationInvalid_Art42"
                   name="Authority certification no longer valid">
      <bpmn:incoming>Flow_GatewayAuthorityRenewed_To_EndAuthorityCertificationInvalid_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_TaskRetainResponsibility_Art42" sourceRef="StartEvent_NeedComplianceSignal_Art42" targetRef="Task_RetainResponsibility_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskRetainResponsibility_To_GatewayVoluntary_Art42" sourceRef="Task_RetainResponsibility_Art42" targetRef="Gateway_VoluntaryCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayVoluntary_To_EndNoCertification_Art42" name="No" sourceRef="Gateway_VoluntaryCertification_Art42" targetRef="EndEvent_NoCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayVoluntary_To_GatewayTransferSafeguards_Art42" name="Yes" sourceRef="Gateway_VoluntaryCertification_Art42" targetRef="Gateway_TransferSafeguards_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayTransferSafeguards_To_TaskBindingCommitments_Art42" name="Yes" sourceRef="Gateway_TransferSafeguards_Art42" targetRef="Task_MakeBindingCommitments_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayTransferSafeguards_To_GatewayIssuingRoute_Art42" name="No" sourceRef="Gateway_TransferSafeguards_Art42" targetRef="Gateway_IssuingRoute_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskBindingCommitments_To_GatewayIssuingRoute_Art42" sourceRef="Task_MakeBindingCommitments_Art42" targetRef="Gateway_IssuingRoute_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayIssuingRoute_To_SendBodyRequest_Art42" name="Yes" sourceRef="Gateway_IssuingRoute_Art42" targetRef="SendTask_RequestBodyCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayIssuingRoute_To_SendAuthorityRequest_Art42" name="No" sourceRef="Gateway_IssuingRoute_Art42" targetRef="SendTask_RequestAuthorityCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_SendBodyRequest_To_TaskProvideBodyInfo_Art42" sourceRef="SendTask_RequestBodyCertification_Art42" targetRef="Task_ProvideBodyInfo_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskProvideBodyInfo_To_ReceiveBodyStatus_Art42" sourceRef="Task_ProvideBodyInfo_Art42" targetRef="ReceiveTask_ReceiveBodyStatus_Art42" />
    <bpmn:sequenceFlow id="Flow_ReceiveBodyStatus_To_GatewayBodyCertified_Art42" sourceRef="ReceiveTask_ReceiveBodyStatus_Art42" targetRef="Gateway_BodyCertified_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayBodyCertified_To_EndBodyNotCertified_Art42" name="No" sourceRef="Gateway_BodyCertified_Art42" targetRef="EndEvent_BodyNotCertified_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayBodyCertified_To_TaskUseBodyCertification_Art42" name="Yes" sourceRef="Gateway_BodyCertified_Art42" targetRef="Task_UseBodyCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskUseBodyCertification_To_GatewayBodyRenewalRequested_Art42" sourceRef="Task_UseBodyCertification_Art42" targetRef="Gateway_BodyRenewalRequested_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayBodyRenewalRequested_To_EndBodyTermEnded_Art42" name="No" sourceRef="Gateway_BodyRenewalRequested_Art42" targetRef="EndEvent_BodyTermEnded_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayBodyRenewalRequested_To_SendBodyRenewalRequest_Art42" name="Yes" sourceRef="Gateway_BodyRenewalRequested_Art42" targetRef="SendTask_RequestBodyRenewal_Art42" />
    <bpmn:sequenceFlow id="Flow_SendBodyRenewalRequest_To_TaskProvideBodyRenewalInfo_Art42" sourceRef="SendTask_RequestBodyRenewal_Art42" targetRef="Task_ProvideBodyRenewalInfo_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskProvideBodyRenewalInfo_To_ReceiveBodyRenewalStatus_Art42" sourceRef="Task_ProvideBodyRenewalInfo_Art42" targetRef="ReceiveTask_ReceiveBodyRenewalStatus_Art42" />
    <bpmn:sequenceFlow id="Flow_ReceiveBodyRenewalStatus_To_GatewayBodyRenewed_Art42" sourceRef="ReceiveTask_ReceiveBodyRenewalStatus_Art42" targetRef="Gateway_BodyRenewed_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayBodyRenewed_To_EndBodyCertificationInvalid_Art42" name="No" sourceRef="Gateway_BodyRenewed_Art42" targetRef="EndEvent_BodyCertificationInvalid_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayBodyRenewed_To_TaskUseBodyCertification_Art42" name="Yes" sourceRef="Gateway_BodyRenewed_Art42" targetRef="Task_UseBodyCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_SendAuthorityRequest_To_TaskProvideAuthorityInfo_Art42" sourceRef="SendTask_RequestAuthorityCertification_Art42" targetRef="Task_ProvideAuthorityInfo_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskProvideAuthorityInfo_To_ReceiveAuthorityStatus_Art42" sourceRef="Task_ProvideAuthorityInfo_Art42" targetRef="ReceiveTask_ReceiveAuthorityStatus_Art42" />
    <bpmn:sequenceFlow id="Flow_ReceiveAuthorityStatus_To_GatewayAuthorityCertified_Art42" sourceRef="ReceiveTask_ReceiveAuthorityStatus_Art42" targetRef="Gateway_AuthorityCertified_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayAuthorityCertified_To_EndAuthorityNotCertified_Art42" name="No" sourceRef="Gateway_AuthorityCertified_Art42" targetRef="EndEvent_AuthorityNotCertified_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayAuthorityCertified_To_TaskUseAuthorityCertification_Art42" name="Yes" sourceRef="Gateway_AuthorityCertified_Art42" targetRef="Task_UseAuthorityCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskUseAuthorityCertification_To_GatewayAuthorityRenewalRequested_Art42" sourceRef="Task_UseAuthorityCertification_Art42" targetRef="Gateway_AuthorityRenewalRequested_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayAuthorityRenewalRequested_To_EndAuthorityTermEnded_Art42" name="No" sourceRef="Gateway_AuthorityRenewalRequested_Art42" targetRef="EndEvent_AuthorityTermEnded_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayAuthorityRenewalRequested_To_SendAuthorityRenewalRequest_Art42" name="Yes" sourceRef="Gateway_AuthorityRenewalRequested_Art42" targetRef="SendTask_RequestAuthorityRenewal_Art42" />
    <bpmn:sequenceFlow id="Flow_SendAuthorityRenewalRequest_To_TaskProvideAuthorityRenewalInfo_Art42" sourceRef="SendTask_RequestAuthorityRenewal_Art42" targetRef="Task_ProvideAuthorityRenewalInfo_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskProvideAuthorityRenewalInfo_To_ReceiveAuthorityRenewalStatus_Art42" sourceRef="Task_ProvideAuthorityRenewalInfo_Art42" targetRef="ReceiveTask_ReceiveAuthorityRenewalStatus_Art42" />
    <bpmn:sequenceFlow id="Flow_ReceiveAuthorityRenewalStatus_To_GatewayAuthorityRenewed_Art42" sourceRef="ReceiveTask_ReceiveAuthorityRenewalStatus_Art42" targetRef="Gateway_AuthorityRenewed_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayAuthorityRenewed_To_EndAuthorityCertificationInvalid_Art42" name="No" sourceRef="Gateway_AuthorityRenewed_Art42" targetRef="EndEvent_AuthorityCertificationInvalid_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayAuthorityRenewed_To_TaskUseAuthorityCertification_Art42" name="Yes" sourceRef="Gateway_AuthorityRenewed_Art42" targetRef="Task_UseAuthorityCertification_Art42" />
  </bpmn:process>

  <bpmn:process id="Process_CertificationBody_Art42"
                name="Issuing certification through an accredited body"
                isExecutable="false">
    <bpmn:documentation>
      This process captures the Article 42(3), (5), (6), and (7) certification-body
      route: transparent assessment against approved criteria, issuance for up to three
      years, renewal under the same conditions, and withdrawal where the requirements
      are not or are no longer met.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_HandleBodyCertification_Art42"
                     name="Handle body certification">
      <bpmn:outgoing>Flow_StartBodyCertification_To_ReceiveBodyRequest_Art42</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveBodyCertificationRequest_Art42"
                      name="Receive body certification request">
      <bpmn:incoming>Flow_StartBodyCertification_To_ReceiveBodyRequest_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveBodyRequest_To_SendBodyInfoRequest_Art42</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:sendTask id="SendTask_RequestBodyInfo_Art42"
                   name="Request body information and access">
      <bpmn:incoming>Flow_ReceiveBodyRequest_To_SendBodyInfoRequest_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendBodyInfoRequest_To_ReceiveBodyInfo_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveBodyInfo_Art42"
                      name="Receive body information and access">
      <bpmn:incoming>Flow_SendBodyInfoRequest_To_ReceiveBodyInfo_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveBodyInfo_To_TaskRunBodyAssessment_Art42</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_RunBodyAssessment_Art42"
               name="Run transparent body assessment">
      <bpmn:incoming>Flow_ReceiveBodyInfo_To_TaskRunBodyAssessment_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRunBodyAssessment_To_GatewayBodyCriteriaMet_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_BodyCriteriaMet_Art42"
                           name="Are the approved criteria met?">
      <bpmn:incoming>Flow_TaskRunBodyAssessment_To_GatewayBodyCriteriaMet_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayBodyCriteriaMet_To_SendRejectBodyCertification_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayBodyCriteriaMet_To_SendIssueBodyCertification_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_RejectBodyCertification_Art42"
                   name="Reject body certification">
      <bpmn:incoming>Flow_GatewayBodyCriteriaMet_To_SendRejectBodyCertification_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRejectBodyCertification_To_EndBodyRejected_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_BodyRejected_Art42"
                   name="Body certification rejected">
      <bpmn:incoming>Flow_SendRejectBodyCertification_To_EndBodyRejected_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_IssueBodyCertification_Art42"
                   name="Issue body certification">
      <bpmn:incoming>Flow_GatewayBodyCriteriaMet_To_SendIssueBodyCertification_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendIssueBodyCertification_To_EndBodyIssued_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_BodyIssued_Art42"
                   name="Body certification issued">
      <bpmn:incoming>Flow_SendIssueBodyCertification_To_EndBodyIssued_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="StartEvent_HandleBodyRenewal_Art42"
                     name="Handle body renewal">
      <bpmn:outgoing>Flow_StartBodyRenewal_To_ReceiveBodyRenewalRequest_Art42</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveBodyRenewalRequest_Art42"
                      name="Receive body renewal request">
      <bpmn:incoming>Flow_StartBodyRenewal_To_ReceiveBodyRenewalRequest_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveBodyRenewalRequest_To_SendBodyRenewalInfoRequest_Art42</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:sendTask id="SendTask_RequestBodyRenewalInfo_Art42"
                   name="Request body renewal information">
      <bpmn:incoming>Flow_ReceiveBodyRenewalRequest_To_SendBodyRenewalInfoRequest_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendBodyRenewalInfoRequest_To_ReceiveBodyRenewalInfo_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveBodyRenewalInfo_Art42"
                      name="Receive body renewal information">
      <bpmn:incoming>Flow_SendBodyRenewalInfoRequest_To_ReceiveBodyRenewalInfo_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveBodyRenewalInfo_To_TaskAssessBodyRenewal_Art42</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_AssessBodyRenewal_Art42"
               name="Assess continued body requirements">
      <bpmn:incoming>Flow_ReceiveBodyRenewalInfo_To_TaskAssessBodyRenewal_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessBodyRenewal_To_GatewayBodyRequirementsContinue_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_BodyRequirementsContinue_Art42"
                           name="Do the requirements continue to be met?">
      <bpmn:incoming>Flow_TaskAssessBodyRenewal_To_GatewayBodyRequirementsContinue_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayBodyRequirementsContinue_To_SendWithdrawBodyCertification_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayBodyRequirementsContinue_To_SendRenewBodyCertification_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_WithdrawBodyCertification_Art42"
                   name="Withdraw body certification">
      <bpmn:incoming>Flow_GatewayBodyRequirementsContinue_To_SendWithdrawBodyCertification_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendWithdrawBodyCertification_To_EndBodyWithdrawn_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_BodyWithdrawn_Art42"
                   name="Body certification withdrawn">
      <bpmn:incoming>Flow_SendWithdrawBodyCertification_To_EndBodyWithdrawn_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_RenewBodyCertification_Art42"
                   name="Renew body certification">
      <bpmn:incoming>Flow_GatewayBodyRequirementsContinue_To_SendRenewBodyCertification_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRenewBodyCertification_To_EndBodyRenewed_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_BodyRenewed_Art42"
                   name="Body certification renewed">
      <bpmn:incoming>Flow_SendRenewBodyCertification_To_EndBodyRenewed_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartBodyCertification_To_ReceiveBodyRequest_Art42" sourceRef="StartEvent_HandleBodyCertification_Art42" targetRef="ReceiveTask_ReceiveBodyCertificationRequest_Art42" />
    <bpmn:sequenceFlow id="Flow_ReceiveBodyRequest_To_SendBodyInfoRequest_Art42" sourceRef="ReceiveTask_ReceiveBodyCertificationRequest_Art42" targetRef="SendTask_RequestBodyInfo_Art42" />
    <bpmn:sequenceFlow id="Flow_SendBodyInfoRequest_To_ReceiveBodyInfo_Art42" sourceRef="SendTask_RequestBodyInfo_Art42" targetRef="ReceiveTask_ReceiveBodyInfo_Art42" />
    <bpmn:sequenceFlow id="Flow_ReceiveBodyInfo_To_TaskRunBodyAssessment_Art42" sourceRef="ReceiveTask_ReceiveBodyInfo_Art42" targetRef="Task_RunBodyAssessment_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskRunBodyAssessment_To_GatewayBodyCriteriaMet_Art42" sourceRef="Task_RunBodyAssessment_Art42" targetRef="Gateway_BodyCriteriaMet_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayBodyCriteriaMet_To_SendRejectBodyCertification_Art42" name="No" sourceRef="Gateway_BodyCriteriaMet_Art42" targetRef="SendTask_RejectBodyCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayBodyCriteriaMet_To_SendIssueBodyCertification_Art42" name="Yes" sourceRef="Gateway_BodyCriteriaMet_Art42" targetRef="SendTask_IssueBodyCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_SendRejectBodyCertification_To_EndBodyRejected_Art42" sourceRef="SendTask_RejectBodyCertification_Art42" targetRef="EndEvent_BodyRejected_Art42" />
    <bpmn:sequenceFlow id="Flow_SendIssueBodyCertification_To_EndBodyIssued_Art42" sourceRef="SendTask_IssueBodyCertification_Art42" targetRef="EndEvent_BodyIssued_Art42" />
    <bpmn:sequenceFlow id="Flow_StartBodyRenewal_To_ReceiveBodyRenewalRequest_Art42" sourceRef="StartEvent_HandleBodyRenewal_Art42" targetRef="ReceiveTask_ReceiveBodyRenewalRequest_Art42" />
    <bpmn:sequenceFlow id="Flow_ReceiveBodyRenewalRequest_To_SendBodyRenewalInfoRequest_Art42" sourceRef="ReceiveTask_ReceiveBodyRenewalRequest_Art42" targetRef="SendTask_RequestBodyRenewalInfo_Art42" />
    <bpmn:sequenceFlow id="Flow_SendBodyRenewalInfoRequest_To_ReceiveBodyRenewalInfo_Art42" sourceRef="SendTask_RequestBodyRenewalInfo_Art42" targetRef="ReceiveTask_ReceiveBodyRenewalInfo_Art42" />
    <bpmn:sequenceFlow id="Flow_ReceiveBodyRenewalInfo_To_TaskAssessBodyRenewal_Art42" sourceRef="ReceiveTask_ReceiveBodyRenewalInfo_Art42" targetRef="Task_AssessBodyRenewal_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskAssessBodyRenewal_To_GatewayBodyRequirementsContinue_Art42" sourceRef="Task_AssessBodyRenewal_Art42" targetRef="Gateway_BodyRequirementsContinue_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayBodyRequirementsContinue_To_SendWithdrawBodyCertification_Art42" name="No" sourceRef="Gateway_BodyRequirementsContinue_Art42" targetRef="SendTask_WithdrawBodyCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayBodyRequirementsContinue_To_SendRenewBodyCertification_Art42" name="Yes" sourceRef="Gateway_BodyRequirementsContinue_Art42" targetRef="SendTask_RenewBodyCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_SendWithdrawBodyCertification_To_EndBodyWithdrawn_Art42" sourceRef="SendTask_WithdrawBodyCertification_Art42" targetRef="EndEvent_BodyWithdrawn_Art42" />
    <bpmn:sequenceFlow id="Flow_SendRenewBodyCertification_To_EndBodyRenewed_Art42" sourceRef="SendTask_RenewBodyCertification_Art42" targetRef="EndEvent_BodyRenewed_Art42" />
  </bpmn:process>

  <bpmn:process id="Process_SupervisoryAuthority_Art42"
                name="Issuing certification through the supervisory authority"
                isExecutable="false">
    <bpmn:documentation>
      This process captures the Article 42(5) supervisory-authority route: authority-
      approved or Board-approved criteria, transparent assessment, issuance for up to
      three years, renewal under the same conditions, and withdrawal where the
      requirements are not or are no longer met.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_SetAuthorityCriteria_Art42"
                     name="Set certification criteria">
      <bpmn:outgoing>Flow_StartAuthorityCriteria_To_GatewayBoardCriteria_Art42</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:exclusiveGateway id="Gateway_BoardCriteria_Art42"
                           name="Are Board-approved criteria applied?">
      <bpmn:incoming>Flow_StartAuthorityCriteria_To_GatewayBoardCriteria_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayBoardCriteria_To_TaskUseAuthorityCriteria_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayBoardCriteria_To_TaskUseBoardCriteria_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_UseAuthorityCriteria_Art42"
               name="Use authority-approved criteria">
      <bpmn:incoming>Flow_GatewayBoardCriteria_To_TaskUseAuthorityCriteria_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskUseAuthorityCriteria_To_EndAuthorityCriteriaReady_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_UseBoardCriteria_Art42"
               name="Use Board-approved criteria">
      <bpmn:incoming>Flow_GatewayBoardCriteria_To_TaskUseBoardCriteria_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskUseBoardCriteria_To_EndAuthorityCriteriaReady_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_AuthorityCriteriaReady_Art42"
                   name="Certification criteria ready">
      <bpmn:incoming>Flow_TaskUseAuthorityCriteria_To_EndAuthorityCriteriaReady_Art42</bpmn:incoming>
      <bpmn:incoming>Flow_TaskUseBoardCriteria_To_EndAuthorityCriteriaReady_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="StartEvent_HandleAuthorityCertification_Art42"
                     name="Handle authority certification">
      <bpmn:outgoing>Flow_StartAuthorityCertification_To_ReceiveAuthorityRequest_Art42</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAuthorityCertificationRequest_Art42"
                      name="Receive authority certification request">
      <bpmn:incoming>Flow_StartAuthorityCertification_To_ReceiveAuthorityRequest_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveAuthorityRequest_To_SendAuthorityInfoRequest_Art42</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:sendTask id="SendTask_RequestAuthorityInfo_Art42"
                   name="Request authority information and access">
      <bpmn:incoming>Flow_ReceiveAuthorityRequest_To_SendAuthorityInfoRequest_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendAuthorityInfoRequest_To_ReceiveAuthorityInfo_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAuthorityInfo_Art42"
                      name="Receive authority information and access">
      <bpmn:incoming>Flow_SendAuthorityInfoRequest_To_ReceiveAuthorityInfo_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveAuthorityInfo_To_TaskRunAuthorityAssessment_Art42</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_RunAuthorityAssessment_Art42"
               name="Run transparent authority assessment">
      <bpmn:incoming>Flow_ReceiveAuthorityInfo_To_TaskRunAuthorityAssessment_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRunAuthorityAssessment_To_GatewayAuthorityCriteriaMet_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_AuthorityCriteriaMet_Art42"
                           name="Are the approved criteria met?">
      <bpmn:incoming>Flow_TaskRunAuthorityAssessment_To_GatewayAuthorityCriteriaMet_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAuthorityCriteriaMet_To_SendRejectAuthorityCertification_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAuthorityCriteriaMet_To_SendIssueAuthorityCertification_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_RejectAuthorityCertification_Art42"
                   name="Reject authority certification">
      <bpmn:incoming>Flow_GatewayAuthorityCriteriaMet_To_SendRejectAuthorityCertification_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRejectAuthorityCertification_To_EndAuthorityRejected_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_AuthorityRejected_Art42"
                   name="Authority certification rejected">
      <bpmn:incoming>Flow_SendRejectAuthorityCertification_To_EndAuthorityRejected_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_IssueAuthorityCertification_Art42"
                   name="Issue authority certification">
      <bpmn:incoming>Flow_GatewayAuthorityCriteriaMet_To_SendIssueAuthorityCertification_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendIssueAuthorityCertification_To_EndAuthorityIssued_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_AuthorityIssued_Art42"
                   name="Authority certification issued">
      <bpmn:incoming>Flow_SendIssueAuthorityCertification_To_EndAuthorityIssued_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:startEvent id="StartEvent_HandleAuthorityRenewal_Art42"
                     name="Handle authority renewal">
      <bpmn:outgoing>Flow_StartAuthorityRenewal_To_ReceiveAuthorityRenewalRequest_Art42</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAuthorityRenewalRequest_Art42"
                      name="Receive authority renewal request">
      <bpmn:incoming>Flow_StartAuthorityRenewal_To_ReceiveAuthorityRenewalRequest_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveAuthorityRenewalRequest_To_SendAuthorityRenewalInfoRequest_Art42</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:sendTask id="SendTask_RequestAuthorityRenewalInfo_Art42"
                   name="Request authority renewal information">
      <bpmn:incoming>Flow_ReceiveAuthorityRenewalRequest_To_SendAuthorityRenewalInfoRequest_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendAuthorityRenewalInfoRequest_To_ReceiveAuthorityRenewalInfo_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="ReceiveTask_ReceiveAuthorityRenewalInfo_Art42"
                      name="Receive authority renewal information">
      <bpmn:incoming>Flow_SendAuthorityRenewalInfoRequest_To_ReceiveAuthorityRenewalInfo_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_ReceiveAuthorityRenewalInfo_To_TaskAssessAuthorityRenewal_Art42</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:task id="Task_AssessAuthorityRenewal_Art42"
               name="Assess continued authority requirements">
      <bpmn:incoming>Flow_ReceiveAuthorityRenewalInfo_To_TaskAssessAuthorityRenewal_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskAssessAuthorityRenewal_To_GatewayAuthorityRequirementsContinue_Art42</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_AuthorityRequirementsContinue_Art42"
                           name="Do the requirements continue to be met?">
      <bpmn:incoming>Flow_TaskAssessAuthorityRenewal_To_GatewayAuthorityRequirementsContinue_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAuthorityRequirementsContinue_To_SendWithdrawAuthorityCertification_Art42</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAuthorityRequirementsContinue_To_SendRenewAuthorityCertification_Art42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="SendTask_WithdrawAuthorityCertification_Art42"
                   name="Withdraw authority certification">
      <bpmn:incoming>Flow_GatewayAuthorityRequirementsContinue_To_SendWithdrawAuthorityCertification_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendWithdrawAuthorityCertification_To_EndAuthorityWithdrawn_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_AuthorityWithdrawn_Art42"
                   name="Authority certification withdrawn">
      <bpmn:incoming>Flow_SendWithdrawAuthorityCertification_To_EndAuthorityWithdrawn_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sendTask id="SendTask_RenewAuthorityCertification_Art42"
                   name="Renew authority certification">
      <bpmn:incoming>Flow_GatewayAuthorityRequirementsContinue_To_SendRenewAuthorityCertification_Art42</bpmn:incoming>
      <bpmn:outgoing>Flow_SendRenewAuthorityCertification_To_EndAuthorityRenewed_Art42</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_AuthorityRenewed_Art42"
                   name="Authority certification renewed">
      <bpmn:incoming>Flow_SendRenewAuthorityCertification_To_EndAuthorityRenewed_Art42</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartAuthorityCriteria_To_GatewayBoardCriteria_Art42" sourceRef="StartEvent_SetAuthorityCriteria_Art42" targetRef="Gateway_BoardCriteria_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayBoardCriteria_To_TaskUseAuthorityCriteria_Art42" name="No" sourceRef="Gateway_BoardCriteria_Art42" targetRef="Task_UseAuthorityCriteria_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayBoardCriteria_To_TaskUseBoardCriteria_Art42" name="Yes" sourceRef="Gateway_BoardCriteria_Art42" targetRef="Task_UseBoardCriteria_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskUseAuthorityCriteria_To_EndAuthorityCriteriaReady_Art42" sourceRef="Task_UseAuthorityCriteria_Art42" targetRef="EndEvent_AuthorityCriteriaReady_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskUseBoardCriteria_To_EndAuthorityCriteriaReady_Art42" sourceRef="Task_UseBoardCriteria_Art42" targetRef="EndEvent_AuthorityCriteriaReady_Art42" />
    <bpmn:sequenceFlow id="Flow_StartAuthorityCertification_To_ReceiveAuthorityRequest_Art42" sourceRef="StartEvent_HandleAuthorityCertification_Art42" targetRef="ReceiveTask_ReceiveAuthorityCertificationRequest_Art42" />
    <bpmn:sequenceFlow id="Flow_ReceiveAuthorityRequest_To_SendAuthorityInfoRequest_Art42" sourceRef="ReceiveTask_ReceiveAuthorityCertificationRequest_Art42" targetRef="SendTask_RequestAuthorityInfo_Art42" />
    <bpmn:sequenceFlow id="Flow_SendAuthorityInfoRequest_To_ReceiveAuthorityInfo_Art42" sourceRef="SendTask_RequestAuthorityInfo_Art42" targetRef="ReceiveTask_ReceiveAuthorityInfo_Art42" />
    <bpmn:sequenceFlow id="Flow_ReceiveAuthorityInfo_To_TaskRunAuthorityAssessment_Art42" sourceRef="ReceiveTask_ReceiveAuthorityInfo_Art42" targetRef="Task_RunAuthorityAssessment_Art42" />
    <bpmn:sequenceFlow id="Flow_TaskRunAuthorityAssessment_To_GatewayAuthorityCriteriaMet_Art42" sourceRef="Task_RunAuthorityAssessment_Art42" targetRef="Gateway_AuthorityCriteriaMet_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayAuthorityCriteriaMet_To_SendRejectAuthorityCertification_Art42" name="No" sourceRef="Gateway_AuthorityCriteriaMet_Art42" targetRef="SendTask_RejectAuthorityCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_GatewayAuthorityCriteriaMet_To_SendIssueAuthorityCertification_Art42" name="Yes" sourceRef="Gateway_AuthorityCriteriaMet_Art42" targetRef="SendTask_IssueAuthorityCertification_Art42" />
    <bpmn:sequenceFlow id="Flow_SendRejectAuthorityCertification_To_EndAuthorityRejected_Art42" sourceRef="SendTask_RejectAuthorityCertification_Art42" targetRef="EndEvent_AuthorityRejected_Art42" />
    <bpmn:sequenceFlow id="Flow_SendIssueAuthorityCertification_To_EndAuthorityIssued_Art42" sourceRef="SendTask_IssueAuthorityCertification_Art42" targetRef="EndEvent_AuthorityIssued_Art42" />
    <bpmn:sequenceFlow id="Flow_StartAuthorityRenewal_To_ReceiveAuthorityRenewalRequest_Art42" sourceRef="StartEvent_HandleAuthorityRenewal_Art42" targetRef="ReceiveTask_ReceiveAuthorityRenewalRequest_Art42" />
    <bpmn:sequenceFlow id="Flow_ReceiveAuthorityRenewalRequest_To_SendAuthorityRenewalInfoRequest_Art42" sourceRef="ReceiveTask_ReceiveAuthorityRenewalRequest_Art42" targetRef="SendTask_RequestAuthorityRenewalInfo_Art42" />
    <bpmn:sequenceFlow id="Flow_SendAuthorityRenewalInfoRequest_To_ReceiveAuthorityRenewalInfo_Art42" sourceRef="SendTask_RequestAuthorityRenewalInfo_Art42" targetRef="ReceiveTask_ReceiveAuthorityRenewalInfo_Art42" />
    <bpmn:sequenceFlow id="Flow_ReceiveAuthorityRenewalInfo_To_TaskAssessAuthorityRenewal_Art42" sourceRef="ReceiveTask_ReceiveAuthorityRenewalInfo_Art42" targetRef="Task_AssessAuthorityRenewal_Art42" />
