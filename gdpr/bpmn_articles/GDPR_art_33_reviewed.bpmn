<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Defs_Art33_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:message id="Message_ProcessorBreachNotice_Art33" name="Processor breach notice" />

  <bpmn:collaboration id="Collaboration_Art33_Reviewed">
    <bpmn:participant id="Participant_Controller_Art33"
                      name="Controller"
                      processRef="Process_Controller_Art33" />
    <bpmn:participant id="Participant_SupervisoryAuthority_Art33"
                      name="Supervisory Authority" />
    <bpmn:participant id="Participant_Processor_Art33"
                      name="Processor"
                      processRef="Process_Processor_Art33" />

    <bpmn:messageFlow id="MessageFlow_ProcessorToController_Art33"
                      sourceRef="SendTask_ProcessorNotifyController_Art33"
                      targetRef="Event_ControllerReceivesProcessorNotice_Art33" />
    <bpmn:messageFlow id="MessageFlow_SendFullNotice_Art33"
                      sourceRef="SendTask_SendFullNotice_Art33"
                      targetRef="Participant_SupervisoryAuthority_Art33" />
    <bpmn:messageFlow id="MessageFlow_SendInitialNotice_Art33"
                      sourceRef="SendTask_SendInitialNotice_Art33"
                      targetRef="Participant_SupervisoryAuthority_Art33" />
    <bpmn:messageFlow id="MessageFlow_SendPhasedInfo_Art33"
                      sourceRef="SendTask_SendPhasedInfo_Art33"
                      targetRef="Participant_SupervisoryAuthority_Art33" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Controller_Art33"
                name="Apply Article 33 breach-notification duties"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 33 based on the real English legal
      text in gdpr_articles. The model captures controller awareness by internal
      detection or processor notice, the Article 33(1) risk threshold, the full
      Article 33(3)(a)-(d) notification content including categories and approximate
      numbers where possible, the 72-hour timing and delay-reasons logic, phased
      provision of information under Article 33(4), and the Article 33(5)
      documentation duty for facts, effects, and remedial action.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_HandleBreach_Art33"
                     name="Need breach handling">
      <bpmn:outgoing>Flow_Start_To_AwarenessGateway_Art33</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:eventBasedGateway id="Gateway_Awareness_Art33">
      <bpmn:incoming>Flow_Start_To_AwarenessGateway_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_AwarenessGateway_To_ProcessorNotice_Art33</bpmn:outgoing>
      <bpmn:outgoing>Flow_AwarenessGateway_To_InternalDetection_Art33</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="Event_ControllerReceivesProcessorNotice_Art33"
                                 name="Receive processor breach notice">
      <bpmn:incoming>Flow_AwarenessGateway_To_ProcessorNotice_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_ProcessorNotice_To_AwarenessMerge_Art33</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDef_ProcessorNotice_Art33"
                                   messageRef="Message_ProcessorBreachNotice_Art33" />
    </bpmn:intermediateCatchEvent>

    <bpmn:intermediateCatchEvent id="Event_ControllerDetectsBreach_Art33"
                                 name="Detect breach internally">
      <bpmn:incoming>Flow_AwarenessGateway_To_InternalDetection_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_InternalDetection_To_AwarenessMerge_Art33</bpmn:outgoing>
      <bpmn:signalEventDefinition id="SignalEventDef_InternalDetection_Art33" />
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="Gateway_AwarenessMerge_Art33">
      <bpmn:incoming>Flow_ProcessorNotice_To_AwarenessMerge_Art33</bpmn:incoming>
      <bpmn:incoming>Flow_InternalDetection_To_AwarenessMerge_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_AwarenessMerge_To_AssessRisk_Art33</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_AssessRisk_Art33"
               name="Assess risk to rights and freedoms">
      <bpmn:incoming>Flow_AwarenessMerge_To_AssessRisk_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessRisk_To_GatewayRisk_Art33</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Risk_Art33"
                           name="Is the breach unlikely to result in risk?">
      <bpmn:incoming>Flow_AssessRisk_To_GatewayRisk_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayRisk_To_TaskDocumentBreach_Art33</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayRisk_To_GatewayCompileSplit_Art33</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:parallelGateway id="Gateway_CompileSplit_Art33">
      <bpmn:incoming>Flow_GatewayRisk_To_GatewayCompileSplit_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayCompileSplit_To_TaskDescribeNature_Art33</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCompileSplit_To_TaskProvideContact_Art33</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCompileSplit_To_TaskDescribeConsequences_Art33</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayCompileSplit_To_TaskDescribeMeasures_Art33</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:task id="Task_DescribeNature_Art33"
               name="Describe breach nature, categories, and approximate numbers">
      <bpmn:incoming>Flow_GatewayCompileSplit_To_TaskDescribeNature_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDescribeNature_To_GatewayCompileJoin_Art33</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ProvideContact_Art33"
               name="Provide DPO or contact point details">
      <bpmn:incoming>Flow_GatewayCompileSplit_To_TaskProvideContact_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskProvideContact_To_GatewayCompileJoin_Art33</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DescribeConsequences_Art33"
               name="Describe likely consequences">
      <bpmn:incoming>Flow_GatewayCompileSplit_To_TaskDescribeConsequences_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDescribeConsequences_To_GatewayCompileJoin_Art33</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DescribeMeasures_Art33"
               name="Describe taken or proposed measures and mitigation">
      <bpmn:incoming>Flow_GatewayCompileSplit_To_TaskDescribeMeasures_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDescribeMeasures_To_GatewayCompileJoin_Art33</bpmn:outgoing>
    </bpmn:task>

    <bpmn:parallelGateway id="Gateway_CompileJoin_Art33">
      <bpmn:incoming>Flow_TaskDescribeNature_To_GatewayCompileJoin_Art33</bpmn:incoming>
      <bpmn:incoming>Flow_TaskProvideContact_To_GatewayCompileJoin_Art33</bpmn:incoming>
      <bpmn:incoming>Flow_TaskDescribeConsequences_To_GatewayCompileJoin_Art33</bpmn:incoming>
      <bpmn:incoming>Flow_TaskDescribeMeasures_To_GatewayCompileJoin_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayCompileJoin_To_GatewayAllInfo_Art33</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:exclusiveGateway id="Gateway_AllInfo_Art33"
                           name="Is all notification information available now?">
      <bpmn:incoming>Flow_GatewayCompileJoin_To_GatewayAllInfo_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayAllInfo_To_GatewayFullWithin72h_Art33</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayAllInfo_To_GatewayInitialWithin72h_Art33</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_FullWithin72h_Art33"
                           name="Will the notice be sent within 72 hours?">
      <bpmn:incoming>Flow_GatewayAllInfo_To_GatewayFullWithin72h_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayFullWithin72h_To_SendFullNotice_Art33</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayFullWithin72h_To_RecordDelayFull_Art33</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_RecordDelayFull_Art33"
               name="Record delay reasons">
      <bpmn:incoming>Flow_GatewayFullWithin72h_To_RecordDelayFull_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRecordDelayFull_To_SendFullNotice_Art33</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_SendFullNotice_Art33"
                   name="Notify competent supervisory authority">
      <bpmn:incoming>Flow_GatewayFullWithin72h_To_SendFullNotice_Art33</bpmn:incoming>
      <bpmn:incoming>Flow_TaskRecordDelayFull_To_SendFullNotice_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_SendFullNotice_To_TaskDocumentBreach_Art33</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="Gateway_InitialWithin72h_Art33"
                           name="Will the initial notice be sent within 72 hours?">
      <bpmn:incoming>Flow_GatewayAllInfo_To_GatewayInitialWithin72h_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayInitialWithin72h_To_SendInitialNotice_Art33</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayInitialWithin72h_To_RecordDelayInitial_Art33</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_RecordDelayInitial_Art33"
               name="Record delay reasons">
      <bpmn:incoming>Flow_GatewayInitialWithin72h_To_RecordDelayInitial_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskRecordDelayInitial_To_SendInitialNotice_Art33</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_SendInitialNotice_Art33"
                   name="Send initial notice">
      <bpmn:incoming>Flow_GatewayInitialWithin72h_To_SendInitialNotice_Art33</bpmn:incoming>
      <bpmn:incoming>Flow_TaskRecordDelayInitial_To_SendInitialNotice_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_SendInitialNotice_To_TaskCollectRemainingInfo_Art33</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_CollectRemainingInfo_Art33"
               name="Collect remaining information">
      <bpmn:incoming>Flow_SendInitialNotice_To_TaskCollectRemainingInfo_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskCollectRemainingInfo_To_SendPhasedInfo_Art33</bpmn:outgoing>
    </bpmn:task>

    <bpmn:sendTask id="SendTask_SendPhasedInfo_Art33"
                   name="Send phased information without undue further delay">
      <bpmn:incoming>Flow_TaskCollectRemainingInfo_To_SendPhasedInfo_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_SendPhasedInfo_To_TaskDocumentBreach_Art33</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:task id="Task_DocumentBreach_Art33"
               name="Document breach facts, effects, and remedial action">
      <bpmn:incoming>Flow_GatewayRisk_To_TaskDocumentBreach_Art33</bpmn:incoming>
      <bpmn:incoming>Flow_SendFullNotice_To_TaskDocumentBreach_Art33</bpmn:incoming>
      <bpmn:incoming>Flow_SendPhasedInfo_To_TaskDocumentBreach_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskDocumentBreach_To_EndCompleted_Art33</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_Completed_Art33"
                   name="Article 33 completed">
      <bpmn:incoming>Flow_TaskDocumentBreach_To_EndCompleted_Art33</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_AwarenessGateway_Art33" sourceRef="StartEvent_HandleBreach_Art33" targetRef="Gateway_Awareness_Art33" />
    <bpmn:sequenceFlow id="Flow_AwarenessGateway_To_ProcessorNotice_Art33" sourceRef="Gateway_Awareness_Art33" targetRef="Event_ControllerReceivesProcessorNotice_Art33" />
    <bpmn:sequenceFlow id="Flow_AwarenessGateway_To_InternalDetection_Art33" sourceRef="Gateway_Awareness_Art33" targetRef="Event_ControllerDetectsBreach_Art33" />
    <bpmn:sequenceFlow id="Flow_ProcessorNotice_To_AwarenessMerge_Art33" sourceRef="Event_ControllerReceivesProcessorNotice_Art33" targetRef="Gateway_AwarenessMerge_Art33" />
    <bpmn:sequenceFlow id="Flow_InternalDetection_To_AwarenessMerge_Art33" sourceRef="Event_ControllerDetectsBreach_Art33" targetRef="Gateway_AwarenessMerge_Art33" />
    <bpmn:sequenceFlow id="Flow_AwarenessMerge_To_AssessRisk_Art33" sourceRef="Gateway_AwarenessMerge_Art33" targetRef="Task_AssessRisk_Art33" />
    <bpmn:sequenceFlow id="Flow_AssessRisk_To_GatewayRisk_Art33" sourceRef="Task_AssessRisk_Art33" targetRef="Gateway_Risk_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayRisk_To_TaskDocumentBreach_Art33" name="Yes" sourceRef="Gateway_Risk_Art33" targetRef="Task_DocumentBreach_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayRisk_To_GatewayCompileSplit_Art33" name="No" sourceRef="Gateway_Risk_Art33" targetRef="Gateway_CompileSplit_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayCompileSplit_To_TaskDescribeNature_Art33" sourceRef="Gateway_CompileSplit_Art33" targetRef="Task_DescribeNature_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayCompileSplit_To_TaskProvideContact_Art33" sourceRef="Gateway_CompileSplit_Art33" targetRef="Task_ProvideContact_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayCompileSplit_To_TaskDescribeConsequences_Art33" sourceRef="Gateway_CompileSplit_Art33" targetRef="Task_DescribeConsequences_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayCompileSplit_To_TaskDescribeMeasures_Art33" sourceRef="Gateway_CompileSplit_Art33" targetRef="Task_DescribeMeasures_Art33" />
    <bpmn:sequenceFlow id="Flow_TaskDescribeNature_To_GatewayCompileJoin_Art33" sourceRef="Task_DescribeNature_Art33" targetRef="Gateway_CompileJoin_Art33" />
    <bpmn:sequenceFlow id="Flow_TaskProvideContact_To_GatewayCompileJoin_Art33" sourceRef="Task_ProvideContact_Art33" targetRef="Gateway_CompileJoin_Art33" />
    <bpmn:sequenceFlow id="Flow_TaskDescribeConsequences_To_GatewayCompileJoin_Art33" sourceRef="Task_DescribeConsequences_Art33" targetRef="Gateway_CompileJoin_Art33" />
    <bpmn:sequenceFlow id="Flow_TaskDescribeMeasures_To_GatewayCompileJoin_Art33" sourceRef="Task_DescribeMeasures_Art33" targetRef="Gateway_CompileJoin_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayCompileJoin_To_GatewayAllInfo_Art33" sourceRef="Gateway_CompileJoin_Art33" targetRef="Gateway_AllInfo_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayAllInfo_To_GatewayFullWithin72h_Art33" name="Yes" sourceRef="Gateway_AllInfo_Art33" targetRef="Gateway_FullWithin72h_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayAllInfo_To_GatewayInitialWithin72h_Art33" name="No" sourceRef="Gateway_AllInfo_Art33" targetRef="Gateway_InitialWithin72h_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayFullWithin72h_To_SendFullNotice_Art33" name="Yes" sourceRef="Gateway_FullWithin72h_Art33" targetRef="SendTask_SendFullNotice_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayFullWithin72h_To_RecordDelayFull_Art33" name="No" sourceRef="Gateway_FullWithin72h_Art33" targetRef="Task_RecordDelayFull_Art33" />
    <bpmn:sequenceFlow id="Flow_TaskRecordDelayFull_To_SendFullNotice_Art33" sourceRef="Task_RecordDelayFull_Art33" targetRef="SendTask_SendFullNotice_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayInitialWithin72h_To_SendInitialNotice_Art33" name="Yes" sourceRef="Gateway_InitialWithin72h_Art33" targetRef="SendTask_SendInitialNotice_Art33" />
    <bpmn:sequenceFlow id="Flow_GatewayInitialWithin72h_To_RecordDelayInitial_Art33" name="No" sourceRef="Gateway_InitialWithin72h_Art33" targetRef="Task_RecordDelayInitial_Art33" />
    <bpmn:sequenceFlow id="Flow_TaskRecordDelayInitial_To_SendInitialNotice_Art33" sourceRef="Task_RecordDelayInitial_Art33" targetRef="SendTask_SendInitialNotice_Art33" />
    <bpmn:sequenceFlow id="Flow_SendFullNotice_To_TaskDocumentBreach_Art33" sourceRef="SendTask_SendFullNotice_Art33" targetRef="Task_DocumentBreach_Art33" />
    <bpmn:sequenceFlow id="Flow_SendInitialNotice_To_TaskCollectRemainingInfo_Art33" sourceRef="SendTask_SendInitialNotice_Art33" targetRef="Task_CollectRemainingInfo_Art33" />
    <bpmn:sequenceFlow id="Flow_TaskCollectRemainingInfo_To_SendPhasedInfo_Art33" sourceRef="Task_CollectRemainingInfo_Art33" targetRef="SendTask_SendPhasedInfo_Art33" />
    <bpmn:sequenceFlow id="Flow_SendPhasedInfo_To_TaskDocumentBreach_Art33" sourceRef="SendTask_SendPhasedInfo_Art33" targetRef="Task_DocumentBreach_Art33" />
    <bpmn:sequenceFlow id="Flow_TaskDocumentBreach_To_EndCompleted_Art33" sourceRef="Task_DocumentBreach_Art33" targetRef="EndEvent_Completed_Art33" />
  </bpmn:process>

  <bpmn:process id="Process_Processor_Art33"
                name="Apply Article 33 processor notice duty"
                isExecutable="false">
    <bpmn:documentation>
      This process captures the Article 33(2) duty of the processor to notify the
      controller without undue delay after becoming aware of a personal data breach.
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_ProcessorAware_Art33"
                     name="Processor becomes aware of breach">
      <bpmn:outgoing>Flow_StartProcessor_To_SendNotice_Art33</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sendTask id="SendTask_ProcessorNotifyController_Art33"
                   name="Notify controller without undue delay">
      <bpmn:incoming>Flow_StartProcessor_To_SendNotice_Art33</bpmn:incoming>
      <bpmn:outgoing>Flow_SendNotice_To_EndProcessor_Art33</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:endEvent id="EndEvent_ProcessorCompleted_Art33"
                   name="Controller notified">
      <bpmn:incoming>Flow_SendNotice_To_EndProcessor_Art33</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_StartProcessor_To_SendNotice_Art33" sourceRef="StartEvent_ProcessorAware_Art33" targetRef="SendTask_ProcessorNotifyController_Art33" />
    <bpmn:sequenceFlow id="Flow_SendNotice_To_EndProcessor_Art33" sourceRef="SendTask_ProcessorNotifyController_Art33" targetRef="EndEvent_ProcessorCompleted_Art33" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art33_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art33_Reviewed" bpmnElement="Collaboration_Art33_Reviewed">
      <bpmndi:BPMNShape id="Participant_Controller_Art33_di" bpmnElement="Participant_Controller_Art33" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="3900" height="680" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_SupervisoryAuthority_Art33_di" bpmnElement="Participant_SupervisoryAuthority_Art33" isHorizontal="true">
        <dc:Bounds x="60" y="760" width="3900" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Processor_Art33_di" bpmnElement="Participant_Processor_Art33" isHorizontal="true">
        <dc:Bounds x="60" y="920" width="3900" height="180" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_HandleBreach_Art33_di" bpmnElement="StartEvent_HandleBreach_Art33">
        <dc:Bounds x="120" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Awareness_Art33_di" bpmnElement="Gateway_Awareness_Art33">
        <dc:Bounds x="220" y="335" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_ControllerReceivesProcessorNotice_Art33_di" bpmnElement="Event_ControllerReceivesProcessorNotice_Art33">
        <dc:Bounds x="350" y="250" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_ControllerDetectsBreach_Art33_di" bpmnElement="Event_ControllerDetectsBreach_Art33">
        <dc:Bounds x="350" y="420" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AwarenessMerge_Art33_di" bpmnElement="Gateway_AwarenessMerge_Art33" isMarkerVisible="true">
        <dc:Bounds x="470" y="335" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssessRisk_Art33_di" bpmnElement="Task_AssessRisk_Art33">
        <dc:Bounds x="580" y="320" width="220" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Risk_Art33_di" bpmnElement="Gateway_Risk_Art33" isMarkerVisible="true">
        <dc:Bounds x="870" y="335" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_CompileSplit_Art33_di" bpmnElement="Gateway_CompileSplit_Art33" isMarkerVisible="true">
        <dc:Bounds x="1000" y="335" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DescribeNature_Art33_di" bpmnElement="Task_DescribeNature_Art33">
        <dc:Bounds x="1140" y="80" width="330" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProvideContact_Art33_di" bpmnElement="Task_ProvideContact_Art33">
        <dc:Bounds x="1140" y="190" width="300" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DescribeConsequences_Art33_di" bpmnElement="Task_DescribeConsequences_Art33">
        <dc:Bounds x="1140" y="410" width="270" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DescribeMeasures_Art33_di" bpmnElement="Task_DescribeMeasures_Art33">
        <dc:Bounds x="1140" y="520" width="350" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_CompileJoin_Art33_di" bpmnElement="Gateway_CompileJoin_Art33" isMarkerVisible="true">
        <dc:Bounds x="1600" y="335" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AllInfo_Art33_di" bpmnElement="Gateway_AllInfo_Art33" isMarkerVisible="true">
        <dc:Bounds x="1730" y="335" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_FullWithin72h_Art33_di" bpmnElement="Gateway_FullWithin72h_Art33" isMarkerVisible="true">
        <dc:Bounds x="1890" y="175" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordDelayFull_Art33_di" bpmnElement="Task_RecordDelayFull_Art33">
        <dc:Bounds x="2050" y="70" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_SendFullNotice_Art33_di" bpmnElement="SendTask_SendFullNotice_Art33">
        <dc:Bounds x="2300" y="160" width="260" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_InitialWithin72h_Art33_di" bpmnElement="Gateway_InitialWithin72h_Art33" isMarkerVisible="true">
        <dc:Bounds x="1890" y="505" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordDelayInitial_Art33_di" bpmnElement="Task_RecordDelayInitial_Art33">
        <dc:Bounds x="2050" y="420" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SendTask_SendInitialNotice_Art33_di" bpmnElement="SendTask_SendInitialNotice_Art33">
