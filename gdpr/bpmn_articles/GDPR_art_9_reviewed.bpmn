<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Art9_Reviewed"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_Controller_Art9"
                name="Assess Article 9 processing"
                isExecutable="false">
    <bpmn:documentation>
      Manual BPMN conversion for GDPR Article 9 based on the real English legal text.
      The model covers the Article 9(1) prohibition, all Article 9(2)(a)-(j)
      exception routes, the additional secrecy condition for the Article 9(2)(h)
      route under Article 9(3), and the possible further Member State conditions for
      genetic data, biometric data, or data concerning health under Article 9(4).
    </bpmn:documentation>

    <bpmn:startEvent id="StartEvent_AssessArticle9_Art9"
                     name="Need Article 9 assessment">
      <bpmn:outgoing>Flow_Start_To_TaskIdentifyData_Art9</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_IdentifySpecialCategoryData_Art9"
               name="Check special-category data">
      <bpmn:incoming>Flow_Start_To_TaskIdentifyData_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskIdentifyData_To_GatewaySpecialCategory_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_SpecialCategory_Art9"
                           name="Does the processing involve a special category of personal data?">
      <bpmn:incoming>Flow_TaskIdentifyData_To_GatewaySpecialCategory_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewaySpecialCategory_To_TaskApplyDefaultProhibition_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewaySpecialCategory_To_EndArticle9NotTriggered_Art9</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ApplyDefaultProhibition_Art9"
               name="Apply default prohibition">
      <bpmn:incoming>Flow_GatewaySpecialCategory_To_TaskApplyDefaultProhibition_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskApplyDefaultProhibition_To_GatewayException_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_Exception_Art9"
                           name="Which Article 9(2) exception applies?">
      <bpmn:incoming>Flow_TaskApplyDefaultProhibition_To_GatewayException_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayException_To_TaskExplicitConsent_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayException_To_TaskEmploymentLaw_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayException_To_TaskVitalInterests_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayException_To_TaskNotForProfitBody_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayException_To_TaskManifestlyPublic_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayException_To_TaskLegalClaims_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayException_To_TaskSubstantialPublicInterest_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayException_To_TaskHealthOrSocialCare_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayException_To_TaskPublicHealth_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayException_To_TaskResearchArchive_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayException_To_EndProhibited_Art9</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_ExplicitConsent_Art9"
               name="Check explicit consent and legal bar">
      <bpmn:incoming>Flow_GatewayException_To_TaskExplicitConsent_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskExplicitConsent_To_GatewayExceptionJoin_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_EmploymentLaw_Art9"
               name="Check employment or social-protection law basis">
      <bpmn:incoming>Flow_GatewayException_To_TaskEmploymentLaw_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskEmploymentLaw_To_GatewayExceptionJoin_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_VitalInterests_Art9"
               name="Check vital-interests necessity">
      <bpmn:incoming>Flow_GatewayException_To_TaskVitalInterests_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskVitalInterests_To_GatewayExceptionJoin_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_NotForProfitBody_Art9"
               name="Check not-for-profit body conditions">
      <bpmn:incoming>Flow_GatewayException_To_TaskNotForProfitBody_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskNotForProfitBody_To_GatewayExceptionJoin_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ManifestlyPublic_Art9"
               name="Check manifestly public data">
      <bpmn:incoming>Flow_GatewayException_To_TaskManifestlyPublic_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskManifestlyPublic_To_GatewayExceptionJoin_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_LegalClaims_Art9"
               name="Check legal-claims basis">
      <bpmn:incoming>Flow_GatewayException_To_TaskLegalClaims_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskLegalClaims_To_GatewayExceptionJoin_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SubstantialPublicInterest_Art9"
               name="Check substantial public interest">
      <bpmn:incoming>Flow_GatewayException_To_TaskSubstantialPublicInterest_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskSubstantialPublicInterest_To_GatewayExceptionJoin_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_HealthOrSocialCare_Art9"
               name="Check health or social-care basis">
      <bpmn:incoming>Flow_GatewayException_To_TaskHealthOrSocialCare_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskHealthOrSocialCare_To_GatewayHealthSecrecy_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PublicHealth_Art9"
               name="Check public-health basis">
      <bpmn:incoming>Flow_GatewayException_To_TaskPublicHealth_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskPublicHealth_To_GatewayExceptionJoin_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ResearchArchive_Art9"
               name="Check Article 89(1) research or archiving basis">
      <bpmn:incoming>Flow_GatewayException_To_TaskResearchArchive_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskResearchArchive_To_GatewayExceptionJoin_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_HealthSecrecy_Art9"
                           name="Is the processing by or under responsibility of a secrecy-bound professional?">
      <bpmn:incoming>Flow_TaskHealthOrSocialCare_To_GatewayHealthSecrecy_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayHealthSecrecy_To_GatewayExceptionJoin_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayHealthSecrecy_To_EndProhibited_Art9</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_ExceptionJoin_Art9">
      <bpmn:incoming>Flow_TaskExplicitConsent_To_GatewayExceptionJoin_Art9</bpmn:incoming>
      <bpmn:incoming>Flow_TaskEmploymentLaw_To_GatewayExceptionJoin_Art9</bpmn:incoming>
      <bpmn:incoming>Flow_TaskVitalInterests_To_GatewayExceptionJoin_Art9</bpmn:incoming>
      <bpmn:incoming>Flow_TaskNotForProfitBody_To_GatewayExceptionJoin_Art9</bpmn:incoming>
      <bpmn:incoming>Flow_TaskManifestlyPublic_To_GatewayExceptionJoin_Art9</bpmn:incoming>
      <bpmn:incoming>Flow_TaskLegalClaims_To_GatewayExceptionJoin_Art9</bpmn:incoming>
      <bpmn:incoming>Flow_TaskSubstantialPublicInterest_To_GatewayExceptionJoin_Art9</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayHealthSecrecy_To_GatewayExceptionJoin_Art9</bpmn:incoming>
      <bpmn:incoming>Flow_TaskPublicHealth_To_GatewayExceptionJoin_Art9</bpmn:incoming>
      <bpmn:incoming>Flow_TaskResearchArchive_To_GatewayExceptionJoin_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayExceptionJoin_To_TaskCheckNationalConditions_Art9</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_CheckNationalConditions_Art9"
               name="Check added national conditions if applicable">
      <bpmn:incoming>Flow_GatewayExceptionJoin_To_TaskCheckNationalConditions_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_TaskCheckNationalConditions_To_GatewayNationalConditionsMet_Art9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_NationalConditionsMet_Art9"
                           name="Are any added national conditions met?">
      <bpmn:incoming>Flow_TaskCheckNationalConditions_To_GatewayNationalConditionsMet_Art9</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayNationalConditionsMet_To_EndExceptionApplies_Art9</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayNationalConditionsMet_To_EndProhibited_Art9</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_ExceptionApplies_Art9"
                   name="Exception conditions met">
      <bpmn:incoming>Flow_GatewayNationalConditionsMet_To_EndExceptionApplies_Art9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Prohibited_Art9"
                   name="Processing prohibited">
      <bpmn:incoming>Flow_GatewayException_To_EndProhibited_Art9</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayHealthSecrecy_To_EndProhibited_Art9</bpmn:incoming>
      <bpmn:incoming>Flow_GatewayNationalConditionsMet_To_EndProhibited_Art9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Article9NotTriggered_Art9"
                   name="Article 9 not triggered">
      <bpmn:incoming>Flow_GatewaySpecialCategory_To_EndArticle9NotTriggered_Art9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_To_TaskIdentifyData_Art9" sourceRef="StartEvent_AssessArticle9_Art9" targetRef="Task_IdentifySpecialCategoryData_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskIdentifyData_To_GatewaySpecialCategory_Art9" sourceRef="Task_IdentifySpecialCategoryData_Art9" targetRef="Gateway_SpecialCategory_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewaySpecialCategory_To_TaskApplyDefaultProhibition_Art9" name="Yes" sourceRef="Gateway_SpecialCategory_Art9" targetRef="Task_ApplyDefaultProhibition_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewaySpecialCategory_To_EndArticle9NotTriggered_Art9" name="No" sourceRef="Gateway_SpecialCategory_Art9" targetRef="EndEvent_Article9NotTriggered_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskApplyDefaultProhibition_To_GatewayException_Art9" sourceRef="Task_ApplyDefaultProhibition_Art9" targetRef="Gateway_Exception_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayException_To_TaskExplicitConsent_Art9" name="Explicit consent" sourceRef="Gateway_Exception_Art9" targetRef="Task_ExplicitConsent_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayException_To_TaskEmploymentLaw_Art9" name="Employment, social security, or social protection law" sourceRef="Gateway_Exception_Art9" targetRef="Task_EmploymentLaw_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayException_To_TaskVitalInterests_Art9" name="Vital interests" sourceRef="Gateway_Exception_Art9" targetRef="Task_VitalInterests_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayException_To_TaskNotForProfitBody_Art9" name="Not-for-profit body" sourceRef="Gateway_Exception_Art9" targetRef="Task_NotForProfitBody_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayException_To_TaskManifestlyPublic_Art9" name="Manifestly public data" sourceRef="Gateway_Exception_Art9" targetRef="Task_ManifestlyPublic_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayException_To_TaskLegalClaims_Art9" name="Legal claims or courts" sourceRef="Gateway_Exception_Art9" targetRef="Task_LegalClaims_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayException_To_TaskSubstantialPublicInterest_Art9" name="Substantial public interest" sourceRef="Gateway_Exception_Art9" targetRef="Task_SubstantialPublicInterest_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayException_To_TaskHealthOrSocialCare_Art9" name="Health or social care" sourceRef="Gateway_Exception_Art9" targetRef="Task_HealthOrSocialCare_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayException_To_TaskPublicHealth_Art9" name="Public health" sourceRef="Gateway_Exception_Art9" targetRef="Task_PublicHealth_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayException_To_TaskResearchArchive_Art9" name="Research, archiving, or statistics" sourceRef="Gateway_Exception_Art9" targetRef="Task_ResearchArchive_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayException_To_EndProhibited_Art9" name="No exception" sourceRef="Gateway_Exception_Art9" targetRef="EndEvent_Prohibited_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskExplicitConsent_To_GatewayExceptionJoin_Art9" sourceRef="Task_ExplicitConsent_Art9" targetRef="Gateway_ExceptionJoin_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskEmploymentLaw_To_GatewayExceptionJoin_Art9" sourceRef="Task_EmploymentLaw_Art9" targetRef="Gateway_ExceptionJoin_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskVitalInterests_To_GatewayExceptionJoin_Art9" sourceRef="Task_VitalInterests_Art9" targetRef="Gateway_ExceptionJoin_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskNotForProfitBody_To_GatewayExceptionJoin_Art9" sourceRef="Task_NotForProfitBody_Art9" targetRef="Gateway_ExceptionJoin_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskManifestlyPublic_To_GatewayExceptionJoin_Art9" sourceRef="Task_ManifestlyPublic_Art9" targetRef="Gateway_ExceptionJoin_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskLegalClaims_To_GatewayExceptionJoin_Art9" sourceRef="Task_LegalClaims_Art9" targetRef="Gateway_ExceptionJoin_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskSubstantialPublicInterest_To_GatewayExceptionJoin_Art9" sourceRef="Task_SubstantialPublicInterest_Art9" targetRef="Gateway_ExceptionJoin_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskHealthOrSocialCare_To_GatewayHealthSecrecy_Art9" sourceRef="Task_HealthOrSocialCare_Art9" targetRef="Gateway_HealthSecrecy_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayHealthSecrecy_To_GatewayExceptionJoin_Art9" name="Yes" sourceRef="Gateway_HealthSecrecy_Art9" targetRef="Gateway_ExceptionJoin_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayHealthSecrecy_To_EndProhibited_Art9" name="No" sourceRef="Gateway_HealthSecrecy_Art9" targetRef="EndEvent_Prohibited_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskPublicHealth_To_GatewayExceptionJoin_Art9" sourceRef="Task_PublicHealth_Art9" targetRef="Gateway_ExceptionJoin_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskResearchArchive_To_GatewayExceptionJoin_Art9" sourceRef="Task_ResearchArchive_Art9" targetRef="Gateway_ExceptionJoin_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayExceptionJoin_To_TaskCheckNationalConditions_Art9" sourceRef="Gateway_ExceptionJoin_Art9" targetRef="Task_CheckNationalConditions_Art9" />
    <bpmn:sequenceFlow id="Flow_TaskCheckNationalConditions_To_GatewayNationalConditionsMet_Art9" sourceRef="Task_CheckNationalConditions_Art9" targetRef="Gateway_NationalConditionsMet_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayNationalConditionsMet_To_EndExceptionApplies_Art9" name="Yes" sourceRef="Gateway_NationalConditionsMet_Art9" targetRef="EndEvent_ExceptionApplies_Art9" />
    <bpmn:sequenceFlow id="Flow_GatewayNationalConditionsMet_To_EndProhibited_Art9" name="No" sourceRef="Gateway_NationalConditionsMet_Art9" targetRef="EndEvent_Prohibited_Art9" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Art9_Reviewed">
    <bpmndi:BPMNPlane id="BPMNPlane_Art9_Reviewed" bpmnElement="Process_Controller_Art9">
      <bpmndi:BPMNShape id="StartEvent_AssessArticle9_Art9_di" bpmnElement="StartEvent_AssessArticle9_Art9">
        <dc:Bounds x="120" y="392" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IdentifySpecialCategoryData_Art9_di" bpmnElement="Task_IdentifySpecialCategoryData_Art9">
        <dc:Bounds x="240" y="370" width="450" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SpecialCategory_Art9_di" bpmnElement="Gateway_SpecialCategory_Art9" isMarkerVisible="true">
        <dc:Bounds x="830" y="385" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ApplyDefaultProhibition_Art9_di" bpmnElement="Task_ApplyDefaultProhibition_Art9">
        <dc:Bounds x="980" y="370" width="380" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Exception_Art9_di" bpmnElement="Gateway_Exception_Art9" isMarkerVisible="true">
        <dc:Bounds x="1470" y="385" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_ExplicitConsent_Art9_di" bpmnElement="Task_ExplicitConsent_Art9">
        <dc:Bounds x="1720" y="20" width="350" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EmploymentLaw_Art9_di" bpmnElement="Task_EmploymentLaw_Art9">
        <dc:Bounds x="1720" y="120" width="520" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_VitalInterests_Art9_di" bpmnElement="Task_VitalInterests_Art9">
        <dc:Bounds x="1720" y="220" width="650" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotForProfitBody_Art9_di" bpmnElement="Task_NotForProfitBody_Art9">
        <dc:Bounds x="1720" y="320" width="690" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ManifestlyPublic_Art9_di" bpmnElement="Task_ManifestlyPublic_Art9">
        <dc:Bounds x="1720" y="420" width="470" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LegalClaims_Art9_di" bpmnElement="Task_LegalClaims_Art9">
        <dc:Bounds x="1720" y="520" width="500" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SubstantialPublicInterest_Art9_di" bpmnElement="Task_SubstantialPublicInterest_Art9">
        <dc:Bounds x="1720" y="620" width="590" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HealthOrSocialCare_Art9_di" bpmnElement="Task_HealthOrSocialCare_Art9">
        <dc:Bounds x="1720" y="720" width="680" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PublicHealth_Art9_di" bpmnElement="Task_PublicHealth_Art9">
        <dc:Bounds x="1720" y="820" width="340" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ResearchArchive_Art9_di" bpmnElement="Task_ResearchArchive_Art9">
        <dc:Bounds x="1720" y="920" width="410" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_HealthSecrecy_Art9_di" bpmnElement="Gateway_HealthSecrecy_Art9" isMarkerVisible="true">
        <dc:Bounds x="2460" y="735" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_ExceptionJoin_Art9_di" bpmnElement="Gateway_ExceptionJoin_Art9" isMarkerVisible="true">
        <dc:Bounds x="2720" y="385" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckNationalConditions_Art9_di" bpmnElement="Task_CheckNationalConditions_Art9">
        <dc:Bounds x="2890" y="370" width="350" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_NationalConditionsMet_Art9_di" bpmnElement="Gateway_NationalConditionsMet_Art9" isMarkerVisible="true">
        <dc:Bounds x="3370" y="385" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ExceptionApplies_Art9_di" bpmnElement="EndEvent_ExceptionApplies_Art9">
        <dc:Bounds x="3602" y="392" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Prohibited_Art9_di" bpmnElement="EndEvent_Prohibited_Art9">
        <dc:Bounds x="3602" y="1092" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Article9NotTriggered_Art9_di" bpmnElement="EndEvent_Article9NotTriggered_Art9">
        <dc:Bounds x="842" y="542" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_To_TaskIdentifyData_Art9_di" bpmnElement="Flow_Start_To_TaskIdentifyData_Art9">
        <di:waypoint x="156" y="410" />
        <di:waypoint x="240" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskIdentifyData_To_GatewaySpecialCategory_Art9_di" bpmnElement="Flow_TaskIdentifyData_To_GatewaySpecialCategory_Art9">
        <di:waypoint x="690" y="410" />
        <di:waypoint x="830" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySpecialCategory_To_TaskApplyDefaultProhibition_Art9_di" bpmnElement="Flow_GatewaySpecialCategory_To_TaskApplyDefaultProhibition_Art9">
        <di:waypoint x="880" y="410" />
        <di:waypoint x="980" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewaySpecialCategory_To_EndArticle9NotTriggered_Art9_di" bpmnElement="Flow_GatewaySpecialCategory_To_EndArticle9NotTriggered_Art9">
        <di:waypoint x="855" y="435" />
        <di:waypoint x="855" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TaskApplyDefaultProhibition_To_GatewayException_Art9_di" bpmnElement="Flow_TaskApplyDefaultProhibition_To_GatewayException_Art9">
        <di:waypoint x="1360" y="410" />
        <di:waypoint x="1470" y="410" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_GatewayException_To_TaskExplicitConsent_Art9_di" bpmnElement="Flow_GatewayException_To_TaskExplicitConsent_Art9">
        <di:waypoint x="1495" y="385" />
        <di:waypoint x="1495" y="60" />
        <di:waypoint x="1720" y="60" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayException_To_TaskEmploymentLaw_Art9_di" bpmnElement="Flow_GatewayException_To_TaskEmploymentLaw_Art9">
        <di:waypoint x="1495" y="385" />
        <di:waypoint x="1495" y="160" />
        <di:waypoint x="1720" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GatewayException_To_TaskVitalInterests_Art9_di" bpmnElement="Flow_GatewayException_To_TaskVitalInterests_Art9">
        <di:waypoint x="1495" y="385" />
        <di:waypoint x="1495" y="260" />
