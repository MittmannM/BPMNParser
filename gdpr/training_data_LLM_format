endEvent\" poolRef=\"Participant_RequestedAuthority_Art61\" />\n    <event id=\"EndEvent_UrgencyTriggered_Art61\" name=\"Urgency route triggered\" type=\"endEvent\" poolRef=\"Participant_RequestingAuthority_Art61\" />\n    <event id=\"IntermediateCatchEvent_OneMonthElapsed_Art61\" name=\"One month elapsed without information\" type=\"intermediateCatchEvent\" poolRef=\"Participant_RequestingAuthority_Art61\" eventDefinition=\"timer\" />\n    <event id=\"StartEvent_NeedMutualAssistance_Art61\" name=\"Need mutual assistance\" type=\"startEvent\" poolRef=\"Participant_RequestingAuthority_Art61\" />\n    <event id=\"StartEvent_ReceiveMutualAssistanceRequest_Art61\" name=\"Receive mutual-assistance request\" type=\"startEvent\" poolRef=\"Participant_RequestedAuthority_Art61\" eventDefinition=\"message\" />\n  </events>\n  <gateways>\n    <gateway id=\"Gateway_RefusalAllowed_Art61\" name=\"Is refusal allowed under Article 61(4)?\" type=\"exclusiveGateway\" poolRef=\"Participant_RequestedAuthority_Art61\" />\n    <gateway id=\"Gateway_ResponseWindow_Art61\" name=\"What is received within one month?\" type=\"eventBasedGateway\" poolRef=\"Participant_RequestingAuthority_Art61\" />\n  </gateways>\n  <sequenceFlows>\n    <sequenceFlow id=\"Flow_AdoptProvisionalMeasure_To_RequestUrgentBoardDecision_Art61\" sourceRef=\"Task_AdoptProvisionalMeasure_Art61\" targetRef=\"Task_RequestUrgentBoardDecision_Art61\" />\n    <sequenceFlow id=\"Flow_AssessRequest_To_GatewayRefusalAllowed_Art61\" sourceRef=\"Task_AssessCompetenceAndLegality_Art61\" targetRef=\"Gateway_RefusalAllowed_Art61\" />\n    <sequenceFlow id=\"Flow_GatewayRefusalAllowed_To_SendRefusalWithReasons_Art61\" name=\"Yes\" sourceRef=\"Gateway_RefusalAllowed_Art61\" targetRef=\"Task_SendRefusalWithReasons_Art61\" />\n    <sequenceFlow id=\"Flow_GatewayRefusalAllowed_To_TakeResponseMeasures_Art61\" name=\"No\" sourceRef=\"Gateway_RefusalAllowed_Art61\" targetRef=\"Task_TakeAppropriateResponseMeasures_Art61\" />\n    <sequenceFl