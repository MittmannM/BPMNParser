Purpose_Art14\" name=\"Will the personal data later be processed for another purpose?\" type=\"exclusiveGateway\" poolRef=\"Participant_Controller_Art14\" />\n    <gateway id=\"Gateway_JoinAdditionalInfo_Art14\" type=\"parallelGateway\" poolRef=\"Participant_Controller_Art14\" />\n    <gateway id=\"Gateway_LegitimateInterests_Art14\" name=\"Is the processing based on Article 6(1)(f)?\" type=\"exclusiveGateway\" poolRef=\"Participant_Controller_Art14\" />\n    <gateway id=\"Gateway_SplitAdditionalInfo_Art14\" type=\"parallelGateway\" poolRef=\"Participant_Controller_Art14\" />\n    <gateway id=\"Gateway_ThirdCountryTransfer_Art14\" name=\"Is a transfer to a third country or international organisation intended?\" type=\"exclusiveGateway\" poolRef=\"Participant_Controller_Art14\" />\n    <gateway id=\"Gateway_TimingCommunication_Art14\" name=\"Will the personal data be used to communicate with the data subject before one month has passed?\" type=\"exclusiveGateway\" poolRef=\"Participant_Controller_Art14\" />\n    <gateway id=\"Gateway_TimingDisclosure_Art14\" name=\"Will the personal data be disclosed to another recipient before one month has passed?\" type=\"exclusiveGateway\" poolRef=\"Participant_Controller_Art14\" />\n  </gateways>\n  <sequenceFlows>\n    <sequenceFlow id=\"Flow_GatewayExceptionA_To_EndNoDirectNotice_Art14\" name=\"Yes\" sourceRef=\"Gateway_ExceptionA_Art14\" targetRef=\"EndEvent_NoDirectNotice_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayExceptionA_To_GatewayExceptionB_Art14\" name=\"No\" sourceRef=\"Gateway_ExceptionA_Art14\" targetRef=\"Gateway_ExceptionB_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayExceptionB_To_GatewayExceptionC_Art14\" name=\"No\" sourceRef=\"Gateway_ExceptionB_Art14\" targetRef=\"Gateway_ExceptionC_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayExceptionB_To_TaskImplementMeasuresEffort_Art14\" name=\"Yes\" sourceRef=\"Gateway_ExceptionB_Art14\" targetRef=\"Task_ImplementMeasuresEffort_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayExceptionC_To_GatewayExceptionD_Art14\" name=\"No\" sourceRef=\"Gateway_ExceptionC_Art14\" targetRef=\"Gateway_ExceptionD_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayExceptionC_To_TaskImplementMeasuresLaw_Art14\" name=\"Yes\" sourceRef=\"Gateway_ExceptionC_Art14\" targetRef=\"Task_ImplementMeasuresLaw_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayExceptionD_To_EndNoDirectNotice_Art14\" name=\"Yes\" sourceRef=\"Gateway_ExceptionD_Art14\" targetRef=\"EndEvent_NoDirectNotice_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayExceptionD_To_TaskPrepareIdentity_Art14\" name=\"No\" sourceRef=\"Gateway_ExceptionD_Art14\" targetRef=\"Task_PrepareIdentity_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayFurtherPurpose_To_EndArticle14Completed_Art14\" name=\"No\" sourceRef=\"Gateway_FurtherPurpose_Art14\" targetRef=\"EndEvent_Article14Completed_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayFurtherPurpose_To_SendTaskSendFurtherPurposeNotice_Art14\" name=\"Yes\" sourceRef=\"Gateway_FurtherPurpose_Art14\" targetRef=\"SendTask_SendFurtherPurposeNotice_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayJoinAdditionalInfo_To_GatewayTimingCommunication_Art14\" sourceRef=\"Gateway_JoinAdditionalInfo_Art14\" targetRef=\"Gateway_TimingCommunication_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayLegitimateInterests_To_TaskPrepareCategories_Art14\" name=\"No\" sourceRef=\"Gateway_LegitimateInterests_Art14\" targetRef=\"Task_PrepareCategories_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayLegitimateInterests_To_TaskPrepareLegitimateInterests_Art14\" name=\"Yes\" sourceRef=\"Gateway_LegitimateInterests_Art14\" targetRef=\"Task_PrepareLegitimateInterests_Art14\" />\n    <sequenceFlow id=\"Flow_GatewaySplitAdditionalInfo_To_TaskPrepareAutomatedDecisionInfo_Art14\" sourceRef=\"Gateway_SplitAdditionalInfo_Art14\" targetRef=\"Task_PrepareAutomatedDecisionInfo_Art14\" />\n    <sequenceFlow id=\"Flow_GatewaySplitAdditionalInfo_To_TaskPrepareRetentionInfo_Art14\" sourceRef=\"Gateway_SplitAdditionalInfo_Art14\" targetRef=\"Task_PrepareRetentionInfo_Art14\" />\n    <sequenceFlow id=\"Flow_GatewaySplitAdditionalInfo_To_TaskPrepareRightsInfo_Art14\" sourceRef=\"Gateway_SplitAdditionalInfo_Art14\" targetRef=\"Task_PrepareRightsInfo_Art14\" />\n    <sequenceFlow id=\"Flow_GatewaySplitAdditionalInfo_To_TaskPrepareSourceInfo_Art14\" sourceRef=\"Gateway_SplitAdditionalInfo_Art14\" targetRef=\"Task_PrepareSourceInfo_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayThirdCountryTransfer_To_GatewaySplitAdditionalInfo_Art14\" name=\"No\" sourceRef=\"Gateway_ThirdCountryTransfer_Art14\" targetRef=\"Gateway_SplitAdditionalInfo_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayThirdCountryTransfer_To_TaskPrepareTransferInfo_Art14\" name=\"Yes\" sourceRef=\"Gateway_ThirdCountryTransfer_Art14\" targetRef=\"Task_PrepareTransferInfo_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayTimingCommunication_To_GatewayTimingDisclosure_Art14\" name=\"No\" sourceRef=\"Gateway_TimingCommunication_Art14\" targetRef=\"Gateway_TimingDisclosure_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayTimingCommunication_To_SendTaskSendArticle14Notice_Art14\" name=\"Yes\" sourceRef=\"Gateway_TimingCommunication_Art14\" targetRef=\"SendTask_SendArticle14Notice_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayTimingDisclosure_To_SendTaskSendArticle14Notice_Art14\" name=\"Yes\" sourceRef=\"Gateway_TimingDisclosure_Art14\" targetRef=\"SendTask_SendArticle14Notice_Art14\" />\n    <sequenceFlow id=\"Flow_GatewayTimingDisclosure_To_TaskSendNoticeWithinOneMonth_Art14\" name=\"No\" sourceRef=\"Gateway_TimingDisclosure_Art14\" targetRef=\"Task_SendNoticeWithinOneMonth_Art14\" />\n    <sequenceFlow id=\"Flow_SendTaskSendArticle14Notice_To_GatewayFurtherPurpose_Art14\" sourceRef=\"SendTask_SendArticle14Notice_Art14\" targetRef=\"Gateway_FurtherPurpose_Art14\" />\n    <sequenceFlow id=\"Flow_SendTaskSendFurtherPurposeNotice_To_EndArticle14Completed_Art14\" sourceRef=\"SendTask_SendFurtherPurposeNotice_Art14\" targetRef=