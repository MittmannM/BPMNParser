eview and withdrawal procedures\" type=\"task\" poolRef=\"Participant_CertificationBody_Art43\" />\n    <task id=\"Task_ShowNoConflicts_Art43\" name=\"Show no conflicts\" type=\"task\" poolRef=\"Participant_CertificationBody_Art43\" />\n    <task id=\"Task_UndertakeApprovedCriteria_Art43\" name=\"Undertake approved criteria\" type=\"task\" poolRef=\"Participant_CertificationBody_Art43\" />\n  </tasks>\n  <events>\n    <event id=\"EndEvent_AccreditationEnded_Art43\" name=\"Accreditation term ended\" type=\"endEvent\" poolRef=\"Participant_CertificationBody_Art43\" />\n    <event id=\"EndEvent_AccreditationMaintained_Art43\" name=\"Accreditation maintained\" type=\"endEvent\" poolRef=\"Participant_SupervisoryAuthority_Art43\" />\n    <event id=\"EndEvent_AccreditationRevoked_Art43\" name=\"Accreditation revoked\" type=\"endEvent\" poolRef=\"Participant_SupervisoryAuthority_Art43\" />\n    <event id=\"EndEvent_CertificationWithdrawn_Art43\" name=\"Certification withdrawn\" type=\"endEvent\" poolRef=\"Participant_CertificationBody_Art43\" />\n    <event id=\"StartEvent_SeekAccreditation_Art43\" name=\"Seek accreditation\" type=\"startEvent\" poolRef=\"Participant_CertificationBody_Art43\" />\n    <event id=\"StartEvent_SetRequirements_Art43\" name=\"Set Article 43 framework\" type=\"startEvent\" poolRef=\"Participant_SupervisoryAuthority_Art43\" />\n  </events>\n  <gateways>\n    <gateway id=\"Gateway_AccreditationRoute_Art43\" name=\"Will the supervisory authority accredit the body?\" type=\"exclusiveGateway\" poolRef=\"Participant_CertificationBody_Art43\" />\n    <gateway id=\"Gateway_ApprovalSource_Art43\" name=\"Will the Board approve the accreditation criteria?\" type=\"exclusiveGateway\" poolRef=\"Participant_SupervisoryAuthority_Art43\" />\n    <gateway id=\"Gateway_CertificationOutcome_Art43\" name=\"Will certification be granted or renewed?\" type=\"exclusiveGateway\" poolRef=\"Participant_CertificationBody_Art43\" />\n    <gateway id=\"Gateway_JoinRequirement