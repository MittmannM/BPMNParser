\" sourceRef=\"Gateway_LawAllowsDisclosure_Art86\" targetRef=\"SendTask_DisclosePersonalData_Art86\" />\n    <sequenceFlow id=\"Flow_GatewayPublicInterestHolder_To_EndNoArt86Route_Art86\" name=\"No\" sourceRef=\"Gateway_PublicInterestHolder_Art86\" targetRef=\"EndEvent_NoArt86Route_Art86\" />\n    <sequenceFlow id=\"Flow_GatewayPublicInterestHolder_To_TaskAssessLaw_Art86\" name=\"Yes\" sourceRef=\"Gateway_PublicInterestHolder_Art86\" targetRef=\"Task_AssessApplicableAccessLaw_Art86\" />\n    <sequenceFlow id=\"Flow_IdentifyDocument_To_GatewayPublicInterestHolder_Art86\" sourceRef=\"Task_IdentifyDocumentAndPersonalData_Art86\" targetRef=\"Gateway_PublicInterestHolder_Art86\" />\n    <sequenceFlow id=\"Flow_ReceiveAccessRequest_To_IdentifyDocument_Art86\" sourceRef=\"ReceiveTask_ReceiveAccessRequest_Art86\" targetRef=\"Task_IdentifyDocumentAndPersonalData_Art86\" />\n    <sequenceFlow id=\"Flow_SendTaskDisclose_To_EndDisclosureCompleted_Art86\" sourceRef=\"SendTask_DisclosePersonalData_Art86\" targetRef=\"EndEvent_DisclosureCompleted_Art86\" />\n    <sequenceFlow id=\"Flow_Start_To_ReceiveAccessRequest_Art86\" sourceRef=\"StartEvent_AssessAccess_Art86\" targetRef=\"ReceiveTask_ReceiveAccessRequest_Art86\" />\n    <sequenceFlow id=\"Flow_TaskAssessLaw_To_TaskReconcileAccessAndProtection_Art86\" sourceRef=\"Task_AssessApplicableAccessLaw_Art86\" targetRef=\"Task_ReconcileAccessAndProtection_Art86\" />\n    <sequenceFlow id=\"Flow_TaskReconcileAccessAndProtection_To_GatewayLawAllowsDisclosure_Art86\" sourceRef=\"Task_ReconcileAccessAndProtection_Art86\" targetRef=\"Gateway_LawAllowsDisclosure_Art86\" />\n  </sequenceFlows>\n  <messageFlows>\n    <messageFlow id=\"MessageFlow_DiscloseDocumentData_Art86\" sourceRef=\"SendTask_DisclosePersonalData_Art86\" targetRef=\"Participant_Requester_Art86\" />\n    <messageFlow id=\"MessageFlow_RequestAccess_Art86\" sourceRef=\"Participant_Requester_Art86\" targetRef=\"ReceiveTask_ReceiveAccessRequest_Art86\" />\n  </messageFlows>\n  