low_GatewayArticle462_To_SASCCs_Art46\" name=\"SA SCCs approved by the Commission\" sourceRef=\"Gateway_Article462Safeguard_Art46\" targetRef=\"Task_UseSASCCs_Art46\" />\n    <sequenceFlow id=\"Flow_GatewayArticle463_To_PrepareAdministrativeArrangement_Art46\" name=\"Administrative arrangement\" sourceRef=\"Gateway_Article463Safeguard_Art46\" targetRef=\"Task_PrepareAdministrativeArrangement_Art46\" />\n    <sequenceFlow id=\"Flow_GatewayArticle463_To_PrepareContractualClauses_Art46\" name=\"Contractual clauses\" sourceRef=\"Gateway_Article463Safeguard_Art46\" targetRef=\"Task_PrepareContractualClauses_Art46\" />\n    <sequenceFlow id=\"Flow_GatewayAuthorisationRequired_To_GatewayArticle462_Art46\" name=\"No\" sourceRef=\"Gateway_AuthorisationRequired_Art46\" targetRef=\"Gateway_Article462Safeguard_Art46\" />\n    <sequenceFlow id=\"Flow_GatewayAuthorisationRequired_To_GatewayArticle463_Art46\" name=\"Yes\" sourceRef=\"Gateway_AuthorisationRequired_Art46\" targetRef=\"Gateway_Article463Safeguard_Art46\" />\n    <sequenceFlow id=\"Flow_GatewayClauseAuthorised_To_ConcludeContractualClauses_Art46\" name=\"Yes\" sourceRef=\"Gateway_ClauseAuthorised_Art46\" targetRef=\"SendTask_ConcludeContractualClauses_Art46\" />\n    <sequenceFlow id=\"Flow_GatewayClauseAuthorised_To_EndClauseRejected_Art46\" name=\"No\" sourceRef=\"Gateway_ClauseAuthorised_Art46\" targetRef=\"EndEvent_ClauseRejected_Art46\" />\n    <sequenceFlow id=\"Flow_GatewayRightsRemedies_To_EndNoTransfer_Art46\" name=\"No\" sourceRef=\"Gateway_RightsRemedies_Art46\" targetRef=\"EndEvent_NoTransfer_Art46\" />\n    <sequenceFlow id=\"Flow_GatewayRightsRemedies_To_GatewayAuthorisationRequired_Art46\" name=\"Yes\" sourceRef=\"Gateway_RightsRemedies_Art46\" targetRef=\"Gateway_AuthorisationRequired_Art46\" />\n    <sequenceFlow id=\"Flow_GatewaySafeguardsReady_To_TransferData_Art46\" sourceRef=\"Gateway_SafeguardsReady_Art46\" targetRef=\"SendTask_TransferData_Art46\" />\n    <sequenceFlow id=\"Flow_LegacyStart_To_C