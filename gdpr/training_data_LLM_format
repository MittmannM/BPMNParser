enceFlow id=\"Flow_GatewayDesignateContactPoint_To_TaskDesignateContactPoint_Art26\" name=\"Yes\" sourceRef=\"Gateway_DesignateContactPoint_Art26\" targetRef=\"Task_DesignateContactPoint_Art26\" />\n    <sequenceFlow id=\"Flow_GatewayJointDetermination_To_EndArticle26NotTriggered_Art26\" name=\"No\" sourceRef=\"Gateway_JointDetermination_Art26\" targetRef=\"EndEvent_Article26NotTriggered_Art26\" />\n    <sequenceFlow id=\"Flow_GatewayJointDetermination_To_GatewayLegalAllocation_Art26\" name=\"Yes\" sourceRef=\"Gateway_JointDetermination_Art26\" targetRef=\"Gateway_LegalAllocation_Art26\" />\n    <sequenceFlow id=\"Flow_GatewayLegalAllocation_To_SendTaskCoordinateArrangement_Art26\" name=\"No\" sourceRef=\"Gateway_LegalAllocation_Art26\" targetRef=\"SendTask_CoordinateArrangement_Art26\" />\n    <sequenceFlow id=\"Flow_GatewayLegalAllocation_To_TaskApplyLegalAllocation_Art26\" name=\"Yes\" sourceRef=\"Gateway_LegalAllocation_Art26\" targetRef=\"Task_ApplyLegalAllocation_Art26\" />\n    <sequenceFlow id=\"Flow_GatewayRightsAgainstA_To_EndFrameworkEstablished_Art26\" name=\"No\" sourceRef=\"Gateway_RightsAgainstA_Art26\" targetRef=\"EndEvent_FrameworkEstablished_Art26\" />\n    <sequenceFlow id=\"Flow_GatewayRightsAgainstA_To_ReceiveTaskReceiveRightsRequestA_Art26\" name=\"Yes\" sourceRef=\"Gateway_RightsAgainstA_Art26\" targetRef=\"ReceiveTask_ReceiveRightsRequestA_Art26\" />\n    <sequenceFlow id=\"Flow_ReceiveTaskReceiveArrangementInput_To_TaskDefineResponsibilities_Art26\" sourceRef=\"ReceiveTask_ReceiveArrangementInput_Art26\" targetRef=\"Task_DefineResponsibilities_Art26\" />\n    <sequenceFlow id=\"Flow_ReceiveTaskReceiveRightsRequestA_To_EndFrameworkEstablished_Art26\" sourceRef=\"ReceiveTask_ReceiveRightsRequestA_Art26\" targetRef=\"EndEvent_FrameworkEstablished_Art26\" />\n    <sequenceFlow id=\"Flow_SendTaskCoordinateArrangement_To_ReceiveTaskReceiveArrangementInput_Art26\" sourceRef=\"SendTask_CoordinateArrangement_Art26\" targetRef=\"ReceiveTask_ReceiveArr