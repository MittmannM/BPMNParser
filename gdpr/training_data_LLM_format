35\" targetRef=\"SendTask_SeekDPOAdvice_Art35\" />\n    <sequenceFlow id=\"Flow_GatewayDPOMerge_To_TaskTakeCodesIntoAccount_Art35\" sourceRef=\"Gateway_DPOMerge_Art35\" targetRef=\"Task_TakeCodesIntoAccount_Art35\" />\n    <sequenceFlow id=\"Flow_GatewayHighRiskLikely_To_TaskCheckArticle353Triggers_Art35\" name=\"No\" sourceRef=\"Gateway_HighRiskLikely_Art35\" targetRef=\"Task_CheckArticle353Triggers_Art35\" />\n    <sequenceFlow id=\"Flow_GatewayHighRiskLikely_To_TaskInitiateDPIA_Art35\" name=\"Yes\" sourceRef=\"Gateway_HighRiskLikely_Art35\" targetRef=\"Task_InitiateDPIA_Art35\" />\n    <sequenceFlow id=\"Flow_GatewayJoinDPIAContents_To_GatewaySeekViews_Art35\" sourceRef=\"Gateway_JoinDPIAContents_Art35\" targetRef=\"Gateway_SeekViews_Art35\" />\n    <sequenceFlow id=\"Flow_GatewayNoDPIAListApplies_To_EndNoDPIARequired_Art35\" name=\"Yes\" sourceRef=\"Gateway_NoDPIAListApplies_Art35\" targetRef=\"EndEvent_NoDPIARequired_Art35\" />\n    <sequenceFlow id=\"Flow_GatewayNoDPIAListApplies_To_TaskAssessHighRisk_Art35\" name=\"No\" sourceRef=\"Gateway_NoDPIAListApplies_Art35\" targetRef=\"Task_AssessHighRisk_Art35\" />\n    <sequenceFlow id=\"Flow_GatewayReviewNeeded_To_EndDPIAHandled_Art35\" name=\"No\" sourceRef=\"Gateway_ReviewNeeded_Art35\" targetRef=\"EndEvent_DPIAHandled_Art35\" />\n    <sequenceFlow id=\"Flow_GatewayReviewNeeded_To_TaskReviewDPIA_Art35\" name=\"Yes\" sourceRef=\"Gateway_ReviewNeeded_Art35\" targetRef=\"Task_ReviewDPIA_Art35\" />\n    <sequenceFlow id=\"Flow_GatewaySeekViews_To_GatewayViewsMerge_Art35\" name=\"No\" sourceRef=\"Gateway_SeekViews_Art35\" targetRef=\"Gateway_ViewsMerge_Art35\" />\n    <sequenceFlow id=\"Flow_GatewaySeekViews_To_SendTaskSeekDataSubjectViews_Art35\" name=\"Yes\" sourceRef=\"Gateway_SeekViews_Art35\" targetRef=\"SendTask_SeekDataSubjectViews_Art35\" />\n    <sequenceFlow id=\"Flow_GatewaySplitDPIAContents_To_TaskAssessNecessityProportionality_Art35\" sourceRef=\"Gateway_SplitDPIAContents_Art35\" targetRef=\"Task_AssessNe