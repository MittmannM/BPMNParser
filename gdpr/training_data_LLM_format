oolRef=\"Participant_Controller_Art20\" />\n    <gateway id=\"Gateway_PublicTaskException_Art20\" name=\"Is the processing necessary for a task carried out in the public interest or in the exercise of official authority?\" type=\"exclusiveGateway\" poolRef=\"Participant_Controller_Art20\" />\n    <gateway id=\"Gateway_RequestExceptions_Art20\" name=\"Were the relevant personal data provided by the data subject and are they available in a portable electronic form?\" type=\"exclusiveGateway\" poolRef=\"Participant_Controller_Art20\" />\n    <gateway id=\"Gateway_RightsFreedoms_Art20\" name=\"Would portability adversely affect the rights and freedoms of others?\" type=\"exclusiveGateway\" poolRef=\"Participant_Controller_Art20\" />\n    <gateway id=\"Gateway_TechnicalFeasibility_Art20\" name=\"Is direct controller-to-controller transmission technically feasible?\" type=\"exclusiveGateway\" poolRef=\"Participant_Controller_Art20\" />\n  </gateways>\n  <sequenceFlows>\n    <sequenceFlow id=\"Flow_GatewayAutomatedProcessing_To_EndNotAutomated_Art20\" name=\"No\" sourceRef=\"Gateway_AutomatedProcessing_Art20\" targetRef=\"EndEvent_NotAutomated_Art20\" />\n    <sequenceFlow id=\"Flow_GatewayAutomatedProcessing_To_GatewayPublicTaskException_Art20\" name=\"Yes\" sourceRef=\"Gateway_AutomatedProcessing_Art20\" targetRef=\"Gateway_PublicTaskException_Art20\" />\n    <sequenceFlow id=\"Flow_GatewayDirectTransmissionRequested_To_GatewayTechnicalFeasibility_Art20\" name=\"Yes\" sourceRef=\"Gateway_DirectTransmissionRequested_Art20\" targetRef=\"Gateway_TechnicalFeasibility_Art20\" />\n    <sequenceFlow id=\"Flow_GatewayDirectTransmissionRequested_To_SendTaskProvidePortableDataToDataSubject_Art20\" name=\"No\" sourceRef=\"Gateway_DirectTransmissionRequested_Art20\" targetRef=\"SendTask_ProvidePortableDataToDataSubject_Art20\" />\n    <sequenceFlow id=\"Flow_GatewayLegalBasis_To_EndNoPortabilityBasis_Art20\" name=\"No\" sourceRef=\"Gateway_LegalBasis_Art20\" targetRef=\"EndEvent_NoP