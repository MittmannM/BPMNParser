cessingNeeded_Art18\" />\n  </sequenceFlows>\n  <messageFlows>\n    <messageFlow id=\"MessageFlow_InformBeforeLift_Art18\" sourceRef=\"SendTask_InformBeforeLift_Art18\" targetRef=\"Participant_DataSubject_Art18\" />\n    <messageFlow id=\"MessageFlow_SendRestrictionRequest_Art18\" sourceRef=\"Participant_DataSubject_Art18\" targetRef=\"ReceiveTask_ReceiveRestrictionRequest_Art18\" />\n  </messageFlows>\n  <dataObjects />\n  <dataStores />\n  <dataAssociations />\n  <annotations />\n  <associations />\n</processModel>"}]}
