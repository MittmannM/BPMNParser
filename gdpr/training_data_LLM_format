festly unfounded or excessive?\" type=\"exclusiveGateway\" poolRef=\"Participant_Controller_Art12\" />\n    <gateway id=\"Gateway_UseIconsElectronic_Art12\" name=\"Use standardized icons with the electronic information?\" type=\"exclusiveGateway\" poolRef=\"Participant_Controller_Art12\" />\n    <gateway id=\"Gateway_UseIconsWritten_Art12\" name=\"Use standardized icons with the written or other non-electronic information?\" type=\"exclusiveGateway\" poolRef=\"Participant_Controller_Art12\" />\n  </gateways>\n  <sequenceFlows>\n    <sequenceFlow id=\"Flow_GatewayElectronicInfo_To_GatewayUseIconsElectronic_Art12\" name=\"Yes\" sourceRef=\"Gateway_ElectronicInfo_Art12\" targetRef=\"Gateway_UseIconsElectronic_Art12\" />\n    <sequenceFlow id=\"Flow_GatewayElectronicInfo_To_GatewayUseIconsWritten_Art12\" name=\"No\" sourceRef=\"Gateway_ElectronicInfo_Art12\" targetRef=\"Gateway_UseIconsWritten_Art12\" />\n    <sequenceFlow id=\"Flow_GatewayElectronicResponse_To_GatewayOralResponse_Art12\" name=\"No\" sourceRef=\"Gateway_ElectronicResponse_Art12\" targetRef=\"Gateway_OralResponse_Art12\" />\n    <sequenceFlow id=\"Flow_GatewayElectronicResponse_To_SendTaskSendElectronicResponse_Art12\" name=\"Yes\" sourceRef=\"Gateway_ElectronicResponse_Art12\" targetRef=\"SendTask_SendElectronicResponse_Art12\" />\n    <sequenceFlow id=\"Flow_GatewayExtensionNecessary_To_SendTaskSendExtensionNotice_Art12\" name=\"Yes\" sourceRef=\"Gateway_ExtensionNecessary_Art12\" targetRef=\"SendTask_SendExtensionNotice_Art12\" />\n    <sequenceFlow id=\"Flow_GatewayExtensionNecessary_To_TaskTakeActionWithinOneMonth_Art12\" name=\"No\" sourceRef=\"Gateway_ExtensionNecessary_Art12\" targetRef=\"Task_TakeActionWithinOneMonth_Art12\" />\n    <sequenceFlow id=\"Flow_GatewayFeeOrRefuse_To_TaskChargeReasonableFee_Art12\" name=\"Charge fee\" sourceRef=\"Gateway_FeeOrRefuse_Art12\" targetRef=\"Task_ChargeReasonableFee_Art12\" />\n    <sequenceFlow id=\"Flow_GatewayFeeOrRefuse_To_TaskPrepareRefusalNotice_Art12