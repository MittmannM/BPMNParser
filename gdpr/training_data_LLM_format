k_TransferData_Art46\" targetRef=\"EndEvent_TransferCompleted_Art46\" />\n  </sequenceFlows>\n  <messageFlows>\n    <messageFlow id=\"MessageFlow_ArrangementAuthorisationDecision_Art46\" sourceRef=\"Participant_SupervisoryAuthority_Art46\" targetRef=\"ReceiveTask_ReceiveArrangementAuthorisation_Art46\" />\n    <messageFlow id=\"MessageFlow_CertificationCommitments_Art46\" sourceRef=\"SendTask_AgreeCertificationCommitments_Art46\" targetRef=\"Participant_Counterparty_Art46\" />\n    <messageFlow id=\"MessageFlow_ClauseAuthorisationDecision_Art46\" sourceRef=\"Participant_SupervisoryAuthority_Art46\" targetRef=\"ReceiveTask_ReceiveClauseAuthorisation_Art46\" />\n    <messageFlow id=\"MessageFlow_CodeCommitments_Art46\" sourceRef=\"SendTask_AgreeCodeCommitments_Art46\" targetRef=\"Participant_Counterparty_Art46\" />\n    <messageFlow id=\"MessageFlow_ConcludeArrangement_Art46\" sourceRef=\"SendTask_ConcludeAdministrativeArrangement_Art46\" targetRef=\"Participant_Counterparty_Art46\" />\n    <messageFlow id=\"MessageFlow_ConcludeClauses_Art46\" sourceRef=\"SendTask_ConcludeContractualClauses_Art46\" targetRef=\"Participant_Counterparty_Art46\" />\n    <messageFlow id=\"MessageFlow_PublicBodyInstrument_Art46\" sourceRef=\"SendTask_UsePublicBodyInstrument_Art46\" targetRef=\"Participant_Counterparty_Art46\" />\n    <messageFlow id=\"MessageFlow_RequestArrangementAuthorisation_Art46\" sourceRef=\"SendTask_RequestArrangementAuthorisation_Art46\" targetRef=\"Participant_SupervisoryAuthority_Art46\" />\n    <messageFlow id=\"MessageFlow_RequestClauseAuthorisation_Art46\" sourceRef=\"SendTask_RequestClauseAuthorisation_Art46\" targetRef=\"Participant_SupervisoryAuthority_Art46\" />\n    <messageFlow id=\"MessageFlow_TransferPersonalData_Art46\" sourceRef=\"SendTask_TransferData_Art46\" targetRef=\"Participant_Counterparty_Art46\" />\n  </messageFlows>\n  <dataObjects />\n  <dataStores />\n  <dataAssociations />\n  <annotations />\n  <associations />\n</processModel><turn|>\n"